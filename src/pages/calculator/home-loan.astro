  <script is:inline>
    (function () {
      const fmt = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function emiAmount(P, annual, months) {
        const r = annual / 100 / 12;
        if (months <= 0) return 0;
        if (r === 0) return P / months;
        return (P * r * Math.pow(1 + r, months)) / (Math.pow(1 + r, months) - 1);
      }
      function simulate(P, annual, months, prep, freq, startAfter) {
        const r = annual / 100 / 12;
        const emi = emiAmount(P, annual, months);
        let bal = P;
        let m = 0;
        let totalInt = 0;
        const yearly = {};
        let onceDone = false;
        while (bal > 0.02 && m < 600) {
          m++;
          const intP = bal * r;
          let prin = emi - intP;
          if (prin > bal) prin = bal;
          bal -= prin;
          totalInt += intP;
          const y = Math.ceil(m / 12);
          if (!yearly[y]) yearly[y] = { prin: 0, int: 0, prep: 0, end: 0 };
          yearly[y].prin += prin;
          yearly[y].int += intP;
          let doPre = false;
          if (prep > 0 && m > startAfter) {
            if (freq === 'monthly') doPre = true;
            else if (freq === 'yearly' && (m - startAfter - 1) % 12 === 0) doPre = true;
            else if (freq === 'once' && !onceDone) {
              doPre = true;
              onceDone = true;
            }
          }
          if (doPre) {
            const pay = Math.min(prep, bal);
            bal -= pay;
            yearly[y].prep += pay;
          }
          yearly[y].end = bal;
        }
        return { emi: emi, months: m, totalInt: totalInt, yearly: yearly };
      }
      function run() {
        let P = Math.max(100000, Math.min(1e9, parseFloat(document.getElementById('hlP').value) || 0));
        let ar = Math.max(1, Math.min(20, parseFloat(document.getElementById('hlR').value) || 0));
        let y = Math.max(1, Math.min(30, parseInt(document.getElementById('hlY').value, 10) || 1));
        let prep = Math.max(0, Math.min(5000000, parseFloat(document.getElementById('hlPre').value) || 0));
        const freq = document.getElementById('hlFreq').value;
        let startAfter = Math.max(0, Math.min(360, parseInt(document.getElementById('hlStart').value, 10) || 0));
        document.getElementById('hlP').value = P;
        document.getElementById('hlR').value = ar;
        document.getElementById('hlY').value = y;
        document.getElementById('hlRR').value = ar;
        document.getElementById('hlYR').value = y;
        const n = y * 12;
        const emi = emiAmount(P, ar, n);
        const baseInt = Math.max(0, emi * n - P);
        document.getElementById('hlEmi').textContent = fmt.format(Math.round(emi));
        document.getElementById('hlInt0').textContent = fmt.format(Math.round(baseInt));
        document.getElementById('hlMo0').textContent = n + ' mo';
        const sim = simulate(P, ar, n, freq === 'none' ? 0 : prep, freq === 'none' ? 'none' : freq, startAfter);
        document.getElementById('hlInt1').textContent = fmt.format(Math.round(sim.totalInt));
        document.getElementById('hlMo1').textContent = sim.months + ' mo';
        document.getElementById('hlSave').textContent = fmt.format(Math.max(0, Math.round(baseInt - sim.totalInt)));
        document.getElementById('hlCut').textContent = Math.max(0, n - sim.months) + ' months';
        const tb = document.getElementById('hlTb');
        tb.innerHTML = '';
        Object.keys(sim.yearly)
          .sort(function (a, b) {
            return +a - +b;
          })
          .forEach(function (k) {
            const row = sim.yearly[k];
            const tr = document.createElement('tr');
            tr.innerHTML =
              '<td>' +
              k +
              '</td><td>' +
              fmt.format(Math.round(row.prin)) +
              '</td><td>' +
              fmt.format(Math.round(row.int)) +
              '</td><td>' +
              fmt.format(Math.round(row.prep)) +
              '</td><td>' +
              fmt.format(Math.round(row.end)) +
              '</td>';
            tb.appendChild(tr);
          });
        const note = document.getElementById('hlEmiNote');
        if (note) {
          note.hidden = freq !== 'none';
        }
      }
      const d = debounce(run, 80);
      ['hlP', 'hlR', 'hlY', 'hlPre', 'hlStart', 'hlRR', 'hlYR', 'hlFreq'].forEach(function (id) {
        const el = document.getElementById(id);
        const handler = function () {
          if (id === 'hlRR') document.getElementById('hlR').value = this.value;
          if (id === 'hlYR') document.getElementById('hlY').value = this.value;
          d();
        };
        el.addEventListener('input', handler);
        if (id === 'hlFreq') el.addEventListener('change', handler);
      });
      run();
    })();
  </script>

