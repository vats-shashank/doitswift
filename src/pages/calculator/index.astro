---
import MainLayout from '../../layouts/MainLayout.astro';
import { calculatorCanonical, type CalculatorFaqItem } from '../../lib/calculatorJsonLd';

const finance = [
  { href: '/calculator/sip/', icon: '📈', title: 'SIP Calculator', desc: 'Systematic investment plan maturity & returns' },
  { href: '/calculator/emi/', icon: '🏦', title: 'EMI Calculator', desc: 'Loan EMI, interest & amortization' },
  { href: '/calculator/home-loan/', icon: '🏠', title: 'Home Loan + Prepay', desc: 'EMI with prepayment simulation' },
  { href: '/calculator/income-tax/', icon: '📋', title: 'Income Tax', desc: 'India FY — new vs old regime' },
  { href: '/calculator/fd/', icon: '💰', title: 'FD Calculator', desc: 'Fixed deposit maturity & interest' },
  { href: '/calculator/gst/', icon: '🧾', title: 'GST Calculator', desc: 'Add or remove GST; CGST/SGST split' },
  { href: '/calculator/ppf/', icon: '🏛️', title: 'PPF Calculator', desc: 'Public Provident Fund maturity & yearly table' },
  { href: '/calculator/lumpsum/', icon: '💵', title: 'Lumpsum Calculator', desc: 'One-time investment growth & chart' },
  { href: '/calculator/hra/', icon: '🏘️', title: 'HRA Calculator', desc: 'House rent allowance exemption' },
  { href: '/calculator/retirement/', icon: '🌴', title: 'Retirement', desc: 'Corpus, inflation & SIP to goal' },
  { href: '/calculator/rd/', icon: '📅', title: 'RD Calculator', desc: 'Recurring deposit maturity & quarters' },
  { href: '/calculator/salary/', icon: '💼', title: 'Salary (CTC → in-hand)', desc: 'India take-home & regime compare' },
  { href: '/calculator/nps/', icon: '🏛️', title: 'NPS Calculator', desc: 'National Pension Scheme corpus & pension estimate' },
  { href: '/calculator/compound-interest/', icon: '📊', title: 'Compound Interest', desc: 'Growth, EAR, and year-by-year table' },
  { href: '/calculator/swp/', icon: '💧', title: 'SWP Calculator', desc: 'Systematic withdrawal & sustainability' },
  { href: '/calculator/personal-loan/', icon: '💳', title: 'Personal Loan EMI', desc: 'Unsecured loan EMI, fees & amortization' },
  { href: '/calculator/mortgage/', icon: '🏡', title: 'Mortgage (US)', desc: 'PITI, PMI, taxes & yearly schedule' },
  { href: '/calculator/stock-average/', icon: '📉', title: 'Stock Average / P&L', desc: 'Average buy price & profit after charges' },
];
const health = [
  { href: '/calculator/bmi/', icon: '⚖️', title: 'BMI Calculator', desc: 'Body mass index & categories' },
  { href: '/calculator/calorie/', icon: '🔥', title: 'Calorie / TDEE', desc: 'Daily calories, BMR, macro example' },
  { href: '/calculator/ideal-weight/', icon: '📏', title: 'Ideal Weight', desc: 'Devine, Robinson, Miller, Hamwi + BMI band' },
  { href: '/calculator/body-fat/', icon: '📐', title: 'Body Fat (US Navy)', desc: 'Tape method body fat percentage' },
  { href: '/calculator/pregnancy-due-date/', icon: '🍼', title: 'Due Date', desc: 'EDD from LMP (280-day & Naegele)' },
  { href: '/calculator/water-intake/', icon: '💧', title: 'Water Intake', desc: 'Daily hydration from weight & activity' },
  { href: '/calculator/macro/', icon: '🥗', title: 'Macro Calculator', desc: 'Protein, carbs & fat for your goal' },
  { href: '/calculator/period-ovulation/', icon: '🌸', title: 'Period & Ovulation', desc: 'Cycle estimates & fertile window' },
  { href: '/calculator/heart-rate/', icon: '❤️', title: 'Heart Rate Zones', desc: 'Max HR & training zones' },
];
const mathEducation = [
  { href: '/calculator/percentage/', icon: '🔢', title: 'Percentage', desc: 'Percent of, change, increase/decrease' },
  { href: '/calculator/scientific/', icon: '🔬', title: 'Scientific Calculator', desc: 'Trig, logs, powers & history' },
  { href: '/calculator/gpa/', icon: '🎓', title: 'GPA Calculator', desc: 'India 10-point & US 4.0 weighted GPA' },
  { href: '/calculator/fraction/', icon: '➗', title: 'Fraction Calculator', desc: 'Add, multiply, simplify, decimal → fraction' },
  { href: '/calculator/statistics/', icon: '📊', title: 'Statistics', desc: 'Mean, median, SD, quartiles & charts' },
];
const timeDate = [
  { href: '/calculator/age/', icon: '🎂', title: 'Age Calculator', desc: 'Years, months, days from date of birth' },
  { href: '/calculator/date-difference/', icon: '📆', title: 'Date Difference', desc: 'Days, weeks & approx. months' },
  { href: '/calculator/time/', icon: '⏱️', title: 'Time Math', desc: 'Add or subtract durations' },
];
const everyday = [
  { href: '/calculator/tip/', icon: '🧾', title: 'Tip Calculator', desc: 'Gratuity & bill split, many currencies' },
  { href: '/calculator/discount/', icon: '🏷️', title: 'Discount', desc: 'Sale price, % off, stacked deals' },
  { href: '/calculator/unit-converter/', icon: '🔁', title: 'Unit Converter', desc: 'Length, weight & temperature' },
  { href: '/calculator/emi-vs-rent/', icon: '🆚', title: 'Buy vs Rent', desc: 'EMI vs rent + invest comparison' },
  { href: '/calculator/markup-margin/', icon: '💹', title: 'Markup & Margin', desc: 'Selling price, margin & bulk pricing' },
];

const allTools = [...finance, ...health, ...mathEducation, ...timeDate, ...everyday];

const canonical = calculatorCanonical(Astro.site, Astro.url.pathname);

const pageDescription =
  'Browse forty free DoItSwift calculators: India-focused finance (SIP, EMI, home loan prepay, income tax, FD, RD, GST, PPF, salary, NPS, SWP, personal loan, stock average), US mortgage PITI, retirement and buy-vs-rent, health (BMI, TDEE, ideal weight, Navy body fat, pregnancy EDD, water, macros, period and ovulation, heart-rate zones), math (percentage, scientific, GPA, fraction, statistics), time tools (age, date span, duration math), and everyday helpers (tip, discount, unit converter, markup and margin). All run in your browser with no signup.';

const indexFaqs: CalculatorFaqItem[] = [
  {
    question: 'Do I need an account?',
    answer:
      'No. Open any calculator, enter your numbers, and see results immediately in your browser.',
  },
  {
    question: 'Are my inputs stored on DoItSwift servers?',
    answer:
      'Calculations run locally in JavaScript. We do not receive your salary, loan, or health numbers unless a future feature explicitly says otherwise.',
  },
  {
    question: 'What’s included in the 40 calculators?',
    answer:
      'Finance (SIP, EMI, home loan, personal loan, mortgage, stock average, income tax, FD, GST, PPF, lumpsum, HRA, retirement, RD, salary, NPS, compound interest, SWP), health (BMI, calorie/TDEE, ideal weight, body fat, pregnancy due date, water intake, macros, period and ovulation, heart rate zones), math and education (percentage, scientific, GPA, fraction, statistics), time and date (age, date difference, time math), and everyday tools (tip, discount, units, buy vs rent, markup and margin). Highlights include mortgage (PITI), period tracking estimates, and descriptive statistics with charts.',
  },
  {
    question: 'Are tax and EMI numbers legally binding?',
    answer:
      'No—they are educational estimates. For tax filing or loan decisions, confirm with a chartered accountant or your bank.',
  },
  {
    question: 'Do calculators work on mobile?',
    answer:
      'Yes. Use any modern phone browser; layouts stack for small screens.',
  },
];

// Head-only JSON-LD (slot="head"). ItemList URLs verified against src/pages/calculator/*.astro.
const calcHubBreadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://doitswift.com/' },
    { '@type': 'ListItem', position: 2, name: 'Calculators', item: 'https://doitswift.com/calculator/' },
  ],
};

const calcHubItemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Free Online Calculators',
  description:
    '40 browser-based calculators covering finance, health, math and education, time and date, and everyday tasks. All calculations run locally; no data is sent to any server.',
  numberOfItems: 40,
  itemListElement: [
    { '@type': 'ListItem', position: 1, url: 'https://doitswift.com/calculator/sip/', name: 'SIP Calculator' },
    { '@type': 'ListItem', position: 2, url: 'https://doitswift.com/calculator/emi/', name: 'EMI Calculator' },
    { '@type': 'ListItem', position: 3, url: 'https://doitswift.com/calculator/home-loan/', name: 'Home Loan Calculator' },
    { '@type': 'ListItem', position: 4, url: 'https://doitswift.com/calculator/income-tax/', name: 'Income Tax Calculator' },
    { '@type': 'ListItem', position: 5, url: 'https://doitswift.com/calculator/fd/', name: 'FD Calculator' },
    { '@type': 'ListItem', position: 6, url: 'https://doitswift.com/calculator/gst/', name: 'GST Calculator' },
    { '@type': 'ListItem', position: 7, url: 'https://doitswift.com/calculator/ppf/', name: 'PPF Calculator' },
    { '@type': 'ListItem', position: 8, url: 'https://doitswift.com/calculator/lumpsum/', name: 'Lumpsum Calculator' },
    { '@type': 'ListItem', position: 9, url: 'https://doitswift.com/calculator/hra/', name: 'HRA Calculator' },
    { '@type': 'ListItem', position: 10, url: 'https://doitswift.com/calculator/retirement/', name: 'Retirement Calculator' },
    { '@type': 'ListItem', position: 11, url: 'https://doitswift.com/calculator/rd/', name: 'RD Calculator' },
    { '@type': 'ListItem', position: 12, url: 'https://doitswift.com/calculator/salary/', name: 'Salary Calculator' },
    { '@type': 'ListItem', position: 13, url: 'https://doitswift.com/calculator/nps/', name: 'NPS Calculator' },
    { '@type': 'ListItem', position: 14, url: 'https://doitswift.com/calculator/compound-interest/', name: 'Compound Interest Calculator' },
    { '@type': 'ListItem', position: 15, url: 'https://doitswift.com/calculator/swp/', name: 'SWP Calculator' },
    { '@type': 'ListItem', position: 16, url: 'https://doitswift.com/calculator/personal-loan/', name: 'Personal Loan EMI Calculator' },
    { '@type': 'ListItem', position: 17, url: 'https://doitswift.com/calculator/mortgage/', name: 'Mortgage Calculator' },
    { '@type': 'ListItem', position: 18, url: 'https://doitswift.com/calculator/stock-average/', name: 'Stock Average Calculator' },
    { '@type': 'ListItem', position: 19, url: 'https://doitswift.com/calculator/bmi/', name: 'BMI Calculator' },
    { '@type': 'ListItem', position: 20, url: 'https://doitswift.com/calculator/calorie/', name: 'Calorie Calculator' },
    { '@type': 'ListItem', position: 21, url: 'https://doitswift.com/calculator/ideal-weight/', name: 'Ideal Weight Calculator' },
    { '@type': 'ListItem', position: 22, url: 'https://doitswift.com/calculator/body-fat/', name: 'Body Fat Calculator' },
    {
      '@type': 'ListItem',
      position: 23,
      url: 'https://doitswift.com/calculator/pregnancy-due-date/',
      name: 'Pregnancy Due Date Calculator',
    },
    { '@type': 'ListItem', position: 24, url: 'https://doitswift.com/calculator/water-intake/', name: 'Water Intake Calculator' },
    { '@type': 'ListItem', position: 25, url: 'https://doitswift.com/calculator/macro/', name: 'Macro Calculator' },
    {
      '@type': 'ListItem',
      position: 26,
      url: 'https://doitswift.com/calculator/period-ovulation/',
      name: 'Period & Ovulation Calculator',
    },
    { '@type': 'ListItem', position: 27, url: 'https://doitswift.com/calculator/heart-rate/', name: 'Heart Rate Zones Calculator' },
    { '@type': 'ListItem', position: 28, url: 'https://doitswift.com/calculator/percentage/', name: 'Percentage Calculator' },
    { '@type': 'ListItem', position: 29, url: 'https://doitswift.com/calculator/scientific/', name: 'Scientific Calculator' },
    { '@type': 'ListItem', position: 30, url: 'https://doitswift.com/calculator/gpa/', name: 'GPA Calculator' },
    { '@type': 'ListItem', position: 31, url: 'https://doitswift.com/calculator/fraction/', name: 'Fraction Calculator' },
    { '@type': 'ListItem', position: 32, url: 'https://doitswift.com/calculator/statistics/', name: 'Statistics Calculator' },
    { '@type': 'ListItem', position: 33, url: 'https://doitswift.com/calculator/age/', name: 'Age Calculator' },
    { '@type': 'ListItem', position: 34, url: 'https://doitswift.com/calculator/date-difference/', name: 'Date Difference Calculator' },
    { '@type': 'ListItem', position: 35, url: 'https://doitswift.com/calculator/time/', name: 'Time Math Calculator' },
    { '@type': 'ListItem', position: 36, url: 'https://doitswift.com/calculator/tip/', name: 'Tip Calculator' },
    { '@type': 'ListItem', position: 37, url: 'https://doitswift.com/calculator/discount/', name: 'Discount Calculator' },
    { '@type': 'ListItem', position: 38, url: 'https://doitswift.com/calculator/unit-converter/', name: 'Unit Converter' },
    { '@type': 'ListItem', position: 39, url: 'https://doitswift.com/calculator/emi-vs-rent/', name: 'Buy vs Rent Calculator' },
    { '@type': 'ListItem', position: 40, url: 'https://doitswift.com/calculator/markup-margin/', name: 'Markup and Margin Calculator' },
  ],
};

const calcHubFaqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: indexFaqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const siteRoot = Astro.site ? new URL('/', Astro.site).href : undefined;

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: 'Free Online Calculators — 40 Tools for Finance, Health, Math & Daily Life | DoItSwift',
      description: pageDescription,
      about: { '@id': `${canonical}#collection` },
      ...(siteRoot ? { isPartOf: { '@type': 'WebSite', name: 'DoItSwift', url: siteRoot } } : {}),
    },
    {
      '@type': 'CollectionPage',
      '@id': `${canonical}#collection`,
      url: canonical,
      name: 'Free Online Calculators',
      description: pageDescription,
      ...(siteRoot ? { isPartOf: { '@type': 'WebSite', name: 'DoItSwift', url: siteRoot } } : {}),
      mainEntity: {
        '@type': 'ItemList',
        numberOfItems: allTools.length,
        itemListElement: allTools.map((t, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: t.title,
          url: Astro.site ? new URL(t.href, Astro.site).href : t.href,
          description: t.desc,
        })),
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: indexFaqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
    ...(Astro.site
      ? [
          {
            '@type': 'BreadcrumbList',
            itemListElement: [
              { '@type': 'ListItem', position: 1, name: 'Home', item: siteRoot },
              { '@type': 'ListItem', position: 2, name: 'Calculators', item: new URL('/calculator/', Astro.site).href },
            ],
          },
        ]
      : []),
  ],
};
---

<MainLayout
  title="Free Online Calculators — 40 Tools for Finance, Health, Math & Daily Life | DoItSwift"
  description={pageDescription}
  keywords="free online calculators, SIP EMI income tax calculator India, mortgage PITI calculator US, BMI TDEE calculator, GPA fraction statistics calculator, period ovulation calculator, unit converter tip discount markup, buy vs rent calculator, browser calculators no signup"
  canonical={canonical}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(calcHubBreadcrumbLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(calcHubItemListLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(calcHubFaqPageLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(collectionJsonLd)} />

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Calculators</div>
      <h1>Free Online Calculators</h1>
      <p class="subtitle">
        <strong>40 calculators</strong> across finance, health, math &amp; education, time &amp; date, and everyday use — all in your browser. No signup; math runs locally in JavaScript.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> No signup</span>
        <span><span class="check">✓</span> Instant results</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> Private</span>
      </div>
    </div>
  </section>

  <div class="jump-nav-wrap">
    <div class="container">
      <nav class="jump-nav" aria-labelledby="jump-nav-heading">
        <p id="jump-nav-heading" class="jump-nav-heading">Browse by category</p>
        <ul class="jump-nav-list">
          <li>
            <a href="#finance">Finance <span class="jump-nav-count">({finance.length})</span></a>
          </li>
          <li>
            <a href="#health">Health <span class="jump-nav-count">({health.length})</span></a>
          </li>
          <li>
            <a href="#math">Math &amp; education <span class="jump-nav-count">({mathEducation.length})</span></a>
          </li>
          <li>
            <a href="#time">Time &amp; date <span class="jump-nav-count">({timeDate.length})</span></a>
          </li>
          <li>
            <a href="#everyday">Everyday <span class="jump-nav-count">({everyday.length})</span></a>
          </li>
          <li>
            <a href="#faq">FAQ</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>

  <section id="finance" class="tools-section calc-anchor">
    <div class="container">
      <h2 class="section-title">Finance calculators</h2>
      <p class="section-sub">Investments, loans, tax, rent, deposits, and GST — tuned for Indian rupees where it matters.</p>
      <div class="grid">
        {finance.map((tool) => (
          <a href={tool.href} class="tool-card">
            <span class="icon">{tool.icon}</span>
            <h3>{tool.title}</h3>
            <p>{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="health" class="tools-section tools-section--alt calc-anchor">
    <div class="container">
      <h2 class="section-title">Health calculators</h2>
      <p class="section-sub">Screening tools — not medical advice. Consult professionals for diagnosis or meal plans.</p>
      <div class="grid">
        {health.map((tool) => (
          <a href={tool.href} class="tool-card">
            <span class="icon">{tool.icon}</span>
            <h3>{tool.title}</h3>
            <p>{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="math" class="tools-section calc-anchor">
    <div class="container">
      <h2 class="section-title">Math &amp; education</h2>
      <p class="section-sub">Fractions, statistics, percentages, GPA, and a full scientific keypad — homework and desk work without installing software.</p>
      <div class="grid">
        {mathEducation.map((tool) => (
          <a href={tool.href} class="tool-card">
            <span class="icon">{tool.icon}</span>
            <h3>{tool.title}</h3>
            <p>{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="time" class="tools-section tools-section--alt calc-anchor">
    <div class="container">
      <h2 class="section-title">Time &amp; date</h2>
      <p class="section-sub">Age from birthday, span between dates, and clock arithmetic for shifts and travel.</p>
      <div class="grid">
        {timeDate.map((tool) => (
          <a href={tool.href} class="tool-card">
            <span class="icon">{tool.icon}</span>
            <h3>{tool.title}</h3>
            <p>{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="everyday" class="tools-section calc-anchor">
    <div class="container">
      <h2 class="section-title">Everyday calculators</h2>
      <p class="section-sub">Tips, discounts, unit conversion, rent vs buy, and retail markup vs margin — quick mental-load helpers.</p>
      <div class="grid">
        {everyday.map((tool) => (
          <a href={tool.href} class="tool-card">
            <span class="icon">{tool.icon}</span>
            <h3>{tool.title}</h3>
            <p>{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="faq calc-anchor">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-list">
        {indexFaqs.map((f) => (
          <div class="faq-item">
            <h4>{f.question}</h4>
            <p>{f.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <p class="back-wrap container">
    <a href="/" class="link-back">← Back to home</a>
  </p>

  <style>
    .jump-nav-wrap {
      padding: 0 0 8px;
    }
    .jump-nav {
      max-width: 640px;
      margin: 0 auto;
      padding: 16px 0 20px;
      border-bottom: 1px solid var(--border);
    }
    .jump-nav-heading {
      margin: 0 0 12px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-align: center;
    }
    .jump-nav-list {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 8px;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .jump-nav-list a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 8px 16px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--card);
      box-shadow: var(--shadow);
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      color: var(--text);
      transition: border-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
    }
    .jump-nav-list a:hover {
      border-color: var(--blue);
      color: var(--blue);
    }
    .jump-nav-list a:focus-visible {
      outline: 2px solid var(--blue);
      outline-offset: 2px;
    }
    .jump-nav-count {
      font-weight: 500;
      color: var(--text-muted);
    }
    .jump-nav-list a:hover .jump-nav-count {
      color: inherit;
      opacity: 0.85;
    }
    /* Clear sticky nav when using in-page anchors */
    .calc-anchor {
      scroll-margin-top: max(5.25rem, calc(3.25rem + env(safe-area-inset-top, 0px)));
    }
    .hero {
      padding: 56px 0 24px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 680px;
      margin: 0 auto 28px;
      line-height: 1.55;
    }
    .section-title {
      text-align: center;
      margin-bottom: 8px;
    }
    .section-sub {
      text-align: center;
      color: var(--text-muted);
      margin-bottom: 28px;
      font-size: 16px;
    }
    .tools-section {
      padding: 32px 0 48px;
    }
    .tools-section--alt {
      background: var(--card);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 14px;
    }
    .tool-card {
      background: var(--card);
      padding: 22px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
