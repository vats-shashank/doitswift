---
import MainLayout from '../../layouts/MainLayout.astro';
import { CALCULATOR_CURRENCY_OPTIONS, LOCALE_BY_CURRENCY } from '../../lib/currencyDisplay';
import { buildCalculatorJsonLd, calculatorCanonical } from '../../lib/calculatorJsonLd';

const canonical = calculatorCanonical(Astro.site, Astro.url.pathname);

const pageDescription =
  'Free SWP (systematic withdrawal plan) calculator: starting corpus, fixed monthly withdrawal, assumed annual return %, withdrawal horizon. See ending balance, total withdrawn, depletion timing, rough max sustainable withdrawal, and year-by-year path. Currency formats display only. Not financial advice.';

const jsonLd = buildCalculatorJsonLd({
  site: Astro.site,
  pathname: Astro.url.pathname,
  appName: 'DoItSwift SWP Calculator',
  breadcrumbName: 'SWP Calculator',
  applicationCategory: 'FinanceApplication',
  browserRequirements: 'Requires JavaScript for SWP simulation and yearly table',
  webAppDescription:
    'Simulate systematic withdrawals from an invested corpus with a constant assumed return. Models monthly withdrawals, projected balance over years, approximate depletion timing, and a rough maximum sustainable withdrawal. Optional currency formatting for display. Does not model taxes, fees, or variable returns — educational illustration only.',
  featureList: [
    'Starting corpus and fixed monthly withdrawal amount',
    'Expected annual return (illustrative, 0–15%)',
    'Withdrawal period up to 50 years',
    'Ending balance, cumulative withdrawals, depletion timing',
    'Rough maximum sustainable monthly withdrawal estimate',
    'Year-by-year balance path table',
    'Multi-currency number formatting (not FX conversion)',
    'Runs locally in the browser',
  ],
  faqs: [
    {
      question: 'What is SWP?',
      answer:
        'SWP (systematic withdrawal plan) means withdrawing a fixed sum regularly from an investment while the remainder stays invested and may continue to earn returns.',
    },
    {
      question: 'Is the return rate in the SWP calculator guaranteed?',
      answer:
        'No. The percentage is an assumption. Actual mutual fund or portfolio returns vary with markets.',
    },
    {
      question: 'What does maximum sustainable withdrawal mean?',
      answer:
        'It is a rough monthly amount that would nearly deplete the corpus by the end of the chosen horizon under the same return assumption — highly sensitive to actual returns.',
    },
    {
      question: 'Does the currency dropdown convert exchange rates?',
      answer:
        'No. It only changes how numbers are formatted on screen.',
    },
    {
      question: 'Is the SWP calculator free and private?',
      answer:
        'Yes. It is free with no signup; inputs are processed in your browser.',
    },
  ],
});
---

<MainLayout
  title="SWP Calculator India — Systematic Withdrawal Plan & Sustainability | DoItSwift"
  description={pageDescription}
  keywords="SWP calculator, systematic withdrawal plan calculator, mutual fund SWP calculator, retirement withdrawal calculator India, monthly SWP calculator, corpus withdrawal calculator"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>SWP Calculator</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Free Calculator</div>
      <h1>SWP Calculator</h1>
      <p class="subtitle">
        Model monthly withdrawals from an invested corpus that keeps earning a constant assumed return. See whether the corpus lasts your horizon, when it might hit zero, and a rough <strong>maximum sustainable</strong> monthly withdrawal.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> No signup</span>
        <span><span class="check">✓</span> Instant results</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <section class="calc-section">
    <div class="container calc-layout">
      <div class="calc-inputs">
        <h2 class="calc-heading">Inputs</h2>
        <div class="field">
          <label for="swpCur">Currency (display)</label>
          <select id="swpCur" aria-label="Currency">
            {CALCULATOR_CURRENCY_OPTIONS.map((o) => (
              <option value={o.code} selected={o.code === 'INR'}>
                {o.label}
              </option>
            ))}
          </select>
        </div>
        <div class="field">
          <label for="swpCorpus">Starting corpus</label>
          <input type="number" id="swpCorpus" min="0" step="50000" value="5000000" inputmode="numeric" />
        </div>
        <div class="field">
          <label for="swpWd">Monthly withdrawal</label>
          <input type="number" id="swpWd" min="0" step="1000" value="50000" inputmode="numeric" />
        </div>
        <div class="field">
          <label for="swpR">Expected annual return (%)</label>
          <input type="range" id="swpRR" min="0" max="15" step="0.5" value="8" aria-hidden="true" />
          <input type="number" id="swpR" min="0" max="15" step="0.1" value="8" inputmode="decimal" />
        </div>
        <div class="field">
          <label for="swpY">Withdrawal period (years)</label>
          <input type="number" id="swpY" min="1" max="50" step="1" value="25" inputmode="numeric" />
        </div>
      </div>

      <div class="calc-results" aria-live="polite">
        <h2 class="calc-heading">Results</h2>
        <div class="result-hero" id="swpEnd">—</div>
        <p class="result-label">Corpus at end of period</p>
        <div class="result-grid">
          <div><div class="result-sub" id="swpTotWd">—</div><div class="result-caption">Total withdrawn</div></div>
          <div><div class="result-sub" id="swpDeplete">—</div><div class="result-caption">Depleted in (year)</div></div>
        </div>
        <p class="sust" id="swpSust"></p>
        <details class="calc-details">
          <summary>Year-by-year breakdown</summary>
          <div class="table-wrap">
            <table>
              <caption class="sr-only">Year-by-year SWP corpus after withdrawals</caption>
              <thead><tr><th>Year</th><th>Start</th><th>Withdrawn</th><th>End</th></tr></thead>
              <tbody id="swpTable"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="edu">
    <div class="container">
      <h2 class="section-title">SWP in context</h2>
      <p>
        A <strong>systematic withdrawal plan</strong> sells units each month to fund a fixed cash amount — unlike dividends, you control the amount (subject to available units and fund rules). Returns are not constant; we use one rate for illustration.
      </p>
      <p>
        The <strong>4% rule</strong> (popular in the US) is a rough withdrawal heuristic from a stock-heavy portfolio — inflation and market crashes can break simple rules; India’s inflation and product mix differ.
      </p>
      <p>
        <strong>Tax:</strong> SWP is often discussed as potentially tax-efficient versus arbitrary dividend choices because you withdraw based on cost basis — confirm with a CA for equity/debt fund rules.
      </p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>What is SWP?</h4><p>Regular withdrawals from an invested corpus while the remainder may keep earning returns.</p></div>
        <div class="faq-item"><h4>Is the return % guaranteed?</h4><p>No — it is an assumption only; real returns vary.</p></div>
        <div class="faq-item"><h4>What is “max sustainable” withdrawal?</h4><p>A rough monthly amount that would nearly exhaust the corpus by the end of the horizon under the same assumption — not a promise.</p></div>
        <div class="faq-item"><h4>Does currency affect the math?</h4><p>No — only display formatting.</p></div>
        <div class="faq-item"><h4>Is my data uploaded?</h4><p>No — calculations run locally in your browser.</p></div>
      </div>
    </div>
  </section>

  <section class="affiliate">
    <div class="container">
      <div class="affiliate-inner">
        <div class="affiliate-icon">🌴</div>
        <div class="affiliate-content">
          <h3>Plan the corpus first</h3>
          <p>Pair SWP with a retirement corpus goal.</p>
        </div>
        <a href="/calculator/retirement/" class="btn btn-orange">Retirement →</a>
      </div>
    </div>
  </section>

  <section class="related">
    <div class="container">
      <h2 class="section-title">Related calculators</h2>
      <p class="related-links">
        <a href="/calculator/retirement/">Retirement</a> · <a href="/calculator/sip/">SIP</a>
      </p>
    </div>
  </section>

  <script is:inline define:vars={{ LOCALE_BY_CURRENCY }}>
    (function () {
      function localeForCurrency(code) {
        return LOCALE_BY_CURRENCY[code] || 'en-US';
      }
      function makeFmt() {
        var code = document.getElementById('swpCur').value || 'INR';
        return new Intl.NumberFormat(localeForCurrency(code), { style: 'currency', currency: code, maximumFractionDigits: 0 });
      }
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function simulate(corpus, wd, annualPct, years) {
        const rm = annualPct / 100 / 12;
        let bal = corpus;
        let totWd = 0;
        let depleteMonth = null;
        const yearly = [];
        for (let y = 1; y <= years; y++) {
          const startY = bal;
          for (let m = 0; m < 12; m++) {
            bal = bal * (1 + rm) - wd;
            totWd += wd;
            if (bal <= 0 && depleteMonth === null) {
              depleteMonth = (y - 1) * 12 + m + 1;
            }
            if (bal < 0) bal = 0;
          }
          yearly.push({ y, start: startY, wd: wd * 12, end: bal });
        }
        return { end: bal, totWd, depleteMonth, yearly };
      }
      function maxWd(corpus, annualPct, years) {
        if (corpus <= 0 || years < 1) return 0;
        let lo = 0;
        let hi = (corpus / (years * 12)) * 8 + corpus * (annualPct / 100);
        for (let i = 0; i < 50; i++) {
          const mid = (lo + hi) / 2;
          if (simulate(corpus, mid, annualPct, years).end > 0) lo = mid;
          else hi = mid;
        }
        return lo;
      }
      function run() {
        const fmt = makeFmt();
        const corpus = Math.max(0, parseFloat(document.getElementById('swpCorpus').value) || 0);
        const wd = Math.max(0, parseFloat(document.getElementById('swpWd').value) || 0);
        const rate = Math.min(15, Math.max(0, parseFloat(document.getElementById('swpR').value) || 0));
        const years = Math.min(50, Math.max(1, parseInt(document.getElementById('swpY').value, 10) || 1));
        document.getElementById('swpR').value = rate;
        document.getElementById('swpRR').value = rate;
        const s = simulate(corpus, wd, rate, years);
        document.getElementById('swpEnd').textContent = fmt.format(Math.round(s.end));
        document.getElementById('swpTotWd').textContent = fmt.format(Math.round(s.totWd));
        document.getElementById('swpDeplete').textContent =
          s.depleteMonth === null ? 'Not in horizon' : 'Year ' + Math.ceil(s.depleteMonth / 12);
        const mx = maxWd(corpus, rate, years);
        document.getElementById('swpSust').textContent =
          'Rough max monthly withdrawal to near-deplete by end of period (same return assumption): ~' +
          fmt.format(Math.round(mx)) +
          ' — highly sensitive to returns.';
        const tbody = document.getElementById('swpTable');
        tbody.innerHTML = '';
        s.yearly.forEach(function (row) {
          const tr = document.createElement('tr');
          tr.innerHTML =
            '<td>' +
            row.y +
            '</td><td>' +
            fmt.format(Math.round(row.start)) +
            '</td><td>' +
            fmt.format(Math.round(row.wd)) +
            '</td><td>' +
            fmt.format(Math.round(row.end)) +
            '</td>';
          tbody.appendChild(tr);
        });
      }
      const d = debounce(run, 80);
      document.getElementById('swpCur').addEventListener('change', d);
      ['swpCorpus', 'swpWd', 'swpR', 'swpY'].forEach((id) => document.getElementById(id).addEventListener('input', d));
      document.getElementById('swpRR').addEventListener('input', function () {
        document.getElementById('swpR').value = this.value;
        d();
      });
      run();
    })();
  </script>

  <style>
    .breadcrumb { font-size: 13px; color: var(--text-muted); padding: 16px 0 0; max-width: 960px; }
    .breadcrumb a { color: var(--blue); text-decoration: none; }
    .hero { padding: 36px 0 16px; text-align: center; }
    .subtitle { font-size: 16px; color: var(--text-muted); max-width: 700px; margin: 0 auto 22px; line-height: 1.55; }
    .subtitle strong { color: var(--text); font-weight: 700; }
    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    .calc-section { padding: 24px 0 40px; }
    .calc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; max-width: 960px; align-items: start; }
    @media (max-width: 768px) { .calc-layout { grid-template-columns: 1fr; } }
    .calc-inputs, .calc-results { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 22px 24px; box-shadow: var(--shadow); }
    .calc-heading { font-size: 1rem; margin: 0 0 16px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; }
    .field { margin-bottom: 14px; }
    .field label { display: block; font-weight: 600; font-size: 14px; margin-bottom: 6px; }
    .field input[type='number'] { width: 100%; padding: 10px 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); font-size: 16px; }
    .field input[type='range'] { width: 100%; margin-bottom: 4px; }
    .result-hero { font-size: 2rem; font-weight: 800; color: var(--blue); }
    .result-label { font-size: 14px; color: var(--text-muted); margin: 4px 0 12px; }
    .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 10px; }
    .result-sub { font-size: 1.15rem; font-weight: 700; }
    .result-caption { font-size: 12px; color: var(--text-muted); }
    .sust { font-size: 13px; color: var(--text-muted); line-height: 1.55; margin-bottom: 10px; }
    .calc-details summary { cursor: pointer; font-weight: 600; }
    .table-wrap { overflow: auto; max-height: 260px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { padding: 8px; border-bottom: 1px solid var(--border); text-align: right; }
    th:first-child, td:first-child { text-align: left; }
    .edu { padding: 36px 0; }
    .edu .container { max-width: 760px; }
    .edu p { font-size: 15px; line-height: 1.75; color: var(--text-muted); margin-bottom: 14px; }
    .section-title { text-align: center; margin-bottom: 18px; font-size: 1.5rem; }
    .faq { padding: 8px 0 28px; }
    .faq .container { max-width: 760px; }
    .faq-list { display: flex; flex-direction: column; gap: 10px; }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 18px;
    }
    .faq-item h4 { font-size: 15px; margin-bottom: 4px; }
    .faq-item p { font-size: 14px; color: var(--text-muted); margin: 0; }
    .affiliate { padding: 28px 0; }
    .affiliate .container { max-width: 900px; }
    .affiliate-inner { background: linear-gradient(135deg, #ecfdf5, #d1fae5); border: 1px solid #6ee7b7; border-radius: var(--radius-lg); padding: 24px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    [data-theme='dark'] .affiliate-inner { background: rgba(16, 185, 129, 0.12); border-color: rgba(52, 211, 153, 0.4); }
    .affiliate-icon { font-size: 36px; }
    .affiliate-content { flex: 1; min-width: 200px; }
    .related { text-align: center; padding-bottom: 48px; }
    .related-links a { color: var(--blue); font-weight: 600; }
  </style>
</MainLayout>
