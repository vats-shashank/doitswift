  <script is:inline>
    (function () {
      const fmt = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
      function debounce(fn, ms) { let t; return function () { clearTimeout(t); t = setTimeout(fn, ms); }; }
      function run() {
        const P = Math.max(1000, parseFloat(document.getElementById('fdP').value) || 0);
        const annual = Math.max(1, Math.min(15, parseFloat(document.getElementById('fdR').value) || 0));
        const t = Math.max(0.08, Math.min(10, parseFloat(document.getElementById('fdT').value) || 0));
        const n = parseInt(document.getElementById('fdN').value, 10);
        document.getElementById('fdRR').value = annual;
        document.getElementById('fdR').value = annual;
        const r = annual / 100;
        const A = P * Math.pow(1 + r / n, n * t);
        const interest = A - P;
        document.getElementById('fdMat').textContent = fmt.format(Math.round(A));
        document.getElementById('fdInt').textContent = fmt.format(Math.round(interest));
        document.getElementById('fdPrin').textContent = fmt.format(Math.round(P));
        const tb = document.getElementById('fdTb');
        tb.innerHTML = '';
        const yMax = Math.ceil(t);
        for (let y = 1; y <= yMax; y++) {
          const ty = Math.min(y, t);
          const bal = P * Math.pow(1 + r / n, n * ty);
          const tr = document.createElement('tr');
          tr.innerHTML = '<td>' + y + '</td><td>' + fmt.format(Math.round(bal)) + '</td>';
          tb.appendChild(tr);
        }
      }
      const d = debounce(run, 80);
      ['fdP', 'fdR', 'fdT', 'fdN'].forEach(function (id) { document.getElementById(id).addEventListener('input', d); });
      document.getElementById('fdRR').addEventListener('input', function () { document.getElementById('fdR').value = this.value; d(); });
      run();
    })();
  </script>

