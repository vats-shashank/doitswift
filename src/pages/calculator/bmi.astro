  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>BMI Calculator</span>
  </nav>

  <section class="hero">
    <div class="container">
