  <script is:inline>
    (function () {
      function debounce(fn, ms) {
        var t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function heightM() {
        var u = document.querySelector('input[name="bmiHunit"]:checked').value;
        if (u === 'cm') {
          var cm = parseFloat(document.getElementById('bmiCm').value) || 0;
          return cm / 100;
        }
        var ft = parseFloat(document.getElementById('bmiFt').value) || 0;
        var inch = parseFloat(document.getElementById('bmiIn').value) || 0;
        return (ft * 12 + inch) * 0.0254;
      }
      function weightKg() {
        var w = parseFloat(document.getElementById('bmiWeight').value) || 0;
        return document.querySelector('input[name="bmiWunit"]:checked').value === 'lb' ? w * 0.45359237 : w;
      }
      function category(bmi) {
        if (bmi < 18.5) return { label: 'Underweight', key: 'u' };
        if (bmi < 25) return { label: 'Normal weight', key: 'n' };
        if (bmi < 30) return { label: 'Overweight', key: 'o' };
        return { label: 'Obese', key: 'x' };
      }
      function syncBmiHeight(newUnit) {
        if (newUnit === 'ft') {
          var cm = parseFloat(document.getElementById('bmiCm').value);
          if (isNaN(cm) || cm <= 0) return;
          var totalIn = cm / 2.54;
          var ft = Math.floor(totalIn / 12);
          var inch = totalIn - ft * 12;
          document.getElementById('bmiFt').value = ft;
          document.getElementById('bmiIn').value = Math.round(inch * 100) / 100;
        } else {
          var ft = parseFloat(document.getElementById('bmiFt').value) || 0;
          var inch = parseFloat(document.getElementById('bmiIn').value) || 0;
          document.getElementById('bmiCm').value = Math.round((ft * 12 + inch) * 2.54 * 100) / 100;
        }
      }
      function syncBmiWeight(newUnit) {
        var w = parseFloat(document.getElementById('bmiWeight').value) || 0;
        if (newUnit === 'lb') {
          document.getElementById('bmiWeight').value = Math.round(w * 2.2046226218 * 10) / 10;
        } else {
          document.getElementById('bmiWeight').value = Math.round(w * 0.45359237 * 10) / 10;
        }
      }
      function run() {
        var hm = heightM();
        var kg = weightKg();
        document.getElementById('hCmWrap').classList.toggle('hidden', document.querySelector('input[name="bmiHunit"]:checked').value !== 'cm');
        document.getElementById('hFtWrap').classList.toggle('hidden', document.querySelector('input[name="bmiHunit"]:checked').value !== 'ft');
        if (hm <= 0 || kg <= 0) {
          document.getElementById('bmiNum').textContent = '—';
          document.getElementById('bmiCat').textContent = 'Enter height and weight';
          document.getElementById('bmiRisk').textContent = '';
          document.getElementById('bmiIdeal').textContent = '';
          document.getElementById('bmiNeedle').style.left = '50%';
          return;
        }
        var bmi = kg / (hm * hm);
        var c = category(bmi);
        document.getElementById('bmiNum').textContent = bmi.toFixed(1);
        document.getElementById('bmiCat').textContent = c.label;
        var risk =
          c.key === 'u'
            ? 'Higher risk of nutrient deficiency or osteoporosis — seek advice if unintended weight loss.'
            : c.key === 'n'
              ? 'Within the common “normal” BMI band for adults — keep up balanced habits.'
              : c.key === 'o'
                ? 'Elevated risk for blood pressure, lipids, and glucose — consider lifestyle review.'
                : 'Higher long-term cardiometabolic risk — a clinician can help with a tailored plan.';
        document.getElementById('bmiRisk').textContent = risk;
        var h2 = hm * hm;
        var wLow = 18.5 * h2;
        var wHigh = 24.9 * h2;
        document.getElementById('bmiIdeal').textContent =
          'Ideal weight range (BMI 18.5–24.9): ' +
          wLow.toFixed(1) +
          '–' +
          wHigh.toFixed(1) +
          ' kg (≈ ' +
          (wLow * 2.20462).toFixed(1) +
          '–' +
          (wHigh * 2.20462).toFixed(1) +
          ' lb).';
        var clamped = Math.max(15, Math.min(40, bmi));
        var pct = ((clamped - 15) / 25) * 100;
        document.getElementById('bmiNeedle').style.left = pct + '%';
      }
      var d = debounce(run, 60);
      ['bmiCm', 'bmiFt', 'bmiIn', 'bmiWeight', 'bmiAge'].forEach(function (id) {
        document.getElementById(id).addEventListener('input', d);
      });
      document.querySelectorAll('input[name="bmiHunit"]').forEach(function (el) {
        el.addEventListener('change', function () {
          syncBmiHeight(this.value);
          d();
        });
      });
      document.querySelectorAll('input[name="bmiWunit"]').forEach(function (el) {
        el.addEventListener('change', function () {
          syncBmiWeight(this.value);
          d();
        });
      });
      run();
    })();
  </script>

