  <script is:inline>
    (function () {
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function kg() {
        const w = parseFloat(document.getElementById('calW').value) || 0;
        return document.querySelector('input[name="calWu"]:checked').value === 'lb' ? w * 0.45359237 : w;
      }
      function heightCm() {
        if (document.querySelector('input[name="calHu"]:checked').value === 'cm') {
          return parseFloat(document.getElementById('calCm').value) || 0;
        }
        const ft = parseFloat(document.getElementById('calFt').value) || 0;
        const inch = parseFloat(document.getElementById('calIn').value) || 0;
        return (ft * 12 + inch) * 2.54;
      }
      function syncCalHeight(newUnit) {
        if (newUnit === 'ft') {
          var cm = parseFloat(document.getElementById('calCm').value);
          if (isNaN(cm) || cm <= 0) return;
          var totalIn = cm / 2.54;
          var ft = Math.floor(totalIn / 12);
          var inch = totalIn - ft * 12;
          document.getElementById('calFt').value = ft;
          document.getElementById('calIn').value = Math.round(inch * 100) / 100;
        } else {
          var ft = parseFloat(document.getElementById('calFt').value) || 0;
          var inch = parseFloat(document.getElementById('calIn').value) || 0;
          document.getElementById('calCm').value = Math.round((ft * 12 + inch) * 2.54 * 100) / 100;
        }
      }
      function syncCalWeight(newUnit) {
        var w = parseFloat(document.getElementById('calW').value) || 0;
        if (newUnit === 'lb') {
          document.getElementById('calW').value = Math.round(w * 2.2046226218 * 10) / 10;
        } else {
          document.getElementById('calW').value = Math.round(w * 0.45359237 * 10) / 10;
        }
      }
      function run() {
        const male = document.querySelector('input[name="calSex"]:checked').value === 'm';
        document.getElementById('calHcm').classList.toggle('hidden', document.querySelector('input[name="calHu"]:checked').value !== 'cm');
        document.getElementById('calHft').classList.toggle('hidden', document.querySelector('input[name="calHu"]:checked').value !== 'ft');
        const age = Math.max(15, Math.min(100, parseInt(document.getElementById('calAge').value, 10) || 25));
        const wkg = kg();
        const h = heightCm();
        const act = parseFloat(document.getElementById('calAct').value);
        const goal = parseFloat(document.getElementById('calGoal').value);
        let bmr = 10 * wkg + 6.25 * h - 5 * age + (male ? 5 : -161);
        const tdee = bmr * act;
        const adj = (goal * 7700) / 7;
        const target = Math.max(800, tdee + adj);
        document.getElementById('calBmr').textContent = Math.round(bmr) + ' kcal';
        document.getElementById('calTdee').textContent = Math.round(tdee) + ' kcal';
        document.getElementById('calDelta').textContent = (adj >= 0 ? '+' : '') + Math.round(adj) + ' kcal';
        document.getElementById('calTarget').textContent = Math.round(target) + ' kcal';
        document.getElementById('calP').textContent = Math.round((target * 0.3) / 4);
        document.getElementById('calC').textContent = Math.round((target * 0.4) / 4);
        document.getElementById('calF').textContent = Math.round((target * 0.3) / 9);
        const pct = Math.max(0, Math.min(100, 50 + (adj / 25) * -1));
        document.getElementById('calMeter').style.width = pct + '%';
      }
      const d = debounce(run, 60);
      ['calAge', 'calCm', 'calFt', 'calIn', 'calW', 'calAct', 'calGoal'].forEach(function (id) {
        document.getElementById(id).addEventListener('input', d);
      });
      document.querySelectorAll('input[name="calHu"]').forEach(function (el) {
        el.addEventListener('change', function () {
          syncCalHeight(this.value);
          d();
        });
      });
      document.querySelectorAll('input[name="calWu"]').forEach(function (el) {
        el.addEventListener('change', function () {
          syncCalWeight(this.value);
          d();
        });
      });
      document.querySelectorAll('input[name="calSex"]').forEach(function (el) {
        el.addEventListener('change', d);
      });
      run();
    })();
  </script>

