      var MILE_KM = 1.609344;
      var GAL_US_L = 3.785411784;
      var GAL_IMP_L = 4.54609;

      function fuelToKmPerL(v, id) {
        if (id === 'km_l') return v;
        if (id === 'l100') return v > 0 ? 100 / v : NaN;
        if (id === 'mpg_us') return (v * MILE_KM) / GAL_US_L;
        if (id === 'mpg_imp') return (v * MILE_KM) / GAL_IMP_L;
        return NaN;
      }

      function kmPerLToFuel(k, id) {
        if (id === 'km_l') return k;
        if (id === 'l100') return k > 0 ? 100 / k : NaN;
        if (id === 'mpg_us') return (k * GAL_US_L) / MILE_KM;
        if (id === 'mpg_imp') return (k * GAL_IMP_L) / MILE_KM;
        return NaN;
      }

      var quickRef = {
