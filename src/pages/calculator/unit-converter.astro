            MPa: { name: 'Megapascal (MPa)', factor: 1e6 },
            bar: { name: 'Bar', factor: 100000 },
            mbar: { name: 'Millibar (mbar)', factor: 100 },
            psi: { name: 'PSI (lb/in²)', factor: 6894.76 },
            atm: { name: 'Atmosphere (atm)', factor: 101325 },
            Torr: { name: 'Torr', factor: 133.322 },
