        area: ['1 hectare = 10 000 m² ≈ 2.471 acres', '1 acre ≈ 4047 m²', '1 m² ≈ 10.764 ft²'],
        speed: ['1 km/h ≈ 0.621 mph', '60 mph ≈ 96.56 km/h', '1 knot ≈ 1.852 km/h', 'Mach 1 ≈ 343 m/s at sea level'],
        time: ['1 hour = 3600 seconds', '1 day = 86 400 s', '1 average year ≈ 365.25 days'],
        energy: ['1 kcal ≈ 4184 J', '1 kWh = 3.6 MJ', '1 eV ≈ 1.602×10⁻¹⁹ J'],
        power: ['1 hp (mechanical) ≈ 745.7 W', '1 PS ≈ 735.5 W', '1 W = 1 J/s'],
        pressure: ['1 atm = 101 325 Pa', '1 bar = 100 000 Pa', '1 PSI ≈ 6895 Pa'],
        data: ['1 KB = 1024 bytes (binary)', '1 MB = 1024 KB', '8 bits = 1 byte'],
        frequency: ['1 kHz = 1000 Hz', '60 RPM = 1 Hz'],
        fuel: ['Higher km/L or mpg means better fuel economy', 'L/100 km decreases as efficiency improves', 'US and Imperial gallons differ'],
        angle: ['π rad = 180°', '1 revolution = 2π rad', '1° = π/180 rad'],
      };

      var lastEdited = 'left';
      var selCat = document.getElementById('ucCategory');
      var v1 = document.getElementById('value-1');
      var v2 = document.getElementById('value-2');
      var u1 = document.getElementById('unit-1');
      var u2 = document.getElementById('unit-2');
      var formulaEl = document.getElementById('ucFormula');
      var quickList = document.getElementById('ucQuickList');

      function catKeys() {
        return Object.keys(categories);
      }

      function fillCategories() {
        selCat.innerHTML = '';
        catKeys().forEach(function (k) {
          var o = document.createElement('option');
          o.value = k;
          o.textContent = categories[k].name;
          selCat.appendChild(o);
        });
      }

      function fillUnits(selectEl, catKey, selectedId) {
        var cat = categories[catKey];
        selectEl.innerHTML = '';
        Object.keys(cat.units).forEach(function (id) {
          var o = document.createElement('option');
          o.value = id;
          o.textContent = cat.units[id].name;
          selectEl.appendChild(o);
        });
        if (selectedId && cat.units[selectedId]) selectEl.value = selectedId;
        else selectEl.selectedIndex = 0;
      }

      function parseNum(s) {
        if (s === '' || s === null || s === undefined) return NaN;
        var t = String(s).replace(/,/g, '').trim();
        if (t === '' || t === '-' || t === '.' || t === '-.') return NaN;
        return parseFloat(t);
      }

      function formatOut(x) {
        if (x === null || x === undefined || (typeof x === 'number' && !isFinite(x))) return '';
        var ax = Math.abs(x);
        if (ax !== 0 && (ax >= 1e15 || ax < 1e-9)) return x.toExponential(8);
        var rounded = Math.round(x * 1e12) / 1e12;
        var s = String(rounded);
        if (s.length > 18) return x.toPrecision(12);
        return s;
      }

      function convertFactor(val, fromId, toId, cat) {
        var fu = cat.units[fromId].factor;
        var tu = cat.units[toId].factor;
        return (val * fu) / tu;
      }

      function convertTemp(val, fromId, toId, cat) {
        var c = cat.units[fromId].toC(val);
        return cat.units[toId].fromC(c);
      }

      function convertFuel(val, fromId, toId) {
        var k = fuelToKmPerL(val, fromId);
        return kmPerLToFuel(k, toId);
      }

      function updateFormula(catKey, id1, id2) {
        var cat = categories[catKey];
        if (cat.type === 'temp') {
          formulaEl.textContent =
            'Formula: (°F − 32) × 5/9 = °C; °C × 9/5 + 32 = °F; K = °C + 273.15; °R = (°C + 273.15) × 9/5; °Ré = °C × 4/5. Temperatures need offsets, not a single multiplier.';
          return;
        }
        if (cat.type === 'fuel') {
          formulaEl.textContent =
            'Formula: convert via km/L — L/100 km = 100 ÷ (km/L). US mpg uses US gallons (3.785 L); Imperial mpg uses Imperial gallons (4.546 L).';
          return;
        }
        if (cat.type === 'factor') {
          var f1 = cat.units[id1].factor;
          var f2 = cat.units[id2].factor;
          var ratio = f1 / f2;
          var line =
            Math.abs(ratio - 1) < 1e-15
              ? 'Same unit — no conversion.'
              : Math.abs(ratio) > 0 && Math.abs(Math.log10(Math.abs(ratio))) < 8
                ? 'Multiply the first value by ' + formatOut(ratio) + ' to obtain the second (factors relative to ' + cat.base + ').'
                : 'Multiply the first value by ' + ratio.toExponential(10) + ' to obtain the second (via base ' + cat.base + ').';
          if (cat.note) line += ' ' + cat.note;
          formulaEl.textContent = 'Formula: ' + line;
          return;
        }
        formulaEl.textContent = '';
      }

      function updateQuick(catKey) {
        var lines = quickRef[catKey] || [];
        quickList.innerHTML = '';
        lines.forEach(function (line) {
          var li = document.createElement('li');
          li.textContent = line;
          quickList.appendChild(li);
        });
      }

      function runFromSide(side) {
        var catKey = selCat.value;
        var cat = categories[catKey];
        var id1 = u1.value;
        var id2 = u2.value;
        var n1 = parseNum(v1.value);
        var n2 = parseNum(v2.value);
        lastEdited = side;

        if (cat.type === 'factor') {
          if (side === 'left') {
            if (isNaN(n1)) {
              v2.value = '';
              return;
            }
            v2.value = formatOut(convertFactor(n1, id1, id2, cat));
          } else {
            if (isNaN(n2)) {
              v1.value = '';
              return;
            }
            v1.value = formatOut(convertFactor(n2, id2, id1, cat));
          }
        } else if (cat.type === 'temp') {
          if (side === 'left') {
            if (isNaN(n1)) {
              v2.value = '';
              return;
            }
            v2.value = formatOut(convertTemp(n1, id1, id2, cat));
          } else {
            if (isNaN(n2)) {
              v1.value = '';
              return;
            }
            v1.value = formatOut(convertTemp(n2, id2, id1, cat));
          }
        } else if (cat.type === 'fuel') {
          if (side === 'left') {
            if (isNaN(n1)) {
              v2.value = '';
              return;
            }
            v2.value = formatOut(convertFuel(n1, id1, id2));
          } else {
            if (isNaN(n2)) {
              v1.value = '';
              return;
            }
            v1.value = formatOut(convertFuel(n2, id2, id1));
          }
        }
        updateFormula(catKey, id1, id2);
      }

      function onCategoryChange() {
        var k = selCat.value;
        var ids = Object.keys(categories[k].units);
        var def = {
          length: ['m', 'cm'],
          mass: ['kg', 'lb'],
          temperature: ['C', 'F'],
          volume: ['L', 'gal_us'],
          area: ['ha', 'acre'],
          speed: ['kmh', 'mph'],
          time: ['h', 'min'],
          energy: ['kWh', 'J'],
          power: ['kW', 'hp'],
          pressure: ['atm', 'Pa'],
          data: ['GB', 'MB'],
          frequency: ['GHz', 'MHz'],
          fuel: ['mpg_us', 'km_l'],
          angle: ['deg', 'rad'],
        };
        var pair = def[k] || [ids[0], ids[Math.min(1, ids.length - 1)]];
        fillUnits(u1, k, pair[0]);
        fillUnits(u2, k, pair[1]);
        v1.value = '1';
        v2.value = '';
        lastEdited = 'left';
        runFromSide('left');
        updateQuick(k);
      }

      function wire() {
        fillCategories();
        selCat.value = 'length';
        onCategoryChange();

        selCat.addEventListener('change', onCategoryChange);
        u1.addEventListener('change', function () {
          runFromSide(lastEdited);
        });
        u2.addEventListener('change', function () {
          runFromSide(lastEdited);
        });
        v1.addEventListener('input', function () {
          runFromSide('left');
        });
        v2.addEventListener('input', function () {
          runFromSide('right');
        });
        v1.addEventListener('focus', function () {
          lastEdited = 'left';
        });
        v2.addEventListener('focus', function () {
          lastEdited = 'right';
        });
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', wire);
      else wire();
    })();
  </script>

