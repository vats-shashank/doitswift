            lb: { name: 'Pound (lb)', factor: 0.45359237 },
            st: { name: 'Stone (st)', factor: 6.35029318 },
            us_ton: { name: 'US ton', factor: 907.18474 },
            imp_ton: { name: 'Imperial ton', factor: 1016.04691 },
            ct: { name: 'Carat', factor: 0.0002 },
            u: { name: 'Atomic mass unit (u)', factor: 1.66054e-27 },
          },
        },
        temperature: {
          name: 'Temperature',
          type: 'temp',
          units: {
            C: {
              name: 'Celsius (°C)',
              toC: function (v) {
                return v;
              },
              fromC: function (v) {
                return v;
              },
            },
            F: {
              name: 'Fahrenheit (°F)',
              toC: function (v) {
                return ((v - 32) * 5) / 9;
              },
              fromC: function (v) {
                return (v * 9) / 5 + 32;
              },
            },
            K: {
              name: 'Kelvin (K)',
              toC: function (v) {
                return v - 273.15;
              },
              fromC: function (v) {
                return v + 273.15;
              },
            },
            R: {
              name: 'Rankine (°R)',
              toC: function (v) {
                return (v * 5) / 9 - 273.15;
              },
              fromC: function (v) {
                return (v + 273.15) * (9 / 5);
              },
            },
            Re: {
              name: 'Réaumur (°Ré)',
              toC: function (v) {
                return (v * 5) / 4;
              },
              fromC: function (v) {
                return (v * 4) / 5;
