            yd2: { name: 'Square yard (yd²)', factor: 0.836127 },
            acre: { name: 'Acre', factor: 4046.86 },
            mi2: { name: 'Square mile (mi²)', factor: 2.59e6 },
            bigha: { name: 'Bigha (India, approx. 2500 m²)', factor: 2500 },
          },
        },
        speed: {
          name: 'Speed',
          type: 'factor',
