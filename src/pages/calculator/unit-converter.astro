---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = 'https://doitswift.com/calculator/unit-converter/';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'Unit Converter — DoItSwift',
      url: canonical,
      applicationCategory: 'UtilityApplication',
      operatingSystem: 'Web',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
      description:
        'Convert length, mass, temperature, volume, area, speed, time, energy, power, pressure, data, frequency, fuel economy, and angle — bidirectional, offline.',
    },
  ],
};
---

<MainLayout
  title="Unit Converter — Length, Weight, Temperature & More | DoItSwift"
  description="Free unit converter with 14 categories: metric and imperial length, mass, temperature, volume, area, speed, time, energy, power, pressure, digital storage, frequency, fuel economy, and angle. Works offline."
  keywords="unit converter, km to miles, kg to lbs, celsius to fahrenheit, gallons to litres, hectares to acres, GB to MB"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>Unit Converter</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Free Calculator</div>
      <h1>Unit Converter</h1>
      <p class="subtitle">
        Convert <strong>14 categories</strong> of units with a clean, two-sided layout — type on either side, pick units below, and see the formula update instantly. No signup; math runs in your browser.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> No signup</span>
        <span><span class="check">✓</span> Instant results</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <section class="uc-section">
    <div class="container">
      <div class="converter-box" id="ucRoot">
        <div class="category-select">
          <label for="ucCategory">Category</label>
          <select id="ucCategory" aria-describedby="ucCatHint"></select>
        </div>
        <p id="ucCatHint" class="uc-hint">Choose a category, then enter a value on either side.</p>

        <div class="conversion-area">
          <div class="converter-side">
            <label class="side-label" for="value-1">From</label>
            <input
              type="text"
              id="value-1"
              class="value-input"
              inputmode="decimal"
              autocomplete="off"
              placeholder="Enter value"
              aria-label="Value to convert from"
            />
            <label class="sr-only" for="unit-1">Unit from</label>
            <select id="unit-1" class="unit-select" aria-label="Unit from"></select>
          </div>

          <div class="converter-divider">
            <span class="equals-desktop" aria-hidden="true">=</span>
            <span class="equals-mobile" aria-hidden="true">⇅</span>
          </div>

          <div class="converter-side">
            <label class="side-label" for="value-2">To</label>
            <input
              type="text"
              id="value-2"
              class="value-input"
              inputmode="decimal"
              autocomplete="off"
              placeholder="Converted value"
              aria-label="Converted value"
            />
            <label class="sr-only" for="unit-2">Unit to</label>
            <select id="unit-2" class="unit-select" aria-label="Unit to"></select>
          </div>
        </div>

        <div class="formula-box" role="status">
          <span class="formula-label">Formula</span>
          <div class="formula-text" id="ucFormula"></div>
        </div>

        <details class="common-conversions" id="ucQuick">
          <summary>Common conversions in this category</summary>
          <ul class="uc-quick" id="ucQuickList"></ul>
        </details>
      </div>
    </div>
  </section>

  <section class="edu uc-edu">
    <div class="container">
      <h2 class="section-title">How to use this unit converter</h2>
      <p>
        Pick a <strong>category</strong> from the menu at the top (length, mass, temperature, and so on). Enter a number in <strong>either</strong> large field — the other side updates immediately. Use the <strong>unit dropdowns</strong> under each value to change meters to feet, kilograms to pounds, Celsius to Fahrenheit, or any other pair in that category. The shaded <strong>formula</strong> line explains the relationship for your current pair (multiply, divide, or a temperature rule). Expand <strong>Common conversions</strong> for a short cheat sheet of popular equivalents in that category.
      </p>

      <h3 class="uc-h3">Categories explained</h3>
      <p>
        <strong>Length</strong> is used for distance and size — from nanometres in chip design to light years in astronomy. <strong>Mass</strong> (often called weight in everyday speech) uses the kilogram as the SI anchor; carats and atomic mass units appear for gems and chemistry. <strong>Temperature</strong> needs <em>offsets</em> as well as scales, so Celsius, Fahrenheit, Kelvin, Rankine, and Réaumur are linked by formulas, not a single multiplier. <strong>Volume</strong> separates liquid cooking measures (US cups, teaspoons) from litres and cubic metres. <strong>Area</strong> covers floors, land, and fields — including hectare and a practical Indian <strong>bigha</strong> reference (definitions vary by state). <strong>Speed</strong> includes km/h, mph, knots, and fixed references like Mach at sea level and the speed of light in vacuum.
      </p>
      <p>
        <strong>Time</strong> spans nanoseconds to centuries; “month” and “year” use common averages because calendar months differ. <strong>Energy</strong> and <strong>power</strong> connect joules, calories, kilowatt-hours, and horsepower. <strong>Pressure</strong> maps pascals to PSI, bar, atmospheres, and millimetres of mercury. <strong>Data storage</strong> here uses <strong>binary</strong> kilo/mega/giga (powers of 1024), which matches how operating systems report file and RAM sizes. <strong>Frequency</strong> links hertz to RPM. <strong>Fuel economy</strong> ties together US mpg, Imperial mpg, km/L, and the inverse L/100 km style common in Europe. <strong>Angle</strong> uses radians as the mathematical base, with degrees, gradians, and arc minutes/seconds for surveying and astronomy.
      </p>

      <h3 class="uc-h3">Common conversions reference</h3>
      <p>
        Handy anchors: <strong>1 inch = 2.54 cm</strong> exactly; <strong>1 mile ≈ 1.609 km</strong>; <strong>1 kg ≈ 2.2046 lb</strong>; <strong>1 US gallon ≈ 3.785 L</strong>; <strong>1 Imperial gallon ≈ 4.546 L</strong>; <strong>0 °C = 32 °F</strong>; <strong>100 °C = 212 °F</strong>; <strong>1 hectare ≈ 2.471 acres</strong>. For digital sizes, <strong>1 KiB = 1024 bytes</strong> (often shown as “KB” in software). For fuel, remember <strong>L/100 km</strong> drops as efficiency improves, while <strong>km/L</strong> and <strong>mpg</strong> rise.
      </p>

      <h3 class="uc-h3">Why metric vs imperial?</h3>
      <p>
        The <strong>metric system</strong> (SI) uses decimal prefixes and shared bases, which simplifies science, trade, and education. The <strong>US customary</strong> and <strong>British imperial</strong> systems persist in everyday life in several countries — road signs in miles, body weight in stones in the UK, US fluid ounces for recipes. Converters bridge the two without replacing local convention; precision matters when engineering or baking.
      </p>

      <h3 class="uc-h3">Precision and rounding</h3>
      <p>
        Factors and constants follow internationally used values (e.g. exact inch–centimetre definition). Displayed numbers are <strong>rounded for readability</strong>; very large or small results may use <strong>scientific notation</strong>. If you need legal or contract-critical figures, confirm against primary standards.
      </p>

      <h3 class="uc-h3">Why temperature is different</h3>
      <p>
        Most units are <strong>proportional</strong>: doubling the number doubles the physical quantity when converted. Temperature scales have different <strong>zeros</strong> and <strong>step sizes</strong>, so you cannot convert °C to °F by multiplying alone — you use a linear formula with an offset (and different handling for Kelvin as an absolute scale). That is why this tool shows explicit temperature rules in the formula box instead of a single “multiply by k” line.
      </p>

      <h3 class="uc-h3">Tips for students, cooks, and travellers</h3>
      <p>
        When doing <strong>homework</strong>, write the unit symbol beside every number until the final answer; this catches mismatched scales early. In the <strong>kitchen</strong>, liquid volumes differ between US cups and metric millilitres — pick the column that matches your recipe card. For <strong>travel</strong>, mentally anchor a few conversions (your height in feet, driving speed in mph, or luggage weight in pounds) so foreign signs feel less abstract. When you only need a rough estimate, rounding to two significant figures is often enough; when you are comparing prices per kilogram in a supermarket, one more digit helps. If two results disagree slightly, check whether one source used US definitions and another used imperial or metric — the labels on this page follow the definitions in the dropdowns.
      </p>
    </div>
  </section>

  <section class="faq uc-faq">
    <div class="container">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Why are the conversions so precise?</h4>
          <p>
            Definitions such as the inch (exactly 2.54 cm) and fixed physical constants allow exact factors. We show enough digits for practical use; rounding happens only for display.
          </p>
        </div>
        <div class="faq-item">
          <h4>What’s the difference between US gallon and Imperial gallon?</h4>
          <p>
            They are different historical measures. A <strong>US liquid gallon</strong> is about 3.785 litres; an <strong>Imperial gallon</strong> is about 4.546 litres. Mixing them breaks recipes and fuel calculations — always check which system a number uses.
          </p>
        </div>
        <div class="faq-item">
          <h4>Why does megabyte show 1024 KB instead of 1000?</h4>
          <p>
            Software often uses <strong>binary</strong> prefixes (1024 = 2¹⁰). Drive makers sometimes advertise decimal GB (1000³ bytes), which is why a “1 TB” disk can show a lower capacity in Windows. This converter uses <strong>1024-based</strong> steps between KB, MB, GB, as on most OS labels.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I add custom units?</h4>
          <p>
            Not on this page — only listed units are supported. For one-off ratios, use a spreadsheet or divide by the conversion factor shown in the formula line.
          </p>
        </div>
        <div class="faq-item">
          <h4>Why is temperature conversion different from other units?</h4>
          <p>
            Temperature intervals can scale linearly, but <strong>absolute values</strong> require offsets between Celsius, Fahrenheit, and Kelvin-style scales. This tool converts via a consistent internal path (usually through Celsius or Kelvin) so combinations stay correct.
          </p>
        </div>
        <div class="faq-item">
          <h4>Does this work offline?</h4>
          <p>
            Yes. After the page loads once, calculations run locally in JavaScript with no server round-trip for your numbers.
          </p>
        </div>
        <div class="faq-item">
          <h4>What about currency conversion?</h4>
          <p>
            Live exchange rates need a trusted API and ongoing maintenance, so <strong>currency is not included</strong> here. Use your bank or a dedicated finance site for up-to-date rates.
          </p>
        </div>
        <div class="faq-item">
          <h4>How accurate is the speed of light reference?</h4>
          <p>
            The value <strong>299,792,458 m/s</strong> is the defined speed of light in vacuum in SI units. It is exact under current definitions; this tool uses it as a fixed conversion reference for speed mode.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="related">
    <div class="container">
      <h2 class="section-title">Related calculators</h2>
      <p class="related-links">
        <a href="/calculator/bmi">BMI</a>
        ·
        <a href="/calculator/percentage">Percentage</a>
        ·
        <a href="/calculator/scientific">Scientific calculator</a>
