  <script is:inline define:vars={{ LOCALE_BY_CURRENCY }}>
    (function () {
      function localeForCurrency(code) {
        return LOCALE_BY_CURRENCY[code] || 'en-US';
      }
      function makeFmt() {
        var code = document.getElementById('lsCur').value || 'INR';
        return new Intl.NumberFormat(localeForCurrency(code), { style: 'currency', currency: code, maximumFractionDigits: 0 });
      }
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function run() {
        const fmt = makeFmt();
        let P = Math.max(1000, Math.min(1e8, parseFloat(document.getElementById('lsP').value) || 0));
        let r = Math.max(1, Math.min(30, parseFloat(document.getElementById('lsR').value) || 0));
        let y = Math.max(1, Math.min(40, parseInt(document.getElementById('lsY').value, 10) || 1));
        document.getElementById('lsP').value = P;
        document.getElementById('lsR').value = r;
        document.getElementById('lsY').value = y;
        document.getElementById('lsRR').value = r;
        document.getElementById('lsYR').value = y;
        const rd = r / 100;
        const A = P * Math.pow(1 + rd, y);
        document.getElementById('lsMat').textContent = fmt.format(Math.round(A));
        document.getElementById('lsInv').textContent = fmt.format(Math.round(P));
        document.getElementById('lsRet').textContent = fmt.format(Math.round(Math.max(0, A - P)));
        const tb = document.getElementById('lsTb');
        const chart = document.getElementById('lsChart');
        tb.innerHTML = '';
        chart.innerHTML = '';
        let maxBal = 0;
        const rows = [];
        for (let yr = 1; yr <= y; yr++) {
          const bal = P * Math.pow(1 + rd, yr);
          maxBal = Math.max(maxBal, bal);
          rows.push({ yr: yr, bal: bal });
        }
        rows.forEach(function (row) {
          const tr = document.createElement('tr');
          tr.innerHTML = '<td>' + row.yr + '</td><td>' + fmt.format(Math.round(row.bal)) + '</td>';
          tb.appendChild(tr);
          const seg = document.createElement('div');
          seg.className = 'grow-seg';
          const inner = document.createElement('div');
          inner.className = 'grow-seg-fill';
          inner.style.height = maxBal > 0 ? Math.max(8, (row.bal / maxBal) * 120) + 'px' : '8px';
          inner.title = 'Year ' + row.yr + ': ' + fmt.format(Math.round(row.bal));
          seg.appendChild(inner);
          chart.appendChild(seg);
        });
      }
      const d = debounce(run, 80);
      document.getElementById('lsCur').addEventListener('change', d);
      ['lsP', 'lsR', 'lsY', 'lsRR', 'lsYR'].forEach(function (id) {
        document.getElementById(id).addEventListener('input', function () {
          if (id === 'lsRR') document.getElementById('lsR').value = this.value;
          if (id === 'lsYR') document.getElementById('lsY').value = this.value;
          d();
        });
      });
      run();
    })();
  </script>

