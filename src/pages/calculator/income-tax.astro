      transition: all 0.3s ease;
    }

    .it-winner-badge.old-wins {
      background: linear-gradient(135deg, #fef3c7, #fde68a);
      border-color: #f59e0b;
    }

    .it-winner-badge.tie {
      background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
      border-color: #94a3b8;
    }

    :global([data-theme='dark']) .it-winner-badge {
      background: rgba(34, 197, 94, 0.15);
    }
    :global([data-theme='dark']) .it-winner-badge.old-wins {
      background: rgba(245, 158, 11, 0.15);
    }

    .it-winner-icon {
      font-size: 2rem;
      flex-shrink: 0;
    }

    .it-winner-text strong {
      display: block;
      font-size: 1.1rem;
      color: #065f46;
      margin-bottom: 2px;
    }
    .it-winner-badge.old-wins .it-winner-text strong {
      color: #92400e;
    }
    .it-winner-badge.tie .it-winner-text strong {
      color: #475569;
    }

    :global([data-theme='dark']) .it-winner-text strong,
    :global([data-theme='dark']) .it-winner-badge.old-wins .it-winner-text strong,
    :global([data-theme='dark']) .it-winner-badge.tie .it-winner-text strong {
      color: #e5e7eb;
    }
    :global([data-theme='dark']) .it-winner-text span {
      color: #d1d5db;
    }

    .it-winner-text span {
      font-size: 0.9rem;
      color: var(--text-secondary, #374151);
    }

    .it-chart-tabs {
      display: flex;
      gap: 4px;
      overflow-x: auto;
      margin-bottom: 20px;
      border-bottom: 1px solid var(--border);
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .it-chart-tab {
      padding: 10px 16px;
      background: transparent;
      border: none;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      font-size: 14px;
      font-weight: 500;
      color: var(--muted, #64748b);
      white-space: nowrap;
      transition: all 0.15s;
      font-family: inherit;
    }

    .it-chart-tab:hover {
      color: var(--text, #0f172a);
    }

    .it-chart-tab--active {
      color: #3b82f6;
      border-bottom-color: #3b82f6;
      font-weight: 600;
    }

    :global([data-theme='dark']) .it-chart-tab--active {
      color: #60a5fa;
      border-bottom-color: #60a5fa;
    }

    .it-chart-panels {
      max-width: 800px;
      margin: 0 auto;
      min-height: 340px;
    }

    .it-chart-panel[hidden] {
      display: none;
    }

    .it-chart-canvas-wrap {
      position: relative;
      height: 320px;
      margin-bottom: 12px;
    }

    @media (max-width: 768px) {
      .it-viz-section .it-winner-badge {
        flex-wrap: wrap;
        justify-content: center;
        text-align: center;
      }
      .it-winner-text {
        flex: 1 1 100%;
      }
      .it-chart-canvas-wrap {
        height: 260px;
      }
    }

    .it-chart-callout {
      padding: 12px 16px;
      background: rgba(59, 130, 246, 0.08);
      border-left: 3px solid #3b82f6;
      border-radius: 6px;
      font-size: 14px;
      color: var(--text, #0f172a);
      margin: 0;
    }
    :global([data-theme='dark']) .it-chart-callout {
      background: rgba(59, 130, 246, 0.12);
      color: #e5e7eb;
    }
  </style>

  <script is:inline>
    (function () {
      if (typeof Chart === 'undefined') return;

      var fmt = new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 });
      var activeTab = 0;
      var chartInstance = null;

      var newSlabs = [
        { from: 0, to: 400000, rate: 0, color: '#e5e7eb' },
        { from: 400000, to: 800000, rate: 0.05, color: '#22c55e' },
        { from: 800000, to: 1200000, rate: 0.1, color: '#84cc16' },
        { from: 1200000, to: 1600000, rate: 0.15, color: '#eab308' },
        { from: 1600000, to: 2000000, rate: 0.2, color: '#f97316' },
        { from: 2000000, to: 2400000, rate: 0.25, color: '#ef4444' },
        { from: 2400000, to: Infinity, rate: 0.3, color: '#991b1b' }
      ];
      var oldSlabs = [
        { from: 0, to: 250000, rate: 0, color: '#e5e7eb' },
        { from: 250000, to: 500000, rate: 0.05, color: '#22c55e' },
        { from: 500000, to: 1000000, rate: 0.2, color: '#f97316' },
        { from: 1000000, to: Infinity, rate: 0.3, color: '#991b1b' }
      ];

      function taxNewRawC(TI) {
        if (TI <= 0) return 0;
        var t = 0;
        if (TI > 400000) t += (Math.min(TI, 800000) - 400000) * 0.05;
        if (TI > 800000) t += (Math.min(TI, 1200000) - 800000) * 0.1;
        if (TI > 1200000) t += (Math.min(TI, 1600000) - 1200000) * 0.15;
        if (TI > 1600000) t += (Math.min(TI, 2000000) - 1600000) * 0.2;
        if (TI > 2000000) t += (Math.min(TI, 2400000) - 2000000) * 0.25;
        if (TI > 2400000) t += (TI - 2400000) * 0.3;
        return Math.round(t);
      }
      function taxNewWithCess(TI) {
        if (TI <= 1200000) return 0;
        return Math.round(taxNewRawC(TI) * 1.04);
      }
      function taxOldWithCess(TI, ageKey) {
        ageKey = ageKey || 'below60';
        var tr;
        if (ageKey === 'below60') {
          if (TI <= 250000) tr = 0;
          else if (TI <= 500000) tr = Math.round((TI - 250000) * 0.05);
          else if (TI <= 1000000) tr = Math.round(12500 + (TI - 500000) * 0.2);
          else tr = Math.round(12500 + 100000 + (TI - 1000000) * 0.3);
        } else if (ageKey === '60to80') {
          if (TI <= 300000) tr = 0;
          else if (TI <= 500000) tr = Math.round((TI - 300000) * 0.05);
          else if (TI <= 1000000) tr = Math.round(10000 + (TI - 500000) * 0.2);
          else tr = Math.round(10000 + 100000 + (TI - 1000000) * 0.3);
        } else {
          if (TI <= 500000) tr = 0;
          else if (TI <= 1000000) tr = Math.round((TI - 500000) * 0.2);
          else tr = Math.round(100000 + (TI - 1000000) * 0.3);
        }
        return Math.round(tr * 1.04);
      }

      function updateWinnerBadge() {
        var st = window.__itState;
        if (!st) return;
        var badge = document.getElementById('itWinnerBadge');
        var label = document.getElementById('itWinnerLabel');
        var savings = document.getElementById('itWinnerSavings');
        if (!badge || !label || !savings) return;

        if (st.gross <= 0) {
          badge.className = 'it-winner-badge tie';
          label.textContent = '—';
          savings.textContent = 'Enter income to compare';
          return;
        }

        if (st.taxN < st.taxO) {
          var diff1 = st.taxO - st.taxN;
          var pct1 = st.taxO > 0 ? ((diff1 / st.taxO) * 100).toFixed(1) : '0';
          badge.className = 'it-winner-badge';
          label.textContent = 'New Regime Wins';
          savings.textContent = 'Saves ₹' + fmt.format(diff1) + ' (' + pct1 + '% lower tax)';
        } else if (st.taxO < st.taxN) {
          var diff2 = st.taxN - st.taxO;
          var pct2 = st.taxN > 0 ? ((diff2 / st.taxN) * 100).toFixed(1) : '0';
          badge.className = 'it-winner-badge old-wins';
          label.textContent = 'Old Regime Wins';
          savings.textContent = 'Saves ₹' + fmt.format(diff2) + ' (' + pct2 + '% lower) with your deductions';
        } else {
          badge.className = 'it-winner-badge tie';
          label.textContent = 'Both Equal';
          savings.textContent = 'Tax amount is identical in both regimes';
        }
      }

      function destroyChart() {
        if (chartInstance) {
          chartInstance.destroy();
          chartInstance = null;
        }
      }

      function renderTab0() {
        var st = window.__itState;
        var canvas = document.getElementById('itVizCanvas0');
        if (!canvas || !st) return;
        destroyChart();
        chartInstance = new Chart(canvas, {
          type: 'bar',
          data: {
            labels: ['New Regime', 'Old Regime'],
            datasets: [
              {
                label: 'Total tax (with cess)',
                data: [st.taxN, st.taxO],
                backgroundColor: ['#3b82f6', '#f59e0b'],
                borderRadius: 6
              }
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: function (ctx) {
                    return '₹' + fmt.format(ctx.parsed.x);
                  }
                }
              }
            },
            scales: {
              x: {
                ticks: {
                  callback: function (v) {
                    return '₹' + fmt.format(v);
                  }
                }
              }
            }
          }
        });

        var co = document.getElementById('itChartCallout0');
        if (co) {
          if (st.gross <= 0) {
            co.textContent = 'Enter your gross income above to compare tax under both regimes.';
          } else if (st.taxN < st.taxO) {
            var d0 = st.taxO - st.taxN;
            co.textContent = 'New regime saves ₹' + fmt.format(d0) + ' in your scenario — less paperwork, no deduction proofs needed.';
          } else if (st.taxO < st.taxN) {
            var d0b = st.taxN - st.taxO;
            co.textContent = 'Old regime saves ₹' + fmt.format(d0b) + ' thanks to your deductions. Requires maintaining proof of each claimed deduction.';
          } else {
            co.textContent = 'Both regimes result in the same tax. New regime is simpler — consider it if you value lower paperwork.';
          }
        }
      }

      function renderTab1() {
        var st = window.__itState;
        var canvas = document.getElementById('itVizCanvas1');
        if (!canvas || !st) return;
        destroyChart();

        var reg = document.querySelector('input[name="itReg"]:checked');
        var regVal = reg ? reg.value : 'new';
        var slabs = regVal === 'new' ? newSlabs : oldSlabs;
        var TI = regVal === 'new' ? st.tiNew : st.tiOld;

        var slabData = slabs.map(function (s) {
          if (TI <= s.from) return 0;
          var amt = Math.min(TI, s.to) - s.from;
          return amt > 0 ? amt : 0;
        });
        var slabLabels = slabs.map(function (s) {
          var label;
          if (s.to === Infinity) label = 'Above ₹' + fmt.format(s.from);
          else label = '₹' + fmt.format(s.from) + ' – ₹' + fmt.format(s.to);
          return label + ' (' + s.rate * 100 + '%)';
        });

        chartInstance = new Chart(canvas, {
          type: 'bar',
          data: {
            labels: ['Your taxable income'],
            datasets: slabs.map(function (s, i) {
              return {
                label: slabLabels[i],
                data: [slabData[i]],
                backgroundColor: s.color,
                borderWidth: 0
              };
            })
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            plugins: {
              legend: { position: 'bottom', labels: { font: { size: 11 } } },
              tooltip: {
                callbacks: {
                  label: function (ctx) {
                    var slab = slabs[ctx.datasetIndex];
                    var amt = ctx.parsed.x;
                    var taxOnSlab = Math.round(amt * slab.rate);
                    return ctx.dataset.label + ': ₹' + fmt.format(amt) + ' (tax: ₹' + fmt.format(taxOnSlab) + ')';
                  }
                }
              }
            },
            scales: {
              x: {
                stacked: true,
                ticks: {
                  callback: function (v) {
                    return '₹' + fmt.format(v);
                  }
                }
              },
              y: { stacked: true }
            }
          }
        });

        var co1 = document.getElementById('itChartCallout1');
        if (co1) {
          if (TI <= 0) co1.textContent = 'Enter income to see the slab breakdown.';
          else {
            var topSlab = slabs.reduce(
              function (acc, s) {
                return TI > s.from && s.rate > acc.rate ? s : acc;
              },
              slabs[0]
            );
            co1.textContent =
              'Your ' +
              (regVal === 'new' ? 'new' : 'old') +
              ' regime taxable income (₹' +
              fmt.format(TI) +
              ') reaches the ' +
              topSlab.rate * 100 +
              '% slab. Only the portion in each slab is taxed at that rate — progressive taxation.';
          }
        }
      }

      function renderTab2() {
        var st = window.__itState;
        var canvas = document.getElementById('itVizCanvas2');
        if (!canvas || !st) return;
        destroyChart();

        var points = 0;
        var labels = [];
        var newPts = [];
        var oldPts = [];
        var userDeductions = st.deductionTotal;
        var ageK = st.ageKey || 'below60';

        for (var g = 300000; g <= 5000000; g += 100000) {
          labels.push('₹' + (g / 100000).toFixed(0) + 'L');
          var tiN = Math.max(0, g - 75000);
          var tiO = Math.max(0, g - userDeductions);
          newPts.push(taxNewWithCess(tiN));
          oldPts.push(taxOldWithCess(tiO, ageK));
          points++;
        }

        var breakEven = null;
        for (var j = 1; j < points; j++) {
          if (
            (newPts[j - 1] < oldPts[j - 1] && newPts[j] >= oldPts[j]) ||
            (newPts[j - 1] > oldPts[j - 1] && newPts[j] <= oldPts[j])
          ) {
            breakEven = 300000 + j * 100000;
            break;
          }
        }

        chartInstance = new Chart(canvas, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'New Regime',
                data: newPts,
                borderColor: '#3b82f6',
                backgroundColor: 'rgba(59, 130, 246, 0.1)',
                fill: false,
                tension: 0.2,
                pointRadius: 0,
                borderWidth: 2
              },
              {
                label: 'Old Regime (your deductions)',
                data: oldPts,
                borderColor: '#f59e0b',
                backgroundColor: 'rgba(245, 158, 11, 0.1)',
                fill: false,
                tension: 0.2,
                pointRadius: 0,
                borderWidth: 2
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            plugins: {
              legend: { position: 'bottom' },
              tooltip: {
                callbacks: {
                  label: function (ctx) {
                    return ctx.dataset.label + ': ₹' + fmt.format(ctx.parsed.y);
                  }
                }
              }
            },
            scales: {
              y: {
                ticks: {
                  callback: function (v) {
                    return '₹' + fmt.format(v);
                  }
                }
              },
              x: { ticks: { maxTicksLimit: 10 } }
            }
          }
        });

        var co2 = document.getElementById('itChartCallout2');
        if (co2) {
          if (breakEven) {
            co2.textContent =
              'With your current ₹' +
              fmt.format(userDeductions) +
              ' old regime deductions, the regimes cross in the shown range around ₹' +
              fmt.format(breakEven) +
              ' gross. Compare the lines: where the old regime line is lower, old tax is less at that income.';
          } else if (newPts[points - 1] < oldPts[points - 1]) {
            co2.textContent =
              'In the 3L–50L range shown, new regime tax is lower at the top end with your current deduction amount (₹' +
              fmt.format(userDeductions) +
              '). Add more HRA, 80C, or 80D in the form to see the old line shift down.';
          } else {
            co2.textContent =
              'In the 3L–50L range shown, old regime tax is lower or equal at the top end with your deductions (₹' +
              fmt.format(userDeductions) +
              ').';
          }
        }
      }

      function renderTab3() {
        var st = window.__itState;
        var canvas = document.getElementById('itVizCanvas3');
        if (!canvas || !st) return;
        destroyChart();

        if (st.gross <= 0) {
          var coEmpty = document.getElementById('itChartCallout3');
          if (coEmpty) {
            coEmpty.textContent = 'Enter your gross income to see how different deduction amounts affect old regime tax.';
          }
          return;
        }

        var deductionLevels = [50000, 150000, 250000, 350000, 450000, 550000];
        var labels3 = ['No extra (₹50K std)', '₹1L', '₹2L', '₹3L', '₹4L', '₹5L'];
        var oldTaxes = deductionLevels.map(function (d) {
          var ti = Math.max(0, st.gross - d);
          return taxOldWithCess(ti, st.ageKey || 'below60');
        });

        var userDed = st.deductionTotal;
        var userTi = Math.max(0, st.gross - userDed);
        var userTax = taxOldWithCess(userTi, st.ageKey || 'below60');
        var labels3b = labels3.slice();
        var oldTaxesB = oldTaxes.slice();
        labels3b.push('Your ₹' + fmt.format(userDed));
        oldTaxesB.push(userTax);
        var refLine = oldTaxesB.map(function () {
          return st.taxN;
        });
        var colors3 = oldTaxes.map(function () {
          return '#f59e0b';
        });
        colors3.push('#6366f1');

        chartInstance = new Chart(canvas, {
          type: 'bar',
          data: {
            labels: labels3b,
            datasets: [
              {
                type: 'bar',
                label: 'Old regime tax',
                data: oldTaxesB,
                backgroundColor: colors3,
                borderRadius: 6
              },
              {
                type: 'line',
                label: 'New regime (reference)',
                data: refLine,
                borderColor: '#3b82f6',
                backgroundColor: 'transparent',
                borderDash: [4, 4],
                pointRadius: 0,
                borderWidth: 2,
                order: 0
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            plugins: {
              legend: { position: 'bottom' },
              tooltip: {
                callbacks: {
                  label: function (ctx) {
                    if (ctx.datasetIndex === 1) {
                      return ctx.dataset.label + ': ₹' + fmt.format(ctx.parsed.y);
                    }
                    return ctx.dataset.label + ': ₹' + fmt.format(ctx.parsed.y);
                  }
                }
              }
            },
            scales: {
              y: {
                ticks: {
                  callback: function (v) {
                    return '₹' + fmt.format(v);
                  }
                }
              }
            }
          }
        });

        var co3 = document.getElementById('itChartCallout3');
        if (co3) {
          var savingsVsZero = oldTaxesB[0] - userTax;
          if (savingsVsZero > 0) {
            co3.textContent =
              'Your ₹' +
              fmt.format(userDed) +
              ' in total deductions (vs. scenarios on the left) — old tax on the indigo bar is ₹' +
              fmt.format(userTax) +
              '. The dashed line is your new regime tax (₹' +
              fmt.format(st.taxN) +
              '); lower orange bars are better for old vs that line.';
          } else {
            co3.textContent =
              'The dashed blue line shows your new regime tax. Orange bars are old-regime tax at that gross for different total deduction levels; the indigo bar is your current inputs.';
          }
        }
      }

      function renderActive() {
        updateWinnerBadge();
        if (activeTab === 0) renderTab0();
        else if (activeTab === 1) renderTab1();
        else if (activeTab === 2) renderTab2();
        else if (activeTab === 3) renderTab3();
      }

      function debounceFn(fn, ms) {
        var t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      var debChart = debounceFn(renderActive, 80);
      window.__itChartDebounced = debChart;

      function selectTab(idx) {
        activeTab = idx;
        var tabs = document.querySelectorAll('.it-chart-tab');
        var panels = document.querySelectorAll('.it-chart-panel');
        for (var ti = 0; ti < tabs.length; ti++) {
          var on = ti === idx;
          tabs[ti].classList.toggle('it-chart-tab--active', on);
          tabs[ti].setAttribute('aria-selected', on ? 'true' : 'false');
          tabs[ti].setAttribute('tabindex', on ? '0' : '-1');
        }
        for (var pi = 0; pi < panels.length; pi++) {
          var pOn = pi === idx;
          panels[pi].classList.toggle('it-chart-panel--active', pOn);
          if (pOn) panels[pi].removeAttribute('hidden');
          else panels[pi].setAttribute('hidden', '');
        }
        renderActive();
      }

      window.addEventListener('load', function () {
        var tabEls = document.querySelectorAll('.it-chart-tab');
        tabEls.forEach(function (tab, idx) {
          tab.addEventListener('click', function () {
            selectTab(idx);
          });
          tab.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
              e.preventDefault();
              var n = (idx + (e.key === 'ArrowRight' ? 1 : -1) + tabEls.length) % tabEls.length;
              tabEls[n].focus();
              selectTab(n);
            }
          });
        });
        document.querySelectorAll('input[name="itReg"]').forEach(function (r) {
          r.addEventListener('change', debChart);
        });
        var obs = new MutationObserver(debChart);
        obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
        if (window.__itState) renderActive();
        else {
          var tryRun = function () {
            if (window.__itState) {
              renderActive();
            }
          };
          setTimeout(tryRun, 0);
        }
      });
    })();
  </script>
</MainLayout>
