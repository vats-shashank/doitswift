  <script is:inline>
    (function () {
      const fmt = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
      function debounce(fn, ms) {
        var t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function cessOn(tax) {
        return Math.round(tax * 1.04);
      }
      /** New regime marginal slabs on taxable income TI (after std deduction). */
      function taxNewRaw(TI) {
        if (TI <= 0) return 0;
        var t = 0;
        if (TI > 400000) t += (Math.min(TI, 800000) - 400000) * 0.05;
        if (TI > 800000) t += (Math.min(TI, 1200000) - 800000) * 0.1;
        if (TI > 1200000) t += (Math.min(TI, 1600000) - 1200000) * 0.15;
        if (TI > 1600000) t += (Math.min(TI, 2000000) - 1600000) * 0.2;
        if (TI > 2000000) t += (Math.min(TI, 2400000) - 2000000) * 0.25;
        if (TI > 2400000) t += (TI - 2400000) * 0.3;
        return Math.round(t);
      }
      function taxNewFinal(TI) {
        if (TI <= 1200000) return 0;
        return taxNewRaw(TI);
      }
      /** Old regime: slabs per age (resident individual, simplified). */
      function taxOldRaw(TI, ageKey) {
        if (ageKey === 'below60') {
          if (TI <= 250000) return 0;
          if (TI <= 500000) return Math.round((TI - 250000) * 0.05);
          if (TI <= 1000000) return Math.round(12500 + (TI - 500000) * 0.2);
          return Math.round(12500 + 100000 + (TI - 1000000) * 0.3);
        }
        if (ageKey === '60to80') {
          if (TI <= 300000) return 0;
          if (TI <= 500000) return Math.round((TI - 300000) * 0.05);
          if (TI <= 1000000) return Math.round(10000 + (TI - 500000) * 0.2);
          return Math.round(10000 + 100000 + (TI - 1000000) * 0.3);
        }
        if (TI <= 500000) return 0;
        if (TI <= 1000000) return Math.round((TI - 500000) * 0.2);
        return Math.round(100000 + (TI - 1000000) * 0.3);
      }
      function run() {
        var gross = Math.max(0, parseFloat(document.getElementById('itGross').value) || 0);
        var ageKey = document.getElementById('itAge').value;
        var std = Math.max(0, parseFloat(document.getElementById('itStd').value) || 0);
        var hra = Math.max(0, parseFloat(document.getElementById('itHRA').value) || 0);
        var c80 = Math.max(0, parseFloat(document.getElementById('it80C').value) || 0);
        var d80 = Math.max(0, parseFloat(document.getElementById('it80D').value) || 0);
        var other = Math.max(0, parseFloat(document.getElementById('itOther').value) || 0);
        var c80cap = Math.min(150000, c80);

        var tiNew = Math.max(0, gross - std);
        var taxN = taxNewFinal(tiNew);
        var totalN = cessOn(taxN);

        var tiOld = Math.max(0, gross - 50000 - hra - c80cap - d80 - other);
        var taxO = taxOldRaw(tiOld, ageKey);
        var totalO = cessOn(taxO);

        document.getElementById('itTaxNew').textContent = fmt.format(totalN);
        document.getElementById('itTaxOld').textContent = fmt.format(totalO);
        document.getElementById('itTiNew').textContent = fmt.format(tiNew);
        document.getElementById('itTiOld').textContent = fmt.format(tiOld);
        var erN = gross > 0 ? ((totalN / gross) * 100).toFixed(2) : '0';
        var erO = gross > 0 ? ((totalO / gross) * 100).toFixed(2) : '0';
        document.getElementById('itErNew').textContent = erN + '%';
        document.getElementById('itErOld').textContent = erO + '%';

        var reg = document.querySelector('input[name="itReg"]:checked').value;
        document.getElementById('boxNew').classList.toggle('is-focus', reg === 'new');
        document.getElementById('boxOld').classList.toggle('is-focus', reg === 'old');

        var tips = [];
        if (totalO < totalN) tips.push('In this scenario, the old regime shows lower tax — ensure your claimed deductions are realistic.');
        else if (totalN < totalO) tips.push('Here, the new regime is lower — fewer proofs to maintain if you can opt in.');
        if (c80cap < 150000 && totalO <= totalN) tips.push('Using more of the ₹1.5L 80C window could reduce old-regime tax if invested in eligible instruments.');
        if (hra === 0 && gross > 800000) tips.push('If you pay rent, calculating eligible HRA exemption may significantly change the old regime.');
        var ul = document.getElementById('itTipList');
        ul.innerHTML = '';
        tips.forEach(function (x) {
          var li = document.createElement('li');
          li.textContent = x;
          ul.appendChild(li);
        });
        window.__itState = {
          gross: gross,
          ageKey: ageKey,
          std: std,
          hra: hra,
          c80cap: c80cap,
          d80: d80,
          other: other,
          tiNew: tiNew,
          tiOld: tiOld,
          taxN: totalN,
          taxO: totalO,
          deductionTotal: 50000 + hra + c80cap + d80 + other
        };
        if (typeof window.__itChartDebounced === 'function') {
          window.__itChartDebounced();
        }
      }
      var d = debounce(run, 80);
      ['itGross', 'itAge', 'itHRA', 'it80C', 'it80D', 'itOther', 'itStd'].forEach(function (id) {
        document.getElementById(id).addEventListener('input', d);
      });
      document.querySelectorAll('input[name="itReg"]').forEach(function (el) {
        el.addEventListener('change', d);
      });
      run();
    })();
  </script>

