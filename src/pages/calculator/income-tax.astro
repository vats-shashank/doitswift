---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = 'https://doitswift.com/calculator/income-tax/';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'Income Tax Calculator (India) — DoItSwift',
      url: canonical,
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Web',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
      description: 'Estimate income tax under India new vs old regime for salaried individuals.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is this official tax filing?',
          acceptedAnswer: { '@type': 'Answer', text: 'No. This is an illustrative estimator only. Verify slabs, rebates, and deductions with a CA or the Income Tax Department for your case.' },
        },
      ],
    },
  ],
};
---

<MainLayout
  title="Income Tax Calculator (India) — Free Online Calculator | DoItSwift"
  description="Estimate tax for FY 2026-27 under India’s new vs old regime: slabs, standard deduction, 80C/80D, HRA, and effective rate. Illustrative only."
  keywords="income tax calculator India, new tax regime calculator, old vs new tax regime, FY 2026-27 tax estimate"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>Income Tax Calculator</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Free Calculator</div>
      <h1>Income Tax Calculator (India)</h1>
      <p class="subtitle">
        Compare <strong>new regime</strong> slabs (FY 2026-27 illustrative) with a simplified <strong>old regime</strong> model including common deductions. Figures are not legal or filing advice — verify with the latest Finance Act and your CA.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> No signup</span>
        <span><span class="check">✓</span> Instant results</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <p class="disclaimer container">
    <strong>Disclaimer:</strong> Tax law changes frequently. This tool uses rounded slab math, a 4% health &amp; education cess on tax, standard deduction defaults, and a simplified rebate (new regime: no tax if taxable income ≤ ₹7 lakh after standard deduction, matching common 87A-style relief — confirm eligibility). Always validate against official notifications.
  </p>

  <section class="calc-section">
    <div class="container calc-layout">
      <div class="calc-inputs">
        <h2 class="calc-heading">Inputs</h2>
        <div class="field">
          <label for="itGross">Gross annual income (₹)</label>
          <input type="number" id="itGross" min="0" step="1000" value="1200000" inputmode="numeric" aria-describedby="itGross-hint" />
          <p id="itGross-hint" class="field-hint">Salary, business, or combined — enter your total before Chapter VI-A (for comparison context).</p>
        </div>
        <div class="field">
          <label for="itAge">Age group</label>
          <select id="itAge" aria-label="Age group for basic exemption in old regime">
            <option value="below60" selected>Below 60</option>
            <option value="60to80">60 to 80</option>
            <option value="above80">Above 80</option>
          </select>
        </div>
        <div class="field">
          <label>Regime to preview</label>
          <div class="seg" role="radiogroup" aria-label="Tax regime">
            <label><input type="radio" name="itReg" value="new" checked /> New regime (default)</label>
            <label><input type="radio" name="itReg" value="old" /> Old regime</label>
          </div>
        </div>
        <div class="field">
          <label for="itStd">Standard deduction — salary, new regime (₹)</label>
          <input type="number" id="itStd" min="0" step="1000" value="50000" aria-describedby="itStd-hint" />
          <p id="itStd-hint" class="field-hint">Applied to new regime taxable income (default ₹50,000 — verify for your year).</p>
        </div>
        <div class="field">
          <label for="itHRA">HRA exemption claimed — old regime (₹)</label>
          <input type="number" id="itHRA" min="0" step="1000" value="0" />
        </div>
        <div class="field">
          <label for="it80C">80C investments (₹, max ₹1.5L counted)</label>
          <input type="number" id="it80C" min="0" step="1000" value="150000" />
        </div>
        <div class="field">
          <label for="it80D">80D medical insurance (₹)</label>
          <input type="number" id="it80D" min="0" step="1000" value="25000" />
        </div>
        <div class="field">
          <label for="itOther">Other deductions — old regime (₹)</label>
          <input type="number" id="itOther" min="0" step="1000" value="0" />
        </div>
      </div>
      <div class="calc-results" aria-live="polite">
        <h2 class="calc-heading">Results</h2>
        <div class="compare-grid">
          <div class="compare-card" id="boxNew">
            <h3>New regime</h3>
            <p class="big" id="itTaxNew">₹0</p>
            <p class="small">Tax + cess</p>
            <p class="line"><span>Taxable income</span><span id="itTiNew">₹0</span></p>
            <p class="line"><span>Effective rate</span><span id="itErNew">0%</span></p>
          </div>
          <div class="compare-card" id="boxOld">
            <h3>Old regime</h3>
            <p class="big" id="itTaxOld">₹0</p>
            <p class="small">Tax + cess</p>
            <p class="line"><span>Taxable income</span><span id="itTiOld">₹0</span></p>
            <p class="line"><span>Effective rate</span><span id="itErOld">0%</span></p>
          </div>
        </div>
        <div class="tips" id="itTips">
          <h4>Tax-saving ideas (generic)</h4>
          <ul id="itTipList"></ul>
        </div>
      </div>
    </div>
  </section>

  <section class="edu">
    <div class="container">
      <h2 class="section-title">How income tax estimation works</h2>
      <p>
        India’s income tax combines <strong>progressive slabs</strong> (higher slices of income face higher marginal rates) with <strong>rebates</strong>, <strong>cess</strong>, and <strong>surcharge</strong> (not modeled here for very high incomes). The <strong>new tax regime</strong> typically offers lower rates but fewer deductions; the <strong>old regime</strong> keeps Section 80C, 80D, HRA, and other provisions if you qualify and opt in where allowed.
      </p>
      <p>
        For this calculator, <strong>new regime taxable income</strong> starts from gross salary-like income minus a configurable <strong>standard deduction</strong> (commonly ₹50,000 for salaried taxpayers — verify the applicable year’s limit). We then apply the slab structure you specified: nil up to ₹3 lakh, then 5% from ₹3–7 lakh, 10% from ₹7–10 lakh, 15% from ₹10–12 lakh, 20% from ₹12–15 lakh, and 30% above ₹15 lakh. If taxable income after standard deduction is <strong>₹7 lakh or below</strong>, we set tax to zero to reflect typical Section 87A-style relief for residents — this is a simplification; actual eligibility depends on income type and current law.
      </p>
      <p>
        The <strong>old regime</strong> path subtracts standard deduction (₹50,000), capped 80C (₹1.5 lakh), your 80D entry, HRA, and other deductions from gross income, then applies classic slabs with a <strong>basic exemption</strong> that depends on age: ₹2.5 lakh below 60, ₹3 lakh for 60–80, and ₹5 lakh above 80. Marginal rates are 5% above the basic exemption up to ₹5 lakh, 20% from ₹5–10 lakh, and 30% above ₹10 lakh. We add <strong>4% cess</strong> on the tax for both regimes in this demo.
      </p>
      <p>
        <strong>What to verify manually:</strong> surcharge on income above ₹50 lakh, alternate minimum tax, perquisites, capital gains, house property loss set-off, and the exact standard deduction for your assessment year. Use this page to build intuition and compare regimes side by side, then confirm with Form 16, AIS, or a qualified professional before filing.
      </p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Which regime should I choose?</h4>
          <p>
            Compare total tax under both regimes each year — the better choice depends on your deductions, rent, loans, and income mix. This calculator gives a directional comparison only.
          </p>
        </div>
        <div class="faq-item">
          <h4>Why doesn’t my tax match Form 16?</h4>
          <p>
            Employers apply TDS with payroll-specific proofs, perquisites, and timing. We don’t model all salary components or filing rebates beyond the simplified 87A-style rule.
          </p>
        </div>
        <div class="faq-item">
          <h4>Are cess and surcharge included?</h4>
          <p>
            We add 4% cess on computed tax. Surcharge for high income is <strong>not</strong> included — add that manually if applicable.
          </p>
        </div>
        <div class="faq-item">
          <h4>Is HRA calculated automatically?</h4>
          <p>
            No. Enter the HRA exemption you are eligible for (as per rent receipts and metro rules) or leave at zero to learn the impact of HRA on the old regime.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can NRIs use this?</h4>
          <p>
            Residential status changes exemptions and slab applicability. This tool assumes resident individual rules unless you adjust inputs yourself.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="related">
    <div class="container">
      <h2 class="section-title">Related calculators</h2>
      <p class="related-links">
        <a href="/calculator/sip/">SIP</a> · <a href="/calculator/emi/">EMI</a> · <a href="/calculator/fd/">FD</a> · <a href="/calculator/gst/">GST</a>
      </p>
    </div>
  </section>

  <script is:inline>
    (function () {
      const fmt = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
      function debounce(fn, ms) {
        var t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function cessOn(tax) {
        return Math.round(tax * 1.04);
      }
      /** New regime marginal slabs on taxable income TI (after std deduction). */
      function taxNewRaw(TI) {
        if (TI <= 0) return 0;
        var t = 0;
        if (TI > 300000) t += (Math.min(TI, 700000) - 300000) * 0.05;
        if (TI > 700000) t += (Math.min(TI, 1000000) - 700000) * 0.1;
        if (TI > 1000000) t += (Math.min(TI, 1200000) - 1000000) * 0.15;
        if (TI > 1200000) t += (Math.min(TI, 1500000) - 1200000) * 0.2;
        if (TI > 1500000) t += (TI - 1500000) * 0.3;
        return Math.round(t);
      }
      function taxNewFinal(TI) {
        if (TI <= 700000) return 0;
        return taxNewRaw(TI);
      }
      /** Old regime: slabs per age (resident individual, simplified). */
      function taxOldRaw(TI, ageKey) {
        if (ageKey === 'below60') {
          if (TI <= 250000) return 0;
          if (TI <= 500000) return Math.round((TI - 250000) * 0.05);
          if (TI <= 1000000) return Math.round(12500 + (TI - 500000) * 0.2);
          return Math.round(12500 + 100000 + (TI - 1000000) * 0.3);
        }
        if (ageKey === '60to80') {
          if (TI <= 300000) return 0;
          if (TI <= 500000) return Math.round((TI - 300000) * 0.05);
          if (TI <= 1000000) return Math.round(10000 + (TI - 500000) * 0.2);
          return Math.round(10000 + 100000 + (TI - 1000000) * 0.3);
        }
        if (TI <= 500000) return 0;
        if (TI <= 1000000) return Math.round((TI - 500000) * 0.2);
        return Math.round(100000 + (TI - 1000000) * 0.3);
      }
      function run() {
        var gross = Math.max(0, parseFloat(document.getElementById('itGross').value) || 0);
        var ageKey = document.getElementById('itAge').value;
        var std = Math.max(0, parseFloat(document.getElementById('itStd').value) || 0);
        var hra = Math.max(0, parseFloat(document.getElementById('itHRA').value) || 0);
        var c80 = Math.max(0, parseFloat(document.getElementById('it80C').value) || 0);
        var d80 = Math.max(0, parseFloat(document.getElementById('it80D').value) || 0);
        var other = Math.max(0, parseFloat(document.getElementById('itOther').value) || 0);
        var c80cap = Math.min(150000, c80);

        var tiNew = Math.max(0, gross - std);
        var taxN = taxNewFinal(tiNew);
        var totalN = cessOn(taxN);

        var tiOld = Math.max(0, gross - 50000 - hra - c80cap - d80 - other);
        var taxO = taxOldRaw(tiOld, ageKey);
        var totalO = cessOn(taxO);

        document.getElementById('itTaxNew').textContent = fmt.format(totalN);
        document.getElementById('itTaxOld').textContent = fmt.format(totalO);
        document.getElementById('itTiNew').textContent = fmt.format(tiNew);
        document.getElementById('itTiOld').textContent = fmt.format(tiOld);
        var erN = gross > 0 ? ((totalN / gross) * 100).toFixed(2) : '0';
        var erO = gross > 0 ? ((totalO / gross) * 100).toFixed(2) : '0';
        document.getElementById('itErNew').textContent = erN + '%';
        document.getElementById('itErOld').textContent = erO + '%';

        var reg = document.querySelector('input[name="itReg"]:checked').value;
        document.getElementById('boxNew').classList.toggle('is-focus', reg === 'new');
        document.getElementById('boxOld').classList.toggle('is-focus', reg === 'old');

        var tips = [];
        if (totalO < totalN) tips.push('In this scenario, the old regime shows lower tax — ensure your claimed deductions are realistic.');
        else if (totalN < totalO) tips.push('Here, the new regime is lower — fewer proofs to maintain if you can opt in.');
        if (c80cap < 150000 && totalO <= totalN) tips.push('Using more of the ₹1.5L 80C window could reduce old-regime tax if invested in eligible instruments.');
        if (hra === 0 && gross > 800000) tips.push('If you pay rent, calculating eligible HRA exemption may significantly change the old regime.');
        var ul = document.getElementById('itTipList');
        ul.innerHTML = '';
        tips.forEach(function (x) {
          var li = document.createElement('li');
          li.textContent = x;
          ul.appendChild(li);
        });
      }
      var d = debounce(run, 80);
      ['itGross', 'itAge', 'itHRA', 'it80C', 'it80D', 'itOther', 'itStd'].forEach(function (id) {
        document.getElementById(id).addEventListener('input', d);
      });
      document.querySelectorAll('input[name="itReg"]').forEach(function (el) {
        el.addEventListener('change', d);
      });
      run();
    })();
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 960px;
    }
    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }
    .hero {
      padding: 36px 0 12px;
      text-align: center;
    }
    .subtitle {
      font-size: 17px;
      color: var(--text-muted);
      max-width: 720px;
      margin: 0 auto 20px;
      line-height: 1.6;
    }
    .disclaimer {
      font-size: 13px;
      color: var(--text-muted);
      max-width: 900px;
      margin: 0 auto 8px;
      padding: 12px 16px;
      background: var(--gray-100);
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
    [data-theme='dark'] .disclaimer {
      background: var(--gray-200);
    }
    .calc-section {
      padding: 20px 0 40px;
    }
    .calc-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      max-width: 1000px;
      align-items: start;
    }
    @media (max-width: 900px) {
      .calc-layout {
        grid-template-columns: 1fr;
      }
    }
    .calc-inputs,
    .calc-results {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 22px 24px;
      box-shadow: var(--shadow);
    }
    .calc-heading {
      font-size: 1rem;
      margin: 0 0 16px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 700;
    }
    .field {
      margin-bottom: 16px;
    }
    .field label {
      display: block;
      font-weight: 600;
      font-size: 14px;
      margin-bottom: 6px;
    }
    .field input,
    .field select {
      width: 100%;
      padding: 10px 12px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      font-size: 16px;
    }
    .field-hint {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 6px;
    }
    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 520px) {
      .compare-grid {
        grid-template-columns: 1fr;
      }
    }
    .compare-card {
      border: 2px solid var(--border);
      border-radius: var(--radius);
      padding: 14px;
      background: var(--gray-100);
    }
    [data-theme='dark'] .compare-card {
      background: var(--gray-200);
    }
    .compare-card.is-focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 1px var(--blue);
    }
    .compare-card h3 {
      font-size: 14px;
      margin: 0 0 8px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      color: var(--text-muted);
    }
    .big {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--blue);
      margin: 0;
    }
    .small {
      font-size: 12px;
      color: var(--text-muted);
      margin: 4px 0 12px;
    }
    .line {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      margin: 6px 0;
      gap: 8px;
    }
    .tips {
      margin-top: 18px;
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }
    .tips h4 {
      font-size: 14px;
      margin-bottom: 8px;
    }
    .tips ul {
      margin: 0;
      padding-left: 18px;
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.55;
    }
    .edu {
      padding: 36px 0 40px;
    }
    .edu .container {
      max-width: 760px;
    }
    .edu p {
      font-size: 15px;
      line-height: 1.8;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .section-title {
      text-align: center;
      margin-bottom: 18px;
      font-size: 1.5rem;
    }
    .faq {
      padding: 28px 0;
    }
    .faq-list {
      max-width: 760px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
    }
    .faq-item h4 {
      margin-bottom: 8px;
      font-size: 15px;
    }
    .faq-item p {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.6;
      margin: 0;
    }
    .related {
      text-align: center;
      padding-bottom: 48px;
    }
    .related-links a {
      color: var(--blue);
      font-weight: 600;
    }
  </style>
</MainLayout>
