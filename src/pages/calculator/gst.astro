---
import MainLayout from '../../layouts/MainLayout.astro';
import { buildCalculatorJsonLd, calculatorCanonical } from '../../lib/calculatorJsonLd';

const canonical = calculatorCanonical(Astro.site, Astro.url.pathname);

const pageDescription =
  'Free GST calculator for India: add GST to a base amount or remove GST from an inclusive total. Preset rates 5%, 12%, 18%, 28% or custom %; intra-state CGST+SGST split or inter-state IGST. Shows taxable value, GST amount, and totals — arithmetic aid only, not GST return filing.';

const jsonLd = buildCalculatorJsonLd({
  site: Astro.site,
  pathname: Astro.url.pathname,
  appName: 'DoItSwift GST Calculator',
  breadcrumbName: 'GST Calculator',
  applicationCategory: 'FinanceApplication',
  browserRequirements: 'Requires JavaScript for GST add/remove and CGST/SGST/IGST breakdown',
  webAppDescription:
    'Quick Goods and Services Tax (GST) math for India: add GST to a taxable amount or derive taxable value and GST from a GST-inclusive figure. Optional intra-state (half CGST, half SGST) or inter-state (IGST) display. Preset slabs plus custom rate. Educational calculator only — not connected to the GST portal and not tax advice.',
  featureList: [
    'Add GST to a base amount or remove GST from an inclusive amount',
    'GST rates: 5%, 12%, 18%, 28%, or custom percentage',
    'Intra-state: CGST and SGST (typically half of total GST each)',
    'Inter-state: IGST as full GST component',
    'Shows GST amount, taxable value, and totals in ₹',
    'Runs locally in the browser',
  ],
  faqs: [
    {
      question: 'What is GST?',
      answer:
        'Goods and Services Tax is an indirect tax on supply. Intra-state often uses CGST and SGST; inter-state uses IGST.',
    },
    {
      question: 'Is this official GST filing?',
      answer:
        'No. It is a calculator only and is not connected to the GST portal.',
    },
    {
      question: 'How do I add or remove GST?',
      answer:
        'To add GST: GST = amount × rate/100. To remove GST from an inclusive total: taxable value = inclusive ÷ (1 + rate/100).',
    },
    {
      question: 'What is the difference between CGST/SGST and IGST?',
      answer:
        'Intra-state shows CGST and SGST (typically half of total GST each). Inter-state shows IGST as the full GST line.',
    },
    {
      question: 'Is my data uploaded?',
      answer:
        'No. Calculations run in your browser and amounts are not sent to DoItSwift servers.',
    },
  ],
});
---

<MainLayout
  title="GST Calculator India — Add/Remove GST, CGST, SGST & IGST | DoItSwift"
  description={pageDescription}
  keywords="GST calculator India, GST inclusive exclusive calculator, remove GST from amount, CGST SGST calculator, IGST calculator, 18% GST calculator, GST back calculation"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb"><a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>GST Calculator</span></nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Free Calculator</div>
      <h1>GST Calculator</h1>
      <p class="subtitle">
        Add GST to a <strong>base price</strong> or back out tax from a <strong>GST-inclusive total</strong>. View <strong>CGST/SGST</strong> (half each) or <strong>IGST</strong> for inter-state — quick math only, not filing.
      </p>
      <div class="trust"><span><span class="check">✓</span> No signup</span><span><span class="check">✓</span> Instant results</span><span><span class="check">✓</span> Works offline</span></div>
    </div>
  </section>

  <section class="calc-section">
    <div class="container calc-layout">
      <div class="calc-inputs">
        <h2 class="calc-heading">Inputs</h2>
        <div class="field">
          <label>Mode</label>
          <div class="seg">
            <label><input type="radio" name="gstMode" value="add" checked /> Add GST to amount</label>
            <label><input type="radio" name="gstMode" value="remove" /> Remove GST from amount</label>
          </div>
        </div>
        <div class="field"><label for="gstAmt">Amount (₹)</label><input type="number" id="gstAmt" min="0" step="0.01" value="10000" /></div>
        <div class="field">
          <label for="gstRateSel">GST rate</label>
          <select id="gstRateSel">
            <option value="5">5%</option>
            <option value="12">12%</option>
            <option value="18" selected>18%</option>
            <option value="28">28%</option>
            <option value="custom">Custom</option>
          </select>
          <input type="number" id="gstRateCustom" min="0" max="50" step="0.01" value="18" style="margin-top:8px;display:none" aria-label="Custom GST percent" />
        </div>
        <div class="field">
          <label>Tax type</label>
          <div class="seg">
            <label><input type="radio" name="gstType" value="intra" checked /> Intra-state (CGST + SGST)</label>
            <label><input type="radio" name="gstType" value="inter" /> Inter-state (IGST)</label>
          </div>
        </div>
      </div>
      <div class="calc-results" aria-live="polite">
        <h2 class="calc-heading">Results</h2>
        <div class="result-grid">
          <div><div class="result-sub" id="gstTax">₹0</div><div class="result-caption">GST amount</div></div>
          <div><div class="result-sub" id="gstBase">₹0</div><div class="result-caption" id="gstBaseLbl">Taxable value</div></div>
          <div><div class="result-sub" id="gstTotal">₹0</div><div class="result-caption" id="gstTotalLbl">Total with GST</div></div>
        </div>
        <div id="gstSplit" class="split-box">
          <p><strong id="gstLine1"></strong></p>
          <p><strong id="gstLine2"></strong></p>
        </div>
      </div>
    </div>
  </section>

  <section class="edu">
    <div class="container">
      <h2 class="section-title">How GST math works</h2>
      <p><strong>Add GST:</strong> GST = Amount × (rate/100), Total = Amount + GST. <strong>Remove GST:</strong> If amount includes GST, Taxable = Amount ÷ (1 + rate/100), GST = Amount − Taxable.</p>
      <p>For <strong>intra-state</strong> supplies, CGST and SGST are typically half of the total GST each. For <strong>inter-state</strong>, IGST equals the full GST rate amount in one component. Actual invoicing must follow your GST registration and HSN/SAC rules — this page is a quick arithmetic aid only.</p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>What is GST?</h4><p>Goods and Services Tax — an indirect tax on supply; intra-state often uses CGST+SGST, inter-state uses IGST.</p></div>
        <div class="faq-item"><h4>Is this official GST filing?</h4><p>No — it is a calculator only, not connected to the GST portal.</p></div>
        <div class="faq-item"><h4>How do I add or remove GST?</h4><p>Add: GST = amount × rate/100. Remove: taxable = inclusive ÷ (1 + rate/100). See the section below for CGST/SGST vs IGST display.</p></div>
        <div class="faq-item"><h4>CGST/SGST vs IGST?</h4><p>Intra-state shows CGST and SGST (typically half of total GST each). Inter-state shows IGST as the full GST line.</p></div>
        <div class="faq-item"><h4>Is my data uploaded?</h4><p>No — calculations run in your browser.</p></div>
      </div>
    </div>
  </section>
  <section class="related"><div class="container"><p class="related-links"><a href="/calculator/fd/">FD</a> · <a href="/calculator/percentage/">Percentage</a> · <a href="/calculator/income-tax/">Income tax</a> · <a href="/calculator/markup-margin/">Markup &amp; margin</a></p></div></section>

  <script is:inline>
    (function () {
      const fmt = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 2 });
      function debounce(fn, ms) { let t; return function () { clearTimeout(t); t = setTimeout(fn, ms); }; }
      function rate() {
        const sel = document.getElementById('gstRateSel').value;
        if (sel === 'custom') return Math.max(0, parseFloat(document.getElementById('gstRateCustom').value) || 0);
        return parseFloat(sel);
      }
      function run() {
        const mode = document.querySelector('input[name="gstMode"]:checked').value;
        const amt = Math.max(0, parseFloat(document.getElementById('gstAmt').value) || 0);
        const r = rate() / 100;
        const inter = document.querySelector('input[name="gstType"]:checked').value === 'inter';
        let base, tax, total;
        if (mode === 'add') {
          base = amt;
          tax = base * r;
          total = base + tax;
        } else {
          total = amt;
          base = r >= 0 ? total / (1 + r) : total;
          tax = total - base;
        }
        document.getElementById('gstTax').textContent = fmt.format(tax);
        document.getElementById('gstBase').textContent = fmt.format(base);
        document.getElementById('gstTotal').textContent = fmt.format(mode === 'add' ? total : amt);
        document.getElementById('gstBaseLbl').textContent = mode === 'add' ? 'Taxable value (base)' : 'Taxable value (ex-GST)';
        document.getElementById('gstTotalLbl').textContent = mode === 'add' ? 'Total with GST' : 'GST-inclusive amount';
        const half = tax / 2;
        if (inter) {
          document.getElementById('gstLine1').textContent = 'IGST: ' + fmt.format(tax);
          document.getElementById('gstLine2').textContent = '';
        } else {
          document.getElementById('gstLine1').textContent = 'CGST: ' + fmt.format(half);
          document.getElementById('gstLine2').textContent = 'SGST: ' + fmt.format(half);
        }
      }
      const d = debounce(run, 80);
      document.getElementById('gstRateSel').addEventListener('change', function () {
        document.getElementById('gstRateCustom').style.display = this.value === 'custom' ? 'block' : 'none';
        d();
      });
      document.querySelectorAll('input[name="gstMode"], input[name="gstType"], #gstAmt, #gstRateCustom').forEach(function (el) { el.addEventListener('input', d); });
      run();
    })();
  </script>

  <style>
    .breadcrumb { font-size: 13px; color: var(--text-muted); padding: 16px 0 0; max-width: 960px; }
    .breadcrumb a { color: var(--blue); }
    .hero { padding: 36px 0 16px; text-align: center; }
    .subtitle { font-size: 18px; color: var(--text-muted); max-width: 680px; margin: 0 auto 24px; line-height: 1.55; }
    .subtitle strong { color: var(--text); font-weight: 700; }
    .calc-section { padding: 24px 0 40px; }
    .calc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; max-width: 960px; align-items: start; }
    @media (max-width: 768px) { .calc-layout { grid-template-columns: 1fr; } }
    .calc-inputs, .calc-results { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 22px 24px; box-shadow: var(--shadow); }
    .calc-heading { font-size: 1rem; margin: 0 0 16px; color: var(--text-muted); text-transform: uppercase; font-weight: 700; }
    .field { margin-bottom: 16px; }
    .field label { display: block; font-weight: 600; font-size: 14px; margin-bottom: 6px; }
    .field input, .field select { width: 100%; padding: 10px 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); font-size: 16px; }
    .result-grid { display: grid; grid-template-columns: 1fr; gap: 14px; }
    .result-sub { font-size: 1.35rem; font-weight: 700; color: var(--blue); }
    .result-caption { font-size: 12px; color: var(--text-muted); }
    .split-box { margin-top: 16px; padding: 14px; background: var(--gray-100); border-radius: var(--radius); font-size: 14px; }
    [data-theme='dark'] .split-box { background: var(--gray-200); }
    .edu { padding: 40px 0; }
    .edu .container { max-width: 760px; }
    .edu p { font-size: 15px; line-height: 1.75; color: var(--text-muted); margin-bottom: 12px; }
    .section-title { text-align: center; font-size: 1.5rem; margin-bottom: 16px; }
    .faq { padding: 8px 0 32px; }
    .faq .container { max-width: 760px; }
    .faq-list { display: flex; flex-direction: column; gap: 10px; }
    .faq-item { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; }
    .faq-item h4 { font-size: 15px; margin-bottom: 4px; }
    .faq-item p { font-size: 14px; color: var(--text-muted); margin: 0; }
    .related { text-align: center; padding: 24px 0 48px; }
    .related-links a { color: var(--blue); font-weight: 600; }
  </style>
</MainLayout>
