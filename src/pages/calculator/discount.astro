---
import MainLayout from '../../layouts/MainLayout.astro';
import { CALCULATOR_CURRENCY_OPTIONS, LOCALE_BY_CURRENCY } from '../../lib/currencyDisplay';
import { buildCalculatorJsonLd, calculatorCanonical, type CalculatorFaqItem } from '../../lib/calculatorJsonLd';

const canonical = calculatorCanonical(Astro.site, Astro.url.pathname);

const pageDescription =
  'Discount calculator with four modes: sale price from percent off, percent discount from original and sale prices, two sequential percentage discounts, and reverse original price from sale price and one markdown. Currency formats numbers only. Explains why stacked discounts multiply rather than add.';

const faqs: CalculatorFaqItem[] = [
  {
    question: 'Do two ten percent discounts equal twenty percent off?',
    answer:
      'No when they apply sequentially to the shrinking price. You pay ninety percent of the price, then ninety percent of that result—about nineteen percent total off, not twenty.',
  },
  {
    question: 'Why is stacked total percent not d1 plus d2?',
    answer:
      'Each step applies to the amount left after the previous discount, so you multiply the survive fractions (one minus each rate) instead of adding the headline percentages.',
  },
  {
    question: 'Does the currency dropdown change math?',
    answer:
      'No. It only affects how amounts are formatted on screen.',
  },
  {
    question: 'Which mode should I use for a single coupon?',
    answer:
      'Use sale price from discount percent, or what percent off when you know both sticker and checkout prices.',
  },
  {
    question: 'Can discounts exceed one hundred percent?',
    answer:
      'Inputs are clamped to sensible retail ranges; unrealistic values would make the price negative.',
  },
  {
    question: 'Are prices uploaded?',
    answer:
      'No. Calculations run locally in JavaScript.',
  },
];

const jsonLd = buildCalculatorJsonLd({
  site: Astro.site,
  pathname: Astro.url.pathname,
  appName: 'DoItSwift Discount Calculator',
  breadcrumbName: 'Discount Calculator',
  applicationCategory: 'UtilitiesApplication',
  browserRequirements: 'Requires JavaScript to switch modes, format currency, and update sale math live',
  webAppDescription:
    'Answer common retail questions in one page: what you pay after a single percent markdown, what percent off a tag represents, how two sequential promotions combine, and what list price implies a given sale price and discount. Includes a visual savings bar and educational notes on Indian sale seasons and GST-inclusive pricing. Not a checkout integration—pure arithmetic.',
  featureList: [
    'Currency display selector',
    'Mode dropdown for four discount workflows',
    'Dynamic fields per mode (original, sale, two discounts, reverse)',
    'Main result line with subtext and savings bar',
    'Percent savings label where applicable',
    'Article on compound discounts and e-commerce literacy',
    'Links to percentage, tip, GST, and markup tools',
  ],
  faqs,
});
---

<MainLayout
  title="Discount Calculator — Sale Price, Stacked % Off, Reverse Price | DoItSwift"
  description={pageDescription}
  keywords="discount calculator online, sale price calculator, stacked discount calculator, sequential percent off, reverse original price from sale, shopping math India"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>Discount Calculator</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Free Calculator</div>
      <h1>Discount Calculator</h1>
      <p class="subtitle">
        Switch modes to answer “what will I pay?”, “what percent off is this?”, “what if two sales stack?”, or reverse-engineer the sticker price before a single markdown.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> No signup</span>
        <span><span class="check">✓</span> Instant results</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <section class="calc-section">
    <div class="container calc-layout">
      <div class="calc-inputs">
        <h2 class="calc-heading">Inputs</h2>
        <div class="field">
          <label for="discCur">Currency (display)</label>
          <select id="discCur" aria-label="Currency">
            {CALCULATOR_CURRENCY_OPTIONS.map((o) => (
              <option value={o.code} selected={o.code === 'INR'}>
                {o.label}
              </option>
            ))}
          </select>
        </div>
        <div class="field">
          <label for="discMode">Mode</label>
          <select id="discMode">
            <option value="sale">Sale price from discount %</option>
            <option value="pct">What % off? (original + sale)</option>
            <option value="stack">Two sequential discounts</option>
            <option value="rev">Original price from sale + %</option>
          </select>
        </div>
        <div>
          <div class="field" id="fieldOrig">
            <label for="discOrig">Original price</label><input type="number" id="discOrig" min="0" step="1" value="4999" />
          </div>
          <div class="field" id="fieldOff1">
            <label for="discOff1">First discount (%)</label><input type="number" id="discOff1" min="0" max="100" step="0.1" value="20" />
          </div>
          <div class="field" id="fieldOff2">
            <label for="discOff2">Second discount (%)</label><input type="number" id="discOff2" min="0" max="100" step="0.1" value="10" />
          </div>
          <div class="field" id="fieldSale">
            <label for="discSale">Sale price</label><input type="number" id="discSale" min="0" step="1" value="3999" />
          </div>
          <div class="field" id="fieldSale2">
            <label for="discSale2">Sale price</label><input type="number" id="discSale2" min="0" step="1" value="3200" />
          </div>
          <div class="field" id="fieldOffR">
            <label for="discOffR">Discount (%)</label><input type="number" id="discOffR" min="0" max="100" step="0.1" value="20" />
          </div>
        </div>
      </div>
      <div class="calc-results" aria-live="polite">
        <h2 class="calc-heading">Results</h2>
        <p class="big" id="discOut">—</p>
        <p class="sub" id="discSub"></p>
        <div class="bar"><div class="bar-in" id="discBar"></div></div>
        <p class="pctlab" id="discPctLab"></p>
      </div>
    </div>
  </section>

  <section class="edu">
    <div class="container">
      <h2 class="section-title">Compound discounts and sale literacy</h2>
      <p>
        Retailers sometimes advertise <strong>“20% + 10% off”</strong>. If those apply <strong>sequentially</strong>, you pay 80% of the price, then 90% of <em>that</em> — about 28% total reduction, not 30%. This calculator’s <strong>stacked mode</strong> multiplies the remaining-fractions: <em>(1 − d₁) × (1 − d₂)</em>. Additive stacking (20% + 10% = 30%) is rare in formal pricing because it would destroy margins — always read the fine print on <strong>e-commerce</strong> checkouts.
      </p>
      <p>
        <strong>Indian sale seasons</strong> — Big Billion Days, Great Indian Festival, Diwali, End of Reason Sale — rotate headline percentages. Compare <strong>net price</strong> after wallet offers and bank cashback, not only list discounts. GST-inclusive vs exclusive display can change perceived savings.
      </p>
      <p>
        <strong>Spotting inflated MSRP:</strong> If “original” prices jump right before a sale, the discount percentage looks bigger. Cross-check with price history trackers and other retailers. Our <a href="/calculator/percentage/">percentage calculator</a> helps sanity-check mental math in aisles.
      </p>
    </div>
  </section>

  <section class="affiliate">
    <div class="container">
      <div class="affiliate-inner">
        <div class="affiliate-icon">🛒</div>
        <div class="affiliate-content">
          <h3>Shop smart</h3>
          <p>Compare unit prices (per kg, per sheet) when bulk “deals” tempt you.</p>
        </div>
        <a href="/calculator/tip/" class="btn btn-orange">Tip calculator</a>
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <div class="faq-item">
            <h4>{f.question}</h4>
            <p>{f.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="related">
    <div class="container">
      <h2 class="section-title">Related calculators</h2>
      <p class="related-links">
        <a href="/calculator/percentage/">Percentage</a> · <a href="/calculator/tip/">Tip</a> · <a href="/calculator/gst/">GST</a> · <a href="/calculator/markup-margin/">Markup &amp; margin</a>
      </p>
    </div>
  </section>

  <script is:inline define:vars={{ LOCALE_BY_CURRENCY }}>
    (function () {
      function localeForCurrency(code) {
        return LOCALE_BY_CURRENCY[code] || 'en-US';
      }
      function makeFmt() {
        var code = document.getElementById('discCur').value || 'INR';
        return new Intl.NumberFormat(localeForCurrency(code), { style: 'currency', currency: code, maximumFractionDigits: 2 });
      }
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function modeVis() {
        const m = document.getElementById('discMode').value;
        const show = function (id, on) {
          document.getElementById(id).style.display = on ? 'block' : 'none';
        };
        show('fieldOrig', m !== 'rev');
        show('fieldOff1', m === 'sale' || m === 'stack');
        show('fieldOff2', m === 'stack');
        show('fieldSale', m === 'pct');
        show('fieldSale2', m === 'rev');
        show('fieldOffR', m === 'rev');
      }
      function run() {
        const fmt = makeFmt();
        modeVis();
        const m = document.getElementById('discMode').value;
        const orig = Math.max(0, parseFloat(document.getElementById('discOrig').value) || 0);
        const off1 = Math.max(0, Math.min(100, parseFloat(document.getElementById('discOff1').value) || 0));
        const off2 = Math.max(0, Math.min(100, parseFloat(document.getElementById('discOff2').value) || 0));
        const sale = Math.max(0, parseFloat(document.getElementById('discSale').value) || 0);
        const sale2 = Math.max(0, parseFloat(document.getElementById('discSale2').value) || 0);
        const offR = Math.max(0, Math.min(100, parseFloat(document.getElementById('discOffR').value) || 0));
        let out = '';
        let sub = '';
        let pct = 0;
        if (m === 'sale') {
          const final = orig * (1 - off1 / 100);
          const sav = orig - final;
          pct = orig > 0 ? (sav / orig) * 100 : 0;
          out = fmt.format(final);
          sub = 'You save ' + fmt.format(sav) + ' (' + pct.toFixed(2) + '%).';
        } else if (m === 'pct') {
          if (orig <= 0) {
            out = '—';
            sub = 'Enter original greater than 0';
          } else {
            const sav = orig - sale;
            pct = (sav / orig) * 100;
            out = pct.toFixed(2) + '% off';
            sub = 'Savings ' + fmt.format(Math.max(0, sav)) + '; sale ' + fmt.format(sale) + '.';
          }
        } else if (m === 'stack') {
          const final = orig * (1 - off1 / 100) * (1 - off2 / 100);
          const sav = orig - final;
          pct = orig > 0 ? (sav / orig) * 100 : 0;
          out = '≈ ' + pct.toFixed(2) + '% combined off';
          sub =
            'Final price ' +
            fmt.format(final) +
            ' — sequential ' +
            off1 +
            '% then ' +
            off2 +
            '%. You save ' +
            fmt.format(sav) +
            ' vs sticker.';
        } else {
          if (offR >= 100) {
            out = '—';
            sub = 'Discount must be below 100%.';
          } else {
            const o = sale2 / (1 - offR / 100);
            const sav = o - sale2;
            pct = offR;
            out = fmt.format(o);
            sub = 'Implied original before ' + offR + '% off. Savings vs original: ' + fmt.format(sav) + '.';
          }
        }
        document.getElementById('discOut').textContent = out;
        document.getElementById('discSub').textContent = sub;
        document.getElementById('discBar').style.width = Math.min(100, pct) + '%';
        document.getElementById('discPctLab').textContent =
          pct > 0
            ? m === 'stack'
              ? 'You pay ' + (100 - pct).toFixed(2) + '% of the original price.'
              : 'Approx. effective discount: ' + pct.toFixed(2) + '%'
            : '';
      }
      const d = debounce(run, 60);
      ['discMode', 'discCur', 'discOrig', 'discOff1', 'discOff2', 'discSale', 'discSale2', 'discOffR'].forEach(function (id) {
        document.getElementById(id).addEventListener('input', d);
      });
      document.getElementById('discCur').addEventListener('change', d);
      run();
    })();
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 960px;
    }
    .breadcrumb a {
      color: var(--blue);
    }
    .hero {
      padding: 36px 0 16px;
      text-align: center;
    }
    .subtitle {
      font-size: 16px;
      color: var(--text-muted);
      max-width: 720px;
      margin: 0 auto 22px;
      line-height: 1.65;
    }
    .calc-section {
      padding: 24px 0 40px;
    }
    .calc-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      max-width: 960px;
      align-items: start;
    }
    @media (max-width: 768px) {
      .calc-layout {
        grid-template-columns: 1fr;
      }
    }
    .calc-inputs,
    .calc-results {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 22px 24px;
      box-shadow: var(--shadow);
    }
    .calc-heading {
      font-size: 1rem;
      margin: 0 0 16px;
      color: var(--text-muted);
      text-transform: uppercase;
      font-weight: 700;
    }
    .field {
      margin-bottom: 12px;
    }
    .field label {
      display: block;
      font-weight: 600;
      font-size: 14px;
      margin-bottom: 6px;
    }
    .field input,
    .field select {
      width: 100%;
      padding: 10px 12px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      font-size: 16px;
    }
    .big {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--blue);
      margin: 0;
      word-break: break-word;
    }
    .sub {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.55;
      margin: 10px 0 14px;
    }
    .bar {
      height: 12px;
      background: var(--gray-200);
      border-radius: 999px;
      overflow: hidden;
    }
    .bar-in {
      height: 100%;
      width: 0;
      background: linear-gradient(90deg, #22c55e, var(--blue));
      transition: width 0.12s ease;
    }
    .pctlab {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 8px;
    }
    .edu {
      padding: 36px 0 40px;
    }
    .edu .container {
      max-width: 760px;
    }
    .edu p {
      font-size: 15px;
      line-height: 1.85;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .edu a {
      color: var(--blue);
      font-weight: 600;
    }
    .section-title {
      text-align: center;
      margin-bottom: 18px;
      font-size: 1.5rem;
    }
    .affiliate {
      padding: 28px 0;
    }
    .affiliate .container {
      max-width: 900px;
    }
    .affiliate-inner {
      background: linear-gradient(135deg, #f0fdf4, #dcfce7);
      border: 1px solid #86efac;
      border-radius: var(--radius-lg);
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .affiliate-icon {
      font-size: 36px;
    }
    .affiliate-content {
      flex: 1;
      min-width: 200px;
    }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      max-width: 760px;
      margin: 0 auto;
    }
    .related {
      text-align: center;
      padding-bottom: 48px;
    }
    .related-links a {
      color: var(--blue);
      font-weight: 600;
    }
  </style>
</MainLayout>
