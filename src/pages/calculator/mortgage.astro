  <script is:inline define:vars={{ LOCALE_BY_CURRENCY }}>
    (function () {
      function localeForCurrency(code) {
        return LOCALE_BY_CURRENCY[code] || 'en-US';
      }
      function makeFmt() {
        var code = document.getElementById('mgCur').value || 'USD';
        return new Intl.NumberFormat(localeForCurrency(code), { style: 'currency', currency: code, maximumFractionDigits: 0 });
      }
      function emi(P, annual, months) {
        var r = annual / 100 / 12;
        if (months <= 0) return 0;
        if (r === 0) return P / months;
        var p = Math.pow(1 + r, months);
        return (P * r * p) / (p - 1);
      }
      function run() {
        var fmt = makeFmt();
        var price = parseFloat(document.getElementById('mgPrice').value) || 0;
        var dpType = document.querySelector('input[name="mgDpT"]:checked').value;
        var dpRaw = parseFloat(document.getElementById('mgDp').value) || 0;
        var down = dpType === 'pct' ? (price * dpRaw) / 100 : dpRaw;
        down = Math.min(down, price * 0.99);
        var loan = Math.max(0, price - down);
        var yrs = parseInt(document.getElementById('mgYears').value, 10) || 30;
        var n = yrs * 12;
        var rate = parseFloat(document.getElementById('mgRate').value) || 0;
        var taxPct = parseFloat(document.getElementById('mgTax').value) || 0;
        var insY = parseFloat(document.getElementById('mgIns').value) || 0;
        var hoa = parseFloat(document.getElementById('mgHoa').value) || 0;
        var pmiPct = parseFloat(document.getElementById('mgPmi').value) || 0;
        var E = emi(loan, rate, n);
        var taxM = (price * (taxPct / 100)) / 12;
        var insM = insY / 12;
        var ltv = price > 0 ? down / price : 1;
        var needPmi = ltv < 0.2 && loan > 0;
        var pmiM = needPmi ? (loan * (pmiPct / 100)) / 12 : 0;
        var tot = E + taxM + insM + pmiM + hoa;
        var totalInt = E * n - loan;
        document.getElementById('mgPi').textContent = fmt.format(Math.round(E));
        document.getElementById('mgTot').textContent = fmt.format(Math.round(tot));
        document.getElementById('mgInt').textContent = fmt.format(Math.round(totalInt));
        document.getElementById('mgCost').textContent = fmt.format(Math.round(E * n));
        document.getElementById('mgPmiNote').textContent = needPmi
          ? 'PMI applied (down payment under 20%).'
          : 'No PMI in this estimate (20%+ down or zero PMI rate).';
        var max = tot || 1;
        document.getElementById('mgBarPi').style.flex = E / max;
        document.getElementById('mgBarTax').style.flex = taxM / max;
        document.getElementById('mgBarIns').style.flex = insM / max;
        document.getElementById('mgBarPmi').style.flex = pmiM / max;
        document.getElementById('mgBarHoa').style.flex = hoa / max;
        document.getElementById('mgLeg').innerHTML =
          '<li>P&amp;I: ' +
          fmt.format(Math.round(E)) +
          '</li><li>Tax: ' +
          fmt.format(Math.round(taxM)) +
          '</li><li>Insurance: ' +
          fmt.format(Math.round(insM)) +
          '</li><li>PMI: ' +
          fmt.format(Math.round(pmiM)) +
          '</li><li>HOA: ' +
          fmt.format(Math.round(hoa)) +
          '</li>';
        var bal = loan;
        var r = rate / 100 / 12;
        var tbody = document.getElementById('mgTable');
        tbody.innerHTML = '';
        var yPrin = 0,
          yInt = 0,
          y = 1;
        for (var m = 1; m <= n; m++) {
          var iP = bal * r;
          var pP = E - iP;
          bal -= pP;
          yPrin += pP;
          yInt += iP;
          if (m % 12 === 0 || m === n) {
            var tr = document.createElement('tr');
            tr.innerHTML =
              '<td>' +
              y +
              '</td><td>' +
              fmt.format(Math.round(yPrin)) +
              '</td><td>' +
              fmt.format(Math.round(yInt)) +
              '</td><td>' +
              fmt.format(Math.max(0, Math.round(bal))) +
              '</td>';
            tbody.appendChild(tr);
            y++;
            yPrin = 0;
            yInt = 0;
          }
        }
      }
      document.querySelectorAll('input[name="mgDpT"]').forEach(function (el) {
        el.addEventListener('change', function () {
          var pct = document.querySelector('input[name="mgDpT"]:checked').value === 'pct';
          document.getElementById('mgDpHint').textContent = pct ? 'Percent of home price' : 'Fixed amount in selected currency';
          document.getElementById('mgDp').value = pct ? '20' : '60000';
          run();
        });
      });
      document.getElementById('mgCur').addEventListener('change', run);
      ['mgPrice', 'mgDp', 'mgYears', 'mgRate', 'mgTax', 'mgIns', 'mgHoa', 'mgPmi'].forEach(function (id) {
        document.getElementById(id).addEventListener('input', run);
      });
      run();
    })();
  </script>

