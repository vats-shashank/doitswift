---
import MainLayout from '../../layouts/MainLayout.astro';
import { CALCULATOR_CURRENCY_OPTIONS, LOCALE_BY_CURRENCY } from '../../lib/currencyDisplay';
import { buildCalculatorJsonLd, calculatorCanonical } from '../../lib/calculatorJsonLd';

const canonical = calculatorCanonical(Astro.site, Astro.url.pathname);

const pageDescription =
  'Free compound interest calculator: principal, nominal annual %, time in years + months, compounding (annual to daily or continuous), optional monthly contributions. See final amount, interest earned, effective annual rate (EAR), principal vs interest bars, and year-by-year table. Currency formats display only.';

const jsonLd = buildCalculatorJsonLd({
  site: Astro.site,
  pathname: Astro.url.pathname,
  appName: 'DoItSwift Compound Interest Calculator',
  breadcrumbName: 'Compound Interest',
  applicationCategory: 'FinanceApplication',
  browserRequirements: 'Requires JavaScript for compounding, EAR, charts, and year-by-year table',
  webAppDescription:
    'Compute compound growth using discrete compounding A = P(1+r/n)^(nt), continuous compounding, or level monthly contributions with monthly accrual. Shows final balance, interest earned, effective annual rate (EAR), comparison bars, and year-by-year balances. Display currency is cosmetic. Educational tool — not investment advice.',
  featureList: [
    'Principal, nominal annual rate, and duration in years plus extra months',
    'Compounding: annual, semi-annual, quarterly, monthly, daily, or continuous',
    'Optional fixed contribution each month',
    'Final amount, interest earned, and EAR',
    'Principal versus interest visualization',
    'Year-by-year balance and cumulative interest table',
    'Multi-currency formatting without FX conversion',
    'Runs locally in the browser',
  ],
  faqs: [
    {
      question: 'What is compound interest?',
      answer:
        'Interest earned on both principal and previously credited interest, so growth accelerates over time compared with simple interest.',
    },
    {
      question: 'What is effective annual rate (EAR)?',
      answer:
        'EAR expresses the annualized return after compounding within the year — higher compounding frequency raises EAR for the same nominal rate.',
    },
    {
      question: 'Does the currency dropdown convert money between countries?',
      answer:
        'No. It only changes number formatting; the math is unchanged.',
    },
    {
      question: 'Can I add monthly savings to the principal?',
      answer:
        'Yes — enter an optional monthly contribution to model regular deposits with monthly interest accrual.',
    },
    {
      question: 'Is this compound interest calculator free and private?',
      answer:
        'Yes. It is free with no signup and runs in your browser without uploading your inputs.',
    },
  ],
});
---

<MainLayout
  title="Compound Interest Calculator — EAR, Daily/Monthly/Continuous | DoItSwift"
  description={pageDescription}
  keywords="compound interest calculator, compounding calculator, EAR calculator, effective annual rate, continuous compounding calculator, monthly contribution compound interest"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>Compound Interest</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Free Calculator</div>
      <h1>Compound Interest Calculator</h1>
      <p class="subtitle">
        Model <strong>A = P(1 + r/n)<sup>nt</sup></strong>, <strong>continuous</strong> compounding, or add <strong>monthly contributions</strong>. Compare the <strong>effective annual rate (EAR)</strong> when compounding frequency changes.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> No signup</span>
        <span><span class="check">✓</span> Instant results</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <section class="calc-section">
    <div class="container calc-layout">
      <div class="calc-inputs">
        <h2 class="calc-heading">Inputs</h2>
        <div class="field">
          <label for="ciCur">Currency (display)</label>
          <select id="ciCur" aria-label="Currency">
            {CALCULATOR_CURRENCY_OPTIONS.map((o) => (
              <option value={o.code} selected={o.code === 'INR'}>
                {o.label}
              </option>
            ))}
          </select>
        </div>
        <div class="field">
          <label for="ciP">Principal</label>
          <input type="number" id="ciP" min="0" step="1000" value="100000" inputmode="decimal" />
        </div>
        <div class="field">
          <label for="ciR">Nominal annual interest rate (%)</label>
          <input type="range" id="ciRR" min="0" max="30" step="0.1" value="8" aria-hidden="true" />
          <input type="number" id="ciR" min="0" max="30" step="0.05" value="8" inputmode="decimal" />
        </div>
        <div class="field">
          <label for="ciY">Time (years)</label>
          <input type="number" id="ciY" min="0" max="50" step="0.25" value="10" inputmode="decimal" />
        </div>
        <div class="field">
          <label for="ciM">Extra months (added to years)</label>
          <input type="number" id="ciM" min="0" max="11" step="1" value="0" inputmode="numeric" />
        </div>
        <div class="field">
          <label for="ciFreq">Compounding</label>
          <select id="ciFreq">
            <option value="1">Annually</option>
            <option value="2">Semi-annually</option>
            <option value="4">Quarterly</option>
            <option value="12" selected>Monthly</option>
            <option value="365">Daily</option>
            <option value="0">Continuously</option>
          </select>
        </div>
        <div class="field">
          <label for="ciAdd">Additional contribution per month (optional)</label>
          <input type="number" id="ciAdd" min="0" step="500" value="0" inputmode="numeric" />
        </div>
      </div>

      <div class="calc-results" aria-live="polite">
        <h2 class="calc-heading">Results</h2>
        <div class="result-hero" id="ciFinal">0</div>
        <p class="result-label">Final amount</p>
        <div class="result-grid">
          <div><div class="result-sub" id="ciInt">0</div><div class="result-caption">Interest earned</div></div>
          <div><div class="result-sub" id="ciEar">0%</div><div class="result-caption">EAR (effective annual)</div></div>
        </div>
        <p class="cmp-note" id="ciCmp"></p>
        <div class="bar-chart" role="img" aria-label="Principal versus interest">
          <div class="bar-row"><span class="bar-label">Principal</span><div class="bar-track"><div class="bar-fill bar-fill--inv" id="ciBarP"></div></div></div>
          <div class="bar-row"><span class="bar-label">Interest</span><div class="bar-track"><div class="bar-fill bar-fill--ret" id="ciBarI"></div></div></div>
        </div>
        <details class="calc-details">
          <summary>Year-by-year balance</summary>
          <div class="table-wrap">
            <table>
              <caption class="sr-only">Year-by-year compound balance and interest earned</caption>
              <thead><tr><th>Year</th><th>Balance</th><th>Interest so far</th></tr></thead>
              <tbody id="ciTable"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="edu">
    <div class="container">
      <h2 class="section-title">Ideas behind compounding</h2>
      <p>
        Albert Einstein is often quoted as calling compound interest “the eighth wonder of the world” — <strong>the quote is widely attributed but not well verified</strong>. The underlying idea <em>is</em> sound: when interest earns interest, growth accelerates over long horizons.
      </p>
      <p>
        <strong>Rule of 72:</strong> roughly <em>72 ÷ annual percent rate</em> estimates years to double money at constant compounded growth (handy, not exact).
      </p>
      <p>
        <strong>EAR:</strong> The <em>effective annual rate</em> lets you compare nominal rates that compound at different frequencies — more frequent compounding within the year lifts the effective yield slightly.
      </p>
      <p>
        This page is <strong>currency-agnostic</strong> — pick a display currency; math is the same. Fees, tax, and inflation are not modeled.
      </p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>What is compound interest?</h4>
          <p>Interest on your principal and on interest already added — growth speeds up versus simple interest.</p>
        </div>
        <div class="faq-item">
          <h4>What is EAR?</h4>
          <p>Effective annual rate: the yearly equivalent after compounding. More compounding within the year → higher EAR for the same nominal rate.</p>
        </div>
        <div class="faq-item">
          <h4>Does currency change the math?</h4>
          <p>No — only display formatting.</p>
        </div>
        <div class="faq-item">
          <h4>Can I model monthly deposits?</h4>
          <p>Yes — use the optional monthly contribution field.</p>
        </div>
        <div class="faq-item">
          <h4>Is my data uploaded?</h4>
          <p>No — calculations run locally in your browser.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="affiliate">
    <div class="container">
      <div class="affiliate-inner">
        <div class="affiliate-icon">📈</div>
        <div class="affiliate-content">
          <h3>Related tools</h3>
          <p>SIP and lumpsum calculators explore monthly vs one-time investing.</p>
        </div>
        <a href="/calculator/sip/" class="btn btn-orange">SIP →</a>
      </div>
    </div>
  </section>

  <section class="related">
    <div class="container">
      <h2 class="section-title">Related calculators</h2>
      <p class="related-links">
        <a href="/calculator/sip/">SIP</a> · <a href="/calculator/lumpsum/">Lumpsum</a> · <a href="/calculator/fd/">FD</a>
      </p>
    </div>
  </section>

  <script is:inline define:vars={{ LOCALE_BY_CURRENCY }}>
    (function () {
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function localeForCurrency(code) {
        return LOCALE_BY_CURRENCY[code] || 'en-US';
      }
      function moneyFmt(code) {
        return new Intl.NumberFormat(localeForCurrency(code), { style: 'currency', currency: code, maximumFractionDigits: 0 });
      }
      function run() {
        const code = document.getElementById('ciCur').value || 'INR';
        const fmt = moneyFmt(code);
        let P = Math.max(0, parseFloat(document.getElementById('ciP').value) || 0);
        const rNom = Math.min(30, Math.max(0, parseFloat(document.getElementById('ciR').value) || 0));
        document.getElementById('ciR').value = rNom;
        document.getElementById('ciRR').value = rNom;
        let y = Math.min(50, Math.max(0, parseFloat(document.getElementById('ciY').value) || 0));
        let mo = Math.min(11, Math.max(0, parseInt(document.getElementById('ciM').value, 10) || 0));
        const t = y + mo / 12;
        const freq = parseInt(document.getElementById('ciFreq').value, 10);
        const add = Math.max(0, parseFloat(document.getElementById('ciAdd').value) || 0);
        const r = rNom / 100;

        let A = 0;
        let totalPrincipal = P;
        if (t <= 0) {
          document.getElementById('ciFinal').textContent = fmt.format(0);
          document.getElementById('ciInt').textContent = fmt.format(0);
          document.getElementById('ciEar').textContent = '—';
          document.getElementById('ciCmp').textContent = '';
          return;
        }

        const months = Math.round(t * 12);
        const rm = r / 12;
        function balanceAtMonth(m) {
          if (add > 0) {
            let bal = P;
            for (let i = 0; i < m; i++) bal = bal * (1 + rm) + add;
            return bal;
          }
          const ty = m / 12;
          if (freq === 0) return P * Math.exp(r * ty);
          const n = freq;
          return P * Math.pow(1 + r / n, n * ty);
        }
        A = balanceAtMonth(months);
        totalPrincipal = P + add * months;

        const intEarned = Math.max(0, A - totalPrincipal);
        let ear = 0;
        if (freq === 0) ear = Math.exp(r) - 1;
        else ear = Math.pow(1 + r / freq, freq) - 1;

        let ANoAdd = P;
        if (freq === 0) ANoAdd = P * Math.exp(r * t);
        else ANoAdd = P * Math.pow(1 + r / freq, freq * t);
        document.getElementById('ciCmp').textContent =
          add > 0
            ? 'Without monthly additions, principal only would grow to about ' + fmt.format(Math.round(ANoAdd)) + '.'
            : '';

        document.getElementById('ciFinal').textContent = fmt.format(Math.round(A));
        document.getElementById('ciInt').textContent = fmt.format(Math.round(intEarned));
        document.getElementById('ciEar').textContent = (ear * 100).toFixed(2) + '%';
        const maxBar = Math.max(totalPrincipal, intEarned, 1);
        document.getElementById('ciBarP').style.width = (totalPrincipal / maxBar) * 100 + '%';
        document.getElementById('ciBarI').style.width = (intEarned / maxBar) * 100 + '%';

        const tbody = document.getElementById('ciTable');
        tbody.innerHTML = '';
        const totalYears = Math.ceil(t);
        for (let yr = 1; yr <= totalYears; yr++) {
          const mEnd = Math.min(months, yr * 12);
          const bal = balanceAtMonth(mEnd);
          const tp = P + add * mEnd;
          const tr = document.createElement('tr');
          tr.innerHTML =
            '<td>' +
            yr +
            '</td><td>' +
            fmt.format(Math.round(bal)) +
            '</td><td>' +
            fmt.format(Math.round(Math.max(0, bal - tp))) +
            '</td>';
          tbody.appendChild(tr);
        }
      }
      const d = debounce(run, 80);
      ['ciP', 'ciR', 'ciY', 'ciM', 'ciAdd', 'ciFreq'].forEach((id) => document.getElementById(id).addEventListener('input', d));
      document.getElementById('ciFreq').addEventListener('change', d);
      document.getElementById('ciCur').addEventListener('change', d);
      document.getElementById('ciRR').addEventListener('input', function () {
        document.getElementById('ciR').value = this.value;
        d();
      });
      run();
    })();
  </script>

  <style>
    .breadcrumb { font-size: 13px; color: var(--text-muted); padding: 16px 0 0; max-width: 960px; }
    .breadcrumb a { color: var(--blue); text-decoration: none; }
    .hero { padding: 36px 0 16px; text-align: center; }
    .subtitle { font-size: 16px; color: var(--text-muted); max-width: 700px; margin: 0 auto 22px; line-height: 1.55; }
    .subtitle strong { color: var(--text); font-weight: 700; }
    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    .calc-section { padding: 24px 0 40px; }
    .calc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; max-width: 960px; align-items: start; }
    @media (max-width: 768px) { .calc-layout { grid-template-columns: 1fr; } }
    .calc-inputs, .calc-results { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 22px 24px; box-shadow: var(--shadow); }
    .calc-heading { font-size: 1rem; margin: 0 0 16px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; }
    .field { margin-bottom: 14px; }
    .field label { display: block; font-weight: 600; font-size: 14px; margin-bottom: 6px; }
    .field input, .field select { width: 100%; padding: 10px 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); font-size: 16px; }
    .field input[type='range'] { width: 100%; margin-bottom: 4px; }
    .result-hero { font-size: 2rem; font-weight: 800; color: var(--blue); }
    .result-label { font-size: 14px; color: var(--text-muted); margin: 4px 0 12px; }
    .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 8px; }
    .result-sub { font-size: 1.2rem; font-weight: 700; }
    .result-caption { font-size: 12px; color: var(--text-muted); }
    .cmp-note { font-size: 13px; color: var(--text-muted); line-height: 1.5; margin: 8px 0 12px; }
    .bar-chart { margin: 10px 0; }
    .bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; font-size: 13px; }
    .bar-label { width: 64px; color: var(--text-muted); }
    .bar-track { flex: 1; height: 22px; background: var(--gray-100); border-radius: 6px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 6px; }
    .bar-fill--inv { background: var(--blue); opacity: 0.9; }
    .bar-fill--ret { background: var(--green); }
    .calc-details summary { cursor: pointer; font-weight: 600; }
    .table-wrap { overflow: auto; max-height: 240px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { padding: 8px; border-bottom: 1px solid var(--border); text-align: right; }
    th:first-child, td:first-child { text-align: left; }
    .edu { padding: 36px 0; }
    .edu .container { max-width: 760px; }
    .edu p { font-size: 15px; line-height: 1.75; color: var(--text-muted); margin-bottom: 14px; }
    .section-title { text-align: center; margin-bottom: 18px; font-size: 1.5rem; }
    .faq { padding: 8px 0 28px; }
    .faq .container { max-width: 760px; }
    .faq-list { display: flex; flex-direction: column; gap: 10px; }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 18px;
    }
    .faq-item h4 { font-size: 15px; margin-bottom: 4px; }
    .faq-item p { font-size: 14px; color: var(--text-muted); margin: 0; }
    .affiliate { padding: 28px 0; }
    .affiliate .container { max-width: 900px; }
    .affiliate-inner { background: linear-gradient(135deg, #eff6ff, #dbeafe); border: 1px solid #93c5fd; border-radius: var(--radius-lg); padding: 24px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
    [data-theme='dark'] .affiliate-inner { background: rgba(59, 130, 246, 0.12); border-color: rgba(147, 197, 253, 0.4); }
    .affiliate-icon { font-size: 36px; }
    .affiliate-content { flex: 1; min-width: 200px; }
    .related { text-align: center; padding-bottom: 48px; }
    .related-links a { color: var(--blue); font-weight: 600; }
  </style>
</MainLayout>
