      <h2 id="sip-viz-heading" class="sip-viz-heading">Visualize Your Wealth Journey</h2>
      <p class="sip-viz-sub">
        See how your SIP grows over time, compare scenarios, and factor in inflation.
      </p>

      <div class="sip-goal-row">
        <div class="field sip-goal-field">
          <label for="sipGoal">My goal amount (₹)</label>
          <input type="number" id="sipGoal" min="0" step="100000" value="10000000" inputmode="numeric" aria-describedby="sipGoal-hint" />
          <p id="sipGoal-hint" class="field-hint">Optional — progress bar shows how close your projected corpus is to this target.</p>
        </div>
        <div class="field sip-inflation-field">
          <label for="sipInflation">Expected inflation rate (%)</label>
          <input type="range" id="sipInflationRange" min="3" max="10" step="0.5" value="6" aria-hidden="true" />
          <input type="number" id="sipInflation" min="3" max="10" step="0.1" value="6" inputmode="decimal" />
          <p class="field-hint">Used in the Inflation tab for real purchasing power (India long-run average ~6%).</p>
        </div>
      </div>

      <div class="sip-goal-gauge" aria-live="polite" id="sipGoalGaugeWrap">
        <div class="sip-goal-gauge-label" id="sipGoalGaugeLabel">—</div>
        <div class="sip-goal-gauge-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" id="sipGoalGaugeBar" aria-labelledby="sipGoalGaugeLabel">
          <div class="sip-goal-gauge-fill" id="sipGoalGaugeFill"></div>
        </div>
      </div>

      <div class="sip-chart-tabs-wrap">
        <div class="sip-chart-tabs" role="tablist" aria-label="SIP chart views" id="sipChartTabs">
          <button type="button" class="sip-chart-tab sip-chart-tab--active" role="tab" id="sipTab0" aria-selected="true" aria-controls="sipPanel0" data-tab="0" tabindex="0">Growth</button>
          <button type="button" class="sip-chart-tab" role="tab" id="sipTab1" aria-selected="false" aria-controls="sipPanel1" data-tab="1" tabindex="-1">Yearly</button>
          <button type="button" class="sip-chart-tab" role="tab" id="sipTab2" aria-selected="false" aria-controls="sipPanel2" data-tab="2" tabindex="-1">Step-Up</button>
          <button type="button" class="sip-chart-tab" role="tab" id="sipTab3" aria-selected="false" aria-controls="sipPanel3" data-tab="3" tabindex="-1">Compare</button>
          <button type="button" class="sip-chart-tab" role="tab" id="sipTab4" aria-selected="false" aria-controls="sipPanel4" data-tab="4" tabindex="-1">Inflation</button>
        </div>
