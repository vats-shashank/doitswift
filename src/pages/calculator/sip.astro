---
import MainLayout from '../../layouts/MainLayout.astro';
import { CALCULATOR_CURRENCY_OPTIONS, LOCALE_BY_CURRENCY } from '../../lib/currencyDisplay';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const pageDescription =
  'Free SIP calculator (India & multi-currency display): monthly mutual fund SIP, annuity-due / beginning-of-month payments, 1–40 years, 1–30% assumed return. Maturity value, invested vs returns bar, year-by-year table. Runs in your browser — no signup.';

const pageTitle =
  'SIP Calculator India — Mutual Fund SIP, Maturity & Year-by-Year | DoItSwift';

const siteRoot = Astro.site ? new URL('/', Astro.site).href : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      url: canonical,
      name: pageTitle,
      description: pageDescription,
      ...(siteRoot
        ? {
            isPartOf: { '@id': `${siteRoot}#website` },
            publisher: { '@id': `${siteRoot}#organization` },
          }
        : {}),
    },
    {
      '@type': 'WebApplication',
      name: 'DoItSwift SIP Calculator',
      url: canonical,
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Web browser',
      browserRequirements: 'Requires JavaScript for live SIP projections',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
      description:
        'Estimate systematic investment plan (SIP) maturity using monthly contributions at an assumed annual return, with payments at the beginning of each month (annuity due). Adjustable monthly amount, return rate, and years; optional currency formatting for display. Shows total invested, estimated returns, bar comparison, and year-by-year values. Not financial advice.',
      featureList: [
        'Monthly SIP amount from 500 to 100,000 in steps of 500',
        'Expected annual return between 1% and 30%',
        'Investment horizon 1 to 40 years',
        'Future value using annuity-due formula (payment at start of each month)',
        'Currency selector for number formatting only — not FX conversion',
        'Displays maturity value, total invested, estimated returns, and invested-vs-returns bars',
        'Expandable year-by-year cumulative invested and estimated value table',
        'All calculations run locally in the browser',
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'What is SIP?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'SIP (Systematic Investment Plan) means investing a fixed sum every month into mutual funds or similar instruments, using rupee-cost averaging and compounding over time.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is SIP return fixed?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. The percentage you enter is an assumption; actual mutual fund returns vary with markets.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does this include tax on capital gains?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No — it shows a gross maturity-style estimate before personal tax rules such as equity or debt fund taxation in India.',
          },
        },
        {
          '@type': 'Question',
          name: 'Why “beginning of month”?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Many SIPs debit at the start of the period; the extra (1+r) factor in the formula reflects that timing.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I use this for daily or weekly SIP?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'This page is monthly only; approximate or use a spreadsheet for other frequencies.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is the SIP calculator free? Are my inputs uploaded?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes, it is free with no signup. Inputs are processed in your browser and are not sent to DoItSwift servers.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are mutual fund fees or expense ratios included?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. Expense ratio, exit loads, and taxes are not modeled — treat results as illustrations.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is this financial advice?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. It is an educational calculator. Consult a SEBI-registered advisor or your financial planner for personal advice.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does the currency dropdown convert exchange rates?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. The currency selector only changes number formatting for display; it does not convert between currencies.',
          },
        },
        {
          '@type': 'Question',
          name: 'SIP vs lumpsum — where should I compare?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Use the lumpsum calculator alongside this page, and read the SIP vs lumpsum article for deeper scenarios.',
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Calculators',
          item: new URL('/calculator/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'SIP Calculator',
          item: canonical,
        },
      ],
    },
  ],
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  keywords="SIP calculator, SIP calculator India, mutual fund SIP calculator, systematic investment plan calculator, monthly SIP returns, SIP maturity calculator, annuity due SIP, equity SIP estimate, free SIP calculator online, lumpsum vs SIP"
  canonical={canonical}
  ogImage="/og-sip.svg"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/calculator/">Calculators</a> › <span>SIP Calculator</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🧮 Free Calculator</div>
      <h1>SIP Calculator India — Mutual Fund SIP &amp; Maturity</h1>
      <p class="subtitle">
        Project mutual fund SIP wealth: <strong>maturity value</strong>, total invested, and estimated returns —{' '}
        <strong>annuity due</strong> (payment at the <strong>start</strong> of each month). Adjust amount, return %, and years;
        open the table for year-by-year growth.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> No signup</span>
        <span><span class="check">✓</span> Instant results</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <section class="calc-section">
    <div class="container calc-layout">
      <div class="calc-inputs">
        <h2 class="calc-heading">Inputs</h2>
        <div class="field">
          <label for="sipCur">Currency (display)</label>
          <select id="sipCur" aria-label="Currency">
            {CALCULATOR_CURRENCY_OPTIONS.map((o) => (
              <option value={o.code} selected={o.code === 'INR'}>
                {o.label}
              </option>
            ))}
          </select>
        </div>
        <div class="field">
          <label for="sipMonthly">Monthly investment</label>
          <input type="range" id="sipMonthlyRange" min="500" max="100000" step="500" value="5000" aria-hidden="true" />
          <input type="number" id="sipMonthly" min="500" max="100000" step="500" value="5000" inputmode="numeric" aria-describedby="sipMonthly-hint" />
          <p id="sipMonthly-hint" class="field-hint">Adjust amount to match your platform’s minimums</p>
        </div>
        <div class="field">
          <label for="sipRate">Expected annual return (%)</label>
          <input type="range" id="sipRateRange" min="1" max="30" step="0.5" value="12" aria-hidden="true" />
          <input type="number" id="sipRate" min="1" max="30" step="0.1" value="12" inputmode="decimal" />
        </div>
        <div class="field">
          <label for="sipYears">Investment period (years)</label>
          <input type="range" id="sipYearsRange" min="1" max="40" step="1" value="10" aria-hidden="true" />
          <input type="number" id="sipYears" min="1" max="40" step="1" value="10" inputmode="numeric" />
        </div>
      </div>

      <div class="calc-results" aria-live="polite">
        <h2 class="calc-heading">Results</h2>
        <div class="result-hero" id="sipMaturity">—</div>
        <p class="result-label">Maturity value (estimated)</p>
        <div class="result-grid">
          <div>
            <div class="result-sub" id="sipInvested">—</div>
            <div class="result-caption">Total invested</div>
          </div>
          <div>
            <div class="result-sub" id="sipReturns">—</div>
            <div class="result-caption">Est. returns</div>
          </div>
        </div>
        <div class="bar-chart" id="sipBar" role="img" aria-label="Invested versus returns bar comparison">
          <div class="bar-row"><span class="bar-label">Invested</span><div class="bar-track"><div class="bar-fill bar-fill--inv" id="sipBarInv"></div></div></div>
          <div class="bar-row"><span class="bar-label">Returns</span><div class="bar-track"><div class="bar-fill bar-fill--ret" id="sipBarRet"></div></div></div>
        </div>
        <details class="calc-details">
          <summary>Year-by-year breakdown</summary>
          <div class="table-wrap">
            <table>
              <caption class="sr-only">Year-by-year cumulative SIP invested and estimated corpus</caption>
              <thead><tr><th>Year</th><th>Cumulative invested</th><th>Est. value</th></tr></thead>
              <tbody id="sipTable"></tbody>
            </table>
          </div>
        </details>
      </div>
    </div>
  </section>

  <article class="sip-edu" aria-label="Guide: how SIP wealth is estimated">
    <div class="container sip-edu-inner">
      <h2 class="section-title">How SIP wealth is estimated</h2>
      <p>
        A <strong>Systematic Investment Plan (SIP)</strong> means you invest the same amount every month. This calculator treats each payment as occurring at the <strong>beginning</strong> of the month, which matches how many mutual fund SIPs operate and uses the standard <strong>future value of an annuity due</strong>. The monthly rate is the annual return divided by 12; the number of periods is years × 12.
      </p>
      <p>
        The formula used is: <em>M = P × ([(1 + r)<sup>n</sup> − 1] / r) × (1 + r)</em>, where <em>P</em> is monthly investment, <em>r</em> is the monthly rate, and <em>n</em> is the number of months. <strong>Expected return</strong> is not guaranteed — markets move up and down. Use 10–12% only as a long-term equity illustration; debt funds might be closer to 6–8%. Fees (expense ratio), tax on redemption, and exit loads are not modeled here.
      </p>
      <p>
        <strong>Example:</strong> ₹5,000/month for 10 years at 12% annualized implies roughly ₹6 lakh invested and a materially higher corpus than keeping cash — the exact numbers update live as you drag the sliders. Starting early matters: the same monthly amount over 20 years typically dominates a late start because compounding has more cycles.
      </p>
      <p>
        Compare with a one-time investment using the <a href="/calculator/lumpsum/">lumpsum calculator</a> and read{' '}
        <a href="/blog/sip-vs-lumpsum/">SIP vs lumpsum</a> for scenarios. For compounding basics, see{' '}
        <a href="/blog/compound-interest-explained/">compound interest explained</a>.
      </p>
      <p>
        <strong>Tips:</strong> Increase SIP when income rises, review asset allocation yearly, and avoid stopping during downturns if your goal is far away. Use this tool to compare scenarios (higher SIP vs longer horizon) before you commit on paper — then invest through a SEBI-registered platform.
      </p>
    </div>
  </article>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently asked questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>What is SIP?</h4>
          <p>
            SIP (Systematic Investment Plan) means investing a fixed sum every month into mutual funds or similar instruments,
            using rupee-cost averaging and compounding over time.
          </p>
        </div>
        <div class="faq-item">
          <h4>Is SIP return fixed?</h4>
          <p>No. The percentage you enter is an assumption; actual mutual fund returns vary with markets.</p>
        </div>
        <div class="faq-item">
          <h4>Does this include tax on capital gains?</h4>
          <p>No — it shows a gross maturity-style estimate before personal tax rules such as equity or debt fund taxation in India.</p>
        </div>
        <div class="faq-item">
          <h4>Why “beginning of month”?</h4>
          <p>Many SIPs debit at the start of the period; the extra (1+r) factor in the formula reflects that timing.</p>
        </div>
        <div class="faq-item">
          <h4>Can I use this for daily or weekly SIP?</h4>
          <p>This page is monthly only; approximate or use a spreadsheet for other frequencies.</p>
        </div>
        <div class="faq-item">
          <h4>Is the SIP calculator free? Are my inputs uploaded?</h4>
          <p>Yes, it is free with no signup. Inputs are processed in your browser and are not sent to DoItSwift servers.</p>
        </div>
        <div class="faq-item">
          <h4>Are mutual fund fees or expense ratios included?</h4>
          <p>No. Expense ratio, exit loads, and taxes are not modeled — treat results as illustrations only.</p>
        </div>
        <div class="faq-item">
          <h4>Is this financial advice?</h4>
          <p>No. It is an educational calculator. Consult a SEBI-registered advisor for personal advice.</p>
        </div>
        <div class="faq-item">
          <h4>Does the currency dropdown convert exchange rates?</h4>
          <p>No — it only changes number formatting. The same numeric projection is shown with different currency symbols.</p>
        </div>
        <div class="faq-item">
          <h4>SIP vs lumpsum — where should I compare?</h4>
          <p>
            Use the <a href="/calculator/lumpsum/">lumpsum calculator</a> alongside this page, and read{' '}
            <a href="/blog/sip-vs-lumpsum/">SIP vs lumpsum</a> for deeper scenarios.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="sip-related" aria-label="Related calculators and guides">
    <div class="container">
      <h2 class="section-title">Related calculators</h2>
      <ul class="sip-related-grid">
        <li><a href="/calculator/lumpsum/">Lumpsum Calculator</a></li>
        <li><a href="/calculator/compound-interest/">Compound Interest Calculator</a></li>
        <li><a href="/calculator/emi/">EMI Calculator</a></li>
        <li><a href="/calculator/ppf/">PPF Calculator</a></li>
        <li><a href="/calculator/fd/">FD Calculator</a></li>
        <li><a href="/calculator/retirement/">Retirement Calculator</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="sip-related-grid sip-related-guides">
        <li><a href="/blog/sip-vs-lumpsum/">SIP vs lumpsum</a></li>
        <li><a href="/blog/compound-interest-explained/">Compound interest explained</a></li>
        <li><a href="/blog/how-much-to-retire-india/">How much to retire in India</a></li>
      </ul>
    </div>
  </section>

  <script is:inline define:vars={{ LOCALE_BY_CURRENCY }}>
    (function () {
      function localeForCurrency(code) {
        return LOCALE_BY_CURRENCY[code] || 'en-US';
      }
      function makeFmt() {
        var code = document.getElementById('sipCur').value || 'INR';
        return new Intl.NumberFormat(localeForCurrency(code), { style: 'currency', currency: code, maximumFractionDigits: 0 });
      }
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function sipFV(P, annualPct, years) {
        const r = annualPct / 100 / 12;
        const n = Math.round(years * 12);
        if (n <= 0) return 0;
        if (r === 0) return P * n;
        return P * ((Math.pow(1 + r, n) - 1) / r) * (1 + r);
      }
      function syncRange(inp, rng) {
        rng.value = inp.value;
      }
      function run() {
        const fmt = makeFmt();
        const P = Math.min(100000, Math.max(500, parseFloat(document.getElementById('sipMonthly').value) || 0));
        const rate = Math.min(30, Math.max(1, parseFloat(document.getElementById('sipRate').value) || 0));
        const yrs = Math.min(40, Math.max(1, parseFloat(document.getElementById('sipYears').value) || 0));
        document.getElementById('sipMonthly').value = P;
        document.getElementById('sipRate').value = rate;
        document.getElementById('sipYears').value = yrs;
        syncRange(document.getElementById('sipMonthly'), document.getElementById('sipMonthlyRange'));
        syncRange(document.getElementById('sipRate'), document.getElementById('sipRateRange'));
        syncRange(document.getElementById('sipYears'), document.getElementById('sipYearsRange'));
        const months = Math.round(yrs * 12);
        const invested = P * months;
        const maturity = sipFV(P, rate, yrs);
        const ret = Math.max(0, maturity - invested);
        document.getElementById('sipMaturity').textContent = fmt.format(Math.round(maturity));
        document.getElementById('sipInvested').textContent = fmt.format(Math.round(invested));
        document.getElementById('sipReturns').textContent = fmt.format(Math.round(ret));
        const maxBar = Math.max(invested, ret, 1);
        document.getElementById('sipBarInv').style.width = (invested / maxBar) * 100 + '%';
        document.getElementById('sipBarRet').style.width = (ret / maxBar) * 100 + '%';
        const tbody = document.getElementById('sipTable');
        tbody.innerHTML = '';
        for (let y = 1; y <= yrs; y++) {
          const invY = P * 12 * y;
          const valY = sipFV(P, rate, y);
          const tr = document.createElement('tr');
          tr.innerHTML = '<td>' + y + '</td><td>' + fmt.format(Math.round(invY)) + '</td><td>' + fmt.format(Math.round(valY)) + '</td>';
          tbody.appendChild(tr);
        }
      }
      const debRun = debounce(run, 80);
      document.getElementById('sipCur').addEventListener('change', debRun);
      ['sipMonthly', 'sipRate', 'sipYears'].forEach((id) => {
        document.getElementById(id).addEventListener('input', debRun);
      });
      [['sipMonthlyRange', 'sipMonthly'], ['sipRateRange', 'sipRate'], ['sipYearsRange', 'sipYears']].forEach(function (pair) {
        document.getElementById(pair[0]).addEventListener('input', function () {
          document.getElementById(pair[1]).value = this.value;
          debRun();
        });
      });
      run();
    })();
  </script>

  <style>
    .breadcrumb { font-size: 13px; color: var(--text-muted); padding: 16px 0 0; max-width: 960px; }
    .breadcrumb a { color: var(--blue); text-decoration: none; }
    .hero { padding: 36px 0 16px; text-align: center; }
    .subtitle { font-size: 18px; color: var(--text-muted); max-width: 640px; margin: 0 auto 24px; line-height: 1.55; }
    .subtitle strong { color: var(--text); font-weight: 700; }
    .calc-section { padding: 24px 0 40px; }
    .calc-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      align-items: start;
      max-width: 960px;
    }
    @media (max-width: 768px) {
      .calc-layout { grid-template-columns: 1fr; }
    }
    .calc-inputs, .calc-results {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 22px 24px;
      box-shadow: var(--shadow);
    }
    .calc-heading { font-size: 1rem; margin: 0 0 16px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; }
    .field { margin-bottom: 18px; }
    .field label { display: block; font-weight: 600; font-size: 14px; margin-bottom: 6px; }
    .field input[type='number'],
    .field select {
      width: 100%; padding: 10px 12px; border-radius: var(--radius-sm); border: 1px solid var(--border); font-size: 16px;
    }
    .field input[type='range'] { width: 100%; margin-bottom: 6px; }
    .field-hint { font-size: 12px; color: var(--text-muted); margin: 6px 0 0; }
    .result-hero { font-size: 2.25rem; font-weight: 800; color: var(--blue); letter-spacing: -0.02em; }
    .result-label { font-size: 14px; color: var(--text-muted); margin: 4px 0 20px; }
    .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
    .result-sub { font-size: 1.25rem; font-weight: 700; }
    .result-caption { font-size: 12px; color: var(--text-muted); }
    .bar-chart { margin: 16px 0; }
    .bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; font-size: 13px; }
    .bar-label { width: 64px; color: var(--text-muted); }
    .bar-track { flex: 1; height: 22px; background: var(--gray-100); border-radius: 6px; overflow: hidden; }
    [data-theme='dark'] .bar-track { background: var(--gray-200); }
    .bar-fill { height: 100%; border-radius: 6px; transition: width 0.2s ease; }
    .bar-fill--inv { background: var(--blue); opacity: 0.85; }
    .bar-fill--ret { background: var(--green); }
    .calc-details { margin-top: 12px; font-size: 14px; }
    .calc-details summary { cursor: pointer; font-weight: 600; padding: 8px 0; }
    .table-wrap { overflow-x: auto; max-height: 280px; overflow-y: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { padding: 8px 10px; border-bottom: 1px solid var(--border); text-align: right; }
    th:first-child, td:first-child { text-align: left; }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .sip-edu { padding: 36px 0 40px; }
    .sip-edu-inner { max-width: 760px; }
    .sip-edu p {
      font-size: 15px;
      line-height: 1.85;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .sip-edu a { color: var(--blue); font-weight: 600; text-decoration: none; }
    .sip-edu a:hover { text-decoration: underline; }
    .section-title { text-align: center; margin-bottom: 20px; font-size: 1.5rem; }
    .section-title-sub { margin-top: 32px; margin-bottom: 14px; font-size: 1.2rem; font-weight: 700; }
    .faq { padding: 32px 0 48px; }
    .faq .container { max-width: 760px; }
    .faq-list { display: flex; flex-direction: column; gap: 10px; }
    .faq-item { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; }
    .faq-item h4 { font-size: 15px; margin-bottom: 4px; }
    .faq-item p { font-size: 14px; color: var(--text-muted); margin: 0; }
    .faq-item a { color: var(--blue); font-weight: 600; text-decoration: none; }
    .faq-item a:hover { text-decoration: underline; }
    .sip-related { padding: 0 0 56px; }
    .sip-related .section-title { margin-bottom: 16px; }
    .sip-related-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 10px 16px;
      max-width: 760px;
      margin-left: auto;
      margin-right: auto;
    }
    .sip-related-grid a {
      display: block;
      padding: 10px 12px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--blue);
      font-weight: 600;
      font-size: 14px;
      text-decoration: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .sip-related-grid a:hover {
      border-color: var(--blue);
      box-shadow: var(--shadow);
    }
    .sip-related-guides { margin-top: 0; }
  </style>
</MainLayout>
