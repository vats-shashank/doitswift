  <script is:inline define:vars={{ LOCALE_BY_CURRENCY }}>
    (function () {
      function localeForCurrency(code) {
        return LOCALE_BY_CURRENCY[code] || 'en-US';
      }
      function makeFmt() {
        var code = document.getElementById('sipCur').value || 'INR';
        return new Intl.NumberFormat(localeForCurrency(code), { style: 'currency', currency: code, maximumFractionDigits: 0 });
      }
      function debounce(fn, ms) {
        let t;
        return function () {
          clearTimeout(t);
          t = setTimeout(fn, ms);
        };
      }
      function sipFV(P, annualPct, years) {
        const r = annualPct / 100 / 12;
        const n = Math.round(years * 12);
        if (n <= 0) return 0;
        if (r === 0) return P * n;
        return P * ((Math.pow(1 + r, n) - 1) / r) * (1 + r);
      }
      var sipDonutChart = null;
      var sipDonutLast = { invested: 0, wealth: 0 };
      function formatIndianFullDonut(num) {
        var n = Math.round(Math.abs(num));
        var s = n.toString();
        var last = s.substring(s.length - 3);
        var rest = s.length > 3 ? s.substring(0, s.length - 3) : '';
        if (rest) rest = rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',');
        return (num < 0 ? '-' : '') + '₹' + (rest ? rest + ',' : '') + last;
      }
      function formatIndianShortDonut(num) {
        var x = Math.abs(num);
        if (x >= 1e7) return '₹' + (num / 1e7).toFixed(x >= 1e8 ? 0 : 2).replace(/\.?0+$/, '') + ' Cr';
        if (x >= 1e5) return '₹' + (num / 1e5).toFixed(num >= 1e6 ? 1 : 2).replace(/\.?0+$/, '') + 'L';
        if (x >= 1e3) return '₹' + (num / 1e3).toFixed(0) + 'k';
        return '₹' + Math.round(num);
      }
      function isDonutDark() {
        return document.documentElement.getAttribute('data-theme') === 'dark';
      }
      function updateResultDonut(invested, wealth) {
        sipDonutLast.invested = invested;
        sipDonutLast.wealth = wealth;
        var canvas = document.getElementById('sipResultDonut');
        if (!canvas || typeof Chart === 'undefined') return;
        var data = [invested, Math.max(0, wealth)];
        var colors = isDonutDark() ? ['#60a5fa', '#34d399'] : ['#3b82f6', '#22c55e'];
        var ctx2d = canvas.getContext('2d');
        if (!sipDonutChart) {
          sipDonutChart = new Chart(ctx2d, {
            type: 'doughnut',
            data: {
              labels: ['Invested', 'Wealth gained'],
              datasets: [
                {
                  data: data,
                  backgroundColor: colors,
                  borderWidth: 0,
                  hoverOffset: 4,
                },
              ],
            },
            options: {
              responsive: false,
              maintainAspectRatio: false,
              cutout: '72%',
              plugins: {
                legend: { display: false },
                tooltip: {
                  callbacks: {
                    label: function (ctx) {
                      var val = ctx.dataset.data[ctx.dataIndex];
                      var total = ctx.dataset.data.reduce(function (a, b) {
                        return a + b;
                      }, 0);
                      var pct = total > 0 ? ((val / total) * 100).toFixed(1) : '0';
                      return ctx.label + ': ' + formatIndianFullDonut(val) + ' (' + pct + '%)';
                    },
                  },
                },
              },
              animation: { duration: 400 },
            },
          });
        } else {
          sipDonutChart.data.datasets[0].data = data;
          sipDonutChart.data.datasets[0].backgroundColor = colors;
          sipDonutChart.update();
        }
      }
      function syncRange(inp, rng) {
        if (rng && inp) rng.value = inp.value;
      }
      function run() {
        const fmt = makeFmt();
        const P = Math.min(100000, Math.max(500, parseFloat(document.getElementById('sipMonthly').value) || 0));
        const rate = Math.min(30, Math.max(1, parseFloat(document.getElementById('sipRate').value) || 0));
        const yrs = Math.min(40, Math.max(1, parseFloat(document.getElementById('sipYears').value) || 0));
        const stepUp = Math.min(25, Math.max(0, parseFloat(document.getElementById('sipStepUp').value) || 0));
        document.getElementById('sipMonthly').value = P;
        document.getElementById('sipRate').value = rate;
        document.getElementById('sipYears').value = yrs;
        document.getElementById('sipStepUp').value = stepUp;
        syncRange(document.getElementById('sipMonthly'), document.getElementById('sipMonthlyRange'));
        syncRange(document.getElementById('sipRate'), document.getElementById('sipRateRange'));
        syncRange(document.getElementById('sipYears'), document.getElementById('sipYearsRange'));
        syncRange(document.getElementById('sipStepUp'), document.getElementById('sipStepUpRange'));
        const inflEl = document.getElementById('sipInflation');
        if (inflEl) {
          const inf = Math.min(10, Math.max(3, parseFloat(inflEl.value) || 6));
          inflEl.value = inf;
          syncRange(inflEl, document.getElementById('sipInflationRange'));
        }
        const months = Math.round(yrs * 12);
        const invested = P * months;
        const maturity = sipFV(P, rate, yrs);
        const ret = Math.max(0, maturity - invested);
        document.getElementById('sipMaturity').textContent = fmt.format(Math.round(maturity));
        document.getElementById('sipInvested').textContent = fmt.format(Math.round(invested));
        document.getElementById('sipReturns').textContent = fmt.format(Math.round(ret));
        var multiplier = invested > 0 ? maturity / invested : 0;
        var multEl = document.getElementById('sipResultMultiplier');
        if (multEl) {
          multEl.textContent = invested > 0 ? multiplier.toFixed(1) + '×' : '—';
        }
        var invEl = document.getElementById('sipDonutInvested');
        var wealthEl = document.getElementById('sipDonutWealth');
        if (invEl) invEl.textContent = formatIndianShortDonut(Math.round(invested));
        if (wealthEl) wealthEl.textContent = formatIndianShortDonut(Math.round(ret));
        updateResultDonut(Math.round(invested), Math.round(ret));
        const tbody = document.getElementById('sipTable');
        tbody.innerHTML = '';
        for (let y = 1; y <= yrs; y++) {
          const invY = P * 12 * y;
          const valY = sipFV(P, rate, y);
          const tr = document.createElement('tr');
          tr.innerHTML = '<td>' + y + '</td><td>' + fmt.format(Math.round(invY)) + '</td><td>' + fmt.format(Math.round(valY)) + '</td>';
          tbody.appendChild(tr);
        }
        window.__sipState = { P: P, rate: rate, yrs: yrs, invested: invested, maturity: maturity, months: months, fmt: fmt, stepUp: stepUp };
        if (typeof window.__sipChartDebounced === 'function') window.__sipChartDebounced();
      }
      const debRun = debounce(run, 80);
      document.getElementById('sipCur').addEventListener('change', debRun);
      ['sipMonthly', 'sipRate', 'sipYears', 'sipStepUp'].forEach(function (id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', debRun);
      });
      [['sipMonthlyRange', 'sipMonthly'], ['sipRateRange', 'sipRate'], ['sipYearsRange', 'sipYears'], ['sipStepUpRange', 'sipStepUp']].forEach(function (pair) {
        var rng = document.getElementById(pair[0]);
        var inp = document.getElementById(pair[1]);
        if (rng && inp) {
          rng.addEventListener('input', function () {
            inp.value = this.value;
            debRun();
          });
        }
      });
      if (typeof MutationObserver !== 'undefined') {
        new MutationObserver(function () {
          updateResultDonut(sipDonutLast.invested, sipDonutLast.wealth);
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
      }
      var sipDonutCta = document.getElementById('sipResultDonutCta');
      if (sipDonutCta) {
        sipDonutCta.addEventListener('click', function (e) {
          var heading = document.getElementById('sip-viz-heading');
          if (heading && 'scrollBehavior' in document.documentElement.style) {
            e.preventDefault();
            heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      }
      run();
    })();
  </script>

