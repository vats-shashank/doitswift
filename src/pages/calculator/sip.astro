          <div class="sip-chart-canvas-wrap" id="sipChartCanvasWrap">
            <canvas id="sipVizCanvas" width="400" height="320" aria-label="Your portfolio growth: invested versus total value by year"></canvas>
          </div>
          <p class="sip-chart-callout" id="sipChartCallout" aria-live="polite"></p>
        </div>
        <div class="sip-chart-panel" role="tabpanel" id="sipPanel1" aria-labelledby="sipTab1" data-panel="1" hidden>
          <div class="sip-chart-canvas-wrap">
            <canvas id="sipVizCanvas1" width="400" height="320" aria-label="Yearly contribution versus returns generated each year"></canvas>
          </div>
          <p class="sip-chart-callout" id="sipChartCallout1" aria-live="polite"></p>
        </div>
        <div class="sip-chart-panel" role="tabpanel" id="sipPanel2" aria-labelledby="sipTab2" data-panel="2" hidden>
          <div class="sip-chart-canvas-wrap">
            <canvas id="sipVizCanvas2" width="400" height="320" aria-label="Fixed SIP versus annual step-up SIP portfolio value"></canvas>
          </div>
          <p class="sip-chart-callout" id="sipChartCallout2" aria-live="polite"></p>
        </div>
