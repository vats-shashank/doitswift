---
// Homepage — DoItSwift
import MainLayout from '../layouts/MainLayout.astro';

const categories = [
  {
    emoji: '🖼️',
    title: 'Image Tools',
    href: '/image/',
    live: true,
    desc: 'Convert HEIC, WEBP, AVIF. Compress, resize, generate favicons.',
  },
  {
    emoji: '📄',
    title: 'PDF Tools',
    href: '/pdf/',
    live: true,
    desc: 'Merge, split, compress, convert PDFs in your browser. 6 tools and counting.',
  },
  {
    emoji: '🧮',
    title: 'Calculators',
    href: '/calculator/',
    live: true,
    desc: '40 free calculators — finance, health, math, time, everyday. Instant results.',
  },
  {
    emoji: '📝',
    title: 'Text Tools',
    href: '#',
    live: false,
    desc: 'Word count, case convert, JSON format, Lorem ipsum.',
  },
  {
    emoji: '🎨',
    title: 'Generators',
    href: '#',
    live: false,
    desc: 'QR codes, barcodes, passwords, UUIDs, invoices.',
  },
  {
    emoji: '🔊',
    title: 'Audio Tools',
    href: '#',
    live: false,
    desc: 'Convert audio, trim, extract from video.',
  },
  {
    emoji: '🎬',
    title: 'Video Tools',
    href: '#',
    live: false,
    desc: 'Compress, convert, extract GIFs from video.',
  },
  {
    emoji: '✨',
    title: 'AI Tools',
    href: '#',
    live: false,
    desc: 'Background remove, upscale, text rewrite.',
  },
];

const tools = [
  { href: '/calculator/sip', icon: '📈', title: 'SIP Calculator', desc: 'Mutual fund SIP maturity & returns', live: true },
  { href: '/calculator/emi', icon: '🏦', title: 'EMI Calculator', desc: 'Loan EMI, interest & amortization', live: true },
  { href: '/calculator/bmi', icon: '⚖️', title: 'BMI Calculator', desc: 'Body mass index & categories', live: true },
  { href: '/image/heic-to-jpg', icon: '📱', title: 'HEIC to JPG', desc: 'Convert iPhone photos to JPG', live: true },
  { href: '/image/webp-to-jpg', icon: '🖼️', title: 'WEBP to JPG', desc: 'Convert WebP images instantly', live: true },
  { href: '/image/image-compressor', icon: '🗜️', title: 'Image Compressor', desc: 'Shrink files up to 80%', live: true },
  { href: '/image/image-resizer', icon: '📐', title: 'Image Resizer', desc: 'Resize for web or print', live: true },
  { href: '/image/svg-to-png', icon: '🎨', title: 'SVG to PNG', desc: 'Convert vectors to raster', live: true },
  { href: '/image/favicon-generator', icon: '⭐', title: 'Favicon Generator', desc: 'Create ICO files for sites', live: true },
  { href: '/image/avif-to-jpg', icon: '✨', title: 'AVIF to JPG', desc: 'Convert next-gen formats', live: true },
  { href: '/image/image-to-base64', icon: '🔢', title: 'Image to Base64', desc: 'Encode images for code', live: true },
];
---

<MainLayout
  title="DoItSwift — Free Online Tools | Browser-Based, Private, Unlimited"
  description="Free online utility tools. Convert files, compress images, generate codes, calculate anything. 100% browser-based, no upload, no signup."
  keywords="doitswift, free online tools, browser utilities, image converter, privacy tools, file converter"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="badge">🔒 Private by design — your files stay on your device</div>
      <h1>Free online tools. Zero friction.</h1>
      <p class="subtitle">
        Convert files, compress images, generate codes, and more — all in your browser. No uploads, no signup, no
        tracking.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> 100% browser-based</span>
        <span><span class="check">✓</span> Unlimited use</span>
        <span><span class="check">✓</span> No watermarks</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <!-- SMART UPLOAD -->
  <section class="smart-upload">
    <div class="container">
        <div class="dropzone" id="smartDrop">
        <div class="dropzone-icon">✨</div>
        <div class="dropzone-text">Drop an image or PDF here</div>
        <div class="dropzone-sub">
          We'll auto-detect the format and route you to the right tool
        </div>
        <input type="file" id="smartInput" accept="image/*,.heic,.heif,.pdf,application/pdf" />
      </div>
      <p class="smart-hint">
        Supported: HEIC, HEIF, WEBP, AVIF, PNG, JPG, SVG, BMP, GIF, PDF · Calculators (SIP, EMI, BMI, and more) live under
        <a href="/calculator/">Browse by Category → Calculators</a> — no file upload needed.
      </p>
    </div>
  </section>

  <!-- BROWSE BY CATEGORY -->
  <section class="category-section" id="categories">
    <div class="container">
      <h2 class="section-title">Browse by Category</h2>
      <p class="section-sub">Image, PDF, and calculator tools are live — more categories are on the way.</p>
      <div class="category-grid">
        {categories.map((cat) =>
          cat.live ? (
            <a href={cat.href} class="category-card is-live">
              <span class="category-icon">{cat.emoji}</span>
              <div class="category-body">
                <h3>
                  {cat.title}
                  <span class="status live">LIVE</span>
                </h3>
                <p>{cat.desc}</p>
              </div>
            </a>
          ) : (
            <div class="category-card soon">
              <span class="category-icon">{cat.emoji}</span>
              <div class="category-body">
                <h3>
                  {cat.title}
                  <span class="status soon-label">COMING SOON</span>
                </h3>
                <p>{cat.desc}</p>
              </div>
            </div>
          )
        )}
      </div>
    </div>
  </section>

  <!-- TOOLS GRID -->
  <section class="tools-section" id="tools">
    <div class="container">
      <h2 class="section-title">Popular Right Now</h2>
      <p class="section-sub">Every tool runs in your browser. Your files stay yours.</p>
      <div class="grid">
        {tools.map((tool) => (
          <a href={tool.live ? tool.href : '#'} class={`tool-card ${!tool.live ? 'soon' : ''}`}>
            <span class="icon">{tool.icon}</span>
            <h3>{tool.title}{!tool.live && <span class="coming">SOON</span>}</h3>
            <p>{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="why">
    <div class="container">
      <h2 class="section-title">Why DoItSwift?</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">🔒</div>
          <h3>Files Never Leave Your Device</h3>
          <p>
            When you convert a HEIC photo or compress a PDF, it happens entirely in your browser using JavaScript. Nothing
            uploads. We couldn&apos;t see your files even if we wanted to.
          </p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">📊</div>
          <h3>54 Tools, One Place</h3>
          <p>
            Most privacy tool sites specialize in just images or just PDFs. DoItSwift covers everything: 8 image
            converters, 6 PDF utilities, and 40+ calculators — finance, health, math, and everyday.
          </p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">🇮🇳</div>
          <h3>Serious Indian Finance Tools</h3>
          <p>
            SIP, PPF, NPS, HRA, Income Tax, GST, Home Loan with prepayment — built with real Indian financial planning in
            mind, not generic US-focused math.
          </p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">📚</div>
          <h3>Actually Useful Content</h3>
          <p>
            Every calculator includes the formula explained. Every tool has practical guidance. Our blog covers topics
            like &ldquo;how much do you need to retire in India.&rdquo; Not just tools — understanding.
          </p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">⚡</div>
          <h3>No Strings Attached</h3>
          <p>
            No signup. No file size limits. No watermarks. No daily quotas. No premium tier gating features. Open a tool,
            use it, close the tab.
          </p>
        </div>
        <div class="why-card">
          <div class="why-icon" aria-hidden="true">🎯</div>
          <h3>Built in 2026, Not 2015</h3>
          <p>
            Modern browser APIs let us do things that used to require servers. Fast, private, and designed for how you
            actually use files today.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq" id="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>How can this be free?</h4>
          <p>
            Browser-based tools avoid heavy server processing for your files. We sustain the site through optional
            partnerships and future Pro features — core utilities stay accessible.
          </p>
        </div>
        <div class="faq-item">
          <h4>Are my files safe?</h4>
          <p>
            For local tools, your data stays on your device. You can load the page, go offline, and still finish the job.
          </p>
        </div>
        <div class="faq-item">
          <h4>Do you support batch processing?</h4>
          <p>
            Yes for our image tools — drop multiple files where the tool allows it. No artificial caps on how many files
            you can process in one session.
          </p>
        </div>
        <div class="faq-item">
          <h4>Does it work on mobile?</h4>
          <p>Yes — use a modern mobile browser. Performance depends on your device and file sizes.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const smartDrop = document.getElementById('smartDrop');
    const smartInput = document.getElementById('smartInput');

    async function routeFile(file) {
      if (!file) return;
      const name = file.name.toLowerCase();
      const type = file.type.toLowerCase();
      let dest = null;

      if (name.endsWith('.pdf') || type === 'application/pdf') {
        dest = '/pdf/compress-pdf';
      } else if (name.endsWith('.heic') || name.endsWith('.heif') || type.includes('heic') || type.includes('heif')) {
        dest = '/image/heic-to-jpg';
      } else if (name.endsWith('.webp') || type.includes('webp')) {
        dest = '/image/webp-to-jpg';
      } else if (name.endsWith('.avif') || type.includes('avif')) {
        dest = '/image/avif-to-jpg';
      } else if (name.endsWith('.svg') || type.includes('svg')) {
        dest = '/image/svg-to-png';
      } else if (type.startsWith('image/')) {
        dest = '/image/image-compressor';
      }

      if (dest) {
        try {
          if (window.DoItSwiftPending) {
            await window.DoItSwiftPending.store(file);
          }
        } catch (e) {
          console.warn(e);
        }
        window.location.href = dest;
      } else {
        alert('Sorry, that file type is not supported yet.');
      }
    }

    smartDrop.addEventListener('click', () => smartInput.click());
    smartDrop.addEventListener('dragover', (e) => {
      e.preventDefault();
      smartDrop.classList.add('drag');
    });
    smartDrop.addEventListener('dragleave', () => smartDrop.classList.remove('drag'));
    smartDrop.addEventListener('drop', (e) => {
      e.preventDefault();
      smartDrop.classList.remove('drag');
      void routeFile(e.dataTransfer.files[0]);
    });
    smartInput.addEventListener('change', (e) => {
      const f = e.target.files[0];
      e.target.value = '';
      void routeFile(f);
    });

  </script>

  <style>
    .hero {
      padding: 70px 0 30px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 auto 28px;
    }
    .smart-upload {
      padding: 30px 0 50px;
    }
    .smart-upload .container {
      max-width: 820px;
    }
    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 60px 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }
    .dropzone:hover,
    .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
      transform: scale(1.01);
    }
    [data-theme='dark'] .dropzone.drag {
      background: rgba(0, 102, 255, 0.1);
    }
    .dropzone-icon {
      font-size: 56px;
      margin-bottom: 14px;
    }
    .dropzone-text {
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .dropzone-sub {
      font-size: 14px;
      color: var(--text-muted);
    }
    #smartInput {
      display: none;
    }
    .smart-hint {
      text-align: center;
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 16px;
    }

    .section-title {
      text-align: center;
      margin-bottom: 8px;
    }
    .section-sub {
      text-align: center;
      color: var(--text-muted);
      margin-bottom: 32px;
      font-size: 16px;
    }

    .category-section {
      padding: 20px 0 40px;
    }
    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 18px;
    }
    .category-card {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      background: var(--card);
      padding: 24px 22px;
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      transition:
        transform 0.2s,
        box-shadow 0.2s,
        border-color 0.2s;
    }
    .category-card.is-live {
      cursor: pointer;
    }
    .category-card.is-live:hover {
      border-color: var(--blue);
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }
    .category-card.soon {
      opacity: 0.6;
      cursor: not-allowed;
      pointer-events: auto;
    }
    .category-icon {
      font-size: 42px;
      line-height: 1;
      flex-shrink: 0;
    }
    .category-body h3 {
      font-size: 17px;
      margin-bottom: 6px;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }
    .category-body p {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.5;
      margin: 0;
    }
    .status {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.04em;
      padding: 3px 8px;
      border-radius: 6px;
    }
    .status.live {
      background: rgba(16, 185, 129, 0.15);
      color: var(--green);
    }
    .status.soon-label {
      background: var(--gray-100);
      color: var(--text-muted);
    }
    [data-theme='dark'] .status.soon-label {
      background: var(--gray-200);
    }

    .tools-section {
      padding: 40px 0 60px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 14px;
    }
    .tool-card {
      background: var(--card);
      padding: 22px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }
    .tool-card:not(.soon):hover {
      border-color: var(--blue);
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
    }
    .tool-card.soon {
      opacity: 0.55;
      cursor: not-allowed;
    }
    .tool-card .icon {
      font-size: 30px;
      display: block;
      margin-bottom: 10px;
    }
    .tool-card h3 {
      font-size: 15px;
      margin-bottom: 4px;
    }
    .tool-card p {
      font-size: 12px;
      color: var(--text-muted);
    }
    .coming {
      font-size: 9px;
      background: var(--gray-100);
      color: var(--text-muted);
      padding: 2px 6px;
      border-radius: 4px;
      margin-left: 6px;
      vertical-align: middle;
    }

    .why {
      padding: 60px 0;
      background: var(--bg);
    }
    .why-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 32px;
    }
    @media (min-width: 640px) {
      .why-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (min-width: 1024px) {
      .why-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .why-card {
      padding: 24px;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--card);
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease,
        border-color 0.2s ease;
      box-shadow: var(--shadow-sm);
    }
    .why-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
      border-color: rgba(0, 102, 255, 0.2);
    }
    [data-theme='dark'] .why-card:hover {
      border-color: rgba(96, 165, 250, 0.35);
    }
    .why-icon {
      font-size: 40px;
      line-height: 1;
      margin-bottom: 14px;
    }
    .why-card h3 {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--text);
    }
    .why-card p {
      font-size: 14px;
      line-height: 1.55;
      color: var(--text-muted);
      margin: 0;
    }

    .faq {
      padding: 60px 0;
    }
    .faq .container {
      max-width: 820px;
    }
    .faq-list {
      margin-top: 32px;
    }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 12px;
      box-shadow: var(--shadow);
    }
    .faq-item h4 {
      font-size: 16px;
      margin-bottom: 6px;
    }
    .faq-item p {
      font-size: 14px;
      color: var(--text-muted);
    }
  </style>
</MainLayout>
