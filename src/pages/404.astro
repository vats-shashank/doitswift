---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Page not found — DoItSwift"
  description="The page you requested does not exist or has moved. Return to DoItSwift home or browse our tools."
  keywords="404, page not found, doitswift"
  noindex
>
  <section class="not-found">
    <div class="container">
      <p class="not-found-code">404</p>
      <h1>Page not found</h1>
      <p class="not-found-lead">
        That link may be outdated, or the page was removed. Try the home page or pick a destination below.
      </p>
      <div class="not-found-actions">
        <a href="/" class="btn btn-lg">← Back to home</a>
        <a href="/image/" class="btn btn-secondary btn-lg">Image tools</a>
        <a href="/pdf/" class="btn btn-secondary btn-lg">PDF tools</a>
        <a href="/calculator/" class="btn btn-secondary btn-lg">Calculators</a>
        <a href="/blog/" class="btn btn-secondary btn-lg">Blog</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .not-found {
    padding: 72px 0 100px;
    text-align: center;
  }
  .not-found .container {
    max-width: 520px;
  }
  .not-found-code {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--blue);
    margin-bottom: 12px;
  }
  .not-found h1 {
    font-size: 34px;
    margin-bottom: 14px;
    letter-spacing: -0.03em;
  }
  .not-found-lead {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    max-width: 560px;
    margin: 0 auto;
  }
</style>
