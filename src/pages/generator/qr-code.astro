---
import MainLayout from '../../layouts/MainLayout.astro';
import { calculatorCanonical } from '../../lib/calculatorJsonLd';

const canonical = calculatorCanonical(Astro.site, Astro.url.pathname);

const pageTitle =
  'Free QR Code Generator — URL, WiFi, vCard, UPI & More (Private & Unlimited) | DoItSwift';
const pageDescription =
  'Free QR code generator with logo, gradients, and custom shapes. Bulk-generate from CSV. 12 types: URL, WiFi, vCard, UPI, WhatsApp, email, SMS, and more. 100% browser-based — nothing uploaded. No signup, no watermarks, unlimited.';
const pageKeywords =
  'qr code generator, qr generator, free qr code generator, qr code maker, qr code generator with logo, qr code generator free, custom qr code, qr code generator no signup, wifi qr code generator, vcard qr code, upi qr code generator, whatsapp qr code, qr code generator online, bulk qr code generator, qr code generator csv, qr code generator india, qr code png svg, static qr code, qr code maker free, privacy qr code generator, qr code generator offline, qr code generator no watermark, qr code generator unlimited';

const faqsForSchema: { question: string; answerPlain: string }[] = [
  {
    question: 'Are my QR codes really generated in my browser?',
    answerPlain:
      'Yes. The qr-code-styling JavaScript library runs in your browser and produces the QR image locally. No content is sent to DoItSwift for generation. You can verify this by opening DevTools → Network, generating a code, and observing that no request carries your input. You can also disconnect from the internet after the page loads and the tool still works — which is impossible for server-based generators.',
  },
  {
    question: 'Will the QR codes I download expire?',
    answerPlain:
      'No. These are static QR codes — the data you enter is encoded directly into the black-and-white pattern. There is no redirect through our servers, no short-link layer, and no expiration date. If you encode https://example.com, the QR will always resolve to exactly that URL, forever, regardless of whether DoItSwift exists in 10 years.',
  },
  {
    question: "Why can't I make a dynamic QR code here?",
    answerPlain:
      "Dynamic QR codes work by encoding a short redirect URL through a service's server. To edit the destination later, the service has to keep its redirect server running, and your printed codes depend on that service staying online and honoring the link forever. We don't run a backend, so we can't offer dynamic codes. If you need editable URLs or scan analytics, you'll need a paid tool that runs its own servers — that's a different product category. We do static codes only, on purpose, because static codes don't depend on us (or anyone else) staying online.",
  },
  {
    question: 'Are there usage limits, watermarks, or signup requirements?',
    answerPlain:
      'None. Generate as many QR codes as your browser can handle in a session. There are no download caps, no "powered by" watermarks, no trial periods, and no account to create. The tool is free to use commercially — the underlying qr-code-styling library is MIT licensed.',
  },
  {
    question: 'How does bulk generation work?',
    answerPlain:
      'Upload a CSV with one row per QR code. We parse the CSV in your browser using Papa Parse, render each QR with qr-code-styling, and zip the results with JSZip. The ZIP downloads directly from your browser. No row of your CSV is uploaded anywhere. Very large batches (>500 codes) may take a minute and use significant memory — keep the tab open until it finishes.',
  },
  {
    question: 'What CSV format does bulk mode expect?',
    answerPlain:
      'Three columns: type, content, filename. Type is one of the 12 supported types (url, text, email, phone, sms, wifi, vcard, whatsapp, upi, geo, event, app). Content is the value to encode — for simple types it\'s the text or URL; for complex types like vCard or WiFi, supply the fully-formed payload string. Filename is optional. Download the template above to see working examples.',
  },
  {
    question: 'What size and resolution should I export for printing?',
    answerPlain:
      'For print, choose SVG (vector, scales to any size without quality loss) or PNG 1024/2048 for raster workflows. Minimum print size is about 2 × 2 cm for URL codes and 3 × 3 cm for data-heavy codes like vCards. Print at 300 DPI or higher. Always scan a test print at the intended size before mass-producing.',
  },
  {
    question: 'Why does my QR code have different pattern density as I type?',
    answerPlain:
      'QR codes have 40 "versions" (sizes) and more data requires a higher version with more modules. As you add characters, the code automatically moves to a larger version to fit the data, which looks denser. Lower your error correction level or shorten the content to keep density lower. The version number is shown under the preview.',
  },
  {
    question: 'Can I add a logo? Will it still scan?',
    answerPlain:
      'Yes, upload a PNG, JPG, or SVG up to 2 MB. The tool masks the center of the QR so the logo sits cleanly. Scannability is preserved by the QR standard\'s error correction — up to 30% of the code can be obscured at error correction level H and still decode. Keep the logo below 30% of the QR\'s width and use level Q or H if you add a logo.',
  },
  {
    question: 'Are WiFi, vCard, and UPI QR codes safe to share privately?',
    answerPlain:
      "A WiFi or vCard QR code contains the credentials or contact details directly — anyone who scans it gets what's inside. That's how the format works. The privacy guarantee here is that DoItSwift never sees those credentials because generation is local; but once you print or publish the QR, anyone who scans it has the content. Treat printed WiFi or vCard QR codes the same as a printed password or business card.",
  },
  {
    question: 'Do UPI QR codes from this tool work with GPay, PhonePe, and Paytm?',
    answerPlain:
      'Yes, if the UPI ID you entered is valid. The tool generates the standard NPCI UPI URL format (upi://pay?pa=...&pn=...&am=...&cu=INR) which all major Indian UPI apps support. Test-scan before printing for merchant use. UPI QR codes only work inside India via UPI-registered apps.',
  },
  {
    question: 'Which error correction level should I choose?',
    answerPlain:
      'L (7%) makes the smallest code and is fine if the code will be displayed clean on a screen. M (15%) is a sensible default for most print. Q (25%) and H (30%) produce denser codes but tolerate damage, dirt, or a logo overlay. Choose H if you\'re embedding a logo or printing in outdoor/high-wear conditions.',
  },
  {
    question: 'Can I use this tool offline?',
    answerPlain:
      'Yes. After the page loads once, your browser caches the scripts. Disconnect from the internet and the tool keeps working — generation, preview, export, and bulk ZIP all happen locally. A first visit on a new device requires a connection to load the page.',
  },
  {
    question: 'Is this tool free for commercial use?',
    answerPlain:
      'Yes. Codes generated here are free to use for any purpose, including commercial projects. There is no attribution requirement. The underlying qr-code-styling library is MIT licensed.',
  },
];

const pageJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'DoItSwift QR Code Generator',
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web Browser',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description:
        'Free browser-based QR code generator with logo, gradients, and custom dot/eye shapes. Generates 12 content types including URL, WiFi, vCard, UPI, and WhatsApp. Batch-generate from CSV. 100% client-side — no uploads, no signup, no watermarks.',
      url: canonical,
      featureList: [
        '12 content types: URL, Text, Email, Phone, SMS, WiFi, vCard, WhatsApp, UPI payment, Geo location, Calendar event, App Store link',
        'Logo embedding with transparency',
        'Custom dot shapes (rounded, dots, classy, square)',
        'Custom eye frame and eye ball shapes',
        'Linear and radial color gradients',
        'Error correction levels L / M / Q / H',
        'Export as PNG (512/1024/2048 px), SVG, or JPEG',
        'Bulk generation from CSV with ZIP download',
        'Works offline after first page load',
        '100% browser-based processing — no uploads',
        'No signup, no watermarks, no usage limits',
      ],
      browserRequirements: 'Requires JavaScript. Supports Chrome, Firefox, Safari, Edge.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqsForSchema.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answerPlain },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: Astro.site ? new URL('/', Astro.site).href : 'https://doitswift.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Generators',
          item: Astro.site ? new URL('/generator/', Astro.site).href : 'https://doitswift.com/generator/',
        },
        { '@type': 'ListItem', position: 3, name: 'QR Code Generator', item: canonical },
      ],
    },
  ],
};
---

<MainLayout title={pageTitle} description={pageDescription} keywords={pageKeywords} canonical={canonical}>
  <script
    slot="head"
    src="https://cdn.jsdelivr.net/npm/qr-code-styling@1.9.2/lib/qr-code-styling.js"
    is:inline
  />
  <script type="application/ld+json" set:html={JSON.stringify(pageJsonLd)} />

  <nav class="breadcrumb container container--tool" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/generator/">Generators</a> › <span>QR Code Generator</span>
  </nav>

  <section class="hero tool-hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Nothing Leaves Your Browser</div>
      <h1>QR Code Generator — Create, Customize & Batch Generate QR Codes Privately</h1>
      <p class="subtitle">
        Generate static QR codes for URLs, WiFi networks, vCards, UPI payments, WhatsApp chats, and 8 more types — with
        custom colors, gradients, shapes, and your logo. Bulk-generate hundreds of codes from a CSV spreadsheet and
        download them as a ZIP. Every QR is rendered in your browser using the open-source qr-code-styling library. Your
        content, Wi-Fi passwords, and contact details never leave your device. No signup, no watermarks, no usage caps, no
        expiring codes.
      </p>
      <p class="subtitle-secondary">
        Most "free" QR generators either upload your data to their servers, bury usable features behind a 14-day trial
        that silently expires your printed codes, or cap your downloads. This tool does none of that. Static QR codes
        generated here work forever because they encode your data directly — no redirect through our domain, no dependency
        on our servers staying online.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> 100% browser-based</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> Unlimited & free</span>
        <span><span class="check">✓</span> No signup, no watermarks</span>
      </div>
      <p class="qr-hero-note">
        Uses qr-code-styling (MIT licensed) for rendering. Error correction per ISO/IEC 18004. Last updated: April 2026.
      </p>
    </div>
  </section>

  <section class="qr-tool tool-section" id="main-content" aria-label="QR Code Generator Tool">
    <div class="container container--tool">
      <h2 class="sr-only">QR Code Generator</h2>

      <div class="qr-mode-tabs" role="tablist" aria-label="Generation mode">
        <button
          type="button"
          class="qr-mode-tab qr-mode-tab--active"
          role="tab"
          id="qrModeSingle"
          data-mode="single"
          aria-selected="true"
          aria-controls="qrPanelSingle"
        >
          Single QR code
        </button>
        <button
          type="button"
          class="qr-mode-tab"
          role="tab"
          id="qrModeBulk"
          data-mode="bulk"
          aria-selected="false"
          aria-controls="qrPanelBulk"
          tabindex="-1"
        >
          Bulk from CSV
        </button>
      </div>

      <div
        class="qr-panel"
        id="qrPanelSingle"
        role="tabpanel"
        aria-labelledby="qrModeSingle"
        data-qr-mode-panel="single"
      >
        <div class="qr-type-tabs" role="tablist" aria-label="Content type">
          {
            [
              { id: 'url', label: 'URL' },
              { id: 'text', label: 'Text' },
              { id: 'email', label: 'Email' },
              { id: 'phone', label: 'Phone' },
              { id: 'sms', label: 'SMS' },
              { id: 'wifi', label: 'WiFi' },
              { id: 'vcard', label: 'vCard' },
              { id: 'whatsapp', label: 'WhatsApp' },
              { id: 'upi', label: 'UPI' },
              { id: 'geo', label: 'Location' },
              { id: 'event', label: 'Event' },
              { id: 'app', label: 'App' },
            ].map((t) => (
              <button
                type="button"
                class:list={['qr-type-tab', { 'qr-type-tab--active': t.id === 'url' }]}
                role="tab"
                aria-selected={t.id === 'url'}
                data-qr-type={t.id}
                id={`qrTypeTab-${t.id}`}
                tabindex={t.id === 'url' ? 0 : -1}
              >
                {t.label}
              </button>
            ))
          }
        </div>

        <div class="qr-layout">
          <div class="qr-input-col">
            <div id="qrInputArea">
              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-url">
                <legend class="sr-only">URL</legend>
                <label for="qrUrl">Website URL</label>
                <input
                  type="url"
                  id="qrUrl"
                  name="url"
                  inputmode="url"
                  autocomplete="url"
                  placeholder="https://example.com or example.com"
                />
                <p class="qr-hint">Enter a full link or a domain; we add https:// when no protocol is present.</p>
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-text" hidden>
                <legend class="sr-only">Plain text</legend>
                <label for="qrText">Text</label>
                <textarea id="qrText" name="text" rows="5" maxlength="2000" placeholder="Any text (up to 2000 characters)"></textarea>
                <p class="qr-hint">Over ~500 characters the QR may become dense and harder to scan.</p>
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-email" hidden>
                <legend class="sr-only">Email</legend>
                <label for="qrEmailTo">To (email) <span class="req">*</span></label>
                <input type="email" id="qrEmailTo" name="to" autocomplete="email" required placeholder="name@example.com" />
                <label for="qrEmailSubject">Subject (optional)</label>
                <input type="text" id="qrEmailSubject" name="subject" />
                <label for="qrEmailBody">Message (optional)</label>
                <textarea id="qrEmailBody" name="body" rows="3"></textarea>
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-phone" hidden>
                <legend class="sr-only">Phone</legend>
                <label for="qrPhoneTel">Phone number <span class="req">*</span></label>
                <input type="tel" id="qrPhoneTel" name="phone" inputmode="tel" placeholder="+911234567890" />
                <p class="qr-hint">Include country code, e.g. +911234567890</p>
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-sms" hidden>
                <legend class="sr-only">SMS</legend>
                <label for="qrSmsPhone">Phone number <span class="req">*</span></label>
                <input type="tel" id="qrSmsPhone" name="phone" inputmode="tel" />
                <label for="qrSmsMessage">Message (optional)</label>
                <textarea id="qrSmsMessage" name="message" rows="3"></textarea>
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-wifi" hidden>
                <legend class="sr-only">WiFi</legend>
                <label for="qrWifiSsid">Network name (SSID) <span class="req">*</span></label>
                <input type="text" id="qrWifiSsid" name="ssid" autocomplete="off" />
                <label for="qrWifiEnc">Security</label>
                <select id="qrWifiEnc" name="encryption">
                  <option value="WPA" selected>WPA / WPA2 / WPA3</option>
                  <option value="WEP">WEP</option>
                  <option value="None">None (open network)</option>
                </select>
                <div class="qr-wifi-row">
                  <div class="qr-wifi-pw-wrap">
                    <label for="qrWifiPassword">Password</label>
                    <input type="password" id="qrWifiPassword" name="password" autocomplete="off" aria-describedby="qrWifiEncHint" />
                  </div>
                  <button type="button" class="qr-btn" id="qrWifiShowPwd" aria-pressed="false">Show</button>
                </div>
                <p id="qrWifiEncHint" class="qr-hint">Leave password empty for an open network, or if Security is None.</p>
                <label class="qr-chk">
                  <input type="checkbox" id="qrWifiHidden" name="hidden" />
                  Network is hidden (does not broadcast SSID)
                </label>
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-vcard" hidden>
                <legend class="sr-only">vCard 3.0</legend>
                <div class="qr-two-col">
                  <div>
                    <label for="qrVcardFirst">First name <span class="req">*</span></label>
                    <input type="text" id="qrVcardFirst" autocomplete="given-name" />
                  </div>
                  <div>
                    <label for="qrVcardLast">Last name <span class="req">*</span></label>
                    <input type="text" id="qrVcardLast" autocomplete="family-name" />
                  </div>
                </div>
                <label for="qrVcardOrg">Organization (optional)</label>
                <input type="text" id="qrVcardOrg" />
                <label for="qrVcardTitle">Job title (optional)</label>
                <input type="text" id="qrVcardTitle" />
                <div class="qr-two-col">
                  <div>
                    <label for="qrVcardPhoneW">Work phone (optional)</label>
                    <input type="tel" id="qrVcardPhoneW" inputmode="tel" />
                  </div>
                  <div>
                    <label for="qrVcardPhoneM">Mobile (optional)</label>
                    <input type="tel" id="qrVcardPhoneM" inputmode="tel" />
                  </div>
                </div>
                <label for="qrVcardEmail">Email (optional)</label>
                <input type="email" id="qrVcardEmail" inputmode="email" />
                <label for="qrVcardWeb">Website (optional)</label>
                <input type="url" id="qrVcardWeb" inputmode="url" placeholder="https://example.com" />
                <label for="qrVcardAdr">Address (optional, one line)</label>
                <input type="text" id="qrVcardAdr" />
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-whatsapp" hidden>
                <legend class="sr-only">WhatsApp</legend>
                <label for="qrWaPhone">Phone (international, with country code) <span class="req">*</span></label>
                <input type="tel" id="qrWaPhone" inputmode="tel" placeholder="e.g. 91XXXXXXXXXX" />
                <label for="qrWaMessage">Message (optional, pre-fills the chat box)</label>
                <textarea id="qrWaMessage" rows="3"></textarea>
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-upi" hidden>
                <legend class="sr-only">UPI (India)</legend>
                <p class="qr-hint"
                  >UPI QR codes work in India in UPI-enabled apps (GPay, PhonePe, Paytm, BHIM, bank apps). Test before printing for
                  stores.</p
                >
                <label for="qrUpiId">UPI ID <span class="req">*</span></label>
                <input
                  type="text"
                  id="qrUpiId"
                  inputmode="email"
                  placeholder="yourname@upi"
                  pattern="[a-zA-Z0-9._-]+@[a-zA-Z0-9._-]+"
                />
                <label for="qrUpiName">Payee name <span class="req">*</span></label>
                <input type="text" id="qrUpiName" />
                <label for="qrUpiAmount">Amount (optional, INR)</label>
                <input type="number" id="qrUpiAmount" name="amount" min="0" step="0.01" />
                <label for="qrUpiNote">Note (optional, max 50 characters)</label>
                <input type="text" id="qrUpiNote" maxlength="50" />
                <p class="qr-hint"
                  >Currency: <strong>INR</strong> (UPI is INR-only; always included in the QR per NPCI format).</p
                >
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-geo" hidden>
                <legend class="sr-only">Location</legend>
                <div class="qr-two-col">
                  <div>
                    <label for="qrLat">Latitude <span class="req">*</span></label>
                    <input type="number" id="qrLat" step="any" min="-90" max="90" placeholder="12.97" />
                  </div>
                  <div>
                    <label for="qrLng">Longitude <span class="req">*</span></label>
                    <input type="number" id="qrLng" step="any" min="-180" max="180" placeholder="77.59" />
                  </div>
                </div>
                <label for="qrGeoQuery">Map label (optional, opens in maps with this search)</label>
                <input type="text" id="qrGeoQuery" placeholder="Optional place name" />
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-event" hidden>
                <legend class="sr-only">Calendar event</legend>
                <label for="qrEventTitle">Title <span class="req">*</span></label>
                <input type="text" id="qrEventTitle" />
                <label for="qrEventLoc">Location (optional)</label>
                <input type="text" id="qrEventLoc" />
                <label for="qrEventStart">Start (local time) <span class="req">*</span></label>
                <input type="datetime-local" id="qrEventStart" />
                <label for="qrEventEnd">End (local time) <span class="req">*</span></label>
                <input type="datetime-local" id="qrEventEnd" />
                <label for="qrEventDesc">Description (optional)</label>
                <textarea id="qrEventDesc" rows="3"></textarea>
                <p class="qr-hint"
                  >Times you enter are stored as UTC in the vEvent payload (as required for portability).</p
                >
              </fieldset>

              <fieldset class="qr-fieldset qr-form-panel" id="qrForm-app" hidden>
                <legend class="sr-only">App Store link</legend>
                <p class="qr-hint"
                  >“Both” does not use a DoItSwift redirect. Enter a link to <strong>your</strong> page that can send iOS and Android
                  users to the right store.</p
                >
                <div class="qr-seg" role="radiogroup" aria-label="App platform">
                  <label
                    ><input type="radio" name="qrAppPlatform" value="ios" id="qrAppPlIos" checked />
                    iOS (App Store)</label
                  >
                  <label
                    ><input type="radio" name="qrAppPlatform" value="android" id="qrAppPlAnd" />
                    Android (Play or HTTPS)</label
                  >
                  <label><input type="radio" name="qrAppPlatform" value="both" id="qrAppPlBoth" /> Both (one landing URL)</label>
                </div>
                <div id="qrAppGroupIos">
                  <label for="qrIosUrl">App Store URL <span class="req">*</span></label>
                  <input type="url" id="qrIosUrl" inputmode="url" placeholder="https://apps.apple.com/..." />
                </div>
                <div id="qrAppGroupAndroid" hidden>
                  <label for="qrAndroidUrl">App URL <span class="req">*</span></label>
                  <input type="url" id="qrAndroidUrl" inputmode="url" placeholder="https://play.google.com/... or your HTTPS link" />
                </div>
                <div id="qrAppGroupBoth" hidden>
                  <label for="qrLandingUrl">Landing page URL <span class="req">*</span></label>
                  <input
                    type="url"
                    id="qrLandingUrl"
                    inputmode="url"
                    placeholder="https://yoursite.com/app"
                  />
                </div>
              </fieldset>
            </div>

            <div class="qr-design-accordion" id="qrDesignArea" aria-label="Visual design options">
              <h3 class="qr-design-heading">Design</h3>
              <details class="qr-design-block" open>
                <summary>Colors &amp; gradients</summary>
                <div class="qr-design-body">
                  <div class="qr-color-row">
                    <label for="qrColorFg">Dot color (foreground)</label>
                    <input type="color" id="qrColorFg" value="#000000" />
                  </div>
                  <div class="qr-color-row">
                    <label for="qrColorBg">Background</label>
                    <input type="color" id="qrColorBg" value="#ffffff" />
                  </div>
                  <label class="qr-chk">
                    <input type="checkbox" id="qrUseGradient" />
                    Use gradient for dots
                  </label>
                  <div class="qr-design-nested" id="qrGradControls" hidden>
                    <label for="qrGradType">Gradient type</label>
                    <select id="qrGradType">
                      <option value="linear" selected>Linear</option>
                      <option value="radial">Radial</option>
                    </select>
                    <div class="qr-color-row">
                      <label for="qrGradA">Color stop 1</label>
                      <input type="color" id="qrGradA" value="#000000" />
                    </div>
                    <div class="qr-color-row">
                      <label for="qrGradB">Color stop 2</label>
                      <input type="color" id="qrGradB" value="#2563eb" />
                    </div>
                    <div id="qrGradAngleRow" class="qr-range-row" hidden>
                      <label for="qrGradAngle">Angle (linear) <span id="qrAngleValue" class="qr-mono">0°</span></label>
                      <input type="range" id="qrGradAngle" min="0" max="360" value="0" step="1" />
                    </div>
                  </div>
                </div>
              </details>
              <details class="qr-design-block">
                <summary>Module &amp; eye shapes</summary>
                <div class="qr-design-body">
                  <p class="qr-hint qr-hint--tight">Data modules (dot style)</p>
                  <div class="qr-radio-grid qr-radio-grid--6" role="group" aria-label="Data dot shape">
                    {
                      [
                        ['square', 'Square'],
                        ['rounded', 'Rounded'],
                        ['dots', 'Dots'],
                        ['classy', 'Classy'],
                        ['classy-rounded', 'Classy Rnd'],
                        ['extra-rounded', 'Extra Rnd'],
