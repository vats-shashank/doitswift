  <script>
    import {
      generate,
      loadWordList,
      getLanguageMeta,
      LANGUAGES,
      type GenerateMode,
      type WordList,
    } from '../../lib/loremGenerator';
    import { COMPONENT_TEMPLATES, generateComponent, type ComponentOutput } from '../../lib/loremComponents';

    // Standard mode elements
    const langSel = document.getElementById('loremLanguage') as HTMLSelectElement;
    const modeSel = document.getElementById('loremMode') as HTMLSelectElement;
    const countInput = document.getElementById('loremCount') as HTMLInputElement;
    const starterRow = document.getElementById('starterRow') as HTMLDivElement;
    const starterCheckbox = document.getElementById('loremStarter') as HTMLInputElement;
    const standardPanel = document.getElementById('loremStandardPanel') as HTMLDivElement;

    // Template mode elements
    const templatesPanel = document.getElementById('loremTemplatesPanel') as HTMLDivElement;
    const templateSel = document.getElementById('loremTemplate') as HTMLSelectElement;
    const templateCountField = document.getElementById('loremTemplateCountField') as HTMLDivElement;
    const templateCountLabel = document.getElementById('loremTemplateCountLabel') as HTMLSpanElement;
    const templateCountInput = document.getElementById('loremTemplateCount') as HTMLInputElement;
    const templateDesc = document.getElementById('loremTemplateDesc') as HTMLParagraphElement;

    // Mode toggle
    const modeTabs = document.querySelectorAll<HTMLButtonElement>('.lorem-mode-tab');

    // Output
    const outputTabs = document.getElementById('loremOutputTabs') as HTMLDivElement;
    const outputTabBtns = document.querySelectorAll<HTMLButtonElement>('#loremOutputTabs .lorem-output-tab[data-output-tab]');
    const standardOutputTabs = document.getElementById('loremStandardOutputTabs') as HTMLDivElement;
    const standardOutputTabBtns = document.querySelectorAll<HTMLButtonElement>(
      '#loremStandardOutputTabs [data-standard-tab]'
    );
    const output = document.getElementById('loremOutput') as HTMLTextAreaElement;
    const stats = document.getElementById('loremStats') as HTMLSpanElement;
    const status = document.getElementById('loremStatus') as HTMLSpanElement;

    // Action buttons
    const generateBtn = document.getElementById('loremGenerate') as HTMLButtonElement;
    const copyBtn = document.getElementById('loremCopy') as HTMLButtonElement;
    const settingsBtn = document.getElementById('loremSettingsBtn') as HTMLButtonElement;
    const settingsPanel = document.getElementById('loremSettingsPanel') as HTMLDivElement;
    const autoCopyCheckbox = document.getElementById('loremAutoCopy') as HTMLInputElement;

    // State
    let currentList: WordList | null = null;
    let currentMode: 'standard' | 'templates' = 'standard';
    let lastComponentOutput: ComponentOutput | null = null;
    let activeOutputTab: 'text' | 'html' | 'json' = 'text';
    let activeStandardFormat: 'plain' | 'html' | 'markdown' = 'plain';
    let lastStandardOutput: string = '';
    let settingAutoCopy = false;

    // ─── Word list loading ────────────────────────────────────────────────────
    async function ensureWordList(language: string): Promise<WordList> {
      currentList = await loadWordList(language);
      return currentList;
    }

    function updateStarterVisibility() {
      if (currentMode !== 'standard') {
        starterRow.style.display = 'none';
        return;
      }
      const meta = getLanguageMeta(langSel.value);
      starterRow.style.display = meta && meta.hasStarter ? 'flex' : 'none';
    }

    // ─── Status + stats ──────────────────────────────────────────────────────
    function setStatus(msg: string, persistMs = 2000) {
      status.textContent = msg;
      if (persistMs > 0) {
        setTimeout(() => {
          if (status.textContent === msg) status.textContent = '';
        }, persistMs);
      }
    }

    function updateStats(text: string) {
      const wordCount = text.trim() ? text.trim().split(/\s+/).length : 0;
      const charCount = text.length;
      const byteCount = new TextEncoder().encode(text).length;
      let line = `${wordCount.toLocaleString()} words · ${charCount.toLocaleString()} characters · ${byteCount.toLocaleString()} bytes`;
      if (currentMode === 'standard') {
        const m = modeSel.value;
        if (m === 'characters') line += ' · Exact character target (no mid-word cut)';
        if (m === 'bytes') line += ' · Exact UTF-8 byte target (no mid-word cut)';
      }
      stats.textContent = line;
    }

    function populateLanguageSelect() {
      langSel.innerHTML = '';
      for (const lang of LANGUAGES) {
        const opt = document.createElement('option');
        opt.value = lang.id;
        opt.textContent = lang.label;
        if (lang.id === 'english-realfeel') opt.selected = true;
        langSel.appendChild(opt);
      }
    }

    function applyLanguageDirection(languageId: string) {
      const meta = getLanguageMeta(languageId);
      if (!meta) return;
      output.dir = meta.direction;
      // Optional: also adjust text alignment for RTL so it reads naturally
      output.style.textAlign = meta.direction === 'rtl' ? 'right' : 'left';
    }

    // ─── Templates dropdown ──────────────────────────────────────────────────
    function populateTemplateSelect() {
      templateSel.innerHTML = '';
      for (const t of COMPONENT_TEMPLATES) {
        const opt = document.createElement('option');
        opt.value = t.id;
        opt.textContent = t.enabled ? t.name : `${t.name} (coming soon)`;
        opt.disabled = !t.enabled;
        templateSel.appendChild(opt);
      }
      // Default to first enabled
      const firstEnabled = COMPONENT_TEMPLATES.find((t) => t.enabled);
      if (firstEnabled) templateSel.value = firstEnabled.id;
      updateTemplateMeta();
    }

    function getCurrentTemplate() {
      return COMPONENT_TEMPLATES.find((t) => t.id === templateSel.value);
    }

    function updateTemplateMeta() {
      const t = getCurrentTemplate();
      if (!t) return;
      templateDesc.textContent = t.description;
      if (t.hasCount) {
        templateCountField.style.display = 'flex';
        templateCountLabel.textContent = t.countLabel || 'Count';
        templateCountInput.min = String(t.minCount ?? 1);
        templateCountInput.max = String(t.maxCount ?? 50);
        templateCountInput.value = String(t.defaultCount ?? 5);
      } else {
        templateCountField.style.display = 'none';
      }

      // Show the matching SVG preview, hide the others
      const previews = document.querySelectorAll('.lorem-preview-svg');
      previews.forEach((p) => {
        const el = p as HTMLElement;
        const matches = el.dataset.preview === t.id;
        el.classList.toggle('is-visible', matches);
      });
    }

    // ─── Mode switching ──────────────────────────────────────────────────────
    function switchMode(newMode: 'standard' | 'templates') {
      currentMode = newMode;
      modeTabs.forEach((tab) => {
        const isActive = tab.dataset.modeGroup === newMode;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      standardPanel.style.display = newMode === 'standard' ? 'block' : 'none';
      templatesPanel.style.display = newMode === 'templates' ? 'block' : 'none';
      outputTabs.style.display = newMode === 'templates' ? 'flex' : 'none';
      standardOutputTabs.style.display = newMode === 'standard' ? 'flex' : 'none';
      const itemCopyHost = document.getElementById('loremItemCopyHost');
      if (itemCopyHost) itemCopyHost.innerHTML = '';
      updateStarterVisibility();
      handleGenerate();
    }

    modeTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const group = tab.dataset.modeGroup as 'standard' | 'templates';
        if (group) switchMode(group);
      });
    });

    // ─── Output tabs (templates mode only) ───────────────────────────────────
    outputTabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.outputTab as 'text' | 'html' | 'json';
        if (!tab) return;
        activeOutputTab = tab;
        outputTabBtns.forEach((b) => {
          const isActive = b.dataset.outputTab === tab;
          b.classList.toggle('is-active', isActive);
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        renderComponentOutput();
      });
    });

    standardOutputTabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.standardTab as 'plain' | 'html' | 'markdown';
        if (!tab) return;
        activeStandardFormat = tab;
        standardOutputTabBtns.forEach((b) => {
          const isActive = b.dataset.standardTab === tab;
          b.classList.toggle('is-active', isActive);
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        renderStandardOutput();
      });
    });

    function renderComponentOutput() {
      if (!lastComponentOutput) return;
      let text = '';
      if (activeOutputTab === 'text') text = lastComponentOutput.text;
      else if (activeOutputTab === 'html') text = lastComponentOutput.html;
      else if (activeOutputTab === 'json') text = JSON.stringify(lastComponentOutput.data, null, 2);
      output.value = text;
      updateStats(text);
      renderItemCopyButtons();
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function wrapStandardOutput(plainText: string, format: 'plain' | 'html' | 'markdown', mode: GenerateMode): string {
      if (format === 'plain') return plainText;

      const blocks = mode === 'paragraphs' ? plainText.split(/\n\n+/) : [plainText];

      if (format === 'html') {
        return blocks.map((b) => `<p>${escapeHtml(b)}</p>`).join('\n');
      }
      if (format === 'markdown') {
        return blocks.join('\n\n');
      }
      return plainText;
    }

    function renderStandardOutput() {
      if (currentMode !== 'standard' || !lastStandardOutput) return;
      const mode = modeSel.value as GenerateMode;
      const rendered = wrapStandardOutput(lastStandardOutput, activeStandardFormat, mode);
      output.value = rendered;
      updateStats(rendered);
    }

    function renderItemCopyButtons() {
      // Per-component copy: only show for templates whose data has an items / cards / tiers / fields array
      const container = document.getElementById('loremItemCopyHost');
      if (!container) return;
      container.innerHTML = '';
      if (!lastComponentOutput || activeOutputTab !== 'text') return;
      const data: any = lastComponentOutput.data;
      let arrayKey: string | null = null;
      if (Array.isArray(data?.items)) arrayKey = 'items';
      else if (Array.isArray(data?.cards)) arrayKey = 'cards';
      else if (Array.isArray(data?.tiers)) arrayKey = 'tiers';
      else if (Array.isArray(data?.fields)) arrayKey = 'fields';
      if (!arrayKey) return;
      const items = data[arrayKey];
      if (items.length < 2) return;
      const label = document.createElement('span');
      label.className = 'lorem-item-copy-label';
      label.textContent = `Copy single ${arrayKey.replace(/s$/, '')}:`;
      container.appendChild(label);
      items.forEach((it: any, i: number) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'lorem-item-copy-btn';
        btn.textContent = `${i + 1}`;
        btn.title = `Copy ${arrayKey.replace(/s$/, '')} ${i + 1}`;
        btn.addEventListener('click', async () => {
          const single = JSON.stringify(it, null, 2);
          try {
            await navigator.clipboard.writeText(single);
          } catch {
            /* graceful */
          }
          setStatus(`Copied ${arrayKey.replace(/s$/, '')} ${i + 1}`, 1500);
        });
        container.appendChild(btn);
      });
    }

    // ─── Generation ──────────────────────────────────────────────────────────
    async function handleGenerate() {
      try {
        const list = await ensureWordList(langSel.value);
        updateStarterVisibility();

        if (currentMode === 'standard') {
          const mode = modeSel.value as GenerateMode;
          const count = Math.max(1, parseInt(countInput.value || '1', 10));
          const plain = generate({
            mode,
            count,
            wordList: list,
            startWithStarter: !!list.starter && starterCheckbox.checked,
          });
          lastStandardOutput = plain;
          const rendered = wrapStandardOutput(plain, activeStandardFormat, mode);
          output.value = rendered;
          updateStats(rendered);
          setStatus('Generated', 1500);
          lastComponentOutput = null;
          renderItemCopyButtons();
          if (settingAutoCopy) {
            void handleCopy();
          }
        } else {
          // Templates mode
          const t = getCurrentTemplate();
          if (!t || !t.enabled) {
            setStatus('Template not yet available', 2500);
            return;
          }
          const count = t.hasCount
            ? Math.min(
                t.maxCount ?? 50,
                Math.max(t.minCount ?? 1, parseInt(templateCountInput.value || String(t.defaultCount ?? 5), 10))
              )
            : undefined;
          lastComponentOutput = generateComponent(t.id, list, count);
          renderComponentOutput();
          setStatus('Generated', 1500);
        }
      } catch (err) {
        console.error(err);
        setStatus('Error generating text. Please retry.', 4000);
      }
    }

    async function handleCopy() {
      if (!output.value) {
        setStatus('Nothing to copy yet — generate first.', 2000);
        return;
      }
      try {
        await navigator.clipboard.writeText(output.value);
        setStatus('Copied to clipboard', 1500);
      } catch {
        output.select();
        document.execCommand('copy');
        setStatus('Copied to clipboard', 1500);
      }
    }

    settingsBtn.addEventListener('click', () => {
      const isHidden = settingsPanel.hasAttribute('hidden');
      if (isHidden) {
        settingsPanel.removeAttribute('hidden');
      } else {
        settingsPanel.setAttribute('hidden', '');
      }
    });

    autoCopyCheckbox.addEventListener('change', () => {
      settingAutoCopy = autoCopyCheckbox.checked;
    });

    // Wire up
    generateBtn.addEventListener('click', handleGenerate);
    copyBtn.addEventListener('click', handleCopy);
    langSel.addEventListener('change', async () => {
      applyLanguageDirection(langSel.value);
      await ensureWordList(langSel.value);
      updateStarterVisibility();
      handleGenerate();
    });
    templateSel.addEventListener('change', () => {
      updateTemplateMeta();
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      const cmd = e.metaKey || e.ctrlKey;
      if (cmd && e.key.toLowerCase() === 'g') {
        e.preventDefault();
        handleGenerate();
      }
      if (cmd && !e.shiftKey && e.key.toLowerCase() === 'c' && document.activeElement === document.body) {
        e.preventDefault();
        handleCopy();
      }
    });

    // Initial setup
    (async () => {
      populateLanguageSelect();
      populateTemplateSelect();
      applyLanguageDirection(langSel.value);
      await ensureWordList(langSel.value);
      updateStarterVisibility();
      handleGenerate();
    })();
  </script>

