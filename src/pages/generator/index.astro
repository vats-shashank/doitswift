---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteRoot = Astro.site ? new URL('/', Astro.site).href : undefined;

const tools = [
  {
    href: '/generator/password-generator/',
    icon: '🔐',
    title: 'Password Generator',
    desc: 'Generate cryptographically secure passwords. Customize length, characters, and include passphrase mode.',
    live: true,
    coming: false,
  },
  {
    href: '/generator/qr-code/',
    icon: '📱',
    title: 'QR Code Generator',
    desc: 'Generate QR codes for URLs, WiFi, contacts, or any text. Customize colors and download as PNG/SVG.',
    live: true,
    coming: false,
  },
  {
    href: '/generator/lorem-ipsum/',
    icon: '📝',
    title: 'Lorem Ipsum Generator',
    desc: 'Designer-first placeholder text in 8 languages, with templates for real UI components.',
    live: true,
    coming: false,
  },
  {
    href: null,
    icon: '🔑',
    title: 'UUID Generator',
    desc: 'Generate UUID v4 (random) and UUID v1 (timestamp-based). Bulk generation and copy in any format.',
    live: false,
    coming: true,
  },
  {
    href: null,
    icon: '📊',
    title: 'Barcode Generator',
    desc: 'Generate Code 128, Code 39, EAN-13, and other barcode formats. Download as PNG or SVG.',
    live: false,
    coming: true,
  },
  {
    href: null,
    icon: '🧾',
    title: 'Invoice Generator',
    desc: 'Create professional invoices with your branding. Download as PDF. Perfect for freelancers.',
    live: false,
    coming: true,
  },
];

const pageDescription =
  'Free browser-based generators for passwords, QR codes, UUIDs, barcodes, and more. Cryptographically secure, no signup, no tracking. Generate instantly in your browser.';

const genHubBreadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://doitswift.com/' },
    { '@type': 'ListItem', position: 2, name: 'Generators', item: 'https://doitswift.com/generator/' },
  ],
};

const genHubItemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Free Online Generators',
  description: pageDescription,
  numberOfItems: 6,
  itemListElement: [
    { '@type': 'ListItem', position: 1, url: 'https://doitswift.com/generator/password-generator/', name: 'Password Generator' },
    { '@type': 'ListItem', position: 2, url: 'https://doitswift.com/generator/qr-code/', name: 'QR Code Generator' },
    { '@type': 'ListItem', position: 3, url: 'https://doitswift.com/generator/uuid/', name: 'UUID Generator' },
    { '@type': 'ListItem', position: 4, url: 'https://doitswift.com/generator/barcode/', name: 'Barcode Generator' },
    { '@type': 'ListItem', position: 5, url: 'https://doitswift.com/generator/lorem-ipsum/', name: 'Lorem Ipsum Generator' },
    { '@type': 'ListItem', position: 6, url: 'https://doitswift.com/generator/invoice/', name: 'Invoice Generator' },
  ],
};

const genHubFaqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Are these generators secure?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'For sensitive outputs (passwords, passphrases, future UUID and random tokens), DoItSwift uses the Web Crypto API (crypto.getRandomValues) in your browser, not weak pseudo-random functions. No generator sends your result to a server, so secrets do not pass through our infrastructure.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is generated content stored anywhere?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'We do not save generated values to a database or localStorage. What you see exists in page memory for your session and disappears when you close the tab. Save anything you need in your own password manager or file.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do these tools work offline?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'After the first load, static pages can run without a network. Random generation and QR-style tools (when they ship) use the same in-tab execution model. Some future tools may need a CDN for fonts; the hub itself stays usable offline for password generation once cached.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are the generators cryptographically secure?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Passwords on DoItSwift use the same cryptographically strong random number generator the browser uses for TLS and other security features. This is a different class of randomness than Math.random() in JavaScript, which is not appropriate for security-sensitive uses.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I use these for commercial purposes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'You may use the tools to produce material for your business or product as long as you follow applicable laws. DoItSwift is not a substitute for legal, tax, or compliance review for generated documents when those launch.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I suggest a new generator?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Use the site contact form with a one-line use case. We look for in-browser, privacy-respecting ideas that do not require uploading user content to our servers by default.',
      },
    },
  ],
};

const genCollectionJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: 'Free Online Generators — Password, QR Code, UUID, Barcode | DoItSwift',
      description: pageDescription,
      about: { '@id': `${canonical}#collection` },
      ...(siteRoot ? { isPartOf: { '@type': 'WebSite', name: 'DoItSwift', url: siteRoot } } : {}),
    },
    {
      '@type': 'CollectionPage',
      '@id': `${canonical}#collection`,
      url: canonical,
      name: 'Free Online Generators',
      description: pageDescription,
      numberOfItems: 6,
      ...(siteRoot ? { isPartOf: { '@type': 'WebSite', name: 'DoItSwift', url: siteRoot } } : {}),
    },
  ],
};
---

<MainLayout
  title="Free Online Generators — Password, QR Code, UUID, Barcode | DoItSwift"
  description={pageDescription}
  keywords="free online generators, password generator, QR code generator, UUID generator, barcode generator, browser tools, doitswift"
  canonical={canonical}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(genHubBreadcrumbLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(genHubItemListLd)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(genHubFaqPageLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(genCollectionJsonLd)} />

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <span>Generators</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🎨 Generators</div>
      <h1>Free Online Generators</h1>
      <p class="subtitle">
        Generate passwords, QR codes, UUIDs, and more — entirely in your browser. No signup, no tracking, no data sent to
        servers.
      </p>
    </div>
  </section>

  <section class="tools-section">
    <div class="container">
      <h2 class="section-title">All generator tools</h2>
      <p class="section-sub">
        Pick a tool — output stays in your session. <strong>Password</strong>, <strong>QR Code</strong>, and
        <strong>Lorem Ipsum</strong> are live; three more are planned.
      </p>
      <div class="grid">
        {tools.map((tool) =>
          tool.coming ? (
            <div class="tool-card tool-card--coming" aria-disabled="true">
              <div class="tool-card__meta">
                <span class="tool-card__badge tool-card__badge--soon">Coming soon</span>
              </div>
              <span class="icon">{tool.icon}</span>
              <h3>{tool.title}</h3>
              <p>{tool.desc}</p>
            </div>
          ) : (
            <a href={tool.href} class="tool-card">
              <div class="tool-card__meta">
                <span class="tool-card__badge tool-card__badge--live">Live</span>
              </div>
              <span class="icon">{tool.icon}</span>
              <h3>{tool.title}</h3>
              <p>{tool.desc}</p>
            </a>
          )
        )}
      </div>
    </div>
  </section>

  <section class="formats">
    <div class="container">
      <h2 class="section-title">Why Use Browser-Based Generators?</h2>
      <p class="section-sub">Especially for secrets — the server should never be in the path.</p>
      <div class="formats-prose">
        <p>
          A <strong>web-based</strong> generator that runs in JavaScript can produce passwords, passphrases, and random
          identifiers without ever transmitting them over the network. The page is delivered as static files; the random
          number generator inside your browser (via <code>crypto.getRandomValues</code>) is the same family of API
          modern browsers use for real security work, not a toy PRNG. That is the right foundation when you are standing up
          credentials, recovery codes, or anything that would be a disaster if leaked.
        </p>
        <p>
          <strong>Speed and reliability</strong> follow: no queue on a server, no rate limit, no “subscribe to export.”
          You can refresh as often as you like, tweak length and character types, and copy the result in milliseconds.
          If you are on a plane or an isolated network, cached assets still run — no API key, no account cookie required
          for the core experience.
        </p>
        <p>
          DoItSwift is built for people who are tired of lead-magnet tools that <strong>push a paid product</strong> the
          moment a password appears. We do not collect what you generate, do not store it in a database, and do not
          A/B-test your passphrases. The trade-off is the usual one for static sites: you are responsible for saving the
          output in a password manager or other secure place before you leave the page.
        </p>
        <p>
          This hub will grow with QR, UUID, barcode, and layout helpers. Each will follow the same default: <strong>run
            locally, disclose what happens in the UI, and avoid opt-out uploads.</strong> When a future tool must call the
          network, we will say so in plain text before you use it.
        </p>
      </div>
    </div>
  </section>

  <section class="gen-categories" aria-label="More categories on DoItSwift">
    <div class="container">
      <h2 class="section-title">Explore more categories</h2>
      <p class="section-sub">Text, image, PDF, and calculators — private and free.</p>
      <ul class="gen-cat-grid">
        <li>
          <a href="/text/">Text tools</a>
          <span>Word counter and more text utilities.</span>
        </li>
        <li>
          <a href="/image/">Image tools</a>
          <span>Convert, compress, resize, Base64, favicons.</span>
        </li>
        <li>
          <a href="/pdf/">PDF tools</a>
          <span>Merge, split, compress, convert — in your tab.</span>
        </li>
        <li>
          <a href="/calculator/">Calculators</a>
          <span>Finance, health, math, and daily helpers.</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="faq" id="faq">
    <div class="container">
      <h2 class="section-title">Generator hub FAQ</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Are these generators secure?</h4>
          <p>
            For sensitive outputs (passwords, passphrases, future UUID and random tokens), DoItSwift uses the Web Crypto
            API (crypto.getRandomValues) in your browser, not weak pseudo-random functions. No generator sends your
            result to a server, so secrets do not pass through our infrastructure.
          </p>
        </div>
        <div class="faq-item">
          <h4>Is generated content stored anywhere?</h4>
          <p>
            We do not save generated values to a database or localStorage. What you see exists in page memory for your
            session and disappears when you close the tab. Save anything you need in your own password manager or file.
          </p>
        </div>
        <div class="faq-item">
          <h4>Do these tools work offline?</h4>
          <p>
            After the first load, static pages can run without a network. Random generation and QR-style tools (when they
            ship) use the same in-tab execution model. Some future tools may need a CDN for fonts; the hub itself stays
            usable offline for password generation once cached.
          </p>
        </div>
        <div class="faq-item">
          <h4>Are the generators cryptographically secure?</h4>
          <p>
            Passwords on DoItSwift use the same cryptographically strong random number generator the browser uses for TLS
            and other security features. This is a different class of randomness than Math.random() in JavaScript, which
            is not appropriate for security-sensitive uses.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I use these for commercial purposes?</h4>
          <p>
            You may use the tools to produce material for your business or product as long as you follow applicable laws.
            DoItSwift is not a substitute for legal, tax, or compliance review for generated documents when those
            launch.
          </p>
        </div>
        <div class="faq-item">
          <h4>How do I suggest a new generator?</h4>
          <p>
            Use the <a href="/contact/">site contact form</a> with a one-line use case. We look for in-browser,
            privacy-respecting ideas that do not require uploading user content to our servers by default.
          </p>
        </div>
      </div>
    </div>
  </section>

  <p class="back-wrap container">
    <a href="/" class="link-back">← Back to home</a>
  </p>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 960px;
    }
    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }
    .breadcrumb a:hover {
      text-decoration: underline;
    }
    .hero {
      padding: 36px 0 16px;
      text-align: center;
    }
    .subtitle {
      font-size: 18px;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 auto 24px;
      line-height: 1.55;
    }
    .section-title {
      text-align: center;
      margin-bottom: 8px;
    }
    .section-sub {
      text-align: center;
      color: var(--text-muted);
      margin-bottom: 32px;
      font-size: 16px;
    }
    .tools-section {
      padding: 40px 0 56px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 14px;
    }
    .tool-card {
      position: relative;
      background: var(--card);
      padding: 22px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }
    a.tool-card {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    a.tool-card:hover {
      border-color: #2563eb;
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
    }
    :global([data-theme='dark']) a.tool-card:hover {
      border-color: #3b82f6;
    }
    .tool-card--coming {
      cursor: not-allowed;
      pointer-events: none;
      opacity: 0.72;
    }
    :global([data-theme='dark']) .tool-card--coming {
      opacity: 0.78;
    }
    .tool-card__meta {
      position: absolute;
      top: 10px;
      right: 12px;
    }
    .tool-card__badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 3px 8px;
      border-radius: 999px;
    }
    .tool-card__badge--live {
      background: rgba(37, 99, 235, 0.12);
      color: #2563eb;
      border: 1px solid rgba(37, 99, 235, 0.35);
    }
    :global([data-theme='dark']) .tool-card__badge--live {
      background: rgba(59, 130, 246, 0.2);
      color: #93c5fd;
      border-color: rgba(59, 130, 246, 0.4);
    }
    .tool-card__badge--soon {
      background: var(--card);
      color: var(--text-muted);
      border: 1px solid var(--border);
    }
    .tool-card .icon {
      font-size: 30px;
      display: block;
      margin-bottom: 10px;
      padding-top: 8px;
    }
    .tool-card h3 {
      font-size: 15px;
      margin-bottom: 4px;
    }
    .tool-card p {
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.5;
    }
    .formats {
      padding: 20px 0 56px;
      background: var(--card);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .formats-prose {
      max-width: 760px;
      margin: 0 auto;
    }
    .formats-prose p,
    .formats-prose code {
      font-size: 15px;
      line-height: 1.75;
      color: var(--text-muted);
      margin-bottom: 16px;
    }
    .formats-prose code {
      font-size: 0.9em;
    }
    .gen-categories {
      padding: 40px 0 20px;
    }
    .gen-cat-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 12px;
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
    }
    @media (min-width: 560px) {
      .gen-cat-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (min-width: 900px) {
      .gen-cat-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }
    .gen-cat-grid li {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 18px 20px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
    }
    .gen-cat-grid a {
      font-size: 16px;
      font-weight: 700;
      color: #2563eb;
      text-decoration: none;
    }
    :global([data-theme='dark']) .gen-cat-grid a {
      color: #60a5fa;
    }
    .gen-cat-grid a:hover {
      text-decoration: underline;
    }
    .gen-cat-grid li span {
      font-size: 14px;
      color: var(--text-muted);
    }
    .faq {
      padding: 40px 0 40px;
    }
    .faq .container {
      max-width: 820px;
    }
    .faq-list {
      margin-top: 28px;
    }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 12px;
      box-shadow: var(--shadow);
    }
    .faq-item h4 {
      font-size: 16px;
      margin-bottom: 6px;
    }
    .faq-item p {
      font-size: 14px;
      color: var(--text-muted);
      margin: 0;
    }
    .faq-item a {
      color: #2563eb;
      font-weight: 600;
    }
    :global([data-theme='dark']) .faq-item a {
      color: #60a5fa;
    }
    .back-wrap {
      padding-bottom: 48px;
      text-align: center;
    }
  </style>
</MainLayout>
