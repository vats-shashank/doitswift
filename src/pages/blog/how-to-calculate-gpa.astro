                <td>Pass</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>University-specific formulas</h3>
        <p>
          <strong>Warning:</strong> Not all universities use the ×9.5 formula. Some common
          variations:
        </p>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>University / Board</th>
                <th>Conversion formula</th>
                <th>Example: CGPA 8.0</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>CBSE (standard)</td>
                <td>CGPA × 9.5</td>
                <td>76%</td>
              </tr>
              <tr>
                <td>Anna University</td>
                <td>Custom table (not linear)</td>
                <td>~75-80%</td>
              </tr>
              <tr>
                <td>Mumbai University</td>
                <td>CGPA × 10 (approximate)</td>
                <td>80%</td>
              </tr>
