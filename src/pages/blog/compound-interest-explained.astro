                <td>₹2,20,804</td>
                <td>₹1,20,804</td>
              </tr>
              <tr>
                <td>Monthly (n=12)</td>
                <td>₹2,21,964</td>
                <td>₹1,21,964</td>
              </tr>
              <tr>
                <td>Daily (n=365)</td>
                <td>₹2,22,535</td>
