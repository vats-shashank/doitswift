---
import MainLayout from '../../layouts/MainLayout.astro';

/** Newest first — add new entries at the top. `categoryKey` drives filters + badges (finance | health | image | pdf). */
const posts = [
  {
    title: 'How to Track Your Period Cycle: A Complete Guide to Understanding Your Menstrual Cycle',
    href: '/blog/how-to-track-period-cycle/',
    categoryKey: 'health',
    date: 'April 18, 2026',
    dateIso: '2026-04-18',
    excerpt:
      'Learn how to track your menstrual cycle, predict your next period, identify your fertile window, and understand what\'s normal. Free period calculator included.',
  },
  {
    title: 'How to Convert PDF to JPG: Free Methods That Keep Your Files Private',
    href: '/blog/how-to-convert-pdf-to-jpg/',
    categoryKey: 'pdf',
    date: 'April 18, 2026',
    dateIso: '2026-04-18',
    excerpt:
      'Convert PDF pages to JPG images for free. Browser-based conversion — files never leave your device. Quality settings, batch conversion, and 5 methods compared.',
  },
  {
    title: 'Best Image Format for Websites in 2026: WebP vs AVIF vs JPG vs PNG (Complete Guide)',
    href: '/blog/best-image-format-for-web/',
    categoryKey: 'image',
    date: 'April 18, 2026',
    dateIso: '2026-04-18',
    excerpt:
      'Which image format should you use? Compare WebP, AVIF, JPG, PNG, and SVG — file size, quality, browser support, and when to use each. With free conversion tools.',
  },
  {
    title: 'How to Split a PDF: Extract Pages, Remove Pages, or Break Into Parts (Free)',
    href: '/blog/how-to-split-pdf/',
    categoryKey: 'pdf',
    date: 'April 18, 2026',
    dateIso: '2026-04-18',
    excerpt:
      'Split any PDF into separate pages, extract specific page ranges, or remove unwanted pages. Free browser-based tool — files never leave your device.',
  },
  {
    title: 'How to Merge PDF Files into One: Free Guide (No Upload, No Signup)',
    href: '/blog/how-to-merge-pdf/',
    categoryKey: 'pdf',
    date: 'April 18, 2026',
    dateIso: '2026-04-18',
    excerpt:
      'Combine multiple PDFs into a single file for free. Browser-based merger — files never leave your device. Step-by-step guide, 10 real use cases, and troubleshooting tips.',
  },
  {
    title: 'How to Compress a PDF Without Losing Quality (Free, No Upload)',
    href: '/blog/how-to-compress-pdf/',
    categoryKey: 'pdf',
    date: 'April 17, 2026',
    dateIso: '2026-04-17',
    excerpt:
      'Reduce PDF file size by 50-90% without visible quality loss. Free browser-based compression, no upload to servers. Best settings for email, WhatsApp, and government portals.',
  },
  {
    title: 'How Many Calories Should You Eat Per Day? (Calculator + Indian Food Guide)',
    href: '/blog/how-many-calories-per-day/',
    categoryKey: 'health',
    date: 'April 17, 2026',
    dateIso: '2026-04-17',
    excerpt:
      'Find your daily calorie needs using TDEE science. Includes calorie calculator, Indian food calorie chart with 50+ common foods, macros breakdown, and sample meal plans.',
  },
  {
    title: 'Old vs New Tax Regime in India: Which Saves You More Money? (FY 2025-26)',
    href: '/blog/old-vs-new-tax-regime/',
    categoryKey: 'finance',
    date: 'April 17, 2026',
    dateIso: '2026-04-17',
    excerpt:
      'Compare old vs new tax regime with real examples at ₹8, ₹12, ₹15, ₹20, and ₹30 LPA. Side-by-side calculations, deduction breakdowns, and a clear decision rule.',
  },
  {
    title: 'How to Calculate Your BMI: Formula, Chart, and What Your Number Really Means (2026 Guide)',
    href: '/blog/how-to-calculate-bmi/',
    categoryKey: 'health',
    date: 'April 17, 2026',
    dateIso: '2026-04-17',
    excerpt:
      'Calculate your BMI with our free tool. Includes the formula, official BMI chart, adjusted ranges for Indians and South Asians, and what steps to take after checking your number.',
  },
  {
    title: 'CTC vs In-Hand Salary: Where Does Your Money Actually Go? (2026 Breakdown)',
    href: '/blog/ctc-vs-in-hand-salary/',
    categoryKey: 'finance',
    date: 'April 17, 2026',
    dateIso: '2026-04-17',
    excerpt:
      'Your CTC says ₹12 lakh but in-hand is only ₹72,000/month? Full breakdown of every deduction — PF, tax, gratuity, HRA — with real examples at every CTC level.',
  },
  {
    title: 'Buy vs Rent a House in India 2026: Honest Math (with Calculator)',
    href: '/blog/buy-vs-rent-india/',
    categoryKey: 'finance',
    date: 'April 14, 2026',
    dateIso: '2026-04-14',
    excerpt:
      'Should you buy or rent in India 2026? Real math comparing ₹50 lakh house vs renting + investing. Break-even analysis, hidden costs, and the answer most articles avoid.',
  },
  {
    title: 'How Much Money Do You REALLY Need to Retire in India? (2026 Math)',
    href: '/blog/how-much-to-retire-india/',
    categoryKey: 'finance',
    date: 'April 14, 2026',
    dateIso: '2026-04-14',
    excerpt:
      'Most Indians need ₹3-7 crore to retire — not the ₹1 crore they think. Real calculations with inflation, healthcare, and expense projections. Find your true retirement number.',
  },
  {
    title: 'SIP vs Lumpsum: Which Investment Wins in 2026? (Real Numbers)',
    href: '/blog/sip-vs-lumpsum/',
    categoryKey: 'finance',
    date: 'April 13, 2026',
    dateIso: '2026-04-13',
    excerpt:
      'You have ₹6 lakh sitting in your bank account. Should you invest it all at once (lumpsum) or split it into ₹5,000 monthly SIPs over 10 years? Here\'s the honest answer — with real calculations and one counter-intuitive truth.',
  },
  {
    title: 'How to Convert iPhone Photos to JPG Without Losing Quality (2026 Guide)',
    href: '/blog/convert-iphone-photos-to-jpg/',
    categoryKey: 'image',
    date: 'April 13, 2026',
    dateIso: '2026-04-13',
    excerpt:
      "You just tried to send an iPhone photo to a colleague on Windows. It arrived as a useless HEIC file. Here are the 5 fastest ways to convert iPhone photos to JPG — tested and ranked.",
  },
  {
    title: 'HEIC vs JPG: Complete Format Comparison for 2026',
    href: '/blog/heic-vs-jpg/',
    categoryKey: 'image',
    date: 'April 13, 2026',
    dateIso: '2026-04-13',
    excerpt:
      "Your iPhone takes photos as HEIC. Every website, email, and old laptop expects JPG. Which one should you actually use? Here's everything that actually matters, backed by real numbers.",
  },
  {
    title: 'How to Open HEIC Files on Windows 11 in 2026 (3 Free Methods)',
    href: '/blog/open-heic-windows-11/',
    categoryKey: 'image',
    date: 'April 12, 2026',
    dateIso: '2026-04-12',
    excerpt:
      "Your iPhone photos won't open on your Windows 11 PC. Here are the three simplest free methods to view and convert HEIC files, including one that requires zero installation.",
  },
] as const;

type CategoryKey = 'finance' | 'health' | 'image' | 'pdf';

const badgeLabel: Record<CategoryKey, string> = {
  finance: 'Finance',
  health: 'Health',
  image: 'Image',
  pdf: 'PDF',
};

const countBy = (key: CategoryKey | 'all') =>
  key === 'all' ? posts.length : posts.filter((p) => p.categoryKey === key).length;
---

<MainLayout
  title="Blog — DoItSwift"
  description="Guides on PDF tools, image formats, Indian finance, health calculators, and privacy-first workflows — plus how to get the most from DoItSwift."
  keywords="doitswift blog, pdf merge split compress, heic webp avif, income tax india, sip retirement, bmi calories health"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <section class="content-page blog-index">
    <div class="container">
      <h1>Blog</h1>
      <p class="lead">
        Practical guides on PDFs, images, money, and health — always with a privacy-minded angle. New posts appear here
        first — no newsletter required.
      </p>

      <h2 class="blog-list-heading">Latest posts</h2>

      <div class="blog-filters" role="group" aria-label="Filter posts by category">
        <button
          type="button"
          class="blog-filter-btn active"
          data-category="all"
          aria-pressed="true"
        >
          All ({countBy('all')})
        </button>
        <button type="button" class="blog-filter-btn" data-category="finance" aria-pressed="false">
          Finance ({countBy('finance')})
        </button>
        <button type="button" class="blog-filter-btn" data-category="health" aria-pressed="false">
          Health ({countBy('health')})
        </button>
        <button type="button" class="blog-filter-btn" data-category="image" aria-pressed="false">
          Image ({countBy('image')})
        </button>
        <button type="button" class="blog-filter-btn" data-category="pdf" aria-pressed="false">
          PDF ({countBy('pdf')})
        </button>
      </div>

      <ul class="blog-card-list blog-post-grid">
        {
          posts.map((post) => (
            <li class="blog-post-card" data-category={post.categoryKey}>
              <a href={post.href} class="blog-card">
                <span class:list={['category-badge', post.categoryKey]}>{badgeLabel[post.categoryKey]}</span>
                <div class="blog-card-meta">
                  <time datetime={post.dateIso} class="blog-card-date">
                    {post.date}
                  </time>
                </div>
                <h3 class="blog-card-title">{post.title}</h3>
                <p class="blog-card-excerpt">{post.excerpt}</p>
                <span class="blog-card-cta">Read article →</span>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="pagination">
        <button type="button" class="pagination-btn pagination-prev" disabled>← Previous</button>
        <span class="pagination-info">
          Page <span class="pagination-current">1</span> of <span class="pagination-total">1</span>
        </span>
        <button type="button" class="pagination-btn pagination-next">Next →</button>
      </div>

      <p class="section-tail">
        <a href="/image/" class="link-back">Browse image tools →</a>
        {' · '}
        <a href="/" class="link-back">Home</a>
      </p>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const POSTS_PER_PAGE = 6;
      const buttons = document.querySelectorAll('.blog-filter-btn');
      const allPosts = Array.from(document.querySelectorAll('.blog-post-card'));
      const prevBtn = document.querySelector('.pagination-prev');
      const nextBtn = document.querySelector('.pagination-next');
      const currentPageEl = document.querySelector('.pagination-current');
      const totalPagesEl = document.querySelector('.pagination-total');
      const postGrid = document.querySelector('.blog-post-grid');
      const paginationEl = document.querySelector('.pagination');

      if (!prevBtn || !nextBtn || !currentPageEl || !totalPagesEl || !postGrid || !paginationEl) return;

      let currentCategory = 'all';
      let currentPage = 1;

      function getFilteredPosts() {
        if (currentCategory === 'all') return allPosts;
        return allPosts.filter((p) => p.dataset.category === currentCategory);
      }

      function getTotalPages() {
        return Math.max(1, Math.ceil(getFilteredPosts().length / POSTS_PER_PAGE));
      }

      function render() {
        const filtered = getFilteredPosts();
        let totalPages = getTotalPages();
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * POSTS_PER_PAGE;
        const end = start + POSTS_PER_PAGE;

        allPosts.forEach((post) => {
          const inCategory = currentCategory === 'all' || post.dataset.category === currentCategory;
          const idx = filtered.indexOf(post);
          const inPage = idx >= start && idx < end;
          post.style.display = inCategory && inPage ? '' : 'none';
        });

        currentPageEl.textContent = String(currentPage);
        totalPagesEl.textContent = String(totalPages);
        prevBtn.disabled = currentPage <= 1;
        nextBtn.disabled = currentPage >= totalPages;

        paginationEl.style.display = totalPages <= 1 ? 'none' : 'flex';
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          currentCategory = btn.dataset.category || 'all';
          currentPage = 1;
          buttons.forEach((b) => {
            b.classList.remove('active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
          render();
        });
      });

      prevBtn.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          render();
          postGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      nextBtn.addEventListener('click', () => {
        if (currentPage < getTotalPages()) {
          currentPage++;
          render();
          postGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      render();
    });
  </script>

  <style>
    .blog-index .blog-list-heading {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 8px;
      margin-bottom: 18px;
    }

    .blog-filters {
      display: flex;
      gap: 8px;
      margin-bottom: 32px;
      overflow-x: auto;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
      max-width: 720px;
    }

    .blog-filter-btn {
      padding: 8px 18px;
      border: 1px solid var(--border);
      border-radius: 100px;
      background: var(--card);
      color: var(--text-muted);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      white-space: nowrap;
      transition:
        border-color 0.15s ease,
        color 0.15s ease,
        background 0.15s ease;
      font-family: inherit;
    }

    .blog-filter-btn:hover {
      border-color: var(--blue);
      color: var(--blue);
    }

    .blog-filter-btn.active {
      background: var(--blue);
      color: #fff;
      border-color: var(--blue);
    }

    .blog-card-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 16px;
      max-width: 720px;
    }

    .blog-card {
      display: block;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 22px 24px;
      box-shadow: var(--shadow);
      transition:
        border-color 0.2s,
        box-shadow 0.2s,
        transform 0.2s;
    }

    .blog-card:hover {
      border-color: rgba(0, 102, 255, 0.28);
      box-shadow: var(--shadow-lg);
      transform: translateY(-2px);
    }

    :global([data-theme='dark']) .blog-card:hover {
      border-color: rgba(96, 165, 250, 0.35);
    }

    .category-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }

    .category-badge.finance {
      background: #dbeafe;
      color: #1d4ed8;
    }

    .category-badge.health {
      background: #d1fae5;
      color: #047857;
    }

    .category-badge.image {
      background: #ffedd5;
      color: #c2410c;
    }

    .category-badge.pdf {
      background: #fce7f3;
      color: #be185d;
    }

    :global([data-theme='dark']) .category-badge.finance {
      background: rgba(29, 78, 216, 0.2);
      color: #93bbfd;
    }

    :global([data-theme='dark']) .category-badge.health {
      background: rgba(4, 120, 87, 0.2);
      color: #6ee7b7;
    }

    :global([data-theme='dark']) .category-badge.image {
      background: rgba(194, 65, 12, 0.2);
      color: #fdba74;
    }

    :global([data-theme='dark']) .category-badge.pdf {
      background: rgba(190, 24, 93, 0.2);
      color: #f9a8d4;
    }

    .blog-card-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px 14px;
      margin-bottom: 10px;
      font-size: 13px;
    }

    .blog-card-date {
      color: var(--text-muted);
      font-weight: 500;
    }

    .blog-card-title {
      font-size: 1.25rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.3;
      margin: 0 0 10px;
      color: var(--text);
    }

    .blog-card-excerpt {
      font-size: 15px;
      line-height: 1.6;
      color: var(--text-muted);
      margin: 0 0 14px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .blog-card-cta {
      font-size: 14px;
      font-weight: 600;
      color: var(--blue);
    }

    .blog-card:hover .blog-card-cta {
      text-decoration: underline;
    }

    .pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin-top: 48px;
      padding-top: 32px;
      border-top: 1px solid var(--border);
      max-width: 720px;
    }

    .pagination-btn {
      padding: 10px 20px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--card);
      color: var(--text);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition:
        border-color 0.15s ease,
        color 0.15s ease;
      font-family: inherit;
    }

    .pagination-btn:hover:not(:disabled) {
      border-color: var(--blue);
      color: var(--blue);
    }

    .pagination-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .pagination-info {
      font-size: 14px;
      color: var(--text-muted);
    }

    .pagination-current {
      font-weight: 700;
      color: var(--text);
    }
  </style>
</MainLayout>
