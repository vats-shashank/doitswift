const description = "HEIC vs JPG: which format is better for photos in 2026? Compare file size, quality, compatibility, and use cases. Get the definitive answer based on real data.";
const publishDate = "2026-04-13";
const lastUpdated = "2026-04-13";
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<MainLayout
  title={`${title} | DoItSwift`}
  description={description}
  keywords="heic vs jpg, heic or jpg, heic vs jpeg, which is better heic or jpg, heic jpg comparison"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": publishDate,
    "dateModified": lastUpdated,
    "author": { "@type": "Organization", "name": "DoItSwift" },
    "publisher": {
      "@type": "Organization",
      "name": "DoItSwift",
