---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="AVIF to JPG Converter Online — Free, Private & Batch | DoItSwift"
  description="Convert AVIF to JPG in your browser — native AVIF decode, JPEG quality presets (100%, 85%, 70%), before/after sizes, batch ZIP. No uploads. For when you need JPEG compatibility from AVIF photos or graphics."
  keywords="avif to jpg, avif to jpeg, convert avif to jpg, avif converter online, what is avif, avif vs jpg, avif format, save avif as jpg, free avif converter, batch avif to jpeg, browser avif decode"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "DoItSwift AVIF to JPG Converter",
    "description": "Free client-side AVIF to JPEG converter. Uses the browser's built-in AVIF decoder (createImageBitmap or Image), exports JPEG with adjustable quality, batch ZIP download, no server upload.",
    "url": "https://doitswift.com/image/avif-to-jpg/",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Web browser with AVIF support",
    "browserRequirements": "Requires AVIF decode support (modern Chrome, Edge, Firefox, Safari)",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "Decode AVIF using native browser codecs",
      "Export JPEG at maximum, balanced (85%), or small-file (70%) quality",
      "White background compositing for transparent AVIF content",
      "Batch conversion with ZIP download",
      "Files processed locally — not uploaded",
      "Shows original vs converted file size per file"
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is AVIF to JPG conversion free and unlimited?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. No signup, watermarks, or usage caps. Conversion runs entirely in your browser." }},
      { "@type": "Question", "name": "Are my AVIF files uploaded to a server?", "acceptedAnswer": { "@type": "Answer", "text": "No. Files stay on your device. Decoding uses the browser's native AVIF support; JPEG is produced with the Canvas API locally." }},
      { "@type": "Question", "name": "What is AVIF and why convert it to JPG?", "acceptedAnswer": { "@type": "Answer", "text": "AVIF is a modern image format based on AV1 compression — often smaller than JPEG at similar quality. You convert to JPG when a workflow requires universal compatibility: email, older software, print, or upload forms that only accept JPEG." }},
      { "@type": "Question", "name": "Which browsers can convert AVIF here?", "acceptedAnswer": { "@type": "Answer", "text": "Your browser must decode AVIF natively. Current Chrome, Edge, Firefox, and recent Safari generally work. If conversion fails, update the browser or try another device — the tool cannot decode AVIF without OS/browser codec support." }},
      { "@type": "Question", "name": "What happens to AVIF transparency?", "acceptedAnswer": { "@type": "Answer", "text": "JPEG does not support alpha transparency. Transparent areas are composited on a white background before export, which is standard for AVIF to JPG conversion." }},
      { "@type": "Question", "name": "Will the JPG file be larger than the AVIF?", "acceptedAnswer": { "@type": "Answer", "text": "Often yes. AVIF is highly efficient; JPEG is chosen here for compatibility. At maximum quality, the JPG can be several times larger than the original AVIF — that is expected." }},
      { "@type": "Question", "name": "What JPEG quality should I use?", "acceptedAnswer": { "@type": "Answer", "text": "Default is 100% for closest visual match. Use 85% for smaller files with minimal visible loss, or 70% when file size is the priority." }},
      { "@type": "Question", "name": "Can I batch convert many AVIF files?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Select or drag multiple .avif files, then download each JPG or all files in one ZIP archive." }},
      { "@type": "Question", "name": "Does it work on mobile?", "acceptedAnswer": { "@type": "Answer", "text": "Yes on mobile browsers that support AVIF decoding and Canvas — typically current iOS Safari and Chrome on Android. Very large files may be slower." }},
      { "@type": "Question", "name": "Is there a monthly conversion limit?", "acceptedAnswer": { "@type": "Answer", "text": "No accounts, no quotas, and no premium tier. Use the converter as often as you need." }}
    ]
  })} />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>AVIF to JPG Converter</h1>
      <p class="subtitle">
        Turn AVIF files into JPEG using your browser’s native decoder — quality presets, batch ZIP, before/after sizes. Nothing is uploaded; AVIF support required.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop AVIF files here or click to browse</div>
        <div class="dropzone-sub">Requires a browser that natively decodes AVIF</div>
        <input type="file" id="fileInput" multiple accept=".avif,image/avif" />
      </div>

      <p class="converter-hint">
        <span id="hintMain">Converting at maximum quality</span>
        ·
        <button type="button" class="hint-toggle" id="toggleAdvanced" aria-expanded="false" aria-controls="advancedPanel">
          Change settings
        </button>
      </p>
      <div id="advancedPanel" class="advanced-panel" hidden>
        <p class="advanced-title">Advanced options</p>
        <div class="preset-buttons" role="radiogroup" aria-label="JPEG quality preset">
          <button type="button" class="preset-btn is-selected" data-q="100" role="radio" aria-checked="true">Maximum</button>
          <button type="button" class="preset-btn" data-q="85" role="radio" aria-checked="false">Balanced</button>
          <button type="button" class="preset-btn" data-q="70" role="radio" aria-checked="false">Small file</button>
        </div>
        <p class="preset-desc" id="presetDesc">100% quality — best fidelity, largest JPEGs.</p>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Converted files (<span id="fileCount">0</span>):
      </div>
      <div id="fileResultsRoot">
        <div id="resultsToolbar" class="results-toolbar" style="display:none">
          <label class="gallery-toggle">
            <input type="checkbox" id="galleryViewToggle" />
            Show thumbnails in list
          </label>
          <p class="toolbar-note" id="galleryToolbarNote" hidden></p>
        </div>
        <div class="results" id="results"></div>
        <div id="resultsMoreBlock" class="results-more-block" style="display:none">
          <button type="button" class="more-files-btn" id="moreFilesBtn">
            <span id="moreFilesLabel"></span>
          </button>
          <div id="resultsMore" class="results results-more-inner" hidden></div>
        </div>
      </div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- Educational content (SEO) -->
  <article class="avif-edu" aria-label="Guide: AVIF format and converting to JPG">
    <div class="container avif-edu-inner">
      <section class="avif-edu-block">
        <h2 id="what-is-avif">What is AVIF?</h2>
        <p>
          <strong>AVIF</strong> (AV1 Image File Format) is a modern image codec built on <strong>AV1</strong> video compression. It often produces <strong>smaller files than JPEG or WebP</strong> at similar visual quality, supports <strong>HDR</strong> and <strong>transparency</strong>, and is widely used for performance-minded websites. You will see <code>.avif</code> files from CDNs, modern export presets, and some phone or camera workflows.
        </p>
        <p>
          <strong>Why convert AVIF to JPG?</strong> Many desktop apps, email clients, print services, and legacy upload forms still expect <strong>JPEG</strong>. Converting gives you a universally accepted file — at the cost of larger size versus AVIF, which is normal.
        </p>
      </section>

      <section class="avif-edu-block">
        <h2 id="how-avif-to-jpg-works">How this converter works</h2>
        <p>
          Your browser must <strong>decode AVIF natively</strong>. The tool uses <strong>createImageBitmap</strong> when available, otherwise an <strong>Image</strong> element, then draws pixels to a <strong>canvas</strong> and calls <strong>toBlob('image/jpeg')</strong> at your selected quality. No WASM decoder and <strong>no upload</strong> — if the browser cannot decode AVIF, conversion cannot proceed on that device.
        </p>
        <ol class="avif-steps">
          <li><strong>Add AVIF files.</strong> Drop or browse; batch many at once.</li>
          <li><strong>Choose JPEG quality.</strong> Open Advanced options: Maximum (100%), Balanced (85%), or Small file (70%).</li>
          <li><strong>Download.</strong> Individual JPGs or <strong>Download All as ZIP</strong>.</li>
        </ol>
        <p>
          For other next-gen formats, see <a href="/image/webp-to-jpg/">WebP to JPG</a>. For Apple HEIC photos, use <a href="/image/heic-to-jpg/">HEIC to JPG</a>.
        </p>
      </section>

      <section class="avif-edu-block">
        <h2 id="avif-vs-jpg">AVIF vs JPG</h2>
        <div class="avif-table-wrap">
          <table class="avif-compare-table">
            <caption class="sr-only">Comparison of AVIF and JPG</caption>
            <thead>
              <tr>
                <th scope="col">Aspect</th>
                <th scope="col">AVIF</th>
                <th scope="col">JPG</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Typical file size</td><td>Often smallest for photos</td><td>Larger at equal quality</td></tr>
              <tr><td>Compatibility</td><td>Strong in modern browsers; weaker in some desktop apps</td><td>Universal</td></tr>
              <tr><td>Transparency</td><td>Yes</td><td>No</td></tr>
              <tr><td>Best for</td><td>Web delivery, Core Web Vitals</td><td>Sharing, email, print, legacy tools</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          For a full comparison including WebP, see <a href="/blog/best-image-format-for-web/">best image format for websites</a>.
        </p>
      </section>

      <section class="avif-edu-block">
        <h2 id="transparency-jpg">Transparency and white background</h2>
        <p>
          <strong>JPEG</strong> has no alpha channel. This tool fills the canvas with <strong>white</strong> before drawing the decoded AVIF, so transparent regions appear on white in the output — the same approach as our <a href="/image/webp-to-jpg/">WebP to JPG</a> tool.
        </p>
      </section>

      <section class="avif-edu-block">
        <h2 id="who-converts-avif">Who converts AVIF to JPEG?</h2>
        <ul class="avif-audience-list">
          <li><strong>Developers and designers</strong> handing assets to clients who only accept JPG.</li>
          <li><strong>Content creators</strong> submitting images to platforms without AVIF upload.</li>
          <li><strong>Anyone</strong> who received or downloaded AVIF and needs a familiar .jpg file.</li>
        </ul>
      </section>

      <section class="avif-edu-block">
        <h2 id="troubleshooting-avif">Troubleshooting</h2>
        <p>
          <strong>“AVIF not supported in this browser”:</strong> Update Chrome, Edge, Firefox, or Safari, or try another device. This page does not bundle a separate AVIF decoder.
        </p>
        <p>
          <strong>Huge JPG vs tiny AVIF:</strong> Expected — JPEG is less efficient; use a lower quality preset only if you accept more compression artifacts.
        </p>
        <p>
          <strong>Need smaller JPG without changing format first:</strong> After export, use our <a href="/image/image-compressor/">image compressor</a> on the JPG if your pipeline allows another step.
        </p>
      </section>
    </div>
  </article>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>Is AVIF to JPG conversion free and unlimited?</h4><p>Yes. No signup, watermarks, or usage caps. Conversion runs entirely in your browser.</p></div>
        <div class="faq-item"><h4>Are my AVIF files uploaded to a server?</h4><p>No. Files stay on your device. Decoding uses the browser's native AVIF support; JPEG is produced with the Canvas API locally.</p></div>
        <div class="faq-item"><h4>What is AVIF and why convert it to JPG?</h4><p>AVIF is a modern image format based on AV1 compression — often smaller than JPEG at similar quality. You convert to JPG when a workflow requires universal compatibility: email, older software, print, or upload forms that only accept JPEG.</p></div>
        <div class="faq-item"><h4>Which browsers can convert AVIF here?</h4><p>Your browser must decode AVIF natively. Current Chrome, Edge, Firefox, and recent Safari generally work. If conversion fails, update the browser or try another device — the tool cannot decode AVIF without OS/browser codec support.</p></div>
        <div class="faq-item"><h4>What happens to AVIF transparency?</h4><p>JPEG does not support alpha transparency. Transparent areas are composited on a white background before export, which is standard for AVIF to JPG conversion.</p></div>
        <div class="faq-item"><h4>Will the JPG file be larger than the AVIF?</h4><p>Often yes. AVIF is highly efficient; JPEG is chosen here for compatibility. At maximum quality, the JPG can be several times larger than the original AVIF — that is expected.</p></div>
        <div class="faq-item"><h4>What JPEG quality should I use?</h4><p>Default is 100% for closest visual match. Use 85% for smaller files with minimal visible loss, or 70% when file size is the priority.</p></div>
        <div class="faq-item"><h4>Can I batch convert many AVIF files?</h4><p>Yes. Select or drag multiple .avif files, then download each JPG or all files in one ZIP archive.</p></div>
        <div class="faq-item"><h4>Does it work on mobile?</h4><p>Yes on mobile browsers that support AVIF decoding and Canvas — typically current iOS Safari and Chrome on Android. Very large files may be slower.</p></div>
        <div class="faq-item"><h4>Is there a monthly conversion limit?</h4><p>No accounts, no quotas, and no premium tier. Use the converter as often as you need.</p></div>
      </div>
    </div>
  </section>

  <section class="avif-related" aria-label="Related tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="avif-related-grid">
        <li><a href="/image/webp-to-jpg/">WebP to JPG Converter</a></li>
        <li><a href="/image/heic-to-jpg/">HEIC to JPG Converter</a></li>
        <li><a href="/image/image-compressor/">Image Compressor</a></li>
        <li><a href="/image/image-resizer/">Image Resizer</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="avif-related-grid avif-related-guides">
        <li><a href="/blog/best-image-format-for-web/">Best Image Format for Websites (AVIF vs WebP vs JPG)</a></li>
        <li><a href="/blog/heic-vs-jpg/">HEIC vs JPG: Complete Comparison</a></li>
        <li><a href="/blog/convert-iphone-photos-to-jpg/">Convert iPhone Photos to JPG</a></li>
      </ul>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      const resultsMore = document.getElementById('resultsMore');
      let converted = [];

      function formatSizeForCompare(bytes) {
        const mb = bytes / (1024 * 1024);
        if (mb >= 0.01) return mb.toFixed(2) + ' MB';
        return (bytes / 1024).toFixed(1) + ' KB';
      }

      function getJpegQuality() {
        const btn = document.querySelector('.preset-btn.is-selected');
        return btn ? parseInt(btn.dataset.q, 10) / 100 : 1;
      }

      function wireQualityPresets() {
        const hintMain = document.getElementById('hintMain');
        const presetDesc = document.getElementById('presetDesc');
        const toggleAdvanced = document.getElementById('toggleAdvanced');
        const advancedPanel = document.getElementById('advancedPanel');
        const HINT = {
          '100': 'Converting at maximum quality',
          '85': 'Converting at balanced quality (85%)',
          '70': 'Converting for smallest file size (70%)',
        };
        const DESC = {
          '100': '100% quality — best fidelity, largest JPEGs.',
          '85': '85% — smaller files with minimal visible loss.',
          '70': '70% — smallest files; more compression visible.',
        };

        function syncPresetLabels() {
          const sel = document.querySelector('.preset-btn.is-selected');
          const q = sel ? sel.dataset.q : '100';
          if (hintMain) hintMain.textContent = HINT[q] || HINT['100'];
          if (presetDesc) presetDesc.textContent = DESC[q] || DESC['100'];
        }

        document.querySelectorAll('.preset-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('.preset-btn').forEach((b) => {
              b.classList.remove('is-selected');
              b.setAttribute('aria-checked', 'false');
            });
            btn.classList.add('is-selected');
            btn.setAttribute('aria-checked', 'true');
            syncPresetLabels();
          });
        });

        toggleAdvanced?.addEventListener('click', () => {
          const open = advancedPanel.hidden;
          advancedPanel.hidden = !open;
          toggleAdvanced.setAttribute('aria-expanded', open ? 'true' : 'false');
        });

        syncPresetLabels();
      }

      wireQualityPresets();

      async function decodeAvifToDrawable(file) {
        if (typeof createImageBitmap === 'function') {
          try {
            const bmp = await createImageBitmap(file);
            return { kind: 'bitmap', drawable: bmp };
          } catch (_) {
            /* fall through */
          }
        }
        return new Promise((resolve, reject) => {
          const url = URL.createObjectURL(file);
          const img = new Image();
          img.onload = () => {
            URL.revokeObjectURL(url);
            resolve({ kind: 'image', drawable: img });
          };
          img.onerror = () => {
            URL.revokeObjectURL(url);
            reject(new Error('AVIF not supported in this browser'));
          };
          img.crossOrigin = 'anonymous';
          img.src = url;
        });
      }

      function drawableToJpegBlob(drawable, kind, quality) {
        const w = kind === 'bitmap' ? drawable.width : drawable.naturalWidth || drawable.width;
        const h = kind === 'bitmap' ? drawable.height : drawable.naturalHeight || drawable.height;
        const canvas = document.createElement('canvas');
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, w, h);
        ctx.drawImage(drawable, 0, 0);
        if (kind === 'bitmap' && drawable.close) drawable.close();
        return new Promise((resolve, reject) => {
          canvas.toBlob(
            b => (b ? resolve(b) : reject(new Error('toBlob failed'))),
            'image/jpeg',
            quality
          );
        });
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', e => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', e => {
        const fs = Array.from(e.target.files);
        e.target.value = '';
        handleFiles(fs);
      });

      async function handleFiles(files) {
        if (!files || !files.length) return;
        const list = files.filter(
          f => f.type === 'image/avif' || /\.avif$/i.test(f.name)
        );
        if (!list.length) {
          alert('Please choose AVIF image files.');
          return;
        }

        const total = list.length;
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const toolbar = document.getElementById('resultsToolbar');
        if (toolbar) toolbar.style.display = 'none';
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;

        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Converting ' + total + ' file(s)...';

        const quality = getJpegQuality();
        let idx = 0;

        for (const file of list) {
          const parent = window.DoItSwiftFileResults
            ? DoItSwiftFileResults.getAppendParent(results, resultsMore, idx)
            : results;
          idx += 1;

          const item = document.createElement('div');
          item.className = 'file-item';
          item.innerHTML = `
            <div class="file-item-main">
              <div class="file-thumb" aria-hidden="true">🖼️</div>
              <div class="file-info">
                <div class="file-name"></div>
                <div class="file-status">Converting…</div>
                <div class="progress-bar"><div class="progress-fill"></div></div>
              </div>
              <div class="file-actions-col">
                <button type="button" class="btn-text btn-preview" disabled style="visibility:hidden">Preview</button>
              </div>
            </div>
            <div class="file-preview-panel" hidden>
              <img alt="Preview" />
            </div>
          `;
          item.querySelector('.file-name').textContent = file.name;
          parent.appendChild(item);
          const fill = item.querySelector('.progress-fill');
          const status = item.querySelector('.file-status');
          fill.style.width = '40%';

          try {
            const { kind, drawable } = await decodeAvifToDrawable(file);
            const finalBlob = await drawableToJpegBlob(drawable, kind, quality);
            const url = URL.createObjectURL(finalBlob);
            const newName = file.name.replace(/\.avif$/i, '.jpg');
            converted.push({ name: newName, blob: finalBlob });
            fill.style.width = '100%';
            status.className = 'file-status done';
            status.innerHTML =
              '<span class="size-compare">Original: ' +
              formatSizeForCompare(file.size) +
              ' → Converted: ' +
              formatSizeForCompare(finalBlob.size) +
              '</span>';
            const actionsCol = item.querySelector('.file-actions-col');
            const dl = document.createElement('a');
            dl.href = url;
            dl.download = newName;
            dl.className = 'btn';
            dl.textContent = 'Download';
            actionsCol.appendChild(dl);
            if (window.DoItSwiftFileResults) {
              DoItSwiftFileResults.initCompletedRow(item, url);
            }
          } catch (err) {
            fill.style.width = '100%';
            fill.style.background = '#ef4444';
            status.className = 'file-status error';
            status.textContent = 'Error: ' + (err.message || 'Failed');
          }
        }

        if (converted.length) {
          actions.style.display = 'flex';
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(converted.length);
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + converted.length + ' file(s) ready — see list below';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const batchOver10 = total > 10;
          if (window.DoItSwiftFileResults) {
            DoItSwiftFileResults.setupToolbar({
              toolbar: document.getElementById('resultsToolbar'),
              galleryToggle: document.getElementById('galleryViewToggle'),
              note: document.getElementById('galleryToolbarNote'),
              batchOver10,
              galleryRoot: document.getElementById('fileResultsRoot'),
            });
            if (total > 10) {
              DoItSwiftFileResults.setupMoreFilesSection({
                moreBlock: document.getElementById('resultsMoreBlock'),
                moreInner: document.getElementById('resultsMore'),
                moreBtn: document.getElementById('moreFilesBtn'),
                moreLabel: document.getElementById('moreFilesLabel'),
                extraCount: total - 10,
              });
            }
          }
        }
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const tb = document.getElementById('resultsToolbar');
        if (tb) tb.style.display = 'none';
        const gt = document.getElementById('galleryViewToggle');
        if (gt) {
          gt.checked = false;
          gt.disabled = false;
        }
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;
        converted = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined') return alert('ZIP library not loaded.');
        const zip = new JSZip();
        converted.forEach(f => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const url = URL.createObjectURL(content);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'doitswift-avif-to-jpg.zip';
        a.click();
        URL.revokeObjectURL(url);
      });

      void (async () => {
        try {
          const pending = await window.DoItSwiftPending?.consume?.();
          if (pending) await handleFiles([pending]);
        } catch (e) {
          console.warn(e);
        }
      })();
    });
  </script>

