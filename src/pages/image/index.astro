---
import MainLayout from '../../layouts/MainLayout.astro';

const tools = [
  { href: '/image/heic-to-jpg/', icon: '📱', title: 'HEIC to JPG', desc: 'Convert iPhone photos to JPG' },
  { href: '/image/webp-to-jpg/', icon: '🖼️', title: 'WEBP to JPG', desc: 'Convert WebP images instantly' },
  { href: '/image/image-compressor/', icon: '🗜️', title: 'Image Compressor', desc: 'Shrink files with a quality slider' },
  { href: '/image/image-resizer/', icon: '📐', title: 'Image Resizer', desc: 'Resize for web or print' },
  { href: '/image/svg-to-png/', icon: '🎨', title: 'SVG to PNG', desc: 'Convert vectors to raster' },
  { href: '/image/favicon-generator/', icon: '⭐', title: 'Favicon Generator', desc: 'Create multi-size ICO files' },
  { href: '/image/avif-to-jpg/', icon: '✨', title: 'AVIF to JPG', desc: 'Convert next-gen AVIF images' },
  { href: '/image/image-to-base64/', icon: '🔢', title: 'Image to Base64', desc: 'Encode images for HTML or APIs' },
];

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Free Online Image Tools',
  description:
    'Free browser-based image tools. Convert HEIC, WEBP, AVIF, SVG. Compress and resize images. No upload, no signup, unlimited usage.',
  url: new URL(Astro.url.pathname, Astro.site).href,
  isPartOf: {
    '@type': 'WebSite',
    name: 'DoItSwift',
    url: new URL('/', Astro.site).href,
  },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: tools.length,
    itemListElement: tools.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: t.title,
      url: new URL(t.href, Astro.site).href,
      description: t.desc,
    })),
  },
};
---

<MainLayout
  title="Free Online Image Tools — Convert, Compress, Resize Images | DoItSwift"
  description="Free browser-based image tools. Convert HEIC, WEBP, AVIF, SVG. Compress and resize images. No upload, no signup, unlimited usage."
  keywords="image converter, heic to jpg, webp converter, image compressor, free image tools, browser image tools, doitswift"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionJsonLd)} />

  <section class="hero">
    <div class="container">
      <div class="badge">🖼️ Image Tools</div>
      <h1>Free Online Image Tools</h1>
      <p class="subtitle">
        Convert, compress, and resize images instantly in your browser. No uploads, no limits.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> 100% browser-based</span>
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No watermarks</span>
        <span><span class="check">✓</span> Works offline</span>
      </div>
    </div>
  </section>

  <section class="tools-section">
    <div class="container">
      <h2 class="section-title">All image tools</h2>
      <p class="section-sub">Pick a tool — processing stays on your device.</p>
      <div class="grid">
        {tools.map((tool) => (
          <a href={tool.href} class="tool-card">
            <span class="icon">{tool.icon}</span>
            <h3>{tool.title}</h3>
            <p>{tool.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="formats">
    <div class="container">
      <h2 class="section-title">About image formats</h2>
      <p class="section-sub">Quick reference for the formats DoItSwift tools handle most often.</p>
      <div class="formats-grid">
        <div class="format-card">
          <h3>HEIC / HEIF</h3>
          <p>
            Apple’s default photo format on iPhone and iPad. It saves space with modern compression. Many desktops need a
            conversion to JPG or PNG for editing or sharing — our HEIC to JPG tool does that locally in your browser.
          </p>
        </div>
        <div class="format-card">
          <h3>WEBP</h3>
          <p>
            Google’s web-optimized format: strong compression with transparency support. Not every older app opens WebP;
            converting to JPG is a common step when you need maximum compatibility.
          </p>
        </div>
        <div class="format-card">
          <h3>AVIF</h3>
          <p>
            A next-generation format with excellent size-to-quality ratio. Support is growing; when you need a JPG for a
            legacy workflow, use AVIF to JPG — decoding happens with your browser’s native AVIF support.
          </p>
        </div>
        <div class="format-card">
          <h3>PNG</h3>
          <p>
            Lossless raster images with transparency. Great for UI assets and graphics. PNG files are often larger than
            JPG; compressing or converting to JPG can shrink photos when transparency is not needed.
          </p>
        </div>
        <div class="format-card">
          <h3>JPG / JPEG</h3>
          <p>
            The universal photo format for web and print previews. Lossy compression; ideal for photographs and any
            situation where a smaller file matters and slight quality loss is acceptable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Image tools FAQ</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Which format should I use for my website?</h4>
          <p>
            For photos, modern sites often serve WebP or AVIF with a JPG fallback. For logos with transparency, PNG or
            SVG is typical. Use our compress and resize tools to keep file sizes small without visible quality loss.
          </p>
        </div>
        <div class="faq-item">
          <h4>Are my images uploaded to DoItSwift?</h4>
          <p>
            No. These tools run in your browser; your files stay on your device unless you explicitly use a future feature
            that says otherwise. Disconnect from the internet after the page loads and conversions still work.
          </p>
        </div>
        <div class="faq-item">
          <h4>Will converting reduce quality?</h4>
          <p>
            JPG and lossy compression always trade size for quality. Use higher quality settings when you need crisp
            output; use stronger compression for thumbnails and social previews.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I process many files at once?</h4>
          <p>
            Yes. Most tools support batch selection or drag-and-drop of multiple files, with ZIP download where it makes
            sense. There are no artificial batch limits.
          </p>
        </div>
        <div class="faq-item">
          <h4>Do these tools work on mobile?</h4>
          <p>
            Yes. Use Safari on iPhone, Chrome on Android, or any modern mobile browser. Very large files may be slower on
            older phones.
          </p>
        </div>
      </div>
    </div>
  </section>

  <p class="back-wrap container">
    <a href="/" class="link-back">← Back to home</a>
  </p>

  <style>
    .hero {
      padding: 56px 0 24px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 620px;
      margin: 0 auto 28px;
    }
    .section-title {
      text-align: center;
      margin-bottom: 8px;
    }
    .section-sub {
      text-align: center;
      color: var(--text-muted);
      margin-bottom: 32px;
      font-size: 16px;
    }
    .tools-section {
      padding: 40px 0 56px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 14px;
    }
    .tool-card {
      background: var(--card);
      padding: 22px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }
    .tool-card:hover {
      border-color: var(--blue);
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
    }
    .tool-card .icon {
      font-size: 30px;
      display: block;
      margin-bottom: 10px;
    }
    .tool-card h3 {
      font-size: 15px;
      margin-bottom: 4px;
    }
    .tool-card p {
      font-size: 12px;
      color: var(--text-muted);
    }
    .formats {
      padding: 40px 0 56px;
      background: var(--card);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .formats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
      margin-top: 8px;
    }
    .format-card {
      padding: 22px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg);
    }
    .format-card h3 {
      font-size: 17px;
      margin-bottom: 8px;
    }
    .format-card p {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.6;
      margin: 0;
    }
    .faq {
      padding: 56px 0 40px;
    }
    .faq .container {
      max-width: 820px;
    }
    .faq-list {
      margin-top: 28px;
    }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 12px;
      box-shadow: var(--shadow);
    }
    .faq-item h4 {
      font-size: 16px;
      margin-bottom: 6px;
    }
    .faq-item p {
      font-size: 14px;
      color: var(--text-muted);
      margin: 0;
    }
    .back-wrap {
      padding-bottom: 48px;
      text-align: center;
    }
  </style>
</MainLayout>
