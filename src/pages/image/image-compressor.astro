---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Free Image Compressor — JPG & PNG to Smaller JPEG | Private & Unlimited | DoItSwift"
  description="Compress JPG and PNG images in your browser — free, private, unlimited. Adjustable JPEG quality (30–100%), before/after file sizes on every row, batch download as ZIP. No uploads; files never leave your device."
  keywords="image compressor, compress jpg, compress png, reduce image file size, shrink photos, jpeg quality, compress images online free, batch compress images, photo compressor browser, optimize images for web, smaller jpg"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <!-- Schema markup for SEO (aligned with on-page FAQ) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is this image compressor really free and unlimited?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. No limits, no signup, no watermarks. Compression runs in your browser using your device — we do not charge or meter usage." }},
      { "@type": "Question", "name": "Are my photos private? Do you upload files?", "acceptedAnswer": { "@type": "Answer", "text": "Your files never leave your device. Compression uses the Canvas API locally; we cannot see, store, or access your images." }},
      { "@type": "Question", "name": "What do before and after sizes mean?", "acceptedAnswer": { "@type": "Answer", "text": "Before is your original file size. After is the new JPEG size at your chosen quality setting, shown in kilobytes on each row." }},
      { "@type": "Question", "name": "Why does PNG upload become a JPG download?", "acceptedAnswer": { "@type": "Answer", "text": "This tool re-encodes images as JPEG so you can control size with the quality slider. Lossless PNG recompression in the browser rarely shrinks photos much; JPEG gives predictable savings. Transparent areas are composited on white." }},
      { "@type": "Question", "name": "What JPEG quality should I use for websites or email?", "acceptedAnswer": { "@type": "Answer", "text": "For web photos, 75–85% is a common sweet spot. For email or archiving when quality matters, use 90–100%. Lower settings (below 70%) shrink files more but show stronger compression artifacts." }},
      { "@type": "Question", "name": "Will compression ruin print quality?", "acceptedAnswer": { "@type": "Answer", "text": "At high quality (90–100%) changes are usually invisible on screen. For professional printing, keep quality high or use your original files; heavy compression is meant for screens and sharing." }},
      { "@type": "Question", "name": "Does it work on mobile?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — on iPhone, iPad, Android, and modern mobile browsers that support the Canvas API." }},
      { "@type": "Question", "name": "Is there a maximum file size?", "acceptedAnswer": { "@type": "Answer", "text": "There is no fixed cap — practical limits depend on your device RAM. Very large images may take longer or fail on low-memory tabs." }},
      { "@type": "Question", "name": "Can I compress many images at once?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Select or drag multiple JPG and PNG files, then download each result or all compressed files as one ZIP." }},
      { "@type": "Question", "name": "Is there a monthly conversion limit?", "acceptedAnswer": { "@type": "Answer", "text": "No. Compress as many images as you want. There are no accounts, quotas, or premium tiers." }}
    ]
  })} />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Image Compressor</h1>
      <p class="subtitle">
        Shrink JPG and PNG photos in your browser — adjustable JPEG quality, before/after sizes on every file, batch ZIP download. Nothing is uploaded.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop JPG or PNG files here or click to browse</div>
        <div class="dropzone-sub">PNG files are output as compressed JPG (transparency → white)</div>
        <input type="file" id="fileInput" multiple accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
      </div>

      <div class="controls">
        <label>JPEG quality:</label>
        <input type="range" id="quality" min="30" max="100" value="80" />
        <span class="quality-val" id="qualityVal">80%</span>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Compressed files (<span id="fileCount">0</span>):
      </div>
      <div id="fileResultsRoot">
        <div id="resultsToolbar" class="results-toolbar" style="display:none">
          <label class="gallery-toggle">
            <input type="checkbox" id="galleryViewToggle" />
            Show thumbnails in list
          </label>
          <p class="toolbar-note" id="galleryToolbarNote" hidden></p>
        </div>
        <div class="results" id="results"></div>
        <div id="resultsMoreBlock" class="results-more-block" style="display:none">
          <button type="button" class="more-files-btn" id="moreFilesBtn">
            <span id="moreFilesLabel"></span>
          </button>
          <div id="resultsMore" class="results results-more-inner" hidden></div>
        </div>
      </div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- Educational content (SEO) -->
  <article class="compress-edu" aria-label="Guide: compressing JPG and PNG images">
    <div class="container compress-edu-inner">
      <section class="compress-edu-block">
        <h2 id="what-is-image-compression">What is image compression (and why file size matters)?</h2>
        <p>
          <strong>Image compression</strong> means reducing how many bytes an image uses while keeping it usable. On the web, smaller files load faster — which helps <strong>Core Web Vitals</strong>, mobile users on slow networks, and email inboxes with attachment limits. For personal use, compression makes it easier to <strong>share photos on WhatsApp</strong>, fit uploads into forms, or free up storage before backup.
        </p>
        <p>
          There are two broad approaches: <strong>lossless</strong> compression (smaller file, identical pixels — typical for PNG) and <strong>lossy</strong> compression (smaller file by discarding imperceptible detail — typical for JPEG). This tool focuses on <strong>JPEG quality</strong> you control with a slider, so you decide the trade-off between size and fidelity.
        </p>
      </section>

      <section class="compress-edu-block">
        <h2 id="why-compress-jpg-png">Why compress JPG and PNG images?</h2>
        <p>
          <strong>JPEG photos</strong> are often exported from cameras or phones at higher quality than needed for screens. Dropping from an oversized original to <strong>75–85% JPEG quality</strong> can cut file size dramatically with little visible change on a phone or laptop display.
        </p>
        <p>
          <strong>PNG</strong> is ideal for screenshots, logos, and graphics with sharp edges; for <strong>photographic PNGs</strong> (e.g. exports from design tools), file size can be huge. Converting to <strong>JPEG</strong> with controlled quality is a standard way to shrink those assets when you do not need transparency.
        </p>
        <p>
          If your goal is <strong>modern web formats</strong> (WebP, AVIF) for maximum savings on a site, see our <a href="/blog/best-image-format-for-web/">image format guide</a> — this compressor is optimized for fast <strong>JPG output</strong> and universal compatibility.
        </p>
      </section>

      <section class="compress-edu-block">
        <h2 id="how-compressor-works">How this compressor works in your browser</h2>
        <p>
          Images are decoded in your tab, drawn to an HTML <strong>canvas</strong>, and exported as a new <strong>JPEG</strong> blob at your selected quality. No data is sent to DoItSwift servers — processing stays on your device.
        </p>
        <ol class="compress-steps">
          <li><strong>Add images.</strong> Drop JPG or PNG files, or click to browse. Batch many files at once.</li>
          <li><strong>Set quality.</strong> Use the slider (30–100%). Default is 80% — a common balance for web-style photos.</li>
          <li><strong>Review sizes.</strong> Each row shows <strong>Before → After</strong> in kilobytes so you can compare savings.</li>
          <li><strong>Download.</strong> Save files one by one or use <strong>Download All as ZIP</strong>.</li>
        </ol>
      </section>

      <section class="compress-edu-block">
        <h2 id="jpeg-quality-guide">JPEG quality: what the numbers mean</h2>
        <div class="compress-table-wrap">
          <table class="compress-compare-table">
            <caption class="sr-only">JPEG quality ranges and typical use</caption>
            <thead>
              <tr>
                <th scope="col">Quality range</th>
                <th scope="col">Typical use</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>90–100%</td><td>Minimal visible loss; larger files — good for archiving or high-res sharing when size is secondary.</td></tr>
              <tr><td>75–85%</td><td>Sweet spot for many websites and social posts — strong size reduction, usually fine on screen.</td></tr>
              <tr><td>60–75%</td><td>Smaller files; check thumbnails — may show banding on gradients or skies.</td></tr>
              <tr><td>30–60%</td><td>Maximum shrink; obvious artifacts on close inspection — use only when tiny file size is the priority.</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          The slider on this page runs from <strong>30% to 100%</strong>. Move it down to see smaller “After” sizes; move it up if you see artifacts you dislike.
        </p>
      </section>

      <section class="compress-edu-block">
        <h2 id="png-to-jpg-note">Why PNG uploads become JPEG downloads</h2>
        <p>
          <strong>PNG</strong> uses lossless compression — you cannot “turn down quality” the same way as JPEG. To achieve meaningful size reduction for photos, this tool outputs <strong>JPG</strong>. <strong>Transparent</strong> PNG areas are composited on a <strong>white background</strong> (same approach as our <a href="/image/webp-to-jpg/">WebP to JPG</a> tool). If you must keep transparency, keep the PNG or use a format that supports alpha (see the <a href="/blog/best-image-format-for-web/">format comparison</a>).
        </p>
      </section>

      <section class="compress-edu-block">
        <h2 id="who-uses-compressor">Who uses an image compressor?</h2>
        <ul class="compress-audience-list">
          <li><strong>Website owners</strong> optimizing hero images and blog photos before upload.</li>
          <li><strong>Job seekers and students</strong> shrinking headshots and scans to meet portal limits.</li>
          <li><strong>Real estate and e-commerce</strong> teams batch-processing listing photos.</li>
          <li><strong>Anyone emailing large attachments</strong> when the inbox caps file size.</li>
          <li><strong>Social media users</strong> reducing camera originals before posting or messaging.</li>
        </ul>
      </section>

      <section class="compress-edu-block">
        <h2 id="troubleshooting-compress">Troubleshooting</h2>
        <p>
          <strong>“After” is larger than “before”:</strong> Can happen if the original was already heavily compressed JPEG — re-encoding adds overhead or your quality setting is high. Try a lower quality or keep the original.
        </p>
        <p>
          <strong>Errors or slow runs:</strong> Try another browser, close heavy tabs, or reduce image dimensions elsewhere (e.g. our <a href="/image/image-resizer/">image resizer</a>) before compressing.
        </p>
      </section>
    </div>
  </article>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>Is this image compressor really free and unlimited?</h4><p>Yes. No limits, no signup, no watermarks. Compression runs in your browser using your device — we do not charge or meter usage.</p></div>
        <div class="faq-item"><h4>Are my photos private? Do you upload files?</h4><p>Your files never leave your device. Compression uses the Canvas API locally; we cannot see, store, or access your images.</p></div>
        <div class="faq-item"><h4>What do before and after sizes mean?</h4><p>Before is your original file size. After is the new JPEG size at your chosen quality setting, shown in kilobytes on each row.</p></div>
        <div class="faq-item"><h4>Why does PNG upload become a JPG download?</h4><p>This tool re-encodes images as JPEG so you can control size with the quality slider. Lossless PNG recompression in the browser rarely shrinks photos much; JPEG gives predictable savings. Transparent areas are composited on white.</p></div>
        <div class="faq-item"><h4>What JPEG quality should I use for websites or email?</h4><p>For web photos, 75–85% is a common sweet spot. For email or archiving when quality matters, use 90–100%. Lower settings (below 70%) shrink files more but show stronger compression artifacts.</p></div>
        <div class="faq-item"><h4>Will compression ruin print quality?</h4><p>At high quality (90–100%) changes are usually invisible on screen. For professional printing, keep quality high or use your original files; heavy compression is meant for screens and sharing.</p></div>
        <div class="faq-item"><h4>Does it work on mobile?</h4><p>Yes — on iPhone, iPad, Android, and modern mobile browsers that support the Canvas API.</p></div>
        <div class="faq-item"><h4>Is there a maximum file size?</h4><p>There is no fixed cap — practical limits depend on your device RAM. Very large images may take longer or fail on low-memory tabs.</p></div>
        <div class="faq-item"><h4>Can I compress many images at once?</h4><p>Yes. Select or drag multiple JPG and PNG files, then download each result or all compressed files as one ZIP.</p></div>
        <div class="faq-item"><h4>Is there a monthly conversion limit?</h4><p>No. Compress as many images as you want. There are no accounts, quotas, or premium tiers.</p></div>
      </div>
    </div>
  </section>

  <section class="compress-related" aria-label="Related tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="compress-related-grid">
        <li><a href="/image/image-resizer/">Image Resizer</a></li>
        <li><a href="/image/webp-to-jpg/">WebP to JPG Converter</a></li>
        <li><a href="/image/heic-to-jpg/">HEIC to JPG Converter</a></li>
        <li><a href="/image/avif-to-jpg/">AVIF to JPG Converter</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="compress-related-grid compress-related-guides">
        <li><a href="/blog/best-image-format-for-web/">Best Image Format for Websites (WebP vs AVIF vs JPG)</a></li>
        <li><a href="/blog/how-to-compress-pdf/">How to Compress a PDF</a></li>
        <li><a href="/blog/heic-vs-jpg/">HEIC vs JPG: Complete Comparison</a></li>
      </ul>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      const resultsMore = document.getElementById('resultsMore');
      const qualitySlider = document.getElementById('quality');
      const qualityVal = document.getElementById('qualityVal');
      let converted = [];

      qualitySlider.addEventListener('input', e => { qualityVal.textContent = e.target.value + '%'; });

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag'); });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', e => {
        const fs = Array.from(e.target.files);
        e.target.value = '';
        handleFiles(fs);
      });

      function loadImage(file) {
        return new Promise((resolve, reject) => {
          const url = URL.createObjectURL(file);
          const img = new Image();
          img.onload = () => { URL.revokeObjectURL(url); resolve(img); };
          img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Could not decode image')); };
          img.crossOrigin = 'anonymous';
          img.src = url;
        });
      }

      function toJpegBlob(img, quality) {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth || img.width;
        canvas.height = img.naturalHeight || img.height;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(img, 0, 0);
        return new Promise((resolve, reject) => {
          canvas.toBlob(
            b => (b ? resolve(b) : reject(new Error('toBlob failed'))),
            'image/jpeg',
            quality
          );
        });
      }

      function outName(originalName) {
        const base = originalName.replace(/\.(jpe?g|png)$/i, '');
        return base + '.jpg';
      }

      async function handleFiles(files) {
        if (!files || !files.length) return;
        const list = files.filter(f => {
          const t = (f.type || '').toLowerCase();
          const n = f.name.toLowerCase();
          return t === 'image/jpeg' || t === 'image/png' || /\.(jpe?g|png)$/i.test(n);
        });
        if (!list.length) {
          alert('Please choose JPG or PNG images.');
          return;
        }

        const total = list.length;
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const toolbar = document.getElementById('resultsToolbar');
        if (toolbar) toolbar.style.display = 'none';
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;

        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Compressing ' + total + ' file(s)...';

        const quality = qualitySlider.value / 100;
        let idx = 0;

        for (const file of list) {
          const beforeKb = (file.size / 1024).toFixed(1);
          const parent = window.DoItSwiftFileResults
            ? DoItSwiftFileResults.getAppendParent(results, resultsMore, idx)
            : results;
          idx += 1;

          const item = document.createElement('div');
          item.className = 'file-item';
          item.innerHTML = `
            <div class="file-item-main">
              <div class="file-thumb" aria-hidden="true">🖼️</div>
              <div class="file-info">
                <div class="file-name"></div>
                <div class="file-status">Compressing…</div>
                <div class="progress-bar"><div class="progress-fill"></div></div>
              </div>
              <div class="file-actions-col">
                <button type="button" class="btn-text btn-preview" disabled style="visibility:hidden">Preview</button>
              </div>
            </div>
            <div class="file-preview-panel" hidden>
              <img alt="Preview" />
            </div>
          `;
          item.querySelector('.file-name').textContent = file.name;
          parent.appendChild(item);
          const fill = item.querySelector('.progress-fill');
          const status = item.querySelector('.file-status');
          fill.style.width = '40%';

          try {
            const img = await loadImage(file);
            const finalBlob = await toJpegBlob(img, quality);
            const afterKb = (finalBlob.size / 1024).toFixed(1);
            const url = URL.createObjectURL(finalBlob);
            const newName = outName(file.name);
            converted.push({ name: newName, blob: finalBlob });
            fill.style.width = '100%';
            status.className = 'file-status done';
            status.textContent = 'Before ' + beforeKb + ' KB → After ' + afterKb + ' KB';
            const actionsCol = item.querySelector('.file-actions-col');
            const dl = document.createElement('a');
            dl.href = url;
            dl.download = newName;
            dl.className = 'btn';
            dl.textContent = 'Download';
            actionsCol.appendChild(dl);
            if (window.DoItSwiftFileResults) {
              DoItSwiftFileResults.initCompletedRow(item, url);
            }
          } catch (err) {
            fill.style.width = '100%';
            fill.style.background = '#ef4444';
            status.className = 'file-status error';
            status.textContent = 'Error: ' + (err.message || 'Failed');
          }
        }

        if (converted.length) {
          actions.style.display = 'flex';
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(converted.length);
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + converted.length + ' file(s) ready — see list below';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const batchOver10 = total > 10;
          if (window.DoItSwiftFileResults) {
            DoItSwiftFileResults.setupToolbar({
              toolbar: document.getElementById('resultsToolbar'),
              galleryToggle: document.getElementById('galleryViewToggle'),
              note: document.getElementById('galleryToolbarNote'),
              batchOver10,
              galleryRoot: document.getElementById('fileResultsRoot'),
            });
            if (total > 10) {
              DoItSwiftFileResults.setupMoreFilesSection({
                moreBlock: document.getElementById('resultsMoreBlock'),
                moreInner: document.getElementById('resultsMore'),
                moreBtn: document.getElementById('moreFilesBtn'),
                moreLabel: document.getElementById('moreFilesLabel'),
                extraCount: total - 10,
              });
            }
          }
        }
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const tb = document.getElementById('resultsToolbar');
        if (tb) tb.style.display = 'none';
        const gt = document.getElementById('galleryViewToggle');
        if (gt) {
          gt.checked = false;
          gt.disabled = false;
        }
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;
        converted = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined') return alert('ZIP library not loaded.');
        const zip = new JSZip();
        converted.forEach(f => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const url = URL.createObjectURL(content);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'doitswift-compressed.zip';
        a.click();
        URL.revokeObjectURL(url);
      });

      void (async () => {
        try {
          const pending = await window.DoItSwiftPending?.consume?.();
          if (pending) await handleFiles([pending]);
        } catch (e) {
          console.warn(e);
        }
      })();
    });
  </script>

  <style>
    .hero { padding: 60px 0 20px; text-align: center; }
    .subtitle { font-size: 19px; color: var(--text-muted); max-width: 620px; margin: 0 auto 28px; }

    .converter-section { padding: 30px 0; }
    .converter-section .container { max-width: 820px; }

    .banner {
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      font-weight: 600;
      text-align: center;
    }
    .banner-info { background: #dbeafe; color: #1e40af; }
    .banner-success { background: #d1fae5; color: #065f46; }
    [data-theme="dark"] .banner-info { background: rgba(30, 64, 175, .2); color: #93c5fd; }
    [data-theme="dark"] .banner-success { background: rgba(6, 95, 70, .2); color: #6ee7b7; }

    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 70px 20px;
      text-align: center;
      cursor: pointer;
      transition: all .2s;
      box-shadow: var(--shadow);
    }
    .dropzone:hover, .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    [data-theme="dark"] .dropzone.drag { background: rgba(0, 102, 255, .1); }
    .dropzone-icon { font-size: 56px; margin-bottom: 14px; }
    .dropzone-text { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
    .dropzone-sub { font-size: 14px; color: var(--text-muted); }
    #fileInput { display: none; }

    .controls {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-top: 16px;
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .controls label { font-size: 14px; font-weight: 600; }
    .controls input[type=range] { flex: 1; min-width: 150px; }
    .quality-val { font-size: 14px; font-weight: 600; color: var(--blue); min-width: 40px; }

    .faq { padding: 60px 0; }
