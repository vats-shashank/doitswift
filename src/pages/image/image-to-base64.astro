---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Image to Base64 Encoder — Data URL or Raw, Copy & ZIP | DoItSwift"
  description="Encode images to Base64 in your browser: full data URL (data:image/…;base64,…) or raw payload only. One-click copy, batch ZIP of .txt files. Uses FileReader locally — no upload. PNG, JPG, WebP, GIF, SVG, and more."
  keywords="image to base64, base64 image encoder, data url generator, data:image base64, raw base64 string, copy base64 to clipboard, browser base64 encode, file to base64, free base64 converter, batch image base64"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "DoItSwift Image to Base64",
    "description": "Encode images to Base64 text in the browser using FileReader.readAsDataURL. Output as full data URLs or raw Base64 only; copy to clipboard or download batch as ZIP of text files. No server upload.",
    "url": "https://doitswift.com/image/image-to-base64/",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web browser",
    "browserRequirements": "Requires JavaScript FileReader and Clipboard API or execCommand fallback for copy",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "Encode any image/* file the browser accepts to Base64",
      "Choose data URL (with data:image/…;base64, prefix) or raw Base64 string only",
      "Per-file Copy button with Clipboard API and fallback",
      "Read-only textarea with full string length for each image",
      "Batch download all encoded strings as a ZIP of .txt files",
      "100% local processing — bytes are not uploaded to DoItSwift"
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is the image to Base64 tool free and unlimited?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Encode as many images as you need with no signup, watermarks, or quotas. Processing uses your browser only." }},
      { "@type": "Question", "name": "Are my images uploaded to your servers?", "acceptedAnswer": { "@type": "Answer", "text": "No. The FileReader API reads each file entirely on your device. Base64 text is generated locally; nothing is sent to DoItSwift." }},
      { "@type": "Question", "name": "What is the difference between Data URL and raw Base64?", "acceptedAnswer": { "@type": "Answer", "text": "A Data URL is the full string starting with data:image/type;base64, followed by the encoded bytes — ready to paste into HTML or CSS src attributes. Raw mode returns only the Base64 payload after the comma, which many APIs and JSON fields expect." }},
      { "@type": "Question", "name": "How do I copy the encoded string?", "acceptedAnswer": { "@type": "Answer", "text": "Use the Copy button on each row. The tool uses the Clipboard API when available, with a fallback for older browsers. You can also select the textarea manually." }},
      { "@type": "Question", "name": "Why does clipboard copy fail sometimes?", "acceptedAnswer": { "@type": "Answer", "text": "Some browsers only expose the Clipboard API on secure origins (HTTPS or localhost). If copy fails, select the text in the box and use your system copy command." }},
      { "@type": "Question", "name": "Are large images a problem?", "acceptedAnswer": { "@type": "Answer", "text": "Base64 expands file size by roughly 33%. Very large images produce very long strings, which can slow the page or stress memory — prefer smaller sources or compress images first." }},
      { "@type": "Question", "name": "Can I encode many images at once?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Drop or select multiple images; each gets its own textarea and Copy button. Download All as ZIP saves each string as a .txt file." }},
      { "@type": "Question", "name": "How do I switch between Data URL and raw mode for the same files?", "acceptedAnswer": { "@type": "Answer", "text": "Select the output format radio option before adding files. To regenerate with a different mode, use Clear All and drop the images again with the other option selected." }},
      { "@type": "Question", "name": "Does it work offline or on mobile?", "acceptedAnswer": { "@type": "Answer", "text": "After the page loads, encoding works offline. Mobile browsers generally support FileReader; very large batches may be slower on phones." }},
      { "@type": "Question", "name": "Is there a monthly limit or account required?", "acceptedAnswer": { "@type": "Answer", "text": "No accounts, no quotas, and no premium tier." }}
    ]
  })} />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Image to Base64</h1>
      <p class="subtitle">
        Encode PNG, JPG, WebP, GIF, SVG, and more to Base64 — full data URL or raw string only. Copy per file or download a ZIP of .txt exports. All local; no upload.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop images here or click to browse</div>
        <div class="dropzone-sub">PNG, JPG, WebP, GIF, SVG, and more — as many as you want</div>
        <input type="file" id="fileInput" multiple accept="image/*" />
      </div>

      <div class="controls controls-stack">
        <span class="controls-label">Output format</span>
        <label class="radio-row">
          <input type="radio" name="outMode" value="dataurl" checked />
          <span>Data URL <code>data:image/…;base64,…</code></span>
        </label>
        <label class="radio-row">
          <input type="radio" name="outMode" value="raw" />
          <span>Raw Base64 only (no prefix)</span>
        </label>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Encoded strings (<span id="fileCount">0</span>):
      </div>
      <div id="fileResultsRoot">
        <div id="resultsToolbar" class="results-toolbar" style="display:none">
          <label class="gallery-toggle">
            <input type="checkbox" id="galleryViewToggle" />
            Show thumbnails in list
          </label>
          <p class="toolbar-note" id="galleryToolbarNote" hidden></p>
        </div>
        <div class="results" id="results"></div>
        <div id="resultsMoreBlock" class="results-more-block" style="display:none">
          <button type="button" class="more-files-btn" id="moreFilesBtn">
            <span id="moreFilesLabel"></span>
          </button>
          <div id="resultsMore" class="results results-more-inner" hidden></div>
        </div>
      </div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP (.txt)</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- Educational content (SEO) -->
  <article class="base64-edu" aria-label="Guide: Base64 encoding for images">
    <div class="container base64-edu-inner">
      <section class="base64-edu-block">
        <h2 id="what-is-base64-image">What is Base64 for images?</h2>
        <p>
          <strong>Base64</strong> encodes binary data (your image bytes) as a text string using only letters, numbers, and a few symbols. That lets you embed small images <strong>inline</strong> in HTML, CSS, JSON, or email-like payloads without a separate file fetch. It is <strong>not encryption</strong> — anyone can decode Base64 back to bytes — so do not use it to hide secrets.
        </p>
        <p>
          A <strong>Data URL</strong> wraps that string in a prefix such as <code>data:image/png;base64,</code> so the browser knows the MIME type. Many tutorials show Data URLs for quick prototypes; for production sites, normal file URLs plus caching usually perform better than giant inline strings.
        </p>
      </section>

      <section class="base64-edu-block">
        <h2 id="how-tool-works">How this tool encodes your images</h2>
        <p>
          The page uses the Web <strong>FileReader</strong> API with <strong>readAsDataURL</strong>, which reads each image file only on your machine. For <strong>raw</strong> mode, everything after the first comma is kept — the pure Base64 payload without the <code>data:…;base64,</code> header.
        </p>
        <ol class="base64-steps">
          <li><strong>Choose output:</strong> Data URL (full string) or Raw Base64 only.</li>
          <li><strong>Add images</strong> (any format your browser accepts as <code>image/*</code>).</li>
          <li><strong>Copy</strong> from each row or <strong>Download All as ZIP</strong> — each file becomes a <code>.txt</code> containing the string.</li>
        </ol>
        <p>
          To reduce string length before encoding, shrink file size with our <a href="/image/image-compressor/">image compressor</a> or fewer pixels via the <a href="/image/image-resizer/">image resizer</a>.
        </p>
      </section>

      <section class="base64-edu-block">
        <h2 id="data-url-vs-raw">Data URL vs raw Base64</h2>
        <div class="base64-table-wrap">
          <table class="base64-compare-table">
            <caption class="sr-only">When to use data URL versus raw Base64</caption>
            <thead>
              <tr>
                <th scope="col">Mode</th>
                <th scope="col">Best for</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Data URL</td><td>Pasting into <code>src=&quot;…&quot;</code> or <code>url()</code> in HTML/CSS for tiny assets, quick tests</td></tr>
              <tr><td>Raw Base64</td><td>JSON APIs, databases, or server fields that expect only the payload</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          Base64 adds roughly <strong>33% overhead</strong> versus raw binary — expect larger “strings” than your original file size in bytes.
        </p>
      </section>

      <section class="base64-edu-block">
        <h2 id="clipboard-secure">Copy button and secure context</h2>
        <p>
          The <strong>Copy</strong> button uses <code>navigator.clipboard.writeText</code> when the browser allows it, with a legacy fallback. On some browsers, clipboard access requires a <strong>secure context</strong> (HTTPS or localhost). If copy fails, select the full textarea and copy manually — the full string is always visible.
        </p>
      </section>

      <section class="base64-edu-block">
        <h2 id="who-uses-base64">Who uses image Base64 encoders?</h2>
        <ul class="base64-audience-list">
          <li><strong>Front-end developers</strong> testing inline images or email templates.</li>
          <li><strong>API integrators</strong> sending image payloads as Base64 in JSON.</li>
          <li><strong>Designers</strong> grabbing a quick Data URL for a small icon in a CodePen-style demo.</li>
        </ul>
        <p>
          For choosing image formats on real websites (WebP, AVIF, SVG), read <a href="/blog/best-image-format-for-web/">best image format for websites</a>.
        </p>
      </section>
    </div>
  </article>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>Is the image to Base64 tool free and unlimited?</h4><p>Yes. Encode as many images as you need with no signup, watermarks, or quotas. Processing uses your browser only.</p></div>
        <div class="faq-item"><h4>Are my images uploaded to your servers?</h4><p>No. The FileReader API reads each file entirely on your device. Base64 text is generated locally; nothing is sent to DoItSwift.</p></div>
        <div class="faq-item"><h4>What is the difference between Data URL and raw Base64?</h4><p>A Data URL is the full string starting with data:image/type;base64, followed by the encoded bytes — ready to paste into HTML or CSS src attributes. Raw mode returns only the Base64 payload after the comma, which many APIs and JSON fields expect.</p></div>
        <div class="faq-item"><h4>How do I copy the encoded string?</h4><p>Use the Copy button on each row. The tool uses the Clipboard API when available, with a fallback for older browsers. You can also select the textarea manually.</p></div>
        <div class="faq-item"><h4>Why does clipboard copy fail sometimes?</h4><p>Some browsers only expose the Clipboard API on secure origins (HTTPS or localhost). If copy fails, select the text in the box and use your system copy command.</p></div>
        <div class="faq-item"><h4>Are large images a problem?</h4><p>Base64 expands file size by roughly 33%. Very large images produce very long strings, which can slow the page or stress memory — prefer smaller sources or compress images first.</p></div>
        <div class="faq-item"><h4>Can I encode many images at once?</h4><p>Yes. Drop or select multiple images; each gets its own textarea and Copy button. Download All as ZIP saves each string as a .txt file.</p></div>
        <div class="faq-item"><h4>How do I switch between Data URL and raw mode for the same files?</h4><p>Select the output format radio option before adding files. To regenerate with a different mode, use Clear All and drop the images again with the other option selected.</p></div>
        <div class="faq-item"><h4>Does it work offline or on mobile?</h4><p>After the page loads, encoding works offline. Mobile browsers generally support FileReader; very large batches may be slower on phones.</p></div>
        <div class="faq-item"><h4>Is there a monthly limit or account required?</h4><p>No accounts, no quotas, and no premium tier.</p></div>
      </div>
    </div>
  </section>

  <section class="base64-related" aria-label="Related tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="base64-related-grid">
        <li><a href="/image/image-compressor/">Image Compressor</a></li>
        <li><a href="/image/image-resizer/">Image Resizer</a></li>
        <li><a href="/image/webp-to-jpg/">WebP to JPG Converter</a></li>
        <li><a href="/image/svg-to-png/">SVG to PNG Converter</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="base64-related-grid base64-related-guides">
        <li><a href="/blog/best-image-format-for-web/">Best Image Format for Websites</a></li>
        <li><a href="/blog/heic-vs-jpg/">HEIC vs JPG: Complete Comparison</a></li>
        <li><a href="/blog/how-to-compress-pdf/">How to Compress a PDF</a></li>
      </ul>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const resultsMore = document.getElementById('resultsMore');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      let converted = [];

      function getOutMode() {
        const r = document.querySelector('input[name="outMode"]:checked');
        return r && r.value === 'raw' ? 'raw' : 'dataurl';
      }

      function fileToBase64Strings(file, mode) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            const res = reader.result;
            if (typeof res !== 'string') {
              reject(new Error('Read failed'));
              return;
            }
            if (mode === 'raw') {
              const comma = res.indexOf(',');
              resolve(comma >= 0 ? res.slice(comma + 1) : res);
            } else {
              resolve(res);
            }
          };
          reader.onerror = () => reject(new Error('Read failed'));
          reader.readAsDataURL(file);
        });
      }

      async function copyText(text, btn) {
        try {
          if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(text);
          } else {
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
          }
          const prev = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = prev; }, 1600);
        } catch (_) {
          alert('Could not copy — select the text in the box and copy manually.');
        }
      }

      function previewUrl(file) {
        return URL.createObjectURL(file);
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', e => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', e => {
        const fs = Array.from(e.target.files);
        e.target.value = '';
        handleFiles(fs);
      });

      async function handleFiles(files) {
        if (!files || !files.length) return;
        const list = files.filter(f => (f.type || '').startsWith('image/'));
        if (!list.length) {
          alert('Please choose image files.');
          return;
        }

        const mode = getOutMode();
        const total = list.length;
        converted = [];
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const toolbar = document.getElementById('resultsToolbar');
        if (toolbar) toolbar.style.display = 'none';
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;

        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Encoding ' + total + ' file(s)...';

        let idx = 0;
        for (const file of list) {
          const parent = window.DoItSwiftFileResults
            ? DoItSwiftFileResults.getAppendParent(results, resultsMore, idx)
            : results;
          idx += 1;

          const thumbUrl = previewUrl(file);
          const item = document.createElement('div');
          item.className = 'file-item';
          item.innerHTML = `
            <div class="file-item-main">
              <div class="file-thumb" aria-hidden="true">🖼️</div>
              <div class="file-info">
                <div class="file-name"></div>
                <div class="file-status">Encoding…</div>
                <div class="progress-bar"><div class="progress-fill"></div></div>
              </div>
              <div class="file-actions-col">
                <button type="button" class="btn-text btn-preview" disabled style="visibility:hidden">Preview</button>
                <button type="button" class="btn copy-btn" disabled>📋 Copy</button>
              </div>
            </div>
            <div class="file-preview-panel" hidden>
              <img alt="Preview" />
            </div>
            <textarea class="b64-out" readonly spellcheck="false"></textarea>
          `;
          item.querySelector('.file-name').textContent = file.name;
          const status = item.querySelector('.file-status');
          const fill = item.querySelector('.progress-fill');
          const ta = item.querySelector('.b64-out');
          const copyBtn = item.querySelector('.copy-btn');
          parent.appendChild(item);
          fill.style.width = '40%';

          try {
            const text = await fileToBase64Strings(file, mode);
            converted.push({
              name: file.name.replace(/\.[^.]+$/, '') + '-base64.txt',
              blob: new Blob([text], { type: 'text/plain;charset=utf-8' }),
            });
            ta.value = text;
            fill.style.width = '100%';
            status.className = 'file-status done';
            status.textContent =
              'Done · ' + (text.length / 1024).toFixed(1) + ' KB string · ' + mode;
            copyBtn.disabled = false;
            copyBtn.addEventListener('click', () => copyText(text, copyBtn));
            if (window.DoItSwiftFileResults) {
              DoItSwiftFileResults.initCompletedRow(item, thumbUrl);
            }
          } catch (err) {
            fill.style.width = '100%';
            fill.style.background = '#ef4444';
            status.className = 'file-status error';
            status.textContent = 'Error: ' + (err.message || 'Failed');
            URL.revokeObjectURL(thumbUrl);
          }
        }

        if (converted.length) {
          actions.style.display = 'flex';
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(converted.length);
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + converted.length + ' string(s) ready — see list below';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const batchOver10 = total > 10;
          if (window.DoItSwiftFileResults) {
            DoItSwiftFileResults.setupToolbar({
              toolbar: document.getElementById('resultsToolbar'),
              galleryToggle: document.getElementById('galleryViewToggle'),
              note: document.getElementById('galleryToolbarNote'),
              batchOver10,
              galleryRoot: document.getElementById('fileResultsRoot'),
            });
            if (total > 10) {
              DoItSwiftFileResults.setupMoreFilesSection({
                moreBlock: document.getElementById('resultsMoreBlock'),
                moreInner: document.getElementById('resultsMore'),
                moreBtn: document.getElementById('moreFilesBtn'),
                moreLabel: document.getElementById('moreFilesLabel'),
                extraCount: total - 10,
              });
            }
          }
        }
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        [results, resultsMore].forEach((root) => {
          if (!root) return;
          root.querySelectorAll('img[src^="blob:"]').forEach((img) => {
            try {
              URL.revokeObjectURL(img.src);
            } catch (_) {}
          });
        });
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const tb = document.getElementById('resultsToolbar');
        if (tb) tb.style.display = 'none';
        const gt = document.getElementById('galleryViewToggle');
        if (gt) {
          gt.checked = false;
          gt.disabled = false;
        }
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;
        converted = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined') return alert('ZIP library not loaded.');
        const zip = new JSZip();
        converted.forEach(f => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const url = URL.createObjectURL(content);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'doitswift-base64.zip';
        a.click();
        URL.revokeObjectURL(url);
      });

      void (async () => {
        try {
          const pending = await window.DoItSwiftPending?.consume?.();
          if (pending) await handleFiles([pending]);
        } catch (e) {
          console.warn(e);
        }
      })();
    });
  </script>

  <style>
    .hero { padding: 60px 0 20px; text-align: center; }
    .subtitle { font-size: 19px; color: var(--text-muted); max-width: 620px; margin: 0 auto 28px; }

    .converter-section { padding: 30px 0; }
    .converter-section .container { max-width: 820px; }

    .banner {
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      font-weight: 600;
      text-align: center;
    }
    .banner-info { background: #dbeafe; color: #1e40af; }
    .banner-success { background: #d1fae5; color: #065f46; }
    [data-theme="dark"] .banner-info { background: rgba(30, 64, 175, .2); color: #93c5fd; }
    [data-theme="dark"] .banner-success { background: rgba(6, 95, 70, .2); color: #6ee7b7; }

    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 70px 20px;
      text-align: center;
      cursor: pointer;
      transition: all .2s;
      box-shadow: var(--shadow);
    }
    .dropzone:hover, .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    [data-theme="dark"] .dropzone.drag { background: rgba(0, 102, 255, .1); }
    .dropzone-icon { font-size: 56px; margin-bottom: 14px; }
    .dropzone-text { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
    .dropzone-sub { font-size: 14px; color: var(--text-muted); }
    #fileInput { display: none; }

    .controls {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-top: 16px;
    }
    .controls-stack {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .controls-label { font-size: 14px; font-weight: 700; margin-bottom: 2px; }
    .radio-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      line-height: 1.45;
