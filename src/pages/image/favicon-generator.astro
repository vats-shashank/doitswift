---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Favicon Generator — Create favicon.ico (16, 32, 48 px) Free & Private | DoItSwift"
  description="Generate favicon.ico from any image in your browser — three PNG frames at 16×16, 32×32, and 48×48 inside one ICO file. Batch download as ZIP. No upload, unlimited, works offline. Perfect for websites and local HTML projects."
  keywords="favicon generator, create favicon ico, favicon ico maker, multi size favicon, 16x16 32x32 favicon, browser tab icon, website favicon, free favicon generator, private favicon tool, batch favicon ico"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "DoItSwift Favicon Generator",
    "description": "Free browser-based favicon.ico generator. Converts images to a standard ICO file containing 16×16, 32×32, and 48×48 PNG frames. Batch processing, ZIP download, no server upload.",
    "url": "https://doitswift.com/image/favicon-generator/",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Web browser",
    "browserRequirements": "Requires HTML5 Canvas and JavaScript",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "Build favicon.ico with 16×16, 32×32, and 48×48 PNG-encoded frames",
      "Accepts common image formats the browser can decode (JPG, PNG, WebP, GIF, etc.)",
      "Scales source images to fit inside each square with a white background",
      "Unlimited batch: one favicon.ico per image, optional ZIP of all files",
      "100% client-side — images are not uploaded",
      "Standard Windows ICO container format for broad compatibility"
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is this favicon generator free and unlimited?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Generate as many favicon.ico files as you need with no signup, watermarks, or usage caps. Everything runs in your browser." }},
      { "@type": "Question", "name": "Are my images uploaded to your servers?", "acceptedAnswer": { "@type": "Answer", "text": "No. Your images are decoded and rendered locally. ICO packing happens on your device — we never receive your files." }},
      { "@type": "Question", "name": "What is inside each favicon.ico file?", "acceptedAnswer": { "@type": "Answer", "text": "Each ICO contains three PNG-encoded bitmaps at 16×16, 32×32, and 48×48 pixels. Browsers and Windows pick the best size for tabs, bookmarks, and shortcuts." }},
      { "@type": "Question", "name": "What source image formats work?", "acceptedAnswer": { "@type": "Answer", "text": "Any raster format your browser can open — typically JPG, PNG, WebP, GIF, and similar. Very large originals may take longer to process." }},
      { "@type": "Question", "name": "My logo is not square — what happens?", "acceptedAnswer": { "@type": "Answer", "text": "The image is scaled to fit inside each square frame without cropping, centered, with a white background filling empty space — similar to letterboxing." }},
      { "@type": "Question", "name": "Will the ICO work in modern browsers?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The file uses PNG data inside the ICO container (common since Windows Vista era). This is widely supported for typical website favicons. Ancient systems that only read legacy BMP icons are uncommon today." }},
      { "@type": "Question", "name": "How do I add the favicon to my website?", "acceptedAnswer": { "@type": "Answer", "text": "Upload favicon.ico to your site root (often /favicon.ico) and/or reference it with a link element: link rel=\"icon\" href=\"/favicon.ico\" type=\"image/x-icon\". Your host or framework may have a specific folder for static assets." }},
      { "@type": "Question", "name": "Can I create favicons for several projects at once?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Drop multiple images — each becomes its own favicon.ico. Download individually or use Download All as ZIP." }},
      { "@type": "Question", "name": "Does it work on mobile or offline?", "acceptedAnswer": { "@type": "Answer", "text": "It works on modern mobile browsers that support Canvas. After the page loads, processing can run without a network connection." }},
      { "@type": "Question", "name": "Is there a monthly limit or account required?", "acceptedAnswer": { "@type": "Answer", "text": "No accounts, no quotas, and no premium tier. Use the generator whenever you need." }}
    ]
  })} />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Favicon Generator</h1>
      <p class="subtitle">
        Create a standard favicon.ico from any image — three built-in sizes (16, 32, 48 px) in one file, batch ZIP, no upload. Ideal for browser tabs, bookmarks, and desktop shortcuts.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop images here or click to browse</div>
        <div class="dropzone-sub">Each image becomes one favicon.ico (16 / 32 / 48)</div>
        <input type="file" id="fileInput" multiple accept="image/*" />
      </div>

      <div class="controls">
        <p class="controls-hint">Square sources look best. ICO uses PNG frames inside the Windows ICO container (Vista+).</p>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Favicon files (<span id="fileCount">0</span>):
      </div>
      <div id="fileResultsRoot">
        <div id="resultsToolbar" class="results-toolbar" style="display:none">
          <label class="gallery-toggle">
            <input type="checkbox" id="galleryViewToggle" />
            Show thumbnails in list
          </label>
          <p class="toolbar-note" id="galleryToolbarNote" hidden></p>
        </div>
        <div class="results" id="results"></div>
        <div id="resultsMoreBlock" class="results-more-block" style="display:none">
          <button type="button" class="more-files-btn" id="moreFilesBtn">
            <span id="moreFilesLabel"></span>
          </button>
          <div id="resultsMore" class="results results-more-inner" hidden></div>
        </div>
      </div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- Educational content (SEO) -->
  <article class="favicon-edu" aria-label="Guide: favicons and creating favicon.ico">
    <div class="container favicon-edu-inner">
      <section class="favicon-edu-block">
        <h2 id="what-is-favicon">What is a favicon — and why use an .ico file?</h2>
        <p>
          A <strong>favicon</strong> (favorites icon) is the small image browsers show in <strong>tabs</strong>, <strong>bookmarks</strong>, and sometimes in <strong>history</strong>. The classic file name is <code>favicon.ico</code> placed at your site root so browsers can discover it automatically.
        </p>
        <p>
          An <strong>ICO</strong> file can hold <strong>multiple sizes</strong> in one package. This generator builds a single <code>favicon.ico</code> containing <strong>16×16</strong>, <strong>32×32</strong>, and <strong>48×48</strong> pixel frames (PNG-encoded), so the OS can choose a crisp icon for the tab bar, taskbar, or shortcuts without you maintaining three separate files by hand.
        </p>
      </section>

      <section class="favicon-edu-block">
        <h2 id="how-generator-works">How this favicon generator works</h2>
        <p>
          You provide any <strong>source image</strong> your browser can decode. For each file we:
        </p>
        <ol class="favicon-steps">
          <li>Draw the image <strong>scaled to fit</strong> inside a square at 16, 32, and 48 pixels (centered, with a <strong>white</strong> background behind transparent or letterboxed areas).</li>
          <li>Encode each square as <strong>PNG</strong> data and pack them into a standard <strong>Windows ICO</strong> binary.</li>
          <li>Offer a download named from your original file (e.g. <code>logo.ico</code> or <code>favicon.ico</code>).</li>
        </ol>
        <p>
          Starting from a <strong>vector logo</strong>? Export PNG or use our <a href="/image/svg-to-png/">SVG to PNG</a> first at a generous size, then generate the ICO here for best clarity at tiny dimensions.
        </p>
      </section>

      <section class="favicon-edu-block">
        <h2 id="sizes-in-ico">Why 16, 32, and 48 pixels?</h2>
        <div class="favicon-table-wrap">
          <table class="favicon-compare-table">
            <caption class="sr-only">Typical use of favicon sizes in an ICO</caption>
            <thead>
              <tr>
                <th scope="col">Size</th>
                <th scope="col">Typical use</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>16×16</td><td>Browser tab favicon on most desktop displays</td></tr>
              <tr><td>32×32</td><td>Higher-DPI tab icons, some toolbar contexts</td></tr>
              <tr><td>48×48</td><td>Windows site shortcuts, some bookmark UIs</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          This tool does not create <strong>Apple touch icons</strong> (180×180 PNG) or <strong>web app manifest</strong> icons — those are separate assets. For overall format strategy on a site, see <a href="/blog/best-image-format-for-web/">best image format for websites</a>.
        </p>
      </section>

      <section class="favicon-edu-block">
        <h2 id="add-favicon-site">How to add favicon.ico to your website</h2>
        <p>
          After downloading: upload <code>favicon.ico</code> to your production server (often the <strong>site root</strong> so it is available at <code>/favicon.ico</code>). Many stacks also let you declare it explicitly in your HTML <code>&lt;head&gt;</code>:
        </p>
        <p>
          <code class="favicon-code-block">&lt;link rel="icon" href="/favicon.ico" type="image/x-icon" /&gt;</code>
        </p>
        <p>
          Paths vary if you use a CDN or static folder — match your host’s documentation. Clear browser cache or hard-refresh when testing a replacement icon.
        </p>
      </section>

      <section class="favicon-edu-block">
        <h2 id="design-tips">Design tips for tiny icons</h2>
        <ul class="favicon-audience-list">
          <li><strong>Prefer simple shapes</strong> — fine lines disappear at 16×16.</li>
          <li><strong>Use high-contrast colors</strong> so the mark reads on light and dark tab backgrounds.</li>
          <li><strong>Square master artwork</strong> avoids letterboxing; wide logos get smaller in the frame.</li>
          <li><strong>Need standalone PNGs at exact sizes?</strong> This tool outputs a multi-size <code>.ico</code> only. For one-off PNG exports from SVG, use <a href="/image/svg-to-png/">SVG to PNG</a> with custom dimensions.</li>
        </ul>
      </section>

      <section class="favicon-edu-block">
        <h2 id="troubleshooting-favicon">Troubleshooting</h2>
        <p>
          <strong>Icon looks fuzzy:</strong> Start from a larger, sharp source image or vector export before ICO generation.
        </p>
        <p>
          <strong>Browser still shows old icon:</strong> Hard-refresh, clear site data for localhost, or rename the file temporarily to bust cache.
        </p>
        <p>
          <strong>Error decoding image:</strong> Try PNG or JPG; ensure the file is not corrupt. Huge images may stress memory — resize first with our <a href="/image/image-resizer/">image resizer</a>.
        </p>
      </section>
    </div>
  </article>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>Is this favicon generator free and unlimited?</h4><p>Yes. Generate as many favicon.ico files as you need with no signup, watermarks, or usage caps. Everything runs in your browser.</p></div>
        <div class="faq-item"><h4>Are my images uploaded to your servers?</h4><p>No. Your images are decoded and rendered locally. ICO packing happens on your device — we never receive your files.</p></div>
        <div class="faq-item"><h4>What is inside each favicon.ico file?</h4><p>Each ICO contains three PNG-encoded bitmaps at 16×16, 32×32, and 48×48 pixels. Browsers and Windows pick the best size for tabs, bookmarks, and shortcuts.</p></div>
        <div class="faq-item"><h4>What source image formats work?</h4><p>Any raster format your browser can open — typically JPG, PNG, WebP, GIF, and similar. Very large originals may take longer to process.</p></div>
        <div class="faq-item"><h4>My logo is not square — what happens?</h4><p>The image is scaled to fit inside each square frame without cropping, centered, with a white background filling empty space — similar to letterboxing.</p></div>
        <div class="faq-item"><h4>Will the ICO work in modern browsers?</h4><p>Yes. The file uses PNG data inside the ICO container (common since Windows Vista era). This is widely supported for typical website favicons. Ancient systems that only read legacy BMP icons are uncommon today.</p></div>
        <div class="faq-item"><h4>How do I add the favicon to my website?</h4><p>Upload favicon.ico to your site root (often /favicon.ico) and/or reference it with a link element: link rel="icon" href="/favicon.ico" type="image/x-icon". Your host or framework may have a specific folder for static assets.</p></div>
        <div class="faq-item"><h4>Can I create favicons for several projects at once?</h4><p>Yes. Drop multiple images — each becomes its own favicon.ico. Download individually or use Download All as ZIP.</p></div>
        <div class="faq-item"><h4>Does it work on mobile or offline?</h4><p>It works on modern mobile browsers that support Canvas. After the page loads, processing can run without a network connection.</p></div>
        <div class="faq-item"><h4>Is there a monthly limit or account required?</h4><p>No accounts, no quotas, and no premium tier. Use the generator whenever you need.</p></div>
      </div>
    </div>
  </section>

  <section class="favicon-related" aria-label="Related tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="favicon-related-grid">
        <li><a href="/image/svg-to-png/">SVG to PNG Converter</a></li>
        <li><a href="/image/image-resizer/">Image Resizer</a></li>
        <li><a href="/image/webp-to-jpg/">WebP to JPG Converter</a></li>
        <li><a href="/image/image-compressor/">Image Compressor</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="favicon-related-grid favicon-related-guides">
        <li><a href="/blog/best-image-format-for-web/">Best Image Format for Websites (icons, photos &amp; more)</a></li>
        <li><a href="/blog/heic-vs-jpg/">HEIC vs JPG: Complete Comparison</a></li>
        <li><a href="/blog/convert-iphone-photos-to-jpg/">Convert iPhone Photos to JPG</a></li>
      </ul>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const SIZES = [16, 32, 48];

      function buildIcoFromPngs(pngArrayBuffers, dims) {
        const n = pngArrayBuffers.length;
        const header = new Uint8Array(6);
        const hv = new DataView(header.buffer);
        hv.setUint16(0, 0, true);
        hv.setUint16(2, 1, true);
        hv.setUint16(4, n, true);

        let offset = 6 + n * 16;
        const entryChunks = [];
        for (let i = 0; i < n; i++) {
          const png = new Uint8Array(pngArrayBuffers[i]);
          const w = dims[i].w;
          const h = dims[i].h;
          const entry = new ArrayBuffer(16);
          const ev = new DataView(entry);
          ev.setUint8(0, w >= 256 ? 0 : w);
          ev.setUint8(1, h >= 256 ? 0 : h);
          ev.setUint8(2, 0);
          ev.setUint8(3, 0);
          ev.setUint16(4, 1, true);
          ev.setUint16(6, 32, true);
          ev.setUint32(8, png.byteLength, true);
          ev.setUint32(12, offset, true);
          offset += png.byteLength;
          entryChunks.push(new Uint8Array(entry));
        }

        const total =
          6 +
          n * 16 +
          pngArrayBuffers.reduce((s, ab) => s + new Uint8Array(ab).byteLength, 0);
        const out = new Uint8Array(total);
        let pos = 0;
        out.set(header, pos);
        pos += 6;
        for (const e of entryChunks) {
          out.set(e, pos);
          pos += e.length;
        }
        for (const ab of pngArrayBuffers) {
          const u8 = new Uint8Array(ab);
          out.set(u8, pos);
          pos += u8.byteLength;
        }
        return out.buffer;
      }

      function loadImage(file) {
        return new Promise((resolve, reject) => {
          const url = URL.createObjectURL(file);
          const img = new Image();
          img.onload = () => {
            URL.revokeObjectURL(url);
            resolve(img);
          };
          img.onerror = () => {
            URL.revokeObjectURL(url);
            reject(new Error('Could not decode image'));
          };
          img.crossOrigin = 'anonymous';
          img.src = url;
        });
      }

      function canvasToPngBlob(canvas) {
        return new Promise((resolve, reject) => {
          canvas.toBlob(
            b => {
              if (!b) {
                reject(new Error('toBlob failed'));
                return;
              }
              b.arrayBuffer().then(resolve, reject);
            },
            'image/png'
          );
        });
      }

      async function imageToSizedPng(img, size) {
        const canvas = document.createElement('canvas');
        canvas.width = size;
        canvas.height = size;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, size, size);
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        const nw = img.naturalWidth || img.width;
        const nh = img.naturalHeight || img.height;
        const scale = Math.min(size / nw, size / nh);
        const dw = Math.round(nw * scale);
        const dh = Math.round(nh * scale);
        const dx = Math.floor((size - dw) / 2);
        const dy = Math.floor((size - dh) / 2);
        ctx.drawImage(img, dx, dy, dw, dh);
        return canvasToPngBlob(canvas);
      }

      async function makeFaviconIcoBlob(img) {
        const buffers = [];
        const dims = [];
        for (const s of SIZES) {
          const ab = await imageToSizedPng(img, s);
          buffers.push(ab);
          dims.push({ w: s, h: s });
        }
        return buildIcoFromPngs(buffers, dims);
      }

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const resultsMore = document.getElementById('resultsMore');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      let converted = [];

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', e => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', e => {
        const fs = Array.from(e.target.files);
        e.target.value = '';
        handleFiles(fs);
      });

      function icoName(originalName) {
        const base = originalName.replace(/\.[^.]+$/, '');
        return (base || 'favicon') + '.ico';
      }

      async function handleFiles(files) {
        if (!files || !files.length) return;
        const list = files.filter(f => (f.type || '').startsWith('image/'));
        if (!list.length) {
          alert('Please choose image files.');
          return;
        }

        const total = list.length;
        converted = [];
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const toolbar = document.getElementById('resultsToolbar');
        if (toolbar) toolbar.style.display = 'none';
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;

        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Building ' + total + ' favicon.ico file(s)...';

        let idx = 0;
        for (const file of list) {
          const parent = window.DoItSwiftFileResults
            ? DoItSwiftFileResults.getAppendParent(results, resultsMore, idx)
            : results;
          idx += 1;

          const item = document.createElement('div');
          item.className = 'file-item';
          item.innerHTML = `
            <div class="file-item-main">
              <div class="file-thumb" aria-hidden="true">🖼️</div>
              <div class="file-info">
                <div class="file-name"></div>
                <div class="file-status">Building ICO…</div>
                <div class="progress-bar"><div class="progress-fill"></div></div>
              </div>
              <div class="file-actions-col">
                <button type="button" class="btn-text btn-preview" disabled style="visibility:hidden">Preview</button>
              </div>
            </div>
            <div class="file-preview-panel" hidden>
              <img alt="ICO preview" />
            </div>
          `;
          item.querySelector('.file-name').textContent = file.name;
          parent.appendChild(item);
          const fill = item.querySelector('.progress-fill');
          const status = item.querySelector('.file-status');
          fill.style.width = '40%';

          try {
            const img = await loadImage(file);
            const icoBuffer = await makeFaviconIcoBlob(img);
            const finalBlob = new Blob([icoBuffer], { type: 'image/x-icon' });
            const url = URL.createObjectURL(finalBlob);
            const newName = icoName(file.name);
            converted.push({ name: newName, blob: finalBlob });
            fill.style.width = '100%';
            status.className = 'file-status done';
            status.textContent = 'Done · 16+32+48 · ' + (finalBlob.size / 1024).toFixed(1) + ' KB';
            const actionsCol = item.querySelector('.file-actions-col');
            const dl = document.createElement('a');
            dl.href = url;
            dl.download = newName;
            dl.className = 'btn';
            dl.textContent = 'Download';
            actionsCol.appendChild(dl);
            if (window.DoItSwiftFileResults) {
              DoItSwiftFileResults.initCompletedRow(item, url, { alt: 'ICO preview' });
            }
          } catch (err) {
            fill.style.width = '100%';
            fill.style.background = '#ef4444';
            status.className = 'file-status error';
            status.textContent = 'Error: ' + (err.message || 'Failed');
          }
        }

        if (converted.length) {
          actions.style.display = 'flex';
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(converted.length);
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + converted.length + ' favicon.ico ready — see list below';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const batchOver10 = total > 10;
          if (window.DoItSwiftFileResults) {
            DoItSwiftFileResults.setupToolbar({
              toolbar: document.getElementById('resultsToolbar'),
              galleryToggle: document.getElementById('galleryViewToggle'),
              note: document.getElementById('galleryToolbarNote'),
              batchOver10,
              galleryRoot: document.getElementById('fileResultsRoot'),
            });
            if (total > 10) {
              DoItSwiftFileResults.setupMoreFilesSection({
                moreBlock: document.getElementById('resultsMoreBlock'),
                moreInner: document.getElementById('resultsMore'),
                moreBtn: document.getElementById('moreFilesBtn'),
                moreLabel: document.getElementById('moreFilesLabel'),
                extraCount: total - 10,
              });
            }
          }
        }
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        [results, resultsMore].forEach((root) => {
          if (!root) return;
          root.querySelectorAll('a[href^="blob:"], img[src^="blob:"]').forEach((el) => {
            const u = el.href || el.src;
            try {
              URL.revokeObjectURL(u);
            } catch (_) {}
          });
        });
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const tb = document.getElementById('resultsToolbar');
        if (tb) tb.style.display = 'none';
        const gt = document.getElementById('galleryViewToggle');
        if (gt) {
          gt.checked = false;
          gt.disabled = false;
        }
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;
        converted = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined') return alert('ZIP library not loaded.');
        const zip = new JSZip();
        converted.forEach(f => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const url = URL.createObjectURL(content);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'doitswift-favicons.zip';
        a.click();
        URL.revokeObjectURL(url);
      });

      void (async () => {
        try {
          const pending = await window.DoItSwiftPending?.consume?.();
          if (pending) await handleFiles([pending]);
        } catch (e) {
          console.warn(e);
        }
      })();
    });
  </script>

