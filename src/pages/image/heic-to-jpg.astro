---
// src/pages/image/heic-to-jpg.astro
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const schemaSoftwareApplication = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'HEIC to JPG Converter',
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Web Browser',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description:
    'Free HEIC to JPG converter. Convert iPhone HEIC photos to JPEG with adjustable quality. Batch conversion, ZIP download. Browser-based, photos never uploaded.',
  url: 'https://doitswift.com/image/heic-to-jpg/',
};

const schemaFaqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is this really free and unlimited?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. There are no per-day limits, no signup, and no watermarks. You can convert as many HEIC files as your device can handle in one session. Processing runs entirely in your browser tab, so you are not buying server credits or hitting a hidden paywall after a few files.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are my files safe?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Your photos are not uploaded to DoItSwift or any conversion server. Files are read and decoded locally with JavaScript, then offered back to you as JPG downloads. When you close the tab, in-memory data is cleared. That design matters for family photos, documents, and anything you would not want stored in the cloud.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is HEIC and why convert it?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'HEIC is Apple default photo format on iPhone and iPad since iOS 11. It stores efficient HEVC-compressed images but is not universally supported on Windows, many Android devices, older desktop apps, email clients, and most website uploaders. Converting to JPG makes the same picture openable and shareable almost everywhere without extra codecs.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will I lose quality?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The default preset is Maximum (100% JPEG quality), which preserves detail very well for typical phone photos. You can open Change settings to pick Balanced or Small file when you need smaller JPGs. Any HEIC-to-JPEG step is technically recompression, but at Maximum the difference is usually imperceptible for everyday sharing.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does it work on mobile?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Use Safari, Chrome, or another modern browser on iPhone, iPad, or Android. Pick files from your photo library or Files app the same way you would attach an image. Very large batches may take longer on phones because decoding uses on-device CPU and memory.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I convert HEIC to JPG on Windows?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Open this page in Chrome, Edge, or Firefox on your PC, drop your .heic files on the converter, then download the JPGs. No install is required for the conversion itself. Optionally install Microsoft HEIF Image Extensions from the Store to preview HEIC in File Explorer, but JPG is still what most apps and uploads expect.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I convert HEIC to JPG on iPhone?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Open this page in Safari on iPhone, tap the drop zone, choose photos from your library or Files, then download the converted JPGs. Conversion uses your phone processor inside the browser tab, not an upload. Alternatively set Settings, Camera, Formats to Most Compatible to capture JPG directly, which uses more storage.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I convert multiple HEIC files at once?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Select or drag many HEIC files in one go. Each file converts to its own JPG row, and you can download individually or use Download All as ZIP. There is no artificial cap on file count; practical limits are device RAM and patience for very large batches.',
      },
    },
    {
      '@type': 'Question',
      name: "What's the difference between HEIC and HEIF?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'HEIF is the standardized High Efficiency Image Format container. HEIC is Apple common file extension for HEIF images that use HEVC compression. In practice people use HEIC and HEIF interchangeably. This page accepts .heic and .heif including uppercase extensions from some cameras and exporters.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does converting HEIC to JPG lose photo metadata (EXIF)?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Browser-based decode and JPEG encode may drop or simplify some EXIF fields such as GPS, camera makernotes, or lens data compared with the original container. For legal evidence or pro workflows that require intact metadata, prefer a desktop DAM or editor that preserves EXIF explicitly. For normal sharing and uploads, missing metadata is rarely a problem.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why are my converted JPGs larger than the original HEIC files?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'HEIC often achieves about half the file size of JPEG at similar visible quality because HEVC is more efficient than classic JPEG compression. When you export JPG, especially at Maximum quality, file sizes commonly grow versus the HEIC original. Use Balanced or Small file presets, or run the JPGs through an image compressor, if size matters more than absolute fidelity.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I convert HEIC to PNG instead of JPG?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'This tool outputs JPEG for broad compatibility and reasonable size. For PNG you would use another workflow such as a desktop editor or a converter that writes PNG directly. Going HEIC to JPG to PNG stacks encoders and is not ideal for archival quality; pick a direct HEIC-to-PNG path when lossless matters.',
      },
    },
  ],
};

const schemaBreadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Image Tools', item: new URL('/image/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'HEIC to JPG', item: canonical },
  ],
};
---

<MainLayout
  title="HEIC to JPG Converter — Convert iPhone Photos to JPEG Free (No Upload) | DoItSwift"
  description="Convert HEIC to JPG instantly in your browser. Batch convert iPhone photos to JPEG with adjustable quality — unlimited files, no signup, no watermarks. 100% private — your photos are never uploaded to any server."
  keywords="heic to jpg, convert heic to jpg, heic to jpeg, heic converter, heic to jpg converter, convert heic to jpeg, iphone photos to jpg, heic file converter, open heic file, heic to jpg online free"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaSoftwareApplication)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFaqPage)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumbList)} />

  <script src="https://cdn.jsdelivr.net/npm/heic2any@0.0.4/dist/heic2any.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>HEIC to JPG Converter — Convert iPhone Photos Free</h1>
      <p class="subtitle">
        Convert HEIC files to JPG instantly — right in your browser. HEIC is the default photo format on iPhones and iPads,
        but it's not supported by Windows, most Android devices, many websites, and email clients. This converter transforms
        your HEIC photos to universally compatible JPEG format with adjustable quality (Maximum, Balanced, or Small file).
        Batch convert unlimited files, download individually or as ZIP. Your photos never leave your device — all conversion
        happens locally using JavaScript. No signup, no watermarks, no file limits.
      </p>
      <p style="font-size: 12px; color: var(--text-muted); margin-top: 8px;">
        Uses the heic2any JavaScript library for browser-based HEIC decoding. No server uploads, no photo retention, no
        tracking. Last updated: April 2026.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <!-- CONVERTER -->
  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop HEIC files here or click to browse</div>
        <div class="dropzone-sub">Convert as many files as you want — all at once</div>
        <input type="file" id="fileInput" multiple accept=".heic,.heif,image/heic,image/heif" />
      </div>

      <p class="converter-hint">
        <span id="hintMain">Converting at maximum quality</span>
        ·
        <button type="button" class="hint-toggle" id="toggleAdvanced" aria-expanded="false" aria-controls="advancedPanel">
          Change settings
        </button>
      </p>
      <div id="advancedPanel" class="advanced-panel" hidden>
        <p class="advanced-title">Advanced options</p>
        <div class="preset-buttons" role="radiogroup" aria-label="JPEG quality preset">
          <button type="button" class="preset-btn is-selected" data-q="100" role="radio" aria-checked="true">Maximum</button>
          <button type="button" class="preset-btn" data-q="85" role="radio" aria-checked="false">Balanced</button>
          <button type="button" class="preset-btn" data-q="70" role="radio" aria-checked="false">Small file</button>
        </div>
        <p class="preset-desc" id="presetDesc">100% quality — best fidelity, largest JPEGs.</p>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Converted files (<span id="fileCount">0</span>):
      </div>
      <div id="fileResultsRoot">
        <div id="resultsToolbar" class="results-toolbar" style="display:none">
          <label class="gallery-toggle">
            <input type="checkbox" id="galleryViewToggle" />
            Show thumbnails in list
          </label>
          <p class="toolbar-note" id="galleryToolbarNote" hidden></p>
        </div>
        <div class="results" id="results"></div>
        <div id="resultsMoreBlock" class="results-more-block" style="display:none">
          <button type="button" class="more-files-btn" id="moreFilesBtn">
            <span id="moreFilesLabel"></span>
          </button>
          <div id="resultsMore" class="results results-more-inner" hidden></div>
        </div>
      </div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- Educational content (SEO) -->
  <article class="heic-edu" aria-label="Guide: HEIC format and converting to JPG">
    <div class="container heic-edu-inner">
      <section class="heic-edu-block">
        <h2 id="how-to-convert-heic">How to Convert HEIC to JPG (Step by Step)</h2>

        <h3>Step 1: Add your HEIC files</h3>
        <p>
          Drag and drop your .heic or .HEIC files onto the drop zone, or click to browse your file manager. You can select
          multiple files at once — there's no cap on how many you convert. On iPhone, use the Files app or AirDrop to transfer
          HEIC files to your computer first.
        </p>

        <h3>Step 2: Choose quality (optional)</h3>
        <p>
          Click &quot;Change settings&quot; to select a quality preset. <strong>Maximum</strong> (100% quality) preserves every detail — best for
          printing and archiving. <strong>Balanced</strong> reduces file size while keeping excellent on-screen quality. <strong>Small file</strong>
          prioritizes minimum file size — good for email and messaging.
        </p>

        <h3>Step 3: Download your JPGs</h3>
        <p>
          Each converted image appears in the results list with a download button. Click &quot;Download All as ZIP&quot; to get all converted
          photos in one file. Thumbnails are shown so you can verify the conversion before downloading.
        </p>
      </section>

      <section class="heic-edu-block">
        <h2 id="what-is-heic">What is HEIC? Why Do iPhones Use It?</h2>
        <p>
          HEIC stands for <strong>High Efficiency Image Container</strong> — it's the file format Apple uses by default on iPhones and iPads
          since iOS 11 (2017). HEIC uses the HEVC (H.265) video codec to compress photos, achieving roughly <strong>50% smaller file sizes</strong>
          than JPEG at equivalent visual quality. This means your iPhone can store roughly twice as many photos in the same storage
          space.
        </p>

        <h3>Why HEIC causes problems</h3>
        <p>Despite its technical advantages, HEIC isn't universally supported:</p>
        <ul class="heic-compat-list">
          <li>
            <strong>Windows:</strong> Requires installing the HEIF Image Extensions from the Microsoft Store (free but not pre-installed).
            Without it, Windows can't open or preview HEIC files
          </li>
          <li>
            <strong>Android:</strong> Some newer Android devices support HEIC, but many don't — sharing HEIC photos with Android users often
            results in &quot;can't open&quot; errors
          </li>
          <li>
            <strong>Web browsers:</strong> Safari supports HEIC natively. Chrome added partial support recently. Firefox still doesn't support
            HEIC display
          </li>
          <li>
            <strong>Email:</strong> Most email clients can't display HEIC inline. Recipients see a download link to a file they may not be able
            to open
          </li>
          <li>
            <strong>Social media:</strong> Instagram, Twitter/X, and LinkedIn accept HEIC uploads (they convert internally), but many smaller
            platforms and forums don't
          </li>
          <li>
            <strong>Websites and CMS:</strong> WordPress, Squarespace, Wix, and most website builders don't support HEIC uploads. You need JPG
            or PNG
          </li>
          <li>
            <strong>Printing services:</strong> Most online print services (Shutterfly, Snapfish, local print shops) require JPG, PNG, or TIFF
            — not HEIC
          </li>
        </ul>
        <p>
          Converting to JPG ensures your photos work everywhere — every device, every browser, every platform, every printer. JPG has
          been the universal image format since 1992.
        </p>
      </section>

      <section class="heic-edu-block">
        <h2 id="browser-heic">How Browser-Based HEIC Conversion Works</h2>
        <p>
          Most HEIC converters (Convertio, CloudConvert, Zamzar) upload your photos to cloud servers for processing. Your personal
          and family photos travel across the internet, are processed on someone else's machines, and stored temporarily on their
          infrastructure.
        </p>
        <p>DoItSwift converts HEIC to JPG entirely in your browser:</p>
        <ol class="heic-steps">
          <li><strong>File read:</strong> The browser reads the HEIC file using the JavaScript FileReader API — no network request</li>
          <li><strong>Decode:</strong> The heic2any JavaScript library decodes the HEVC-compressed image data in memory</li>
          <li><strong>Re-encode:</strong> The decoded pixels are encoded as JPEG at your selected quality level</li>
          <li><strong>Download:</strong> The JPG file is offered for download via a local blob URL — still no server involved</li>
        </ol>
        <p>
          <strong>Privacy proof:</strong> Disconnect your internet connection, then try converting a HEIC file. It works — because no server is
          needed. Upload-based converters fail instantly when offline.
        </p>
        <p>
          <strong>Why this matters for personal photos:</strong> HEIC files from your iPhone contain your family photos, selfies, screenshots,
          and potentially sensitive images. Uploading these to a random conversion server means trusting them with your most personal
          content. Browser-based conversion eliminates that trust requirement entirely.
        </p>
      </section>

      <section class="heic-edu-block">
        <h2 id="heic-vs-jpg">HEIC vs JPG: Key Differences</h2>
        <div class="heic-table-wrap">
          <table class="heic-compare-table">
            <caption class="sr-only">HEIC vs JPG comparison</caption>
            <thead>
              <tr>
                <th scope="col">Feature</th>
                <th scope="col">HEIC</th>
                <th scope="col">JPG</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>File size</td>
                <td><strong>~50% smaller</strong> at same quality</td>
                <td>Larger but universally readable</td>
              </tr>
              <tr>
                <td>Quality</td>
                <td>Excellent (10-bit color depth)</td>
                <td>Excellent (8-bit, lossy compression)</td>
              </tr>
              <tr>
                <td>Transparency</td>
                <td>Yes (alpha channel)</td>
                <td>No</td>
              </tr>
              <tr>
                <td>Animation</td>
                <td>Yes (Live Photos)</td>
                <td>No</td>
              </tr>
              <tr>
                <td>iOS/macOS support</td>
                <td>Native since iOS 11</td>
                <td>Universal</td>
              </tr>
              <tr>
                <td>Windows support</td>
                <td>Requires extension install</td>
                <td><strong>Universal — always works</strong></td>
              </tr>
              <tr>
                <td>Android support</td>
                <td>Partial (varies by device)</td>
                <td><strong>Universal</strong></td>
              </tr>
              <tr>
                <td>Web browser support</td>
                <td>Safari only (Chrome partial)</td>
                <td><strong>100% — all browsers</strong></td>
              </tr>
              <tr>
                <td>Email support</td>
                <td>Poor</td>
                <td><strong>Universal</strong></td>
              </tr>
              <tr>
                <td>Print service support</td>
                <td>Rare</td>
                <td><strong>Universal</strong></td>
              </tr>
              <tr>
                <td>Best for</td>
                <td>iPhone storage (saves space)</td>
                <td>Sharing, web, printing, archiving</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          <strong>Bottom line:</strong> Keep photos as HEIC on your iPhone to save storage. Convert to JPG when sharing with non-Apple users,
          uploading to websites, emailing, or printing. For a detailed analysis, read our guide:{' '}
          <a href="/blog/heic-vs-jpg/">HEIC vs JPG: Complete Comparison</a>.
        </p>
      </section>

      <section class="heic-edu-block">
        <h2 id="common-scenarios">Common Scenarios for HEIC to JPG Conversion</h2>

        <h3>Sharing photos with non-Apple users</h3>
        <p>
          You took photos on your iPhone and want to share with a friend on Android or Windows. They receive .heic files they can't
          open. Convert to JPG first, or AirDrop to yourself and convert before sharing via WhatsApp, email, or Google Drive.
        </p>

        <h3>Uploading to websites and social media</h3>
        <p>
          WordPress, Squarespace, Shopify, and most website builders don't accept HEIC uploads. Convert your product photos, blog
          images, or portfolio pieces to JPG before uploading. Even platforms that accept HEIC (Instagram, Facebook) recompress
          internally — starting from JPG gives you more control over the final quality.
        </p>

        <h3>Sending via email</h3>
        <p>
          Many email clients can't display HEIC inline. Your beautiful vacation photos appear as download links that recipients can't
          open. Converting to JPG ensures photos display properly in every email client — Gmail, Outlook, Yahoo, Apple Mail, and
          corporate email systems.
        </p>

        <h3>Printing photos</h3>
        <p>
          Online print services (Shutterfly, Snapfish, Canva Print, local print shops) almost universally require JPG, PNG, or TIFF.
          HEIC files are rejected or produce errors. Convert to JPG at Maximum quality for the best print results.
        </p>

        <h3>Uploading to government or job portals</h3>
        <p>
          Passport applications, visa forms, university admissions, and job portals typically accept only JPG or PNG. Convert your
          iPhone headshot or document scan from HEIC to JPG, then <a href="/image/image-compressor/">compress</a> if the portal has a file size
          limit (often 100-200 KB).
        </p>

        <h3>Editing in non-Apple software</h3>
        <p>
          Photoshop (older versions), GIMP, Canva, and many image editors don't support HEIC natively. Converting to JPG first
          ensures your photos open in any editing application.
        </p>
      </section>

      <section class="heic-edu-block">
        <h2 id="iphone-jpg-settings">How to Make Your iPhone Save Photos as JPG Instead of HEIC</h2>
        <p>If you want to avoid HEIC conversion altogether, you can change your iPhone's camera settings:</p>
        <ol class="heic-steps">
          <li>Open <strong>Settings</strong> → <strong>Camera</strong> → <strong>Formats</strong></li>
          <li>Select <strong>&quot;Most Compatible&quot;</strong> instead of &quot;High Efficiency&quot;</li>
        </ol>
        <p>
          This makes your camera save photos as JPG directly. The trade-off: your photos will use roughly <strong>twice the storage space</strong>.
          For iPhones with 64-128 GB, this can be significant. For 256 GB+, the difference is manageable.
        </p>
        <p>
          <strong>Alternative approach:</strong> Keep HEIC on your iPhone (saves storage), then batch-convert to JPG using this tool only when
          you need to share or upload. This gives you the best of both worlds — space-efficient storage with universal compatibility
          when needed.
        </p>
        <p>
          For a complete walkthrough including Windows solutions, read our guide:{' '}
          <a href="/blog/open-heic-windows-11/">How to Open HEIC on Windows 11</a>.
        </p>
      </section>

      <section class="heic-edu-block">
        <h2 id="doitswift-vs-competitors">DoItSwift vs Other HEIC to JPG Converters</h2>
        <div class="heic-table-wrap">
          <table class="heic-compare-table heic-compare-table--competitors">
            <caption class="sr-only">DoItSwift vs other HEIC converters</caption>
            <thead>
              <tr>
                <th scope="col">Feature</th>
                <th scope="col">DoItSwift</th>
                <th scope="col">Convertio</th>
                <th scope="col">CloudConvert</th>
                <th scope="col">iMazing HEIC</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Photos stay on device</td>
                <td><strong>Yes — never uploaded</strong></td>
                <td>No — uploaded to server</td>
                <td>No — uploaded to server</td>
                <td>Yes (desktop app)</td>
              </tr>
              <tr>
                <td>Quality control</td>
                <td><strong>3 presets (Max/Balanced/Small)</strong></td>
                <td>No choice</td>
                <td>Some control</td>
                <td>Quality slider</td>
              </tr>
              <tr>
                <td>Batch conversion</td>
                <td><strong>Unlimited files</strong></td>
                <td>2 files free</td>
                <td>25/day free</td>
                <td>Unlimited</td>
              </tr>
              <tr>
                <td>ZIP download</td>
                <td><strong>Yes</strong></td>
                <td>Yes (paid)</td>
                <td>Yes</td>
                <td>No</td>
              </tr>
              <tr>
                <td>Installation required</td>
                <td><strong>No — runs in browser</strong></td>
                <td>No</td>
                <td>No</td>
                <td>Yes (Windows/Mac app)</td>
              </tr>
              <tr>
                <td>Works offline</td>
                <td><strong>Yes</strong></td>
                <td>No</td>
                <td>No</td>
                <td>Yes</td>
              </tr>
              <tr>
                <td>Free tier limits</td>
                <td><strong>None — fully free</strong></td>
                <td>2 files, 100 MB</td>
                <td>25 conversions/day</td>
                <td>Fully free</td>
              </tr>
              <tr>
                <td>Works on mobile</td>
                <td><strong>Yes</strong></td>
                <td>Yes</td>
                <td>Yes</td>
                <td>No (desktop only)</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          <strong>Where DoItSwift wins:</strong> Privacy (your personal photos never leave your device), unlimited batch conversion without
          signup, and quality control — all in a browser with no installation. Convertio and CloudConvert are popular but upload your
          photos and limit free usage.
        </p>
        <p>
          <strong>Where others win:</strong> iMazing HEIC Converter is a well-built desktop app with an excellent interface. CloudConvert
          supports more output formats (PNG, TIFF, WebP). For most people who just need to convert iPhone photos to JPG, DoItSwift is
          the fastest and most private option.
        </p>
      </section>
    </div>
  </article>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>Is this really free and unlimited?</h3>
          <p>
            Yes. There are no per-day limits, no signup, and no watermarks. You can convert as many HEIC files as your device can
            handle in one session. Processing runs entirely in your browser tab, so you are not buying server credits or hitting a
            hidden paywall after a few files.
          </p>
        </div>
        <div class="faq-item">
          <h3>Are my files safe?</h3>
          <p>
            Your photos are not uploaded to DoItSwift or any conversion server. Files are read and decoded locally with
            JavaScript, then offered back to you as JPG downloads. When you close the tab, in-memory data is cleared. That design
            matters for family photos, documents, and anything you would not want stored in the cloud.
          </p>
        </div>
        <div class="faq-item">
          <h3>What is HEIC and why convert it?</h3>
          <p>
            HEIC is Apple default photo format on iPhone and iPad since iOS 11. It stores efficient HEVC-compressed images but is
            not universally supported on Windows, many Android devices, older desktop apps, email clients, and most website
            uploaders. Converting to JPG makes the same picture openable and shareable almost everywhere without extra codecs.
          </p>
        </div>
        <div class="faq-item">
          <h3>Will I lose quality?</h3>
          <p>
            The default preset is Maximum (100% JPEG quality), which preserves detail very well for typical phone photos. You can
            open Change settings to pick Balanced or Small file when you need smaller JPGs. Any HEIC-to-JPEG step is technically
            recompression, but at Maximum the difference is usually imperceptible for everyday sharing.
          </p>
        </div>
        <div class="faq-item">
          <h3>Does it work on mobile?</h3>
          <p>
            Yes. Use Safari, Chrome, or another modern browser on iPhone, iPad, or Android. Pick files from your photo library or
            Files app the same way you would attach an image. Very large batches may take longer on phones because decoding uses
            on-device CPU and memory.
          </p>
        </div>
        <div class="faq-item">
          <h3>How do I convert HEIC to JPG on Windows?</h3>
          <p>
            Open this page in any browser (Chrome, Edge, Firefox) on your Windows PC, drop your HEIC files onto the converter, and
            download the JPGs. No software installation needed. Alternatively, you can install the free HEIF Image Extensions from
            the Microsoft Store to view HEIC natively in Windows, but you'll still need a converter to get JPG files for sharing or
            uploading. For a complete guide, see <a href="/blog/open-heic-windows-11/">How to Open HEIC on Windows 11</a>.
          </p>
        </div>
        <div class="faq-item">
          <h3>How do I convert HEIC to JPG on iPhone?</h3>
          <p>
            Open this page in Safari on your iPhone, tap the drop zone to browse your Photos library or Files app, select your
            HEIC images, and download the converted JPGs. The conversion runs in Safari using your phone's processor — nothing is
            uploaded. Alternatively, change your iPhone camera settings (Settings → Camera → Formats → Most Compatible) to capture
            photos as JPG directly, avoiding HEIC entirely.
          </p>
        </div>
        <div class="faq-item">
          <h3>Can I convert multiple HEIC files at once?</h3>
          <p>
            Yes — select or drag as many HEIC files as you want. There's no limit on the number of files. Each file is converted
            independently, and you can download them individually or all at once as a ZIP archive. For large batches (100+ photos),
            conversion may take a minute depending on your device's processing power.
          </p>
        </div>
        <div class="faq-item">
          <h3>What's the difference between HEIC and HEIF?</h3>
          <p>
            HEIF (High Efficiency Image Format) is the container format standard. HEIC is the specific file extension Apple uses for
            HEIF files encoded with the HEVC codec. In practice, .heic and .heif files are the same thing — this converter handles
            both. You may also encounter .HEIC (uppercase) from some file managers; the converter accepts both cases.
          </p>
        </div>
        <div class="faq-item">
          <h3>Does converting HEIC to JPG lose photo metadata (EXIF)?</h3>
          <p>
            The browser-based conversion process may strip some EXIF metadata (camera settings, GPS location, date taken) during
            the decoding and re-encoding process. If preserving full metadata is critical (for professional photography or legal
            documentation), use a desktop application like iMazing HEIC Converter or Adobe Lightroom. For everyday sharing and
            uploading, the loss of metadata is typically not an issue.
          </p>
        </div>
        <div class="faq-item">
          <h3>Why are my converted JPGs larger than the original HEIC files?</h3>
          <p>
            This is expected. HEIC uses more efficient compression than JPEG — typically 50% smaller at the same quality. When you
            convert to JPG, the file naturally becomes larger because JPG's compression algorithm is less efficient. At Maximum
            quality (100%), JPGs can be 2-3× larger than the HEIC original. Use the Balanced or Small file preset if size matters
            — or <a href="/image/image-compressor/">compress the JPGs</a> after conversion.
          </p>
        </div>
        <div class="faq-item">
          <h3>Can I convert HEIC to PNG instead of JPG?</h3>
          <p>
            This tool outputs JPG for maximum compatibility and smaller file sizes. If you need PNG (for transparency or lossless
            quality), convert to JPG here first, then use an image editor or online converter to go from JPG to PNG. Note that
            HEIC-to-JPG-to-PNG introduces two rounds of encoding, so for critical quality needs, a desktop tool that exports
            directly to PNG may be preferable.
          </p>
        </div>
      </div>
    </div>
  </section>

