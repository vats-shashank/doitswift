---
// src/pages/image/heic-to-jpg.astro
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="HEIC to JPG Converter — Free, Private & Unlimited | DoItSwift"
  description="Convert HEIC to JPG instantly in your browser — free, private, unlimited. Learn what HEIC format is, why iPhone HEIC photos need JPG for sharing, HEIC vs JPG differences, and step-by-step conversion. No uploads."
  keywords="heic to jpg, heic to jpeg, heic converter, iphone photo converter, what is heic, heic format, heic vs jpg, heic compatibility, share iphone photos, free heic converter, batch heic converter"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <!-- Schema markup for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is this really free and unlimited?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. No limits, no signup, no watermarks. The site runs entirely in your browser." }},
      { "@type": "Question", "name": "Are my files safe?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Files never leave your device. We can't see, store, or access them." }},
      { "@type": "Question", "name": "What is HEIC and why convert it?", "acceptedAnswer": { "@type": "Answer", "text": "HEIC is Apple's iPhone image format. It's not supported on Windows, Android, or many websites — converting to JPG ensures compatibility everywhere." }},
      { "@type": "Question", "name": "Will I lose quality?", "acceptedAnswer": { "@type": "Answer", "text": "Default is maximum (100%) JPEG quality. Use Advanced options to pick Balanced or Small file if you want a smaller download." }},
      { "@type": "Question", "name": "Does it work on mobile?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — works on iPhone, iPad, Android, and any modern browser." }},
      { "@type": "Question", "name": "What's the maximum file size?", "acceptedAnswer": { "@type": "Answer", "text": "There's no imposed limit — it's bound by your device's RAM. Typical iPhone photos (2-5MB HEIC) convert instantly. Very large files (50MB+) may take a few seconds." }},
      { "@type": "Question", "name": "Does converting lose quality?", "acceptedAnswer": { "@type": "Answer", "text": "At default 100% quality, visual difference is imperceptible. JPG files will be 2-3× larger than the original HEIC since JPG uses less efficient compression." }},
      { "@type": "Question", "name": "Can I batch convert a whole folder?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — select multiple files at once or drag an entire folder onto the dropzone. Download all converted files as a single ZIP." }},
      { "@type": "Question", "name": "Does this work on iPhone and iPad?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — opens in Safari, Chrome, or Firefox on iOS. You can select HEIC photos directly from your Photos library." }},
      { "@type": "Question", "name": "Is there a monthly conversion limit?", "acceptedAnswer": { "@type": "Answer", "text": "No. Convert as many files as you want, as often as you want. There are no accounts, no quotas, and no premium tiers." }}
    ]
  })} />

  <script src="https://cdn.jsdelivr.net/npm/heic2any@0.0.4/dist/heic2any.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>HEIC to JPG Converter</h1>
      <p class="subtitle">
        Convert iPhone HEIC photos to JPG instantly. No uploads, no limits, no signup.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <!-- CONVERTER -->
  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop HEIC files here or click to browse</div>
        <div class="dropzone-sub">Convert as many files as you want — all at once</div>
        <input type="file" id="fileInput" multiple accept=".heic,.heif,image/heic,image/heif" />
      </div>

      <p class="converter-hint">
        <span id="hintMain">Converting at maximum quality</span>
        ·
        <button type="button" class="hint-toggle" id="toggleAdvanced" aria-expanded="false" aria-controls="advancedPanel">
          Change settings
        </button>
      </p>
