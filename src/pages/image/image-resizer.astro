---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Free Image Resizer Online — JPG, PNG & WebP | Pixel Width, Height & Aspect Ratio | DoItSwift"
  description="Resize JPG, PNG, and WebP images in your browser — set width and height, lock aspect ratio to fit without stretching, or stretch to exact pixels. JPEG export with quality presets, batch ZIP, no uploads. Private and unlimited."
  keywords="image resizer, resize image online, resize photo, change image dimensions, resize jpg, resize png, resize webp, batch resize images, aspect ratio resize, fit image to width height, pixel dimensions, free image resizer, private photo resizer"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "DoItSwift Image Resizer",
    "description": "Free browser-based image resizer for JPG, PNG, and WebP. Set target dimensions, optional aspect ratio lock, JPEG quality presets, batch download as ZIP. Files are processed locally with no upload.",
    "url": "https://doitswift.com/image/image-resizer/",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Web browser",
    "browserRequirements": "Requires HTML5 Canvas and JavaScript",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "Resize JPG, PNG, and WebP to target width and height",
      "Maintain aspect ratio — fit inside dimensions without stretching",
      "Optional exact width × height (may stretch image)",
      "JPEG export with maximum, balanced, or small-file quality",
      "Batch processing and ZIP download",
      "100% client-side — files never leave your device"
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is this image resizer free and unlimited?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Resize as many images as you want with no signup, watermarks, or fees. Processing runs in your browser." }},
      { "@type": "Question", "name": "Are my images uploaded to your servers?", "acceptedAnswer": { "@type": "Answer", "text": "No. Files never leave your device. Resizing uses the HTML5 Canvas API locally — we cannot see or store your photos." }},
      { "@type": "Question", "name": "What does “maintain aspect ratio” and fit inside width × height mean?", "acceptedAnswer": { "@type": "Answer", "text": "When enabled, each image scales uniformly to fit inside your target box without cropping or stretching. The output dimensions may be smaller than the box so the whole image remains visible. Images larger than the box are scaled down; smaller images are not enlarged." }},
      { "@type": "Question", "name": "What if I turn off maintain aspect ratio?", "acceptedAnswer": { "@type": "Answer", "text": "Each image is stretched or squeezed to exactly the width and height you entered. Use this only when you want a precise pixel box and accept possible distortion." }},
      { "@type": "Question", "name": "Why is the download a JPG file?", "acceptedAnswer": { "@type": "Answer", "text": "Exports use JPEG for broad compatibility and reasonable file size after resizing. Filenames end with -resized.jpg. Use Advanced options to change JPEG quality." }},
      { "@type": "Question", "name": "What happens to PNG or WebP transparency?", "acceptedAnswer": { "@type": "Answer", "text": "JPEG does not support transparency. Transparent areas are composited on a white background before export." }},
      { "@type": "Question", "name": "Does it work on mobile phones and tablets?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, on modern mobile browsers that support Canvas. Very large images may be slower or hit device memory limits." }},
      { "@type": "Question", "name": "What are the width and height limits?", "acceptedAnswer": { "@type": "Answer", "text": "You can enter dimensions from 1 up to 16384 pixels. Extremely large outputs may fail if the browser runs out of memory — try smaller targets if that happens." }},
      { "@type": "Question", "name": "Can I resize many photos at once?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Select or drag multiple files; each is processed with the same settings. Download individually or as one ZIP archive." }},
      { "@type": "Question", "name": "Is there a monthly limit or account required?", "acceptedAnswer": { "@type": "Answer", "text": "No accounts, no quotas, and no premium tier. Use the tool as often as you need." }}
    ]
  })} />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Image Resizer</h1>
      <p class="subtitle">
        Resize JPG, PNG, or WebP to exact pixels — lock aspect ratio to fit inside your box without stretching, or fill width × height exactly. JPEG export, quality presets, batch ZIP. 100% private.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop images here or click to browse</div>
        <div class="dropzone-sub">JPG, PNG, WebP — as many as you want</div>
        <input type="file" id="fileInput" multiple accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
      </div>

      <p class="converter-hint">
        <span id="hintMain">Exporting at maximum JPEG quality</span>
        ·
        <button type="button" class="hint-toggle" id="toggleAdvanced" aria-expanded="false" aria-controls="advancedPanel">
          Change settings
        </button>
      </p>
      <div id="advancedPanel" class="advanced-panel" hidden>
        <p class="advanced-title">Advanced options</p>
        <div class="preset-buttons" role="radiogroup" aria-label="JPEG quality preset">
          <button type="button" class="preset-btn is-selected" data-q="100" role="radio" aria-checked="true">Maximum</button>
          <button type="button" class="preset-btn" data-q="85" role="radio" aria-checked="false">Balanced</button>
          <button type="button" class="preset-btn" data-q="70" role="radio" aria-checked="false">Small file</button>
        </div>
        <p class="preset-desc" id="presetDesc">100% quality — best fidelity, largest JPEGs.</p>
      </div>

      <div class="controls controls-grid">
        <div class="control-row">
          <label for="widthInp">Width (px)</label>
          <input type="number" id="widthInp" min="1" max="16384" value="800" />
        </div>
        <div class="control-row">
          <label for="heightInp">Height (px)</label>
          <input type="number" id="heightInp" min="1" max="16384" value="600" />
        </div>
        <label class="check-row">
          <input type="checkbox" id="keepAspect" checked />
          <span>Maintain aspect ratio (fit inside width × height)</span>
        </label>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Resized files (<span id="fileCount">0</span>):
      </div>
      <div id="fileResultsRoot">
        <div id="resultsToolbar" class="results-toolbar" style="display:none">
          <label class="gallery-toggle">
            <input type="checkbox" id="galleryViewToggle" />
            Show thumbnails in list
          </label>
          <p class="toolbar-note" id="galleryToolbarNote" hidden></p>
        </div>
        <div class="results" id="results"></div>
        <div id="resultsMoreBlock" class="results-more-block" style="display:none">
          <button type="button" class="more-files-btn" id="moreFilesBtn">
            <span id="moreFilesLabel"></span>
          </button>
          <div id="resultsMore" class="results results-more-inner" hidden></div>
        </div>
      </div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- Educational content (SEO) -->
  <article class="resize-edu" aria-label="Guide: resizing images by pixels and aspect ratio">
    <div class="container resize-edu-inner">
      <section class="resize-edu-block">
        <h2 id="why-resize-images">Why resize images (pixels, performance, and requirements)?</h2>
        <p>
          Every raster image is a grid of pixels. <strong>Width</strong> and <strong>height</strong> in pixels determine how much detail the file carries — and how heavy it is to load, email, or upload. <strong>Resizing</strong> changes that grid: smaller dimensions usually mean smaller files and faster pages, which matters for <strong>SEO</strong>, mobile users, and forms with strict size limits.
        </p>
        <p>
          Typical reasons to resize: meeting a portal’s <strong>maximum dimensions</strong>, preparing <strong>hero or blog images</strong> for a CMS, fitting <strong>social platform</strong> recommendations, or shrinking camera originals before sharing. This tool focuses on <strong>practical pixel control</strong> in the browser — no upload to our servers.
        </p>
      </section>

      <section class="resize-edu-block">
        <h2 id="how-resizer-works">How this resizer works (fit inside vs exact size)</h2>
        <p>
          You set a <strong>target width</strong> and <strong>height</strong> (defaults 800×600; you can go up to 16384 px). Each JPG, PNG, or WebP file is decoded locally, drawn to a canvas, and exported as a <strong>JPEG</strong> at your chosen quality.
        </p>
        <p>
          <strong>With “Maintain aspect ratio” on (recommended):</strong> each image <strong>scales uniformly</strong> to <em>fit inside</em> your width × height box — no cropping, no stretching. The result’s pixel dimensions are often <em>smaller</em> than the box so the full image stays visible. <strong>Important:</strong> images that are already smaller than your box are <strong>not enlarged</strong> — we only scale down (or leave dimensions as needed) so you do not accidentally upscale low-resolution assets.
        </p>
        <p>
          <strong>With “Maintain aspect ratio” off:</strong> every image is stretched to <strong>exactly</strong> your width and height. Use this when you need a precise pixel output and accept possible <strong>distortion</strong> if the original proportions differ from your box.
        </p>
        <p>
          For format-specific conversion without changing dimensions first, see <a href="/image/webp-to-jpg/">WebP to JPG</a> or <a href="/image/heic-to-jpg/">HEIC to JPG</a>. To shrink file size without changing pixel size, use our <a href="/image/image-compressor/">image compressor</a>.
        </p>
      </section>

      <section class="resize-edu-block">
        <h2 id="jpeg-quality-output">JPEG quality and why downloads are .jpg</h2>
        <p>
          Exports are <strong>JPEG</strong> for universal compatibility and sensible size after resize. Open <strong>Advanced options</strong> to pick <strong>Maximum (100%)</strong>, <strong>Balanced (85%)</strong>, or <strong>Small file (70%)</strong>. Downloads use names like <code>filename-resized.jpg</code>.
        </p>
        <p>
          <strong>PNG and WebP with transparency:</strong> JPEG cannot store an alpha channel — transparent areas are composited on a <strong>white</strong> background, same idea as our <a href="/image/image-compressor/">compressor</a> and WebP converter.
        </p>
      </section>

      <section class="resize-edu-block">
        <h2 id="common-image-sizes">Common target sizes (reference — check each platform’s current specs)</h2>
        <div class="resize-table-wrap">
          <table class="resize-compare-table">
            <caption class="sr-only">Typical image dimension ranges by use case</caption>
            <thead>
              <tr>
                <th scope="col">Use case</th>
                <th scope="col">Typical width / notes</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Blog / article inline images</td><td>Often 600–1200 px wide</td></tr>
              <tr><td>Full-width web banners</td><td>Often 1200–1920 px wide (depends on theme)</td></tr>
              <tr><td>Thumbnail / gallery</td><td>Often 150–400 px on the long edge</td></tr>
              <tr><td>Email-friendly attachments</td><td>Many clients render well under ~1200 px wide</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          Always verify dimensions for your CMS, ad platform, or social network — requirements change. For choosing between WebP, AVIF, and JPG on sites, read <a href="/blog/best-image-format-for-web/">best image format for websites</a>.
        </p>
      </section>

      <section class="resize-edu-block">
        <h2 id="who-uses-image-resizer">Who uses an online image resizer?</h2>
        <ul class="resize-audience-list">
          <li><strong>Bloggers and site owners</strong> matching theme image slots and improving load speed.</li>
          <li><strong>E-commerce</strong> sellers normalizing product photos to a consistent long edge.</li>
          <li><strong>Job seekers and students</strong> fitting photo uploads to application limits.</li>
          <li><strong>Marketers</strong> batch-preparing assets for ads or landing pages.</li>
          <li><strong>Anyone on a phone</strong> shrinking huge camera photos before WhatsApp or email.</li>
        </ul>
      </section>

      <section class="resize-edu-block">
        <h2 id="troubleshooting-resize">Troubleshooting</h2>
        <p>
          <strong>Out of memory or slow:</strong> Try a smaller target width/height, fewer tabs open, or resize very large sources in stages.
        </p>
        <p>
          <strong>Image looks blurry:</strong> You may be stretching a small source — avoid upscaling; start from a higher-resolution original. With aspect ratio on, we do not upscale past the original size.
        </p>
        <p>
          <strong>Wrong proportions:</strong> Ensure “Maintain aspect ratio” matches your intent — off forces exact WxH and can distort.
        </p>
      </section>
    </div>
  </article>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>Is this image resizer free and unlimited?</h4><p>Yes. Resize as many images as you want with no signup, watermarks, or fees. Processing runs in your browser.</p></div>
        <div class="faq-item"><h4>Are my images uploaded to your servers?</h4><p>No. Files never leave your device. Resizing uses the HTML5 Canvas API locally — we cannot see or store your photos.</p></div>
        <div class="faq-item"><h4>What does “maintain aspect ratio” and fit inside width × height mean?</h4><p>When enabled, each image scales uniformly to fit inside your target box without cropping or stretching. The output dimensions may be smaller than the box so the whole image stays visible. Images larger than the box are scaled down; smaller images are not enlarged.</p></div>
        <div class="faq-item"><h4>What if I turn off maintain aspect ratio?</h4><p>Each image is stretched or squeezed to exactly the width and height you entered. Use this only when you want a precise pixel box and accept possible distortion.</p></div>
        <div class="faq-item"><h4>Why is the download a JPG file?</h4><p>Exports use JPEG for broad compatibility and reasonable file size after resizing. Filenames end with -resized.jpg. Use Advanced options to change JPEG quality.</p></div>
        <div class="faq-item"><h4>What happens to PNG or WebP transparency?</h4><p>JPEG does not support transparency. Transparent areas are composited on a white background before export.</p></div>
        <div class="faq-item"><h4>Does it work on mobile phones and tablets?</h4><p>Yes, on modern mobile browsers that support Canvas. Very large images may be slower or hit device memory limits.</p></div>
        <div class="faq-item"><h4>What are the width and height limits?</h4><p>You can enter dimensions from 1 up to 16384 pixels. Extremely large outputs may fail if the browser runs out of memory — try smaller targets if that happens.</p></div>
        <div class="faq-item"><h4>Can I resize many photos at once?</h4><p>Yes. Select or drag multiple files; each is processed with the same settings. Download individually or as one ZIP archive.</p></div>
        <div class="faq-item"><h4>Is there a monthly limit or account required?</h4><p>No accounts, no quotas, and no premium tier. Use the tool as often as you need.</p></div>
      </div>
    </div>
  </section>

  <section class="resize-related" aria-label="Related tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="resize-related-grid">
        <li><a href="/image/image-compressor/">Image Compressor</a></li>
        <li><a href="/image/webp-to-jpg/">WebP to JPG Converter</a></li>
        <li><a href="/image/heic-to-jpg/">HEIC to JPG Converter</a></li>
        <li><a href="/image/avif-to-jpg/">AVIF to JPG Converter</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="resize-related-grid resize-related-guides">
        <li><a href="/blog/best-image-format-for-web/">Best Image Format for Websites (WebP vs AVIF vs JPG)</a></li>
        <li><a href="/blog/heic-vs-jpg/">HEIC vs JPG: Complete Comparison</a></li>
        <li><a href="/blog/convert-iphone-photos-to-jpg/">Convert iPhone Photos to JPG</a></li>
      </ul>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      const resultsMore = document.getElementById('resultsMore');
      const widthInp = document.getElementById('widthInp');
      const heightInp = document.getElementById('heightInp');
      const keepAspect = document.getElementById('keepAspect');
      let converted = [];
      let aspectLockSource = null;

      function formatSizeForCompare(bytes) {
        const mb = bytes / (1024 * 1024);
        if (mb >= 0.01) return mb.toFixed(2) + ' MB';
        return (bytes / 1024).toFixed(1) + ' KB';
      }

      function getJpegQuality() {
        const btn = document.querySelector('.preset-btn.is-selected');
        return btn ? parseInt(btn.dataset.q, 10) / 100 : 1;
      }

      function wireQualityPresets() {
        const hintMain = document.getElementById('hintMain');
        const presetDesc = document.getElementById('presetDesc');
        const toggleAdvanced = document.getElementById('toggleAdvanced');
        const advancedPanel = document.getElementById('advancedPanel');
        const HINT = {
          '100': 'Exporting at maximum JPEG quality',
          '85': 'Exporting at balanced JPEG quality (85%)',
          '70': 'Exporting for smallest file size (70%)',
        };
        const DESC = {
          '100': '100% quality — best fidelity, largest JPEGs.',
          '85': '85% — smaller files with minimal visible loss.',
          '70': '70% — smallest files; more compression visible.',
        };

        function syncPresetLabels() {
          const sel = document.querySelector('.preset-btn.is-selected');
          const q = sel ? sel.dataset.q : '100';
          if (hintMain) hintMain.textContent = HINT[q] || HINT['100'];
          if (presetDesc) presetDesc.textContent = DESC[q] || DESC['100'];
        }

        document.querySelectorAll('.preset-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('.preset-btn').forEach((b) => {
              b.classList.remove('is-selected');
              b.setAttribute('aria-checked', 'false');
            });
            btn.classList.add('is-selected');
            btn.setAttribute('aria-checked', 'true');
            syncPresetLabels();
          });
        });

        toggleAdvanced?.addEventListener('click', () => {
          const open = advancedPanel.hidden;
          advancedPanel.hidden = !open;
          toggleAdvanced.setAttribute('aria-expanded', open ? 'true' : 'false');
        });

        syncPresetLabels();
      }

      wireQualityPresets();

      function parseDim(el) {
        const v = parseInt(el.value, 10);
        return Number.isFinite(v) && v > 0 ? v : 1;
      }

      function computeTargetDims(nw, nh, maxW, maxH, lock) {
        if (!lock) return { w: maxW, h: maxH };
        const scale = Math.min(maxW / nw, maxH / nh, 1);
        return {
          w: Math.max(1, Math.round(nw * scale)),
          h: Math.max(1, Math.round(nh * scale)),
        };
      }

      widthInp.addEventListener('input', () => {
        if (!keepAspect.checked || !aspectLockSource) return;
        const ar = aspectLockSource.h / aspectLockSource.w;
        heightInp.value = Math.max(1, Math.round(parseDim(widthInp) * ar));
      });
      heightInp.addEventListener('input', () => {
        if (!keepAspect.checked || !aspectLockSource) return;
        const ar = aspectLockSource.w / aspectLockSource.h;
        widthInp.value = Math.max(1, Math.round(parseDim(heightInp) * ar));
      });
      keepAspect.addEventListener('change', () => {
        if (keepAspect.checked) aspectLockSource = { w: parseDim(widthInp), h: parseDim(heightInp) };
      });

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag'); });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', e => {
        const fs = Array.from(e.target.files);
        e.target.value = '';
        handleFiles(fs);
      });

      function loadImage(file) {
        return new Promise((resolve, reject) => {
          const url = URL.createObjectURL(file);
          const img = new Image();
          img.onload = () => { URL.revokeObjectURL(url); resolve(img); };
          img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Could not decode image')); };
          img.crossOrigin = 'anonymous';
          img.src = url;
        });
      }

      function resizeToBlob(img, tw, th, quality) {
        const canvas = document.createElement('canvas');
        canvas.width = tw;
        canvas.height = th;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, tw, th);
        ctx.imageSmoothingEnabled = true;
        ctx.imageSmoothingQuality = 'high';
        ctx.drawImage(img, 0, 0, tw, th);
        return new Promise((resolve, reject) => {
          canvas.toBlob(
            b => (b ? resolve(b) : reject(new Error('toBlob failed'))),
            'image/jpeg',
            quality
          );
        });
      }

      function outName(originalName) {
        const base = originalName.replace(/\.(jpe?g|png|webp)$/i, '');
        return base + '-resized.jpg';
      }

      async function handleFiles(files) {
        if (!files || !files.length) return;
        const list = files.filter(f => {
          const t = (f.type || '').toLowerCase();
          const n = f.name.toLowerCase();
          return (
            t === 'image/jpeg' ||
            t === 'image/png' ||
            t === 'image/webp' ||
            /\.(jpe?g|png|webp)$/i.test(n)
          );
        });
        if (!list.length) {
          alert('Please choose JPG, PNG, or WebP images.');
          return;
        }

        if (!aspectLockSource) {
          aspectLockSource = { w: parseDim(widthInp), h: parseDim(heightInp) };
        }

        const total = list.length;
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const toolbar = document.getElementById('resultsToolbar');
        if (toolbar) toolbar.style.display = 'none';
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;

        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Resizing ' + total + ' file(s)...';

        const maxW = parseDim(widthInp);
        const maxH = parseDim(heightInp);
        const lock = keepAspect.checked;
        const quality = getJpegQuality();
        let idx = 0;

        for (const file of list) {
          const parent = window.DoItSwiftFileResults
            ? DoItSwiftFileResults.getAppendParent(results, resultsMore, idx)
            : results;
          idx += 1;

          const item = document.createElement('div');
          item.className = 'file-item';
          item.innerHTML = `
            <div class="file-item-main">
              <div class="file-thumb" aria-hidden="true">🖼️</div>
              <div class="file-info">
                <div class="file-name"></div>
                <div class="file-status">Resizing…</div>
                <div class="progress-bar"><div class="progress-fill"></div></div>
              </div>
              <div class="file-actions-col">
                <button type="button" class="btn-text btn-preview" disabled style="visibility:hidden">Preview</button>
              </div>
            </div>
            <div class="file-preview-panel" hidden>
              <img alt="Preview" />
            </div>
          `;
          item.querySelector('.file-name').textContent = file.name;
          parent.appendChild(item);
          const fill = item.querySelector('.progress-fill');
          const status = item.querySelector('.file-status');
          fill.style.width = '40%';

          try {
            const img = await loadImage(file);
            const nw = img.naturalWidth || img.width;
            const nh = img.naturalHeight || img.height;
            const { w: tw, h: th } = computeTargetDims(nw, nh, maxW, maxH, lock);
            const finalBlob = await resizeToBlob(img, tw, th, quality);
            const url = URL.createObjectURL(finalBlob);
            const newName = outName(file.name);
            converted.push({ name: newName, blob: finalBlob });
            fill.style.width = '100%';
            status.className = 'file-status done';
            status.innerHTML =
              '<span class="size-compare">Original: ' +
              formatSizeForCompare(file.size) +
              ' → Converted: ' +
              formatSizeForCompare(finalBlob.size) +
              '</span>' +
              '<span class="dim-note">' +
              tw +
              '×' +
              th +
              ' px</span>';
            const actionsCol = item.querySelector('.file-actions-col');
            const dl = document.createElement('a');
            dl.href = url;
            dl.download = newName;
            dl.className = 'btn';
            dl.textContent = 'Download';
            actionsCol.appendChild(dl);
            if (window.DoItSwiftFileResults) {
              DoItSwiftFileResults.initCompletedRow(item, url);
            }
          } catch (err) {
            fill.style.width = '100%';
            fill.style.background = '#ef4444';
            status.className = 'file-status error';
            status.textContent = 'Error: ' + (err.message || 'Failed');
          }
        }

        if (converted.length) {
          actions.style.display = 'flex';
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(converted.length);
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + converted.length + ' file(s) ready — see list below';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const batchOver10 = total > 10;
          if (window.DoItSwiftFileResults) {
            DoItSwiftFileResults.setupToolbar({
              toolbar: document.getElementById('resultsToolbar'),
              galleryToggle: document.getElementById('galleryViewToggle'),
              note: document.getElementById('galleryToolbarNote'),
              batchOver10,
              galleryRoot: document.getElementById('fileResultsRoot'),
            });
            if (total > 10) {
              DoItSwiftFileResults.setupMoreFilesSection({
                moreBlock: document.getElementById('resultsMoreBlock'),
                moreInner: document.getElementById('resultsMore'),
                moreBtn: document.getElementById('moreFilesBtn'),
                moreLabel: document.getElementById('moreFilesLabel'),
                extraCount: total - 10,
              });
            }
          }
        }
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const tb = document.getElementById('resultsToolbar');
        if (tb) tb.style.display = 'none';
        const gt = document.getElementById('galleryViewToggle');
        if (gt) {
          gt.checked = false;
          gt.disabled = false;
        }
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;
        converted = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined') return alert('ZIP library not loaded.');
        const zip = new JSZip();
        converted.forEach(f => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const url = URL.createObjectURL(content);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'doitswift-resized.zip';
        a.click();
        URL.revokeObjectURL(url);
      });

      void (async () => {
        try {
          const pending = await window.DoItSwiftPending?.consume?.();
          if (pending) await handleFiles([pending]);
        } catch (e) {
          console.warn(e);
        }
      })();
    });
  </script>

