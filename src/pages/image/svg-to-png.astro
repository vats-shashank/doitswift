---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="SVG to PNG Converter Online — Custom Size, Batch & Private | DoItSwift"
  description="Convert SVG to PNG in your browser — set exact output width and height (up to 8192 px), quick presets for icons and HD, batch ZIP download. Free, unlimited, no upload. Vector logos and illustrations to raster PNG for any app."
  keywords="svg to png, convert svg to png, svg to png online, rasterize svg, vector to png, svg png converter, export svg as png, free svg to png, batch svg to png, svg icon png, logo svg to png, private svg converter"
  canonical={new URL(Astro.url.pathname, Astro.site).toString()}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "DoItSwift SVG to PNG Converter",
    "description": "Free browser-based SVG to PNG converter. Set output dimensions in pixels, use quick size presets, export lossless PNG, batch download as ZIP. All processing is local — files are not uploaded.",
    "url": "https://doitswift.com/image/svg-to-png/",
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Web browser",
    "browserRequirements": "Requires HTML5 Canvas and JavaScript",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "Convert SVG files to PNG raster images",
      "Custom output width and height from 1 to 8192 pixels",
      "Quick presets: 256, 512, 1024 square, and 1920×1080",
      "Unlimited batch conversion with ZIP download",
      "Client-side rendering — no server upload",
      "PNG output with before/after file size on each row"
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Is SVG to PNG conversion free and unlimited?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Convert as many SVG files as you want with no signup, watermarks, or fees. Everything runs in your browser." }},
      { "@type": "Question", "name": "Are my SVG files private? Are they uploaded?", "acceptedAnswer": { "@type": "Answer", "text": "Files never leave your device. The tool reads each SVG locally, renders it on an HTML5 canvas, and exports PNG — no upload to our servers." }},
      { "@type": "Question", "name": "How do width and height work for SVG to PNG?", "acceptedAnswer": { "@type": "Answer", "text": "SVG is vector-based and has no fixed pixel size until rasterized. You choose the output bitmap size in pixels (1–8192). The graphic is drawn to fill that canvas — larger dimensions produce sharper PNGs and usually larger files." }},
      { "@type": "Question", "name": "What are the quick preset buttons for?", "acceptedAnswer": { "@type": "Answer", "text": "Presets set common output sizes: 256×256 and 512×512 for icons and app assets, 1024×1024 for high-resolution squares, and 1920×1080 for slide or wallpaper-style exports." }},
      { "@type": "Question", "name": "Why is there a white background behind my PNG?", "acceptedAnswer": { "@type": "Answer", "text": "The canvas is filled with white before the SVG is drawn. Transparent areas of the SVG composite against that white background in the exported PNG." }},
      { "@type": "Question", "name": "Will images or fonts inside my SVG always load?", "acceptedAnswer": { "@type": "Answer", "text": "Embedded data and typical local assets usually work. External URLs referenced in the SVG may be blocked by browser security (CORS), so remote images or fonts might not appear. Text may render differently if a referenced web font is unavailable." }},
      { "@type": "Question", "name": "Does it work on mobile?", "acceptedAnswer": { "@type": "Answer", "text": "Yes on modern mobile browsers that support Canvas. Very large output dimensions or complex SVGs may be slow or hit memory limits." }},
      { "@type": "Question", "name": "Can I convert many SVG files at once?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Select or drag multiple .svg files; each is rendered at the same width and height you set. Download individually or all at once as a ZIP." }},
      { "@type": "Question", "name": "What is the maximum output size?", "acceptedAnswer": { "@type": "Answer", "text": "You can enter up to 8192 pixels per side. Extremely large canvases may fail if the browser runs out of memory." }},
      { "@type": "Question", "name": "Is there a monthly limit or account required?", "acceptedAnswer": { "@type": "Answer", "text": "No accounts, no quotas, and no premium tier. Use the converter as often as you need." }}
    ]
  })} />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" is:inline></script>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>SVG to PNG Converter</h1>
      <p class="subtitle">
        Rasterize vector SVG files to PNG — custom pixel width and height, icon presets, batch ZIP. Rendering stays in your browser; nothing is uploaded.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📁</div>
        <div class="dropzone-text">Drop SVG files here or click to browse</div>
        <div class="dropzone-sub">Convert as many SVGs as you want — all at once</div>
        <input type="file" id="fileInput" multiple accept=".svg,image/svg+xml" />
      </div>

      <div class="controls controls-grid">
        <div class="control-row">
          <label for="outW">Width (px)</label>
          <input type="number" id="outW" min="1" max="8192" value="512" />
        </div>
        <div class="control-row">
          <label for="outH">Height (px)</label>
          <input type="number" id="outH" min="1" max="8192" value="512" />
        </div>
        <div class="presets">
          <span class="presets-label">Quick:</span>
          <button type="button" class="preset-btn" data-w="256" data-h="256">256²</button>
          <button type="button" class="preset-btn" data-w="512" data-h="512">512²</button>
          <button type="button" class="preset-btn" data-w="1024" data-h="1024">1024²</button>
          <button type="button" class="preset-btn" data-w="1920" data-h="1080">1920×1080</button>
        </div>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        PNG files (<span id="fileCount">0</span>):
      </div>
      <div id="fileResultsRoot">
        <div id="resultsToolbar" class="results-toolbar" style="display:none">
          <label class="gallery-toggle">
            <input type="checkbox" id="galleryViewToggle" />
            Show thumbnails in list
          </label>
          <p class="toolbar-note" id="galleryToolbarNote" hidden></p>
        </div>
        <div class="results" id="results"></div>
        <div id="resultsMoreBlock" class="results-more-block" style="display:none">
          <button type="button" class="more-files-btn" id="moreFilesBtn">
            <span id="moreFilesLabel"></span>
          </button>
          <div id="resultsMore" class="results results-more-inner" hidden></div>
        </div>
      </div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- Educational content (SEO) -->
  <article class="svg-edu" aria-label="Guide: SVG format and converting to PNG">
    <div class="container svg-edu-inner">
      <section class="svg-edu-block">
        <h2 id="what-is-svg-vs-png">What is SVG — and when do you need PNG instead?</h2>
        <p>
          <strong>SVG</strong> (Scalable Vector Graphics) stores drawings as <strong>math and markup</strong> — paths, shapes, text — so the same file stays sharp at any zoom. <strong>PNG</strong> is a <strong>raster</strong> format: a fixed grid of pixels. You convert <strong>SVG to PNG</strong> when a workflow needs a bitmap: older apps, some social templates, slide decks, game engines, or print pipelines that insist on PNG or JPEG.
        </p>
        <p>
          This tool <strong>rasterizes</strong> your SVG: it draws the vector graphic onto a pixel canvas and saves the result as a <strong>PNG</strong> at the exact width and height you choose. That matches how designers export “@2x” or icon assets from vector tools — except it runs locally in your browser with <strong>no file upload</strong>.
        </p>
      </section>

      <section class="svg-edu-block">
        <h2 id="how-svg-to-png-works">How this SVG to PNG converter works</h2>
        <p>
          Each <code>.svg</code> file is read as text in your browser, loaded as an image, drawn to an HTML5 <strong>canvas</strong> at your target dimensions, and exported with <strong>PNG</strong> encoding. You see <strong>before and after file sizes</strong> on every row plus the output resolution (e.g. 512×512 px).
        </p>
        <ol class="svg-steps">
          <li><strong>Set output size.</strong> Enter width and height in pixels (1–8192), or use <strong>Quick</strong> presets: 256², 512², 1024², or 1920×1080.</li>
          <li><strong>Add SVG files.</strong> Drop files or browse; batch as many as you need.</li>
          <li><strong>Download.</strong> Save each PNG separately or use <strong>Download All as ZIP</strong>.</li>
        </ol>
        <p>
          Need a different raster size later? Use our <a href="/image/image-resizer/">image resizer</a> on the PNG, or re-export from this page with new dimensions — vectors stay in the SVG source file.
        </p>
      </section>

      <section class="svg-edu-block">
        <h2 id="svg-vs-png-table">SVG vs PNG at a glance</h2>
        <div class="svg-table-wrap">
          <table class="svg-compare-table">
            <caption class="sr-only">Comparison of SVG and PNG</caption>
            <thead>
              <tr>
                <th scope="col">Aspect</th>
                <th scope="col">SVG</th>
                <th scope="col">PNG (this export)</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Type</td><td>Vector (scalable)</td><td>Raster (fixed pixels)</td></tr>
              <tr><td>Best for</td><td>Logos, icons, illustrations</td><td>Universal bitmap use, strict pixel dimensions</td></tr>
              <tr><td>File size</td><td>Often tiny for simple graphics</td><td>Grows with width × height and detail</td></tr>
              <tr><td>Scaling</td><td>Infinite without quality loss</td><td>Fixed — upscale can look soft</td></tr>
              <tr><td>Photos</td><td>Not suitable</td><td>Yes (if source is photographic raster)</td></tr>
            </tbody>
          </table>
        </div>
        <p>
          For choosing formats across a whole website (WebP, AVIF, JPG, SVG), see <a href="/blog/best-image-format-for-web/">best image format for websites</a>.
        </p>
      </section>

      <section class="svg-edu-block">
        <h2 id="transparency-cors-fonts">Transparency, external assets, and fonts</h2>
        <p>
          <strong>Background:</strong> The export canvas is filled with <strong>white</strong> before drawing. Transparent regions of your SVG composite against white in the final PNG (similar to flattening layers in a design app).
        </p>
        <p>
          <strong>External images and CORS:</strong> If your SVG references images by <strong>URL</strong>, the browser may block them unless the remote server allows cross-origin use. For reliable results, embed assets or use files that do not depend on blocked network requests.
        </p>
        <p>
          <strong>Fonts:</strong> Text renders using available fonts. Outlined paths or system fonts are safest; missing <strong>web fonts</strong> can cause substitution or layout shifts. For pixel-perfect text, outline fonts in your design tool before export.
        </p>
      </section>

      <section class="svg-edu-block">
        <h2 id="who-uses-svg-to-png">Who uses SVG to PNG conversion?</h2>
        <ul class="svg-audience-list">
          <li><strong>Developers</strong> generating app icons or splash assets at required pixel sizes.</li>
          <li><strong>Designers</strong> handing off PNGs to clients whose tools do not accept SVG.</li>
          <li><strong>Marketers</strong> placing logos in slide decks or PDFs that need raster previews.</li>
          <li><strong>Anyone</strong> who downloaded an SVG icon and needs a quick PNG for upload.</li>
        </ul>
        <p>
          Building a favicon set? Our <a href="/image/favicon-generator/">favicon generator</a> complements SVG and PNG workflows.
        </p>
      </section>

      <section class="svg-edu-block">
        <h2 id="troubleshooting-svg-png">Troubleshooting</h2>
        <p>
          <strong>Blank or partial render:</strong> Check for blocked external resources, invalid SVG markup, or huge viewBoxes — simplify the file and try again.
        </p>
        <p>
          <strong>Out of memory:</strong> Reduce output dimensions (try 512 or 1024 first) or process fewer files at once.
        </p>
        <p>
          <strong>Blurry PNG:</strong> Increase width and height — you are asking for more pixels, not “enhancing” a small export.
        </p>
      </section>
    </div>
  </article>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item"><h4>Is SVG to PNG conversion free and unlimited?</h4><p>Yes. Convert as many SVG files as you want with no signup, watermarks, or fees. Everything runs in your browser.</p></div>
        <div class="faq-item"><h4>Are my SVG files private? Are they uploaded?</h4><p>Files never leave your device. The tool reads each SVG locally, renders it on an HTML5 canvas, and exports PNG — no upload to our servers.</p></div>
        <div class="faq-item"><h4>How do width and height work for SVG to PNG?</h4><p>SVG is vector-based and has no fixed pixel size until rasterized. You choose the output bitmap size in pixels (1–8192). The graphic is drawn to fill that canvas — larger dimensions produce sharper PNGs and usually larger files.</p></div>
        <div class="faq-item"><h4>What are the quick preset buttons for?</h4><p>Presets set common output sizes: 256×256 and 512×512 for icons and app assets, 1024×1024 for high-resolution squares, and 1920×1080 for slide or wallpaper-style exports.</p></div>
        <div class="faq-item"><h4>Why is there a white background behind my PNG?</h4><p>The canvas is filled with white before the SVG is drawn. Transparent areas of the SVG composite against that white background in the exported PNG.</p></div>
        <div class="faq-item"><h4>Will images or fonts inside my SVG always load?</h4><p>Embedded data and typical local assets usually work. External URLs referenced in the SVG may be blocked by browser security (CORS), so remote images or fonts might not appear. Text may render differently if a referenced web font is unavailable.</p></div>
        <div class="faq-item"><h4>Does it work on mobile?</h4><p>Yes on modern mobile browsers that support Canvas. Very large output dimensions or complex SVGs may be slow or hit memory limits.</p></div>
        <div class="faq-item"><h4>Can I convert many SVG files at once?</h4><p>Yes. Select or drag multiple .svg files; each is rendered at the same width and height you set. Download individually or all at once as a ZIP.</p></div>
        <div class="faq-item"><h4>What is the maximum output size?</h4><p>You can enter up to 8192 pixels per side. Extremely large canvases may fail if the browser runs out of memory.</p></div>
        <div class="faq-item"><h4>Is there a monthly limit or account required?</h4><p>No accounts, no quotas, and no premium tier. Use the converter as often as you need.</p></div>
      </div>
    </div>
  </section>

  <section class="svg-related" aria-label="Related tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="svg-related-grid">
        <li><a href="/image/favicon-generator/">Favicon Generator</a></li>
        <li><a href="/image/image-resizer/">Image Resizer</a></li>
        <li><a href="/image/webp-to-jpg/">WebP to JPG Converter</a></li>
        <li><a href="/image/image-compressor/">Image Compressor</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="svg-related-grid svg-related-guides">
        <li><a href="/blog/best-image-format-for-web/">Best Image Format for Websites (SVG, WebP, JPG &amp; more)</a></li>
        <li><a href="/blog/heic-vs-jpg/">HEIC vs JPG: Complete Comparison</a></li>
        <li><a href="/blog/convert-iphone-photos-to-jpg/">Convert iPhone Photos to JPG</a></li>
      </ul>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      const resultsMore = document.getElementById('resultsMore');
      const outW = document.getElementById('outW');
      const outH = document.getElementById('outH');
      let converted = [];

      function formatSizeForCompare(bytes) {
        const mb = bytes / (1024 * 1024);
        if (mb >= 0.01) return mb.toFixed(2) + ' MB';
        return (bytes / 1024).toFixed(1) + ' KB';
      }

      document.querySelectorAll('.preset-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          outW.value = btn.getAttribute('data-w');
          outH.value = btn.getAttribute('data-h');
        });
      });

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('drag'); });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', e => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', e => {
        const fs = Array.from(e.target.files);
        e.target.value = '';
        handleFiles(fs);
      });

      function parseDim(el) {
        const v = parseInt(el.value, 10);
        return Number.isFinite(v) && v > 0 ? Math.min(v, 8192) : 512;
      }

      function svgFileToPngBlob(file, w, h) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            try {
              const text = typeof reader.result === 'string' ? reader.result : '';
              const blob = new Blob([text], { type: 'image/svg+xml;charset=utf-8' });
              const url = URL.createObjectURL(blob);
              const img = new Image();
              img.onload = () => {
                const canvas = document.createElement('canvas');
                canvas.width = w;
                canvas.height = h;
                const ctx = canvas.getContext('2d');
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(0, 0, w, h);
                ctx.imageSmoothingEnabled = true;
                ctx.imageSmoothingQuality = 'high';
                ctx.drawImage(img, 0, 0, w, h);
                URL.revokeObjectURL(url);
                canvas.toBlob(
                  b => (b ? resolve(b) : reject(new Error('toBlob failed'))),
                  'image/png'
                );
              };
              img.onerror = () => {
                URL.revokeObjectURL(url);
                reject(new Error('Could not render SVG'));
              };
              img.crossOrigin = 'anonymous';
              img.src = url;
            } catch (e) {
              reject(e);
            }
          };
          reader.onerror = () => reject(new Error('Read failed'));
          reader.readAsText(file);
        });
      }

      async function handleFiles(files) {
        if (!files || !files.length) return;
        const list = files.filter(f => f.type === 'image/svg+xml' || /\.svg$/i.test(f.name));
        if (!list.length) {
          alert('Please choose SVG files.');
          return;
        }

        const w = parseDim(outW);
        const h = parseDim(outH);

        const total = list.length;
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const toolbar = document.getElementById('resultsToolbar');
        if (toolbar) toolbar.style.display = 'none';
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;

        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Converting ' + total + ' file(s)...';

        let idx = 0;
        for (const file of list) {
          const parent = window.DoItSwiftFileResults
            ? DoItSwiftFileResults.getAppendParent(results, resultsMore, idx)
            : results;
          idx += 1;

          const item = document.createElement('div');
          item.className = 'file-item';
          item.innerHTML = `
            <div class="file-item-main">
              <div class="file-thumb" aria-hidden="true">🖼️</div>
              <div class="file-info">
                <div class="file-name"></div>
                <div class="file-status">Rendering…</div>
                <div class="progress-bar"><div class="progress-fill"></div></div>
              </div>
              <div class="file-actions-col">
                <button type="button" class="btn-text btn-preview" disabled style="visibility:hidden">Preview</button>
              </div>
            </div>
            <div class="file-preview-panel" hidden>
              <img alt="Preview" />
            </div>
          `;
          item.querySelector('.file-name').textContent = file.name;
          parent.appendChild(item);
          const fill = item.querySelector('.progress-fill');
          const status = item.querySelector('.file-status');
          fill.style.width = '40%';

          try {
            const finalBlob = await svgFileToPngBlob(file, w, h);
            const url = URL.createObjectURL(finalBlob);
            const newName = file.name.replace(/\.svg$/i, '.png');
            converted.push({ name: newName, blob: finalBlob });
            fill.style.width = '100%';
            status.className = 'file-status done';
            status.innerHTML =
              '<span class="size-compare">Original: ' +
              formatSizeForCompare(file.size) +
              ' → Converted: ' +
              formatSizeForCompare(finalBlob.size) +
              '</span><span class="dim-note">' +
              w +
              '×' +
              h +
              ' px</span>';
            const actionsCol = item.querySelector('.file-actions-col');
            const dl = document.createElement('a');
            dl.href = url;
            dl.download = newName;
            dl.className = 'btn';
            dl.textContent = 'Download';
            actionsCol.appendChild(dl);
            if (window.DoItSwiftFileResults) {
              DoItSwiftFileResults.initCompletedRow(item, url);
            }
          } catch (err) {
            fill.style.width = '100%';
            fill.style.background = '#ef4444';
            status.className = 'file-status error';
            status.textContent = 'Error: ' + (err.message || 'Failed');
          }
        }

        if (converted.length) {
          actions.style.display = 'flex';
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(converted.length);
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + converted.length + ' file(s) ready — see list below';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
          const batchOver10 = total > 10;
          if (window.DoItSwiftFileResults) {
            DoItSwiftFileResults.setupToolbar({
              toolbar: document.getElementById('resultsToolbar'),
              galleryToggle: document.getElementById('galleryViewToggle'),
              note: document.getElementById('galleryToolbarNote'),
              batchOver10,
              galleryRoot: document.getElementById('fileResultsRoot'),
            });
            if (total > 10) {
              DoItSwiftFileResults.setupMoreFilesSection({
                moreBlock: document.getElementById('resultsMoreBlock'),
                moreInner: document.getElementById('resultsMore'),
                moreBtn: document.getElementById('moreFilesBtn'),
                moreLabel: document.getElementById('moreFilesLabel'),
                extraCount: total - 10,
              });
            }
          }
        }
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        results.innerHTML = '';
        if (resultsMore) resultsMore.innerHTML = '';
        const moreBlock = document.getElementById('resultsMoreBlock');
        if (moreBlock) moreBlock.style.display = 'none';
        const tb = document.getElementById('resultsToolbar');
        if (tb) tb.style.display = 'none';
        const gt = document.getElementById('galleryViewToggle');
        if (gt) {
          gt.checked = false;
          gt.disabled = false;
        }
        const note = document.getElementById('galleryToolbarNote');
        if (note) note.hidden = true;
        converted = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined') return alert('ZIP library not loaded.');
        const zip = new JSZip();
        converted.forEach(f => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const url = URL.createObjectURL(content);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'doitswift-svg-to-png.zip';
        a.click();
        URL.revokeObjectURL(url);
      });

      void (async () => {
        try {
          const pending = await window.DoItSwiftPending?.consume?.();
          if (pending) await handleFiles([pending]);
        } catch (e) {
          console.warn(e);
        }
      })();
