---
import MainLayout from '../../layouts/MainLayout.astro';
import CaseConverterEducation from '../../components/CaseConverterEducation.astro';
import { calculatorCanonical } from '../../lib/calculatorJsonLd';

const canonical = calculatorCanonical(Astro.site, Astro.url.pathname);
const pageTitle = 'Free Case Converter — 15 Formats, Browser-Based & Private';
const pageDescription =
  'Convert text between 15 case formats — UPPERCASE, lowercase, Title Case, camelCase, snake_case & more. 100% browser-based. No signup, no ads.';
const pageKeywords =
  'case converter, text case converter, free case converter, online case converter, case converter online, uppercase converter, lowercase converter, lowercase to uppercase, uppercase to lowercase, title case converter, sentence case converter, capitalize each word, camelcase converter, pascalcase converter, snake case converter, snake_case converter, kebab case converter, kebab-case converter, constant case converter, alternating case converter, inverse case converter, dot case converter, train case converter, slug generator, url slug converter, text formatting tool, change case online, convert to title case, what is camelcase, what is snake case, case converter no signup, private case converter, browser case converter, case converter offline, case converter unlimited';

const softwareAppDescription =
  'Free browser-based case converter supporting 15 text case formats including UPPERCASE, lowercase, Title Case, camelCase, snake_case, and kebab-case. Privacy-first: text never leaves your browser.';

const faqItems = [
  {
    question: 'What is a text case converter?',
    answer:
      'A text case converter rewrites the same string in different capitalization and naming styles—UPPERCASE, sentence case, Title Case, programming styles like camelCase and snake_case, and more—without retyping. Writers, developers, and SEO specialists use it to fix Caps Lock mistakes, build URL slugs, and match team style guides. DoItSwift’s tool does this in your browser, so you can copy the result in one step.',
  },
  {
    question: 'Is the DoItSwift case converter free? Are there limits?',
    answer:
      'Yes. The case converter is free to use with no signup, no paywall, and no ads. There is no character limit imposed by us: your browser holds the text and runs the conversion locally, so very large pastes are only limited by your device memory, not a server cap.',
  },
  {
    question: 'Is my text uploaded to a server or stored in the cloud?',
    answer:
      'No. The page is static; conversion runs in JavaScript in your tab. Your text is not uploaded to DoItSwift for this feature, is not written to our databases, and is not used to train models. You can use DevTools → Network to confirm: converting text does not add new requests. Close the tab and the content is gone unless you saved it yourself.',
  },
  {
    question: 'How many case formats does this tool support?',
    answer:
      'Fifteen formats: Sentence case, UPPER CASE, lowercase, Capitalize Each Word, Title Case, aLtErNaTiNg cAsE, InVeRsE cAsE, camelCase, PascalCase, snake_case, CONSTANT_CASE, kebab-case, Train-Case, dot.case, and path/case. Optional "Compare all" shows every result at once.',
  },
  {
    question: 'What is the difference between sentence case and title case?',
    answer:
      'Sentence case capitalizes the first word of each sentence (and, with smart options, proper nouns) like body copy. Title case follows headline rules: important words are capitalized while short words like "a" and "the" often stay lowercase in the middle, per common style guides. Use sentence case for modern UI and many emails; title case for traditional headlines and some titles of works.',
  },
  {
    question: 'When should I use camelCase instead of snake_case in code?',
    answer:
      'Convention depends on the ecosystem. JavaScript, TypeScript, Java, and C# often use camelCase for variables and methods, while Python and Ruby commonly use snake_case. Databases and many APIs use snake_case for column names, while JSON in JavaScript-heavy stacks often uses camelCase. Match your language guide and the codebase you are editing; this tool outputs both from the same input.',
  },
  {
    question: 'Why is kebab-case the standard for URL slugs and SEO-friendly paths?',
    answer:
      'Search engines treat hyphens as word separators, while underscores are not always tokenized the same way. Lowercase kebab-case avoids case ambiguity, reads clearly for humans, and is safe in URLs without encoding. That is why blog and product URLs like /my-blog-post are so common. Use this tool to turn a title into a slug in one click.',
  },
  {
    question: 'What is "smart" Title Case compared to capitalizing every word?',
    answer:
      'Basic title case can capitalize every word, including "of" and "in," which is wrong for many style guides. Smart title case keeps short prepositions, articles, and conjunctions lowercase in the middle of a title, except the first and last word. This matches expectations closer to Chicago, AP, and other common published standards.',
  },
  {
    question: 'How does the proper noun and acronym dictionary work?',
    answer:
      'For sentence and title case, you can enable automatic restoration of well-known acronyms and brand names (e.g. NASA, iPhone, JavaScript) using a large built-in dictionary (hundreds of entries) applied longest match first. Rare names may still need manual editing. You can turn this off in Settings for plain mechanical casing.',
  },
  {
    question: 'What keyboard shortcuts are available?',
    answer:
      'With the text area focused, use Ctrl+1 through Ctrl+5 (Cmd+1–5 on Mac) for Sentence, lowercase, UPPER, Capitalize Each Word, and Title case. Ctrl+Z (Cmd+Z) undoes the last in-tool conversion when our undo stack has a step, without blocking normal text editing when the stack is empty. Use the Copy button and standard copy shortcuts for the clipboard.',
  },
  {
    question: 'Can I use the case converter offline?',
    answer:
      'After the first load, the app’s scripts and page can be cached by your browser. You can work offline in many browsers once the page is open, with no network needed for conversion itself. A fresh visit still requires a connection to load the site unless your browser already has a cached copy.',
  },
  {
    question: 'Is there a character or word limit?',
    answer:
      'We do not impose a cap. Converting ten thousand or a hundred thousand words is handled locally, so the practical limit is your device and tab performance, not a server quota. If something feels slow, try splitting very large jobs or closing other heavy tabs.',
  },
  {
    question: 'What is the difference between camelCase and PascalCase?',
    answer:
      'Both formats remove spaces and capitalize each word, but they differ on the first letter. camelCase keeps the first letter lowercase ("getUserName"), while PascalCase capitalizes the first letter too ("GetUserName"). camelCase is conventional for variables and method names in JavaScript, Java, and C#. PascalCase is conventional for class names, type names, and constructors in those same languages, and for most identifiers in C# and TypeScript. Pick based on what you\'re naming, not personal preference — your codebase\'s existing convention is the right one to follow.',
  },
  {
    question: 'How do I turn a blog post title into a URL slug?',
    answer:
      'A clean URL slug uses kebab-case: lowercase letters separated by hyphens, with no special characters. Paste your title into the case converter, choose kebab-case, and the output is your slug. For example, "How to Bake Sourdough Bread" becomes "how-to-bake-sourdough-bread". Search engines treat hyphens as word separators, while underscores are not always tokenized the same way, which is why kebab-case is the standard for SEO-friendly URLs. The DoItSwift Case Converter also strips punctuation and collapses multiple spaces automatically when converting to kebab-case.',
  },
  {
    question: 'Who maintains this tool and how is the methodology checked?',
    answer:
      "DoItSwift's tools and educational content are maintained by DoItSwift Editorial under a published editorial standard. Case-conversion algorithms follow standard definitions from programming language specifications (JavaScript ECMA-262, Python PEP 8) and style guides (Chicago Manual of Style for Title Case). The proper noun dictionary is reviewed when widely-recognized brand or technology names emerge or when existing entries need correction. You can read the full editorial policy, research methodology, and fact-checking standards at /about/editorial-policy/, /about/how-we-research/, and /about/fact-checking/.",
  },
];

const howToLd = {
  '@type': 'HowTo',
  name: 'How to Convert Text Case Online',
  description: 'Change text between UPPERCASE, lowercase, Title Case, camelCase, and 12 other formats in your browser.',
  totalTime: 'PT10S',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Paste or type your text',
      text: 'Click the text area and paste your content or type directly.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Choose a case format',
      text: 'Click one of the 15 case format buttons below the text area.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Copy or download the result',
      text: "Click 'Copy' to copy to clipboard, or 'Download' to save as a .txt file.",
    },
  ],
};

const pageJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'DoItSwift Case Converter',
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Any (Web Browser)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description: softwareAppDescription,
      url: 'https://doitswift.com/text/case-converter/',
      featureList: [
        'Convert to UPPERCASE',
        'Convert to lowercase',
        'Convert to Title Case with smart proper noun detection',
        'Convert to Sentence case with 200+ proper noun dictionary',
        'Convert to camelCase',
        'Convert to PascalCase',
        'Convert to snake_case',
        'Convert to CONSTANT_CASE',
        'Convert to kebab-case',
        'Convert to Train-Case',
        'Convert to dot.case',
        'Convert to path/case',
        'Convert to aLtErNaTiNg cAsE',
        'Convert to InVeRsE CaSe',
        'Browser-based privacy (no data upload)',
        'Works offline after first load',
        'Unlimited text length',
        'Keyboard shortcuts (Ctrl+1 through Ctrl+5)',
        'Download output as .txt file',
        'Undo/redo functionality',
      ],
      browserRequirements: 'Requires JavaScript. Supports Chrome, Firefox, Safari, Edge.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://doitswift.com/' },
        { '@type': 'ListItem', position: 2, name: 'Text Tools', item: 'https://doitswift.com/text/' },
        { '@type': 'ListItem', position: 3, name: 'Case Converter', item: 'https://doitswift.com/text/case-converter/' },
      ],
    },
    howToLd,
  ],
};
---

<MainLayout title={pageTitle} description={pageDescription} keywords={pageKeywords} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(pageJsonLd)} />

  <nav class="breadcrumb container container--tool" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/text/">Text Tools</a> › <span>Case Converter</span>
  </nav>

  <section class="hero tool-hero">
    <div class="container">
      <div class="badge">📝 Free Text Tool</div>
      <h1>Free Case Converter — Change Text Between 15 Formats in Your Browser</h1>
      <p class="subtitle">
        A case converter is a free online tool that changes text between capitalization styles — UPPERCASE, lowercase, Title Case, Sentence case, camelCase, snake_case, kebab-case, and 9 other formats — without retyping. The DoItSwift Case Converter supports all 15 formats with a single click, plus optional smart Title Case rules and a 200+ proper noun dictionary that preserves brand names like iPhone and JavaScript. Conversion runs entirely in your browser, so your text is never uploaded to any server, never stored, and never shared with third parties. The tool is free for personal and commercial use, with no signup, no character limit, and no ads.
      </p>
      <p class="subtitle-secondary">
        Whether you left Caps Lock on for a whole paragraph, need camelCase variable names for code, want a kebab-case URL slug, or need to format a blog title correctly, the converter handles it in one click. Works on desktop and mobile. No signup. No character limit. No usage restrictions.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Privacy-first (browser-based)</span>
        <span><span class="check">✓</span> Real-time conversion (no server delay)</span>
        <span><span class="check">✓</span> No character limit</span>
        <span><span class="check">✓</span> No signup, no ads, no tracking</span>
      </div>
    </div>
  </section>

  <section class="cc-tool tool-section" aria-labelledby="cc-tool-heading">
    <div class="container container--tool">
      <h2 id="cc-tool-heading" class="sr-only">Case Converter Tool</h2>

      <div class="cc-toolbar-top" role="toolbar" aria-label="Text actions">
        <button type="button" id="ccCopyBtn" class="cc-icon-btn" title="Copy to clipboard" aria-label="Copy to clipboard">
          <span class="cc-icon" aria-hidden="true">📋</span> <span class="cc-btn-label">Copy</span>
        </button>
        <button
          type="button"
          id="ccDownloadBtn"
          class="cc-icon-btn"
          title="Download as .txt file"
          aria-label="Download as text file"
        >
          <span class="cc-icon" aria-hidden="true">⬇</span> <span class="cc-btn-label">Download</span>
        </button>
        <button type="button" id="ccUndoBtn" class="cc-icon-btn" title="Undo (Ctrl+Z when history available)" aria-label="Undo last change">
          <span class="cc-icon" aria-hidden="true">↶</span> <span class="cc-btn-label">Undo</span>
        </button>
        <button type="button" id="ccClearBtn" class="cc-icon-btn" title="Clear text" aria-label="Clear text">
          <span class="cc-icon" aria-hidden="true">✕</span> <span class="cc-btn-label">Clear</span>
        </button>
      </div>

      <textarea
        id="ccTextarea"
        class="cc-textarea"
        placeholder="Type or paste your text here, then click a case below to convert it instantly..."
        aria-label="Text to convert"
        spellcheck="false"
      />

      <div class="cc-stats-bar" role="status" aria-live="polite">
        <span>Characters: <strong id="ccCharCount">0</strong></span>
        <span>Words: <strong id="ccWordCount">0</strong></span>
        <span>Lines: <strong id="ccLineCount">0</strong></span>
        <span class="cc-stats-current"
          >Current case: <strong id="ccCurrentCase">—</strong></span
        >
      </div>

      <div class="cc-tabs-wrap">
        <div class="cc-tabs" role="tablist" aria-label="Case type selector">
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="sentence"
            title="Sentence case (Ctrl+1)"
            id="cc-tab-sentence"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">Sc</span> <span class="cc-tab-name">Sentence case</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="lower"
            title="lowercase (Ctrl+2)"
            id="cc-tab-lower"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">lc</span> <span class="cc-tab-name">lower case</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="upper"
            title="UPPER CASE (Ctrl+3)"
            id="cc-tab-upper"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">UC</span> <span class="cc-tab-name">UPPER CASE</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="capitalized"
            title="Capitalize Each Word (Ctrl+4)"
            id="cc-tab-capitalized"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">CC</span> <span class="cc-tab-name">Capitalize Each Word</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="title"
            title="Title Case (Ctrl+5)"
            id="cc-tab-title"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">TC</span> <span class="cc-tab-name">Title Case</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="alternating"
            title="aLtErNaTiNg cAsE"
            id="cc-tab-alternating"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">aC</span> <span class="cc-tab-name">aLtErNaTiNg cAsE</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="inverse"
            title="InVeRsE cAsE"
            id="cc-tab-inverse"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">iC</span> <span class="cc-tab-name">InVeRsE cAsE</span>
          </button>

          <span class="cc-tab-separator" aria-hidden="true" />

          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="camel"
            title="camelCase"
            id="cc-tab-camel"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">cC</span> <span class="cc-tab-name">camelCase</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="pascal"
            title="PascalCase"
            id="cc-tab-pascal"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">PC</span> <span class="cc-tab-name">PascalCase</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="snake"
            title="snake_case"
            id="cc-tab-snake"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">sn</span> <span class="cc-tab-name">snake_case</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="constant"
            title="CONSTANT_CASE"
            id="cc-tab-constant"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">CO</span> <span class="cc-tab-name">CONSTANT_CASE</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="kebab"
            title="kebab-case"
            id="cc-tab-kebab"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">kb</span> <span class="cc-tab-name">kebab-case</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="train"
            title="Train-Case"
            id="cc-tab-train"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">tr</span> <span class="cc-tab-name">Train-Case</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="dot"
            title="dot.case"
            id="cc-tab-dot"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">dt</span> <span class="cc-tab-name">dot.case</span>
          </button>
          <button
            type="button"
            class="cc-tab"
            role="tab"
            data-case="path"
            title="path/case"
            id="cc-tab-path"
            aria-pressed="false"
            aria-selected="false"
            tabindex="0"
          >
            <span class="cc-tab-code">pa</span> <span class="cc-tab-name">path/case</span>
          </button>
        </div>

        <details class="cc-advanced">
          <summary>⚙️ Settings & options</summary>
          <div class="cc-advanced-content">
            <label class="cc-checkbox">
              <input type="checkbox" id="ccAutoProperNouns" checked />
              <span>Auto-correct proper nouns and acronyms (NASA, iPhone, JavaScript, etc.) in sentence and title case</span>
            </label>
            <label class="cc-checkbox">
              <input type="checkbox" id="ccCompareAll" />
              <span>Show "Compare all" view below (see all conversions at once)</span>
            </label>
          </div>
        </details>
      </div>

      <div id="ccCompareAllView" class="cc-compare-all" hidden aria-label="All conversions">
        <h3 class="cc-compare-heading">All conversions</h3>
        <div class="cc-compare-grid"></div>
      </div>

      <div id="ccSampleHint" class="cc-sample-hint">
        <p>
          💡 New here? Try our
          <button type="button" id="ccLoadSample" class="cc-sample-btn">sample text</button> to see how it works.
        </p>
      </div>
    </div>
  </section>

  <CaseConverterEducation />

  <section class="cc-faq faq tool-faq" id="faq">
    <div class="container container--tool">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        {
          faqItems.map((f) => (
            <div class="faq-item">
              <h3>{f.question}</h3>
              <p>{f.answer}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="cc-related-tools tool-related">
    <div class="container container--tool">
      <h2 class="section-title">Related Text Tools</h2>
      <p>Explore more free, browser-based text tools from DoItSwift:</p>
      <div class="cc-tools-grid">
        <a href="/text/word-counter/" class="cc-tool-card">
          <div class="cc-tool-icon">🔢</div>
          <h3>Word Counter</h3>
          <p>Count words, characters, and reading time in any text. Browser-based, no upload.</p>
        </a>
        <a href="/text/" class="cc-tool-card">
          <div class="cc-tool-icon">📝</div>
          <h3>All Text Tools</h3>
          <p>Browse all free text tools: counters, converters, generators.</p>
        </a>
        <a href="/generator/password-generator/" class="cc-tool-card">
          <div class="cc-tool-icon">🔐</div>
          <h3>Password Generator</h3>
          <p>Generate strong passwords in your browser. Privacy-first, no logging.</p>
        </a>
        <a href="/calculator/" class="cc-tool-card">
          <div class="cc-tool-icon">🧮</div>
          <h3>Free Calculators</h3>
          <p>Finance, health, and everyday calculators. 40+ tools, all browser-based.</p>
        </a>
      </div>
    </div>
  </section>

  <div class="tool-editorial">
    <div class="container container--tool">
      <p>
        <strong>Reviewed by DoItSwift Editorial.</strong> Conversion algorithms follow standard definitions from
        programming language specifications (JavaScript ECMA-262, Python PEP 8) and naming convention guides.
        Title case rules follow the Chicago Manual of Style. The proper noun dictionary includes 200+ common
        brand names, acronyms, and technical terms, applied longest-match first to handle nested cases (e.g.
        "iPhone" within "the new iPhone is here"). Read our
        <a href="/about/editorial-policy/">editorial policy</a>,
        <a href="/about/how-we-research/">research methodology</a>, and
        <a href="/about/fact-checking/">fact-checking standards</a>.
      </p>
      <p class="tool-editorial-meta">Last reviewed: April 2026 · DoItSwift Editorial</p>
      <p class="tool-editorial-meta">See an error or missing case format? <a href="/contact/">Let us know</a>.</p>
    </div>
  </div>

  <p class="back-wrap container container--tool">
    <a href="/text/" class="link-back">← Text tools hub</a>
  </p>

  <script>
    import { initCaseConverterTabs } from '../../lib/case-converter-ui';
    initCaseConverterTabs();
  </script>

  <style>
    .cc-tool.tool-section {
      padding: 24px 0 40px;
    }
    .cc-toolbar-top {
      display: flex;
      gap: 8px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }
    .cc-icon-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: var(--card-bg, var(--card, #fff));
      border: 1px solid var(--border, #e5e7eb);
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.875rem;
      color: var(--text, #111827);
      transition: all 0.15s;
    }
    .cc-icon-btn:hover {
      border-color: var(--blue, #2563eb);
      color: var(--blue, #2563eb);
    }
    .cc-icon-btn.active {
      background: var(--blue, #2563eb);
      color: #fff;
      border-color: var(--blue, #2563eb);
    }
    .cc-icon-btn:focus-visible {
      outline: 2px solid var(--blue, #2563eb);
      outline-offset: 2px;
    }
    .cc-icon {
      font-size: 1rem;
    }
    .cc-textarea {
      width: 100%;
      min-height: 320px;
      max-height: 70vh;
      padding: 16px;
      font-family: -apple-system, 'SF Mono', 'Monaco', 'Consolas', monospace;
      font-size: 15px;
      line-height: 1.6;
      border: 1px solid var(--border, #e5e7eb);
