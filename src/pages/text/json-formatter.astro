      background: var(--bg);
      padding: 1px 6px;
      border-radius: 3px;
      border: 1px solid var(--border);
      font-size: 12px;
      color: var(--text);
    }
    .jf-qm-copy {
      padding: 3px 10px;
      font-size: 11px;
    }
    .jf-qm-value {
      margin: 0;
      padding: 12px 14px;
      font-family:
        ui-monospace,
        'SF Mono',
        Menlo,
        monospace;
      font-size: 13px;
      line-height: 1.5;
      color: var(--text);
      white-space: pre-wrap;
      word-break: break-word;
      max-height: 200px;
      overflow-y: auto;
    }

    /* Query highlighted source */
    .jf-query-source {
      margin: 0;
      padding: 12px 14px;
      font-family:
        ui-monospace,
        'SF Mono',
        Menlo,
        monospace;
      font-size: 13px;
      line-height: 1.5;
      color: var(--text);
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      white-space: pre;
      overflow: auto;
      max-height: 600px;
    }
    .jq-match {
      background: rgba(37, 99, 235, 0.18);
      border-radius: 3px;
      padding: 1px 3px;
      outline: 1px solid rgba(37, 99, 235, 0.4);
    }
    [data-theme='dark'] .jq-match {
      background: rgba(96, 165, 250, 0.25);
      outline-color: rgba(147, 197, 253, 0.5);
    }

    @media (max-width: 640px) {
      .jf-query-row {
        flex-direction: column;
        align-items: stretch;
      }
      .jf-query-input-field {
        flex: 1 1 100%;
      }
      .jf-query-btn {
        width: 100%;
      }
    }

    /* Validation results */
    .jf-validation-results {
      flex: 1;
      min-height: 100px;
      padding: 16px;
      background: var(--bg);
    }
    .jf-validation-placeholder {
      color: var(--text-muted);
      font-style: italic;
      margin: 0;
    }
    .jf-validation-ok {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-left: 4px solid #16a34a;
      border-radius: 8px;
      color: #15803d;
      font-size: 14px;
    }
    .jf-validation-ok strong {
      font-size: 15px;
    }
    [data-theme='dark'] .jf-validation-ok {
      background: rgba(22, 163, 74, 0.1);
      border-color: rgba(74, 222, 128, 0.3);
      border-left-color: #4ade80;
      color: #4ade80;
    }
    .jf-validation-fail {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-left: 4px solid #dc2626;
      border-radius: 8px;
      color: #991b1b;
      font-size: 14px;
      margin-bottom: 12px;
    }
    .jf-validation-fail strong {
      font-size: 15px;
    }
    [data-theme='dark'] .jf-validation-fail {
      background: rgba(220, 38, 38, 0.1);
      border-color: rgba(248, 113, 113, 0.3);
      border-left-color: #f87171;
      color: #f87171;
    }
    .jf-validation-warn {
      margin: 12px 0 0 0;
      padding: 10px 14px;
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-left: 4px solid #ca8a04;
      border-radius: 8px;
      color: #854d0e;
      font-size: 13px;
      line-height: 1.5;
    }
    .jf-validation-warn code {
      background: rgba(202, 138, 4, 0.1);
      padding: 1px 4px;
      border-radius: 3px;
      font-size: 12px;
    }
    [data-theme='dark'] .jf-validation-warn {
      background: rgba(202, 138, 4, 0.1);
      border-color: rgba(250, 204, 21, 0.3);
      border-left-color: #facc15;
      color: #facc15;
    }
    [data-theme='dark'] .jf-validation-warn code {
      background: rgba(250, 204, 21, 0.15);
    }
    .jf-validation-errors {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .jf-validation-error {
      padding: 12px 14px;
      background: var(--bg-subtle, #f8fafc);
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    [data-theme='dark'] .jf-validation-error {
      background: var(--bg-subtle-dark, #1f2937);
    }
    .jf-vee-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 6px;
      flex-wrap: wrap;
    }
    .jf-vee-keyword {
      display: inline-block;
      padding: 2px 8px;
      background: #fef2f2;
      color: #dc2626;
      border-radius: 4px;
      font-family: ui-monospace, 'SF Mono', monospace;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    [data-theme='dark'] .jf-vee-keyword {
      background: rgba(220, 38, 38, 0.15);
      color: #f87171;
    }
    .jf-vee-path {
      font-size: 13px;
      color: var(--text-muted);
    }
    .jf-vee-path code {
      font-family: ui-monospace, 'SF Mono', monospace;
      background: var(--bg);
      padding: 1px 6px;
      border-radius: 3px;
      border: 1px solid var(--border);
      font-size: 12px;
      color: var(--text);
    }
    .jf-vee-message {
      margin: 0 0 6px 0;
      font-size: 14px;
      color: var(--text);
    }
    .jf-vee-detail {
      margin: 4px 0;
      font-size: 12px;
      color: var(--text-muted);
    }
    .jf-vee-detail code {
      font-family: ui-monospace, 'SF Mono', monospace;
      background: var(--bg);
      padding: 1px 5px;
      border-radius: 3px;
      border: 1px solid var(--border);
      color: var(--text);
    }

    .jf-pane {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      background: var(--bg);
    }
    .jf-pane-header {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
      padding: 8px 12px;
      background: var(--bg-subtle, #f8fafc);
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }
    [data-theme='dark'] .jf-pane-header {
      background: var(--bg-subtle-dark, #1f2937);
    }
    .jf-pane-label {
      font-weight: 600;
      color: var(--text);
    }
    .jf-pane-stats {
      color: var(--text-muted);
      font-size: 12px;
      flex: 1;
    }
    .jf-pane-actions {
      display: flex;
      gap: 6px;
    }
    .btn-icon {
      padding: 4px 10px;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text-muted);
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: color 0.15s ease, background 0.15s ease;
    }
    .btn-icon:hover {
      color: var(--text);
      background: var(--bg-subtle, #f1f5f9);
    }
    [data-theme='dark'] .btn-icon:hover {
      background: var(--bg-subtle-dark, #1f2937);
    }
    /* ────────────────────────────────────────────────────────────────────────── */
    /* JSON Code Editor                                                            */
    /* ────────────────────────────────────────────────────────────────────────── */

    .jf-input-editor {
      position: relative;
      display: flex;
      flex: 1;
      width: 100%;
      height: 100%;
      min-height: 380px;
      background: var(--bg);
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      font-size: 14px;
      line-height: 21px; /* MUST match JsonCodeEditor.lineHeight */
      overflow: hidden;
    }
    .jf-input-editor.is-focused {
      outline: 2px solid var(--accent, #2563eb);
      outline-offset: -2px;
    }

    .jce-host {
      display: flex;
      flex: 1;
      min-height: 380px;
      position: relative;
    }

    /* Gutter */
    .jce-gutter {
      flex: 0 0 auto;
      width: 48px;
      padding: 12px 8px 12px 0;
      background: var(--bg-subtle, #f8fafc);
      border-right: 1px solid var(--border);
      color: var(--text-muted);
      font-family: inherit;
      font-size: 12px;
      line-height: 21px;
      text-align: right;
      user-select: none;
      overflow: hidden;
    }
    [data-theme='dark'] .jce-gutter {
      background: var(--bg-subtle-dark, #111827);
    }
    .jce-line-num {
      height: 21px;
      padding-right: 4px;
      color: var(--text-muted);
      opacity: 0.6;
    }
    .jce-line-num.is-active {
      color: var(--text);
      opacity: 1;
      font-weight: 600;
    }

    /* Editor area */
    .jce-area {
      position: relative;
      flex: 1;
      overflow: hidden;
    }
    .jce-layer {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }

    /* Highlight layer (the visible colored text) */
    .jce-highlight {
      position: absolute;
      top: 0;
      left: 0;
      margin: 0;
      padding: 12px;
      width: max-content;
      min-width: 100%;
      font-family: inherit;
      font-size: inherit;
      line-height: inherit;
      color: var(--text);
      white-space: pre;
      pointer-events: none;
      z-index: 2;
    }

    /* Current line highlight */
    .jce-current-line {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 21px;
      background: rgba(37, 99, 235, 0.06);
      pointer-events: none;
      z-index: 1;
    }
    [data-theme='dark'] .jce-current-line {
      background: rgba(96, 165, 250, 0.08);
    }
    .jce-host:not(.is-focused) .jce-current-line {
      opacity: 0;
    }

    /* Bracket match markers */
    .jce-bracket-highlights {
      position: absolute;
      top: 0;
      left: 0;
      pointer-events: none;
      z-index: 1;
    }
    .jce-bracket-marker {
      position: absolute;
      background: rgba(234, 179, 8, 0.25);
      border: 1px solid rgba(234, 179, 8, 0.6);
      border-radius: 2px;
      pointer-events: none;
    }
    [data-theme='dark'] .jce-bracket-marker {
      background: rgba(250, 204, 21, 0.2);
      border-color: rgba(250, 204, 21, 0.5);
    }

    /* Textarea (transparent overlay capturing input) */
    .jce-textarea {
      position: absolute;
      inset: 0;
      margin: 0;
      padding: 12px;
      border: none;
      background: transparent;
      color: transparent;
      caret-color: var(--text);
      font-family: inherit;
      font-size: inherit;
      line-height: inherit;
      resize: none;
      outline: none;
      white-space: pre;
      overflow: auto;
      z-index: 3;
      /* Selection should still be visible — use a tinted color */
    }
    .jce-textarea::selection {
      background: rgba(37, 99, 235, 0.25);
      color: transparent;
    }
    [data-theme='dark'] .jce-textarea::selection {
      background: rgba(96, 165, 250, 0.3);
    }

    /* The textarea must scroll, but the highlight layer stays in sync via JS-driven transform */
    .jce-textarea {
      scrollbar-width: thin;
    }

    /* Hide the placeholder when the editor has content; show otherwise.
       Since we swap the textarea visibility for a real editor, the placeholder
       is rendered via a pseudo on the host instead. */
    .jce-host[data-empty='true'] .jce-textarea::placeholder {
      color: var(--text-muted);
    }

    /* Mobile adjustments */
    @media (max-width: 640px) {
      .jce-gutter { width: 36px; font-size: 11px; }
      .jce-highlight, .jce-textarea { padding: 10px; font-size: 13px; }
    }

    .jf-textarea {
      min-height: 480px;
      padding: 12px;
      border: none;
      background: var(--bg);
      color: var(--text);
      font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      font-size: 14px;
      line-height: 1.5;
      resize: vertical;
      outline: none;
      tab-size: 2;
      white-space: pre;
      overflow: auto;
    }
    .jf-dropzone .jf-textarea {
      flex: 1;
      width: 100%;
    }
    .jf-output-wrap {
      display: flex;
      flex-direction: column;
      min-height: 480px;
      max-height: 720px;
      overflow: auto;
      background: var(--bg);
    }
    .jf-output {
      margin: 0;
      padding: 12px;
      font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      font-size: 14px;
      line-height: 1.5;
      color: var(--text);
      tab-size: 2;
      white-space: pre;
    }

    /* Syntax highlighting */
    .jh-key {
      color: #0550ae;
      font-weight: 500;
    }
    .jh-string {
      color: #032f62;
    }
    .jh-number {
      color: #1a7f37;
    }
    .jh-bool {
      color: #cf222e;
      font-weight: 500;
    }
    .jh-null {
      color: #6e7781;
      font-style: italic;
    }
    .jh-punct {
      color: var(--text-muted);
    }

    [data-theme='dark'] .jh-key {
      color: #79c0ff;
    }
    [data-theme='dark'] .jh-string {
      color: #a5d6ff;
    }
    [data-theme='dark'] .jh-number {
      color: #56d364;
    }
    [data-theme='dark'] .jh-bool {
      color: #ff7b72;
    }
    [data-theme='dark'] .jh-null {
      color: #8b949e;
    }

    /* Error panel */
    .jf-error-panel {
      margin-top: 16px;
      padding: 16px;
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-left: 4px solid #dc2626;
      border-radius: 8px;
    }
    [data-theme='dark'] .jf-error-panel {
      background: #2a1414;
      border-color: #5b1e1e;
      border-left-color: #f87171;
    }
    .jf-error-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 8px;
    }
    .jf-error-header strong {
      color: #dc2626;
      font-size: 14px;
    }
    [data-theme='dark'] .jf-error-header strong {
      color: #f87171;
    }
    .jf-error-position {
      font-size: 13px;
      color: var(--text-muted);
      font-family: ui-monospace, 'SF Mono', monospace;
    }
    .jf-error-friendly {
      margin: 8px 0;
      font-size: 14px;
      color: var(--text);
      line-height: 1.5;
    }
    .jf-error-excerpt {
      margin: 8px 0;
      padding: 10px 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-family: ui-monospace, 'SF Mono', monospace;
      font-size: 13px;
      line-height: 1.5;
      color: var(--text);
      white-space: pre;
      overflow-x: auto;
    }
    .jf-error-raw {
      margin: 8px 0 0 0;
      font-size: 12px;
      color: var(--text-muted);
    }
    .jf-error-raw code {
      font-family: ui-monospace, 'SF Mono', monospace;
      background: var(--bg);
      padding: 2px 6px;
      border-radius: 4px;
      border: 1px solid var(--border);
    }

    /* Shortcut hints */
    .jf-shortcut-hint {
      margin-top: 12px;
      color: var(--text-muted);
      font-size: 12px;
    }
    .jf-shortcut-hint kbd {
      display: inline-block;
      padding: 2px 6px;
      background: var(--bg-subtle, #f1f5f9);
      border: 1px solid var(--border);
      border-radius: 4px;
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: 11px;
      font-weight: 600;
      color: var(--text);
    }
    [data-theme='dark'] .jf-shortcut-hint kbd {
      background: var(--bg-subtle-dark, #1f2937);
    }
    @media (max-width: 640px) {
      .jf-shortcut-hint {
        display: none;
      }
    }

    /* Related tools grid (matches image tool pages) */
    .jf-related-grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }
    @media (min-width: 520px) {
      .jf-related-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    .jf-related-grid li {
      font-size: 15px;
      line-height: 1.6;
      color: var(--text);
    }
    .jf-related-grid a {
      display: block;
      padding: 14px 16px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--blue);
      font-weight: 600;
      font-size: 15px;
      text-decoration: none;
      box-shadow: var(--shadow-sm);
      transition: border-color 0.15s ease, background 0.15s ease;
    }
    .jf-related-grid a:hover {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    [data-theme='dark'] .jf-related-grid a:hover {
      background: rgba(0, 102, 255, 0.12);
    }

    /* View tabs */
    .jf-view-tabs {
      display: inline-flex;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 2px;
      gap: 2px;
      margin-right: 8px;
    }
    .jf-view-tab {
      padding: 4px 10px;
      border: none;
      background: transparent;
      color: var(--text-muted);
      font-size: 12px;
      font-weight: 600;
      border-radius: 4px;
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease;
    }
    .jf-view-tab.is-active {
      background: var(--accent, #2563eb);
      color: white;
    }
    .jf-view-tab:not(.is-active):hover {
      color: var(--text);
      background: var(--bg-subtle, #f1f5f9);
    }
    [data-theme='dark'] .jf-view-tab:not(.is-active):hover {
      background: var(--bg-subtle-dark, #1f2937);
    }

    /* Tree view */
    .jf-tree-view {
      margin: 0;
      padding: 12px;
      font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      font-size: 14px;
      line-height: 1.6;
      color: var(--text);
      overflow-x: auto;
    }
    .jt-root {
      padding-left: 0;
    }
    .jt-node {
      margin-left: 0;
    }
    .jt-summary {
      cursor: pointer;
      list-style: none;
      padding: 1px 0;
      user-select: none;
    }
    .jt-summary::-webkit-details-marker {
      display: none;
    }
    .jt-summary::before {
      content: '▸';
      display: inline-block;
      width: 14px;
      color: var(--text-muted);
      font-size: 10px;
      transition: transform 0.1s ease;
    }
    .jt-node[open] > .jt-summary::before {
      transform: rotate(90deg);
    }
    .jt-children {
      margin-left: 18px;
      border-left: 1px solid var(--border);
      padding-left: 8px;
    }
    .jt-leaf {
      padding: 1px 0 1px 14px;
    }
    .jt-close {
      padding-left: 0;
    }

    .jt-key {
      color: #0550ae;
      font-weight: 500;
    }
    .jt-string {
      color: #032f62;
    }
    .jt-number {
      color: #1a7f37;
    }
    .jt-bool {
      color: #cf222e;
      font-weight: 500;
    }
    .jt-null {
      color: #6e7781;
      font-style: italic;
    }
    .jt-meta {
      color: var(--text-muted);
      font-size: 12px;
      font-style: italic;
      padding: 0 4px;
    }
    .jt-punct {
      color: var(--text-muted);
    }

    [data-theme='dark'] .jt-key {
      color: #79c0ff;
    }
    [data-theme='dark'] .jt-string {
      color: #a5d6ff;
    }
    [data-theme='dark'] .jt-number {
      color: #56d364;
    }
    [data-theme='dark'] .jt-bool {
      color: #ff7b72;
    }
    [data-theme='dark'] .jt-null {
      color: #8b949e;
    }

    /* Drop zone */
    .jf-dropzone {
      position: relative;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .jf-dropzone-overlay {
      position: absolute;
      inset: 0;
      background: rgba(37, 99, 235, 0.08);
      border: 2px dashed var(--accent, #2563eb);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s ease;
    }
    .jf-dropzone-overlay.is-active {
      opacity: 1;
    }
    .jf-dropzone-message {
      background: var(--bg);
      padding: 16px 24px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--accent, #2563eb);
    }

    /* Privacy badge */
    .jf-privacy-badge-wrap {
      margin-top: 12px;
      text-align: center;
    }
    .jf-privacy-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      background: var(--bg-subtle, #f0fdf4);
      color: #16a34a;
      border: 1px solid #bbf7d0;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s ease, transform 0.1s ease;
    }
    .jf-privacy-badge:hover {
      background: #dcfce7;
      transform: translateY(-1px);
    }
    [data-theme='dark'] .jf-privacy-badge {
      background: rgba(22, 163, 74, 0.1);
      color: #4ade80;
      border-color: rgba(74, 222, 128, 0.3);
    }
    [data-theme='dark'] .jf-privacy-badge:hover {
      background: rgba(22, 163, 74, 0.2);
    }

    /* Modal */
    .jf-modal {
      position: fixed;
      inset: 0;
      z-index: 10000;
      display: flex;
