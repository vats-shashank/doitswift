---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const pageDescription =
  'Compress PDFs in your browser: Light cleanup (structure/metadata, keeps vectors) or Smaller file (rasterize pages to JPEG with presets or custom quality). Optional size targets in raster mode. Batch queue, before/after sizes, ZIP download. pdf-lib + PDF.js — no upload.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'DoItSwift Compress PDF',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web browser',
      browserRequirements:
        'Requires JavaScript, pdf-lib, PDF.js for raster mode, and JSZip for batch ZIP (loaded from CDN)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description:
        'Reduce PDF file size locally with two strategies: Light cleanup rewrites the PDF and strips metadata while copying pages (vectors preserved). Smaller file rasterizes each page via PDF.js to JPEG with Balanced, Strong, Maximum, or Custom quality and scale; optional target max megabytes or minimum shrink percentage runs extra passes in raster mode. Compare original and output sizes in the UI. No server upload.',
      featureList: [
        'Light cleanup: copy pages with pdf-lib, clear common metadata, save with object streams — modest size reduction, text stays selectable',
        'Smaller file: render each page with PDF.js and embed JPEGs in a new PDF — strong reduction for scans and photo-heavy documents',
        'Raster presets: Balanced, Strong, Maximum, or Custom JPEG quality and sharpness sliders',
        'Optional targets in Smaller file mode: try to stay under a max MB or shrink by a percentage (binary search; structure mode ignores these)',
        'Queue multiple PDFs, compress with one run, per-file download with before → after size comparison',
        'Download all results as compressed-pdfs.zip',
        'Output files named with original stem plus -compressed.pdf',
        'Warns when adding a single file over about 50 MB',
        'Encrypted PDFs may fail until unlocked elsewhere',
        '100% client-side — PDF bytes are not uploaded to DoItSwift',
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is Compress PDF free and unlimited?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Compress as many PDFs as your device can handle with no signup, watermarks, or usage quotas.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are my PDFs uploaded to DoItSwift servers?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. pdf-lib and PDF.js run in your browser; compression happens locally.',
          },
        },
        {
          '@type': 'Question',
          name: 'What is the difference between Light cleanup and Smaller file?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Light cleanup rewrites the PDF and strips metadata while keeping vector text — often modest savings. Smaller file redraws each page as a JPEG image, which can greatly reduce scans and photos but may soften text and reduce copy-paste quality.',
          },
        },
        {
          '@type': 'Question',
          name: 'Will every PDF get smaller?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Usually, but minimal or already-optimized PDFs may barely shrink in Light cleanup. In Smaller file mode the output can occasionally be larger than the original — the UI shows before and after sizes.',
          },
        },
        {
          '@type': 'Question',
          name: 'How do optional target size goals work?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'In Smaller file mode you can optionally set a max output size in MB or a minimum shrink percentage. If both are set, the max MB goal takes precedence. Targets are ignored in Light cleanup mode.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I compress multiple PDFs at once?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Add several files to the queue, run compress once, then download each result or all outputs in a ZIP named compressed-pdfs.zip.',
          },
        },
        {
          '@type': 'Question',
          name: 'What are the output filenames?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Each compressed file uses the original name stem plus -compressed.pdf.',
          },
        },
        {
          '@type': 'Question',
          name: 'Do password-protected PDFs work?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Encrypted inputs may fail until unlocked. Use DoItSwift Unlock PDF or another trusted tool first.',
          },
        },
        {
          '@type': 'Question',
          name: 'What about very large PDFs?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The tool warns when adding a file over about 50 MB. Huge documents can take a long time and use significant memory.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is there a monthly limit or account required?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No accounts, no quotas, and no premium tier.',
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'PDF Tools',
          item: new URL('/pdf/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Compress PDF',
          item: canonical,
        },
      ],
    },
  ],
};
---

<MainLayout
  title="Compress PDF — Light Cleanup or Raster, Size Targets, Batch ZIP | DoItSwift"
  description={pageDescription}
  keywords="compress pdf, reduce pdf size, shrink pdf online, pdf compressor browser, pdf smaller file, scan pdf compress, pdf metadata strip, rasterize pdf jpeg, target pdf size mb, batch compress pdf, private compress pdf, no upload pdf, pdf-lib compress"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js" is:inline></script>

  <script type="module" is:inline>
    import * as pdfjsLib from 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs';
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';
    window.__pdfjsCompress = pdfjsLib;
  </script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>Compress PDF</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Compress PDF</h1>
      <p class="subtitle">
        Choose <strong>Light cleanup</strong> (vectors, modest savings) or <strong>Smaller file</strong> (JPEG pages, big
        wins on scans). Optional MB/% targets in raster mode. Queue PDFs, compare before → after, download or ZIP — all
        local.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Batch files</span>
        <span><span class="check">✓</span> Size comparison</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none" role="status" aria-live="polite">
        <span id="bannerText">Ready</span>
      </div>

      <div class="compress-opts">
        <span class="opt-label">1. How should we shrink your PDF?</span>
        <div class="preset-buttons" role="radiogroup" aria-label="Compression strategy">
          <button type="button" class="preset-btn is-selected" data-strategy="structure" role="radio" aria-checked="true">
            Light cleanup
          </button>
          <button type="button" class="preset-btn" data-strategy="raster" role="radio" aria-checked="false">
            Smaller file (photos &amp; scans)
          </button>
        </div>
        <p class="preset-desc" id="strategyDesc">
          Keeps text sharp and selectable — good for forms and reports. The file may only get a little smaller.
        </p>

        <div id="rasterBlock" class="raster-block" style="display: none" hidden>
          <span class="opt-label sub">Strength</span>
          <div class="preset-buttons" role="radiogroup" aria-label="Image compression strength">
            <button type="button" class="preset-btn raster-preset is-selected" data-rpreset="balanced" role="radio" aria-checked="true">
              Balanced
            </button>
            <button type="button" class="preset-btn raster-preset" data-rpreset="strong" role="radio" aria-checked="false">
              Strong
            </button>
            <button type="button" class="preset-btn raster-preset" data-rpreset="max" role="radio" aria-checked="false">
              Maximum
            </button>
            <button type="button" class="preset-btn raster-preset" data-rpreset="custom" role="radio" aria-checked="false">
              Custom
            </button>
          </div>
          <p class="preset-desc" id="rasterPresetDesc">
            Good balance of size and readability — pages redrawn as JPEGs.
          </p>

          <div id="customRaster" class="custom-raster" style="display: none" hidden>
            <div class="slider-row">
              <label for="jpegQuality">Picture quality <span id="jpegVal">72</span>%</label>
              <input type="range" id="jpegQuality" min="40" max="95" value="72" />
            </div>
            <div class="slider-row">
              <label for="rasterScale">Sharpness / detail <span id="scaleVal">1.35</span>×</label>
              <input type="range" id="rasterScale" min="80" max="200" value="135" />
              <p class="field-hint">Left = smaller file, softer. Right = sharper, larger file.</p>
            </div>
          </div>
        </div>

        <div class="target-row">
          <span class="opt-label sub">Optional target (smaller file mode only)</span>
          <div class="target-inputs">
            <label class="target-field">
              <span>Try to stay under (MB)</span>
              <input type="number" id="targetMb" min="0.1" max="500" step="0.1" placeholder="—" />
            </label>
            <span class="target-or">or</span>
            <label class="target-field">
              <span>Try to shrink by at least (%)</span>
              <input type="number" id="targetPct" min="1" max="95" step="1" placeholder="—" />
            </label>
          </div>
          <p class="field-hint" id="targetHint">
            Leave blank to use the strength buttons above. If you fill both, <strong>max MB</strong> is used. Targets can take
            longer.
          </p>
        </div>
      </div>

      <div class="compress-help" id="compressHelp">
        <h3 class="compress-help-title">Quick guide</h3>
        <ol class="compress-help-steps">
          <li><strong>Choose a mode</strong> — Light cleanup is safest for text. “Smaller file” helps most with scanned or photo PDFs.</li>
          <li><strong>Add PDFs</strong> — They stay on your computer until you compress.</li>
          <li><strong>Click Compress PDFs</strong> — Wait for the size comparison, then download.</li>
          <li><strong>Try again?</strong> — Change options and compress again; your files stay in the list until you remove them.</li>
        </ol>
        <p class="compress-help-note">
          <strong>Light cleanup</strong> tidies the file but often saves only a little space.
          <strong>Smaller file</strong> redraws each page as a picture — much smaller for scans, but text may look softer and
          copy/paste can get worse. Skip “smaller file” for important contracts unless you’ve checked the preview.
        </p>
      </div>

      <div class="add-files-block">
        <span class="opt-label">2. Add PDFs</span>
        <div class="dropzone" id="dropzone">
          <div class="dropzone-icon">📄</div>
          <div class="dropzone-text">Drop PDFs here or click to browse</div>
          <div class="dropzone-sub">Nothing runs yet — files are only listed until you press Compress PDFs below.</div>
          <input type="file" id="fileInput" multiple accept=".pdf,application/pdf" />
        </div>

        <div id="fileQueueWrap" class="file-queue-wrap" style="display: none" hidden>
          <div class="file-queue-head">
            <span class="file-queue-title">Ready to compress: <strong id="queueCount">0</strong> file(s)</span>
            <button type="button" class="btn-text" id="clearQueue">Remove all</button>
          </div>
          <ul class="file-queue" id="fileQueue" aria-label="Queued PDF files"></ul>
        </div>

        <div class="compress-run">
          <button type="button" class="btn btn-lg compress-go" id="compressBtn" disabled>
            Compress PDFs
          </button>
          <p class="compress-run-hint" id="compressBtnHint">
            Add at least one PDF, then click here. You can change options above and compress again without re-uploading.
          </p>
        </div>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">3. Results</div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadZip">⬇ Download all as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearResults">Clear results</button>
      </div>
    </div>
  </section>

  <article class="compress-edu" aria-label="Guide: PDF compression modes">
    <div class="container compress-edu-inner">
      <section class="compress-edu-block">
        <h2 id="what-compression-means">Understanding PDF compression on this page</h2>
        <p>
          PDFs mix vector text, fonts, embedded images, and metadata. <strong>Light cleanup</strong> rewrites the document
          with pdf-lib, clears common metadata fields, and saves with object streams — <strong>vectors stay vectors</strong>,
          so savings are often small if the file was already lean. <strong>Smaller file</strong> uses PDF.js to render each
          page and embeds JPEGs — often dramatic for scans and photo-heavy PDFs, but pages become images, so text can look
          softer and copy/search may suffer.
        </p>
        <p>
          For a longer privacy-focused guide, read{' '}
          <a href="/blog/how-to-compress-pdf/">how to compress a PDF</a> on the DoItSwift blog.
        </p>
      </section>

      <section class="compress-edu-block">
        <h2 id="modes-table">Light cleanup vs Smaller file</h2>
        <div class="compress-table-wrap">
          <table class="compress-compare-table">
            <caption class="sr-only">Comparison of Light cleanup and Smaller file compression</caption>
            <thead>
              <tr>
                <th scope="col">Mode</th>
                <th scope="col">Best for</th>
                <th scope="col">Trade-off</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Light cleanup</td>
                <td>Forms, reports, crisp text</td>
                <td>Often modest file reduction</td>
              </tr>
              <tr>
                <td>Smaller file</td>
                <td>Scans, photos, huge attachments</td>
                <td>Lossy JPEG pages; check output before deleting originals</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          <strong>Optional targets</strong> (max MB or shrink %) apply only in Smaller file mode; they trigger extra passes to
          approach your goal. If both fields are filled, <strong>max MB</strong> wins. Light cleanup ignores those fields.
        </p>
      </section>

      <section class="compress-edu-block">
        <h2 id="workflow-next-steps">Split, merge, or export images</h2>
        <p>
          Still too big? Try <a href="/pdf/split-pdf/">Split PDF</a> and compress parts separately, or{' '}
          <a href="/pdf/merge-pdf/">Merge PDF</a> after shrinking pieces. To get pictures out of a PDF, use{' '}
          <a href="/pdf/pdf-to-jpg/">PDF to JPG</a>.
        </p>
      </section>
    </div>
  </article>

  <section class="compress-related" aria-label="Related PDF tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="compress-related-grid">
        <li><a href="/pdf/split-pdf/">Split PDF</a></li>
        <li><a href="/pdf/merge-pdf/">Merge PDF</a></li>
        <li><a href="/pdf/unlock-pdf/">Unlock PDF</a></li>
        <li><a href="/pdf/pdf-to-jpg/">PDF to JPG</a></li>
        <li><a href="/pdf/image-to-pdf/">Image to PDF</a></li>
        <li><a href="/pdf/jpg-to-pdf/">JPG to PDF</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="compress-related-grid compress-related-guides">
        <li><a href="/blog/how-to-compress-pdf/">How to compress a PDF</a></li>
        <li><a href="/blog/how-to-merge-pdf/">How to merge PDFs</a></li>
        <li><a href="/blog/how-to-split-pdf/">How to split a PDF</a></li>
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Is Compress PDF free and unlimited?</h4>
          <p>Yes. Compress as many PDFs as your device can handle with no signup, watermarks, or usage quotas.</p>
        </div>
        <div class="faq-item">
          <h4>Are my PDFs uploaded to DoItSwift servers?</h4>
          <p>No. pdf-lib and PDF.js run in your browser; compression happens locally.</p>
        </div>
        <div class="faq-item">
          <h4>What is the difference between Light cleanup and Smaller file?</h4>
          <p>
            Light cleanup rewrites the PDF and strips metadata while keeping vector text — often modest savings. Smaller file
            redraws each page as a JPEG image, which can greatly reduce scans and photos but may soften text and reduce
            copy-paste quality.
          </p>
        </div>
        <div class="faq-item">
          <h4>Will every PDF get smaller?</h4>
          <p>
            Usually, but minimal or already-optimized PDFs may barely shrink in Light cleanup. In Smaller file mode the output
            can occasionally be larger than the original — the UI shows before and after sizes. Smaller file uses{' '}
            <strong>lossy</strong> JPEG per page, not lossless compression.
          </p>
        </div>
        <div class="faq-item">
          <h4>How do optional target size goals work?</h4>
          <p>
            In Smaller file mode you can set a max output size in MB or a minimum shrink percentage. If both are set, max MB
            takes precedence. Targets are ignored in Light cleanup mode.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I compress multiple PDFs at once?</h4>
          <p>
            Yes. Add several files to the queue, run compress once, then download each result or all outputs in a ZIP named
            compressed-pdfs.zip.
          </p>
        </div>
        <div class="faq-item">
          <h4>What are the output filenames?</h4>
          <p>Each file uses the original name stem plus <code>-compressed.pdf</code>.</p>
        </div>
        <div class="faq-item">
          <h4>Do password-protected PDFs work?</h4>
          <p>
            Encrypted inputs may fail until unlocked. Use <a href="/pdf/unlock-pdf/">Unlock PDF</a> or another trusted tool
            first.
          </p>
        </div>
        <div class="faq-item">
          <h4>What about very large PDFs?</h4>
          <p>
            The tool warns when adding a file over about 50 MB. Huge documents can take a long time and use significant memory.
          </p>
        </div>
        <div class="faq-item">
          <h4>Is there a monthly limit or account required?</h4>
          <p>No accounts, no quotas, and no premium tier.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const pdfjsLib = window.__pdfjsCompress;
      const PDFLibGlobal = typeof PDFLib !== 'undefined' ? PDFLib : window.PDFLib;
      if (!PDFLibGlobal) return;
      const { PDFDocument } = PDFLibGlobal;

      const STRATEGY_DESC = {
        structure:
          'Keeps text sharp and selectable — good for forms and reports. The file may only get a little smaller.',
        raster:
          'Redraws each page as a picture (JPEG). Often much smaller for scans and photos; text may look softer — use Light cleanup if you need crisp text.',
      };

      const RASTER_PRESET_DESC = {
        balanced: 'Balanced — smaller files with readable text for most documents.',
        strong: 'Strong — noticeably smaller; best for scans and attachments.',
        max: 'Maximum — smallest files; text and fine lines may look soft.',
        custom: 'Your JPEG quality and detail settings below.',
      };

      const RASTER_DEFAULTS = {
        balanced: { scale: 1.28, jpeg: 0.76 },
        strong: { scale: 1.5, jpeg: 0.6 },
        max: { scale: 1.75, jpeg: 0.46 },
      };

      const strategyBtns = document.querySelectorAll('.preset-btn[data-strategy]');
      const rasterBlock = document.getElementById('rasterBlock');
      const strategyDesc = document.getElementById('strategyDesc');
      const customRaster = document.getElementById('customRaster');
      const rasterPresetDesc = document.getElementById('rasterPresetDesc');
      const jpegSlider = document.getElementById('jpegQuality');
      const scaleSlider = document.getElementById('rasterScale');
      const jpegVal = document.getElementById('jpegVal');
      const scaleVal = document.getElementById('scaleVal');

      strategyBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          strategyBtns.forEach((b) => {
            b.classList.remove('is-selected');
            b.setAttribute('aria-checked', 'false');
          });
          btn.classList.add('is-selected');
          btn.setAttribute('aria-checked', 'true');
          const st = btn.dataset.strategy;
          strategyDesc.textContent = STRATEGY_DESC[st] || STRATEGY_DESC.structure;
          const show = st === 'raster';
          rasterBlock.style.display = show ? 'block' : 'none';
          rasterBlock.hidden = !show;
        });
      });

      document.querySelectorAll('.raster-preset').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.raster-preset').forEach((b) => {
            b.classList.remove('is-selected');
            b.setAttribute('aria-checked', 'false');
          });
          btn.classList.add('is-selected');
          btn.setAttribute('aria-checked', 'true');
          const rp = btn.dataset.rpreset;
          rasterPresetDesc.textContent = RASTER_PRESET_DESC[rp] || RASTER_PRESET_DESC.balanced;
          const showCust = rp === 'custom';
          customRaster.style.display = showCust ? 'block' : 'none';
          customRaster.hidden = !showCust;
        });
      });

      function syncSliders() {
        if (jpegSlider && jpegVal) jpegVal.textContent = jpegSlider.value;
        if (scaleSlider && scaleVal) scaleVal.textContent = (Number(scaleSlider.value) / 100).toFixed(2);
      }
      jpegSlider?.addEventListener('input', syncSliders);
      scaleSlider?.addEventListener('input', syncSliders);
      syncSliders();

      function getStrategy() {
        const b = document.querySelector('.preset-btn[data-strategy].is-selected');
        return b ? b.dataset.strategy : 'structure';
      }

      function getRasterPreset() {
        const b = document.querySelector('.raster-preset.is-selected');
        return b ? b.dataset.rpreset : 'balanced';
      }

      function getRasterBaseSettings() {
        const rp = getRasterPreset();
        if (rp === 'custom') {
          return {
            scale: Number(scaleSlider.value) / 100,
            jpeg: Number(jpegSlider.value) / 100,
          };
        }
        return RASTER_DEFAULTS[rp] || RASTER_DEFAULTS.balanced;
      }

      /** Target max bytes from MB input, or null */
      function getTargetBytes(origSize) {
        const mbEl = document.getElementById('targetMb');
        const pctEl = document.getElementById('targetPct');
        const mb = parseFloat(mbEl?.value || '');
        const pct = parseFloat(pctEl?.value || '');
        if (!Number.isNaN(mb) && mb > 0) return Math.floor(mb * 1024 * 1024);
        if (!Number.isNaN(pct) && pct > 0 && pct < 100) return Math.floor(origSize * (1 - pct / 100));
        return null;
      }

      function formatBytes(n) {
        if (n >= 1048576) return (n / 1048576).toFixed(2) + ' MB';
        return (n / 1024).toFixed(1) + ' KB';
      }

      /** Structure-only: metadata strip + object streams (vector preserved). */
      async function compressStructureOnly(buf) {
        const src = await PDFDocument.load(buf, { ignoreEncryption: true });
        const out = await PDFDocument.create();
        const pages = await out.copyPages(src, src.getPageIndices());
        pages.forEach((p) => out.addPage(p));
        out.setTitle('');
        out.setAuthor('');
        out.setSubject('');
        return out.save({ useObjectStreams: true, addDefaultPage: false });
      }

      /**
       * Rasterize each page to JPEG. viewportScale multiplies PDF.js default scale (page size in pt).
       * Uses each page's real dimensions (not fixed A4).
       */
      async function compressRaster(buf, pdfjs, viewportScale, jpegQuality) {
        const pdf = await pdfjs.getDocument({ data: buf.slice(0) }).promise;
        const out = await PDFDocument.create();
        const num = pdf.numPages;
        const q = Math.min(0.98, Math.max(0.35, jpegQuality));
        const vs = Math.min(2.25, Math.max(0.65, viewportScale));
        for (let i = 1; i <= num; i++) {
          const page = await pdf.getPage(i);
          const baseVp = page.getViewport({ scale: 1 });
          const pageW = baseVp.width;
          const pageH = baseVp.height;
          const vp = page.getViewport({ scale: vs });
          const canvas = document.createElement('canvas');
          canvas.width = Math.max(1, Math.floor(vp.width));
          canvas.height = Math.max(1, Math.floor(vp.height));
          const ctx = canvas.getContext('2d');
          await page.render({ canvasContext: ctx, viewport: vp }).promise;
          const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', q));
          const jpgBytes = new Uint8Array(await blob.arrayBuffer());
          const img = await out.embedJpg(jpgBytes);
          const pg = out.addPage([pageW, pageH]);
          const s = Math.min(pageW / img.width, pageH / img.height);
          const dw = img.width * s;
          const dh = img.height * s;
          pg.drawImage(img, { x: (pageW - dw) / 2, y: (pageH - dh) / 2, width: dw, height: dh });
        }
        return out.save({ useObjectStreams: true });
      }

      /**
       * Find highest JPEG quality (binary search) so size <= targetBytes at given scale.
       * If impossible at this scale, reduce scale and retry.
       */
      async function compressRasterToTarget(buf, pdfjs, baseScale, targetBytes) {
        let scale = baseScale;
        for (let round = 0; round < 10; round++) {
          let lo = 0.35;
          let hi = 0.95;
          let bestFit = null;
          for (let iter = 0; iter < 15; iter++) {
            const mid = (lo + hi) / 2;
            const out = await compressRaster(buf, pdfjs, scale, mid);
            if (out.byteLength <= targetBytes) {
              bestFit = out;
              lo = mid;
            } else {
              hi = mid;
            }
          }
          if (bestFit) return bestFit;
          scale *= 0.85;
          if (scale < 0.52) break;
        }
        return compressRaster(buf, pdfjs, Math.max(0.55, baseScale * 0.75), 0.38);
      }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const compressBtn = document.getElementById('compressBtn');
      let lastOutputs = [];
      let stagedFiles = [];
      let isCompressing = false;

      function renderQueue() {
        const ul = document.getElementById('fileQueue');
        const wrap = document.getElementById('fileQueueWrap');
        const countEl = document.getElementById('queueCount');
        const hint = document.getElementById('compressBtnHint');
        if (countEl) countEl.textContent = String(stagedFiles.length);
        if (wrap) {
          wrap.style.display = stagedFiles.length ? 'block' : 'none';
          wrap.hidden = stagedFiles.length === 0;
        }
        if (ul) {
          ul.innerHTML = '';
          stagedFiles.forEach((file, i) => {
            const li = document.createElement('li');
            li.className = 'file-queue-item';
            li.innerHTML =
              '<span class="file-queue-name">' +
              escapeHtml(file.name) +
              '</span><span class="file-queue-meta">' +
              formatBytes(file.size) +
              '</span><button type="button" class="btn-text file-queue-remove" data-qi="' +
              i +
              '" aria-label="Remove file from list">Remove</button>';
            ul.appendChild(li);
          });
          ul.querySelectorAll('.file-queue-remove').forEach((b) => {
            b.addEventListener('click', (e) => {
              const idx = Number(e.currentTarget.getAttribute('data-qi'));
              if (!Number.isNaN(idx)) {
                stagedFiles.splice(idx, 1);
                renderQueue();
              }
            });
          });
        }
        if (!isCompressing && compressBtn) {
          compressBtn.disabled = stagedFiles.length === 0;
        }
        if (hint) {
          hint.textContent = stagedFiles.length
            ? 'Click when you’re ready — you can change options above and run again without re-adding files.'
            : 'Add at least one PDF, then click Compress PDFs.';
        }
      }

      function stageFiles(files) {
        const pdfs = files.filter((f) => f.type === 'application/pdf' || /\.pdf$/i.test(f.name));
        if (!pdfs.length) {
          alert('Please choose PDF files only.');
          return;
        }
        for (const f of pdfs) {
          if (f.size > 50 * 1024 * 1024) {
            if (!confirm(f.name + ' is over 50 MB. Add it to the list anyway?')) continue;
          }
          stagedFiles.push(f);
        }
        renderQueue();
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        stageFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        stageFiles(fs);
      });

      document.getElementById('clearQueue')?.addEventListener('click', () => {
        stagedFiles = [];
        renderQueue();
      });

      compressBtn?.addEventListener('click', () => {
        void runCompression();
      });

      async function runCompression() {
        if (isCompressing) return;
        const pdfs = stagedFiles.slice();
        if (!pdfs.length) {
          alert('Add at least one PDF first (step 2).');
          return;
        }
        let activePdfjs = pdfjsLib;
        const needRaster = getStrategy() === 'raster';
        if (needRaster) {
          for (let i = 0; i < 60; i++) {
            activePdfjs = window.__pdfjsCompress;
            if (activePdfjs) break;
            await new Promise((r) => setTimeout(r, 50));
          }
          if (!activePdfjs) {
            alert('The PDF viewer is still loading. Wait a few seconds and try Compress again.');
            return;
          }
        }
        isCompressing = true;
        if (compressBtn) {
          compressBtn.disabled = true;
          compressBtn.textContent = 'Compressing…';
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        const strat0 = getStrategy();
        const mb0 = document.getElementById('targetMb')?.value?.trim();
        const pct0 = document.getElementById('targetPct')?.value?.trim();
        const hasGoal = Boolean(mb0 || pct0);
        if (strat0 === 'structure' && hasGoal) {
          bannerText.textContent =
            'ℹ️ Size targets apply to “Smaller file” mode only — using Light cleanup for this run (targets ignored).';
        } else {
          bannerText.textContent = '⏳ Working on your PDFs… This can take a while for large files.';
        }
        try {
        results.innerHTML = '';
        lastOutputs = [];
        for (const file of pdfs) {
          const orig = await file.arrayBuffer();
          const origSize = orig.byteLength;
          let outBytes;
          try {
            const strategy = getStrategy();
            const targetBytes = getTargetBytes(origSize);
            if (strategy === 'structure') {
              outBytes = await compressStructureOnly(orig);
            } else {
              const { scale, jpeg } = getRasterBaseSettings();
              if (targetBytes != null) {
                const trial = await compressRaster(orig, activePdfjs, scale, jpeg);
                if (trial.byteLength <= targetBytes) {
                  outBytes = trial;
                } else {
                  outBytes = await compressRasterToTarget(orig, activePdfjs, scale, targetBytes);
                }
              } else {
                outBytes = await compressRaster(orig, activePdfjs, scale, jpeg);
              }
            }
          } catch (err) {
            const row = document.createElement('div');
            row.className = 'file-item error';
            row.textContent = file.name + ': ' + (err.message || 'failed');
            results.appendChild(row);
            continue;
          }
          const base = file.name.replace(/\.pdf$/i, '') || 'document';
          const name = base + '-compressed.pdf';
          const blob = new Blob([outBytes], { type: 'application/pdf' });
          lastOutputs.push({ name, blob });
          const url = URL.createObjectURL(blob);
          const row = document.createElement('div');
          row.className = 'file-item';
          row.innerHTML =
            '<div class="file-item-main"><div class="file-thumb">🗜️</div><div class="file-info">' +
            '<div class="file-name">' +
            escapeHtml(name) +
            '</div>' +
            '<div class="file-status done">' +
            formatBytes(origSize) +
            ' → ' +
            formatBytes(outBytes.byteLength) +
            ' (' +
            (outBytes.byteLength <= origSize
              ? Math.round((1 - outBytes.byteLength / origSize) * 100) + '% smaller'
              : 'larger than original — try Light cleanup or lower strength') +
            ')</div></div>' +
            '<div class="file-actions-col"><a class="btn" href="' +
            url +
            '" download="' +
            escapeHtml(name) +
            '">Download</a></div></div>';
          results.appendChild(row);
        }
        resultsHeader.style.display = 'block';
        if (lastOutputs.length > 0) {
          actions.style.display = 'flex';
          banner.className = 'banner banner-success';
          bannerText.textContent =
            '✓ Done — your downloads are below. Change options and compress again if needed.';
        } else {
          actions.style.display = 'none';
          banner.className = 'banner banner-info';
          bannerText.textContent = 'No file was compressed successfully — check the error messages above.';
        }
        } catch (err) {
          banner.style.display = 'block';
          banner.className = 'banner banner-info';
          bannerText.textContent = '✗ ' + (err.message || 'Compression failed. Try again or pick a different mode.');
        } finally {
          isCompressing = false;
          if (compressBtn) {
            compressBtn.textContent = 'Compress PDFs';
          }
          renderQueue();
        }
      }


      document.getElementById('downloadZip').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined' || !lastOutputs.length) return;
        const zip = new JSZip();
        lastOutputs.forEach((o) => zip.file(o.name, o.blob));
        const blob = await zip.generateAsync({ type: 'blob' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'compressed-pdfs.zip';
        a.click();
      });

      document.getElementById('clearResults').addEventListener('click', () => {
        results.innerHTML = '';
        lastOutputs = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      renderQueue();

      void (async () => {
        try {
          const pending = await window.DoItSwiftPending?.consume?.();
          if (pending) {
            stageFiles([pending]);
            banner.style.display = 'block';
            banner.className = 'banner banner-info';
            bannerText.textContent = 'File added — adjust options if you like, then click Compress PDFs.';
          }
        } catch (e) {
          console.warn(e);
        }
      })();
    });
  </script>

