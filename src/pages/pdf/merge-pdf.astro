---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = 'https://doitswift.com/pdf/merge-pdf/';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'Merge PDF — DoItSwift',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description: 'Combine multiple PDF files into one document in your browser. Private, unlimited, no upload.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I merge PDFs for free without uploading?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Use DoItSwift Merge PDF in your browser. Files are combined locally with pdf-lib; nothing is sent to our servers.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I change the order of PDFs before merging?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Drag and drop rows to reorder, then download the merged PDF.',
          },
        },
      ],
    },
  ],
};
---

<MainLayout
  title="Merge PDF — Free, Private & Unlimited | DoItSwift"
  description="Merge PDF files online for free. Combine documents in your browser — no upload, no signup. Drag to reorder, then download merged.pdf."
  keywords="merge pdf, combine pdf, join pdf files, merge pdf online free, pdf merger browser"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js" is:inline></script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>Merge PDF</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Merge PDF</h1>
      <p class="subtitle">
        Combine multiple PDFs into a single file. Reorder documents before merging — page counts shown for each file.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📎</div>
        <div class="dropzone-text">Drop PDF files here or click to browse</div>
        <div class="dropzone-sub">Add two or more PDFs — drag rows below to set order</div>
        <input type="file" id="fileInput" multiple accept=".pdf,application/pdf" />
      </div>

      <div id="mergePanel" class="merge-panel" style="display:none">
        <p class="merge-panel-title">Order (drag to reorder)</p>
        <ul id="mergeList" class="merge-list"></ul>
        <button type="button" class="btn btn-lg" id="mergeBtn">Merge into one PDF</button>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">Result:</div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- ShareButtons: place ShareButtons component before FAQ when enabling blog-style sharing -->

  <section class="long-form">
    <div class="container">
      <h2 class="section-title">How merging PDFs helps in real workflows</h2>
      <p>
        Professionals merge PDFs every day: accountants bundle monthly invoices, lawyers combine exhibits, students merge
        lecture notes, and HR teams join signed forms into one packet. A browser-based merger avoids emailing sensitive
        documents to a third-party converter. You keep custody of the file from selection through download.
      </p>
      <p>
        DoItSwift reads each PDF with pdf-lib, copies every page in list order into a new document, and saves a fresh
        file named <code>merged.pdf</code>. Reordering happens entirely in the page — drag a row up or down before you
        click merge. If one PDF is password-protected or corrupted, that file may fail; try unlocking or re-exporting it
        from the original app first.
      </p>
      <p>
        For archival, merging reduces clutter: instead of twelve separate “Statement_Jan.pdf” files, one “Statements_2026.pdf”
        is easier to back up and share. Combine that with our split and compress tools when you need the opposite
        operations later.
      </p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Is merge PDF free?</h4>
          <p>Yes — unlimited merges in your browser, no account.</p>
        </div>
        <div class="faq-item">
          <h4>Are files uploaded?</h4>
          <p>No. Merging uses JavaScript on your device; we never see your PDFs.</p>
        </div>
        <div class="faq-item">
          <h4>Why do I need at least two PDFs?</h4>
          <p>Merging combines multiple sources. For a single file, use split or compress instead.</p>
        </div>
        <div class="faq-item">
          <h4>Does order matter?</h4>
          <p>Yes. Top of the list becomes the first pages of the merged PDF. Drag rows to fix order.</p>
        </div>
        <div class="faq-item">
          <h4>Will bookmarks and forms be preserved?</h4>
          <p>pdf-lib copies page content; complex interactive features may not transfer perfectly. Test important forms after merge.</p>
        </div>
        <div class="faq-item">
          <h4>Can I merge on mobile?</h4>
          <p>Yes on modern phones; very large PDFs may be slow — use Wi-Fi and patience.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const PDFLibGlobal = typeof PDFLib !== 'undefined' ? PDFLib : window.PDFLib;
      if (!PDFLibGlobal) {
        console.error('pdf-lib not loaded');
        return;
      }
      const { PDFDocument } = PDFLibGlobal;

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const mergePanel = document.getElementById('mergePanel');
      const mergeList = document.getElementById('mergeList');
      const mergeBtn = document.getElementById('mergeBtn');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');

      let items = [];

      function uid() {
        return 'i' + Math.random().toString(36).slice(2, 10);
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        void addFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        void addFiles(fs);
      });

      async function addFiles(files) {
        const pdfs = files.filter((f) => f.type === 'application/pdf' || /\.pdf$/i.test(f.name));
        if (!pdfs.length) {
          alert('Please choose PDF files only.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Reading PDFs…';
        for (const file of pdfs) {
          try {
            const buf = await file.arrayBuffer();
            const doc = await PDFDocument.load(buf, { ignoreEncryption: true }).catch(() => null);
            if (!doc) {
              alert('Could not read: ' + file.name + ' (encrypted or invalid?)');
              continue;
            }
            const pageCount = doc.getPageCount();
            items.push({ id: uid(), file, name: file.name, pageCount, buffer: buf });
          } catch (err) {
            alert('Error reading ' + file.name + ': ' + (err.message || err));
          }
        }
        banner.className = 'banner banner-success';
        bannerText.textContent = '✓ ' + items.length + ' PDF(s) added — set order and tap Merge';
        renderList();
        mergePanel.style.display = 'block';
      }

      function renderList() {
        mergeList.innerHTML = '';
        items.forEach((it, index) => {
          const li = document.createElement('li');
          li.className = 'merge-row';
          li.draggable = true;
          li.dataset.id = it.id;
          li.innerHTML =
            '<span class="merge-grip" aria-hidden="true">⋮⋮</span>' +
            '<span class="merge-name">' +
            escapeHtml(it.name) +
            '</span>' +
            '<span class="merge-pages">' +
            it.pageCount +
            ' pg</span>' +
            '<button type="button" class="btn-text merge-remove" data-id="' +
            it.id +
            '">Remove</button>';
          li.addEventListener('dragstart', (e) => {
            e.dataTransfer.setData('text/plain', it.id);
            li.classList.add('dragging');
          });
          li.addEventListener('dragend', () => li.classList.remove('dragging'));
          li.addEventListener('dragover', (e) => e.preventDefault());
          li.addEventListener('drop', (e) => {
            e.preventDefault();
            const fromId = e.dataTransfer.getData('text/plain');
            const toId = it.id;
            if (!fromId || fromId === toId) return;
            const fromIx = items.findIndex((x) => x.id === fromId);
            const toIx = items.findIndex((x) => x.id === toId);
            if (fromIx < 0 || toIx < 0) return;
            const [moved] = items.splice(fromIx, 1);
            items.splice(toIx, 0, moved);
            renderList();
          });
          mergeList.appendChild(li);
        });
        mergeList.querySelectorAll('.merge-remove').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            items = items.filter((x) => x.id !== id);
            if (!items.length) {
              mergePanel.style.display = 'none';
              banner.style.display = 'none';
            } else renderList();
          });
        });
      }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      mergeBtn.addEventListener('click', async () => {
        if (items.length < 2) {
          alert('Add at least two PDF files to merge.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Merging… This may take a moment for large files.';
        results.innerHTML = '';
        try {
          const mergedPdf = await PDFDocument.create();
          for (const it of items) {
            const src = await PDFDocument.load(it.buffer);
            const copiedPages = await mergedPdf.copyPages(src, src.getPageIndices());
            copiedPages.forEach((p) => mergedPdf.addPage(p));
          }
          const bytes = await mergedPdf.save();
          const blob = new Blob([bytes], { type: 'application/pdf' });
          const url = URL.createObjectURL(blob);
          resultsHeader.style.display = 'block';
          const row = document.createElement('div');
          row.className = 'file-item';
          row.innerHTML =
            '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info">' +
            '<div class="file-name">merged.pdf</div>' +
            '<div class="file-status done">Ready — ' +
            (bytes.byteLength / 1024).toFixed(1) +
            ' KB</div></div>' +
            '<div class="file-actions-col"><a class="btn" href="' +
            url +
            '" download="merged.pdf">Download</a></div></div>';
          results.appendChild(row);
          actions.style.display = 'flex';
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ Merged PDF ready';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } catch (err) {
          banner.className = 'banner banner-info';
          bannerText.textContent = 'Error: ' + (err.message || 'Merge failed');
          alert('Merge failed: ' + (err.message || err));
        }
      });

      document.getElementById('clearAll').addEventListener('click', () => {
        items = [];
        mergeList.innerHTML = '';
        mergePanel.style.display = 'none';
        results.innerHTML = '';
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });
    });
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 820px;
    }
    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }
    .breadcrumb a:hover {
      text-decoration: underline;
    }
    .hero {
      padding: 40px 0 20px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 620px;
      margin: 0 auto 28px;
    }
    .converter-section {
      padding: 30px 0;
    }
    .converter-section .container {
      max-width: 820px;
    }
    .banner {
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      font-weight: 600;
      text-align: center;
    }
    .banner-info {
      background: #dbeafe;
      color: #1e40af;
    }
    .banner-success {
      background: #d1fae5;
      color: #065f46;
    }
    [data-theme='dark'] .banner-info {
      background: rgba(30, 64, 175, 0.2);
      color: #93c5fd;
    }
    [data-theme='dark'] .banner-success {
      background: rgba(6, 95, 70, 0.2);
      color: #6ee7b7;
    }
    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 70px 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }
    .dropzone:hover,
    .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    .dropzone-icon {
      font-size: 56px;
      margin-bottom: 14px;
    }
    .dropzone-text {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .dropzone-sub {
      font-size: 14px;
      color: var(--text-muted);
    }
    #fileInput {
      display: none;
    }
    .merge-panel {
      margin-top: 20px;
    }
    .merge-panel-title {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 10px;
    }
    .merge-list {
      list-style: none;
      padding: 0;
      margin: 0 0 16px;
    }
    .merge-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 8px;
      cursor: grab;
    }
    .merge-row.dragging {
      opacity: 0.6;
    }
    .merge-grip {
      color: var(--text-muted);
      user-select: none;
    }
    .merge-name {
      flex: 1;
      font-size: 14px;
      font-weight: 600;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .merge-pages {
      font-size: 13px;
      color: var(--text-muted);
    }
    .results-header {
      font-weight: 700;
      margin: 20px 0 10px;
    }
    .file-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 10px;
    }
    .file-item-main {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .file-thumb {
      font-size: 28px;
    }
    .file-name {
      font-weight: 600;
    }
    .file-status.done {
      font-size: 13px;
      color: var(--text-muted);
    }
    .actions {
      display: flex;
      gap: 12px;
      margin-top: 16px;
    }
    .long-form {
      padding: 40px 0;
    }
    .long-form .container {
      max-width: 760px;
    }
    .long-form p {
      font-size: 15px;
      line-height: 1.75;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .long-form code {
      font-size: 0.9em;
      padding: 2px 6px;
      background: var(--gray-100);
      border-radius: 4px;
    }
    .faq {
      padding: 40px 0 60px;
    }
    .faq .container {
      max-width: 820px;
    }
    .section-title {
      text-align: center;
      margin-bottom: 24px;
    }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 12px;
      box-shadow: var(--shadow);
    }
    .faq-item h4 {
      font-size: 16px;
      margin-bottom: 6px;
    }
    .faq-item p {
      font-size: 14px;
      color: var(--text-muted);
    }
  </style>
</MainLayout>
