---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const pageDescription =
  'Merge PDF files in your browser with pdf-lib — combine two or more documents, drag to reorder, see page counts per file, download merged.pdf. Private, unlimited, no upload. Works offline after load.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'DoItSwift Merge PDF',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web browser',
      browserRequirements: 'Requires JavaScript and pdf-lib (loaded from CDN)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description:
        'Combine multiple PDF files into one document using pdf-lib in the browser. Reorder sources with drag and drop, copy all pages in sequence, save as merged.pdf. Processing is local — PDFs are not uploaded to DoItSwift.',
      featureList: [
        'Merge two or more PDFs into a single downloadable file',
        'Drag-and-drop list to set merge order before combining',
        'Shows page count per file in the merge queue',
        'Copies every page from each source PDF in list order',
        'Default download filename merged.pdf',
        'Client-side merge with pdf-lib — no server upload',
        'Merge button requires at least two PDFs',
        'Password-protected or unreadable PDFs may fail; unlock or re-export first',
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is Merge PDF free and unlimited?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Combine as many PDFs as your device can handle with no signup, watermarks, or usage quotas.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are my PDFs uploaded to DoItSwift servers?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. pdf-lib runs in your browser; merge happens locally and we never receive your files.',
          },
        },
        {
          '@type': 'Question',
          name: 'Why do I need at least two PDF files?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Merging combines multiple sources into one. For a single PDF, use split, compress, or other tools instead.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does the order of files matter?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. The top of the list becomes the first pages of the merged PDF. Drag rows to change order before merging.',
          },
        },
        {
          '@type': 'Question',
          name: 'Will bookmarks, forms, and links be preserved?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'pdf-lib copies page content; complex interactive features may not transfer perfectly. Test important forms after merging.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I merge password-protected or encrypted PDFs?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Encrypted PDFs may fail to load. Unlock with the correct password using DoItSwift Unlock PDF, or re-export from the original app, then merge.',
          },
        },
        {
          '@type': 'Question',
          name: 'What is the download filename?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The merged file downloads as merged.pdf by default; you can rename it after saving.',
          },
        },
        {
          '@type': 'Question',
          name: 'How many PDFs can I combine at once?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'There is no fixed count limit — practical limits are your device memory and browser performance for very large batches.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does Merge PDF work on mobile?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes on modern phones; very large PDFs may be slow — use Wi-Fi and keep the tab active until the merge finishes.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is there a monthly limit or account required?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No accounts, no quotas, and no premium tier.',
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'PDF Tools',
          item: new URL('/pdf/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Merge PDF',
          item: canonical,
        },
      ],
    },
  ],
};
---

<MainLayout
  title="Merge PDF — Combine PDFs Online, Reorder Pages, merged.pdf | DoItSwift"
  description={pageDescription}
  keywords="merge pdf, combine pdf files, join pdf online, merge pdf free, pdf merger browser, combine multiple pdfs, reorder pdf merge, pdf-lib merge, private merge pdf, no upload merge pdf, unlimited merge pdf"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js" is:inline></script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>Merge PDF</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Merge PDF</h1>
      <p class="subtitle">
        Combine two or more PDFs with pdf-lib in your browser — drag rows to set order, see page counts, download{' '}
        <code class="hero-code">merged.pdf</code>. Nothing uploads to our servers.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited files</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">📎</div>
        <div class="dropzone-text">Drop PDF files here or click to browse</div>
        <div class="dropzone-sub">Add two or more PDFs — drag rows below to set order</div>
        <input type="file" id="fileInput" multiple accept=".pdf,application/pdf" />
      </div>

      <div id="mergePanel" class="merge-panel" style="display:none">
        <p class="merge-panel-title">Order (drag to reorder)</p>
        <ul id="mergeList" class="merge-list"></ul>
        <button type="button" class="btn btn-lg" id="mergeBtn">Merge into one PDF</button>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">Result:</div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- ShareButtons: place ShareButtons component before FAQ when enabling blog-style sharing -->

  <article class="merge-edu" aria-label="Guide: merging PDF files">
    <div class="container merge-edu-inner">
      <section class="merge-edu-block">
        <h2 id="merge-workflows">How merging PDFs helps in real workflows</h2>
        <p>
          People merge PDFs every day: bundling invoices, combining legal exhibits, joining lecture notes, or assembling
          signed forms. A <strong>browser-based</strong> merger keeps sensitive documents off random upload servers — you
          stay in control from selection through download.
        </p>
        <p>
          For step-by-step context and privacy tips, read{' '}
          <a href="/blog/how-to-merge-pdf/">how to merge PDFs</a> on the DoItSwift blog.
        </p>
      </section>

      <section class="merge-edu-block">
        <h2 id="how-merge-works">How this tool merges your PDFs</h2>
        <p>
          The page uses <strong>pdf-lib</strong>: each chosen file is loaded in memory, then <strong>all pages are copied
          in list order</strong> into one new document. You can <strong>drag rows</strong> to change which file comes first;
          the banner shows <strong>page counts</strong> per file so you know what you are combining. Output downloads as{' '}
          <code>merged.pdf</code> — rename after saving if you need a different name.
        </p>
        <p>
          If a file is <strong>encrypted or corrupted</strong>, it may fail to load; use{' '}
          <a href="/pdf/unlock-pdf/">Unlock PDF</a> when you have the password, or re-export from the original application.
        </p>
      </section>

      <section class="merge-edu-block">
        <h2 id="merge-vs-split">After merging: split or compress</h2>
        <p>
          Merged files can grow large. Use <a href="/pdf/compress-pdf/">Compress PDF</a> to shrink the download, or{' '}
          <a href="/pdf/split-pdf/">Split PDF</a> if you later need separate documents again.
        </p>
      </section>
    </div>
  </article>

  <section class="merge-related" aria-label="Related PDF tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="merge-related-grid">
        <li><a href="/pdf/split-pdf/">Split PDF</a></li>
        <li><a href="/pdf/compress-pdf/">Compress PDF</a></li>
        <li><a href="/pdf/unlock-pdf/">Unlock PDF</a></li>
        <li><a href="/pdf/image-to-pdf/">Image to PDF</a></li>
        <li><a href="/pdf/pdf-to-jpg/">PDF to JPG</a></li>
        <li><a href="/pdf/jpg-to-pdf/">JPG to PDF</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="merge-related-grid merge-related-guides">
        <li><a href="/blog/how-to-merge-pdf/">How to merge PDFs</a></li>
        <li><a href="/blog/how-to-split-pdf/">How to split a PDF</a></li>
        <li><a href="/blog/how-to-compress-pdf/">How to compress a PDF</a></li>
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Is Merge PDF free and unlimited?</h4>
          <p>Yes. Combine as many PDFs as your device can handle with no signup, watermarks, or usage quotas.</p>
        </div>
        <div class="faq-item">
          <h4>Are my PDFs uploaded to DoItSwift servers?</h4>
          <p>No. pdf-lib runs in your browser; merge happens locally and we never receive your files.</p>
        </div>
        <div class="faq-item">
          <h4>Why do I need at least two PDF files?</h4>
          <p>
            Merging combines multiple sources into one. For a single PDF, use{' '}
            <a href="/pdf/split-pdf/">Split PDF</a>, <a href="/pdf/compress-pdf/">Compress PDF</a>, or other tools instead.
          </p>
        </div>
        <div class="faq-item">
          <h4>Does the order of files matter?</h4>
          <p>Yes. The top of the list becomes the first pages of the merged PDF. Drag rows to change order before merging.</p>
        </div>
        <div class="faq-item">
          <h4>Will bookmarks, forms, and links be preserved?</h4>
          <p>
            pdf-lib copies page content; complex interactive features may not transfer perfectly. Test important forms after
            merging.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I merge password-protected or encrypted PDFs?</h4>
          <p>
            Encrypted PDFs may fail to load. Unlock with the correct password using{' '}
            <a href="/pdf/unlock-pdf/">Unlock PDF</a>, or re-export from the original app, then merge.
          </p>
        </div>
        <div class="faq-item">
          <h4>What is the download filename?</h4>
          <p>The merged file downloads as <code>merged.pdf</code> by default; you can rename it after saving.</p>
        </div>
        <div class="faq-item">
          <h4>How many PDFs can I combine at once?</h4>
          <p>
            There is no fixed count limit — practical limits are your device memory and browser performance for very large
            batches.
          </p>
        </div>
        <div class="faq-item">
          <h4>Does Merge PDF work on mobile?</h4>
          <p>Yes on modern phones; very large PDFs may be slow — use Wi-Fi and keep the tab active until the merge finishes.</p>
        </div>
        <div class="faq-item">
          <h4>Is there a monthly limit or account required?</h4>
          <p>No accounts, no quotas, and no premium tier.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const PDFLibGlobal = typeof PDFLib !== 'undefined' ? PDFLib : window.PDFLib;
      if (!PDFLibGlobal) {
        console.error('pdf-lib not loaded');
        return;
      }
      const { PDFDocument } = PDFLibGlobal;

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const mergePanel = document.getElementById('mergePanel');
      const mergeList = document.getElementById('mergeList');
      const mergeBtn = document.getElementById('mergeBtn');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');

      let items = [];

      function uid() {
        return 'i' + Math.random().toString(36).slice(2, 10);
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        void addFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        void addFiles(fs);
      });

      async function addFiles(files) {
        const pdfs = files.filter((f) => f.type === 'application/pdf' || /\.pdf$/i.test(f.name));
        if (!pdfs.length) {
          alert('Please choose PDF files only.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Reading PDFs…';
        for (const file of pdfs) {
          try {
            const buf = await file.arrayBuffer();
            const doc = await PDFDocument.load(buf, { ignoreEncryption: true }).catch(() => null);
            if (!doc) {
              alert('Could not read: ' + file.name + ' (encrypted or invalid?)');
              continue;
            }
            const pageCount = doc.getPageCount();
            items.push({ id: uid(), file, name: file.name, pageCount, buffer: buf });
          } catch (err) {
            alert('Error reading ' + file.name + ': ' + (err.message || err));
          }
        }
        banner.className = 'banner banner-success';
        bannerText.textContent = '✓ ' + items.length + ' PDF(s) added — set order and tap Merge';
        renderList();
        mergePanel.style.display = 'block';
      }

      function renderList() {
        mergeList.innerHTML = '';
        items.forEach((it, index) => {
          const li = document.createElement('li');
          li.className = 'merge-row';
          li.draggable = true;
          li.dataset.id = it.id;
          li.innerHTML =
            '<span class="merge-grip" aria-hidden="true">⋮⋮</span>' +
            '<span class="merge-name">' +
            escapeHtml(it.name) +
            '</span>' +
            '<span class="merge-pages">' +
            it.pageCount +
            ' pg</span>' +
            '<button type="button" class="btn-text merge-remove" data-id="' +
            it.id +
            '">Remove</button>';
          li.addEventListener('dragstart', (e) => {
            e.dataTransfer.setData('text/plain', it.id);
            li.classList.add('dragging');
          });
          li.addEventListener('dragend', () => li.classList.remove('dragging'));
          li.addEventListener('dragover', (e) => e.preventDefault());
          li.addEventListener('drop', (e) => {
            e.preventDefault();
            const fromId = e.dataTransfer.getData('text/plain');
            const toId = it.id;
            if (!fromId || fromId === toId) return;
            const fromIx = items.findIndex((x) => x.id === fromId);
            const toIx = items.findIndex((x) => x.id === toId);
            if (fromIx < 0 || toIx < 0) return;
            const [moved] = items.splice(fromIx, 1);
            items.splice(toIx, 0, moved);
            renderList();
          });
          mergeList.appendChild(li);
        });
        mergeList.querySelectorAll('.merge-remove').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            items = items.filter((x) => x.id !== id);
            if (!items.length) {
              mergePanel.style.display = 'none';
              banner.style.display = 'none';
            } else renderList();
          });
        });
      }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      mergeBtn.addEventListener('click', async () => {
        if (items.length < 2) {
          alert('Add at least two PDF files to merge.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Merging… This may take a moment for large files.';
        results.innerHTML = '';
        try {
          const mergedPdf = await PDFDocument.create();
          for (const it of items) {
            const src = await PDFDocument.load(it.buffer);
            const copiedPages = await mergedPdf.copyPages(src, src.getPageIndices());
            copiedPages.forEach((p) => mergedPdf.addPage(p));
          }
          const bytes = await mergedPdf.save();
          const blob = new Blob([bytes], { type: 'application/pdf' });
          const url = URL.createObjectURL(blob);
          resultsHeader.style.display = 'block';
          const row = document.createElement('div');
          row.className = 'file-item';
          row.innerHTML =
            '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info">' +
            '<div class="file-name">merged.pdf</div>' +
            '<div class="file-status done">Ready — ' +
            (bytes.byteLength / 1024).toFixed(1) +
            ' KB</div></div>' +
            '<div class="file-actions-col"><a class="btn" href="' +
            url +
            '" download="merged.pdf">Download</a></div></div>';
          results.appendChild(row);
          actions.style.display = 'flex';
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ Merged PDF ready';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } catch (err) {
          banner.className = 'banner banner-info';
          bannerText.textContent = 'Error: ' + (err.message || 'Merge failed');
          alert('Merge failed: ' + (err.message || err));
        }
      });

      document.getElementById('clearAll').addEventListener('click', () => {
        items = [];
        mergeList.innerHTML = '';
        mergePanel.style.display = 'none';
        results.innerHTML = '';
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });
    });
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 820px;
    }
    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }
    .breadcrumb a:hover {
      text-decoration: underline;
    }
    .hero {
      padding: 40px 0 20px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 auto 28px;
    }
    .hero-code {
      font-family: ui-monospace, 'Cascadia Code', 'Courier New', monospace;
      font-size: 0.88em;
      padding: 0.12em 0.35em;
      background: var(--gray-100);
      border-radius: 4px;
      color: var(--text);
    }
    [data-theme='dark'] .hero-code {
      background: rgba(255, 255, 255, 0.1);
    }
    .converter-section {
      padding: 30px 0;
    }
    .converter-section .container {
      max-width: 820px;
    }
    .banner {
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      font-weight: 600;
      text-align: center;
    }
    .banner-info {
      background: #dbeafe;
      color: #1e40af;
    }
    .banner-success {
      background: #d1fae5;
      color: #065f46;
    }
    [data-theme='dark'] .banner-info {
      background: rgba(30, 64, 175, 0.2);
      color: #93c5fd;
    }
    [data-theme='dark'] .banner-success {
      background: rgba(6, 95, 70, 0.2);
      color: #6ee7b7;
    }
    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 70px 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: var(--shadow);
    }
    .dropzone:hover,
    .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    .dropzone-icon {
      font-size: 56px;
      margin-bottom: 14px;
    }
    .dropzone-text {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .dropzone-sub {
      font-size: 14px;
      color: var(--text-muted);
    }
    #fileInput {
      display: none;
    }
    .merge-panel {
      margin-top: 20px;
    }
    .merge-panel-title {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 10px;
    }
    .merge-list {
      list-style: none;
      padding: 0;
      margin: 0 0 16px;
    }
    .merge-row {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 8px;
      cursor: grab;
    }
