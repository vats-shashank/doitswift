  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const PDFLibGlobal = typeof PDFLib !== 'undefined' ? PDFLib : window.PDFLib;
      if (!PDFLibGlobal) {
        console.error('pdf-lib not loaded');
        return;
      }
      const { PDFDocument } = PDFLibGlobal;

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const mergePanel = document.getElementById('mergePanel');
      const mergeList = document.getElementById('mergeList');
      const mergeBtn = document.getElementById('mergeBtn');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');

      let items = [];

      function uid() {
        return 'i' + Math.random().toString(36).slice(2, 10);
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        void addFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        void addFiles(fs);
      });

      async function addFiles(files) {
        const pdfs = files.filter((f) => f.type === 'application/pdf' || /\.pdf$/i.test(f.name));
        if (!pdfs.length) {
          alert('Please choose PDF files only.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Reading PDFs…';
        for (const file of pdfs) {
          try {
            const buf = await file.arrayBuffer();
            const doc = await PDFDocument.load(buf, { ignoreEncryption: true }).catch(() => null);
            if (!doc) {
              alert('Could not read: ' + file.name + ' (encrypted or invalid?)');
              continue;
            }
            const pageCount = doc.getPageCount();
            items.push({ id: uid(), file, name: file.name, pageCount, buffer: buf });
          } catch (err) {
            alert('Error reading ' + file.name + ': ' + (err.message || err));
          }
        }
        banner.className = 'banner banner-success';
        bannerText.textContent = '✓ ' + items.length + ' PDF(s) added — set order and tap Merge';
        renderList();
        mergePanel.style.display = 'block';
      }

      function renderList() {
        mergeList.innerHTML = '';
        items.forEach((it, index) => {
          const li = document.createElement('li');
          li.className = 'merge-row';
          li.draggable = true;
          li.dataset.id = it.id;
          li.innerHTML =
            '<span class="merge-grip" aria-hidden="true">⋮⋮</span>' +
            '<span class="merge-name">' +
            escapeHtml(it.name) +
            '</span>' +
            '<span class="merge-pages">' +
            it.pageCount +
            ' pg</span>' +
            '<button type="button" class="btn-text merge-remove" data-id="' +
            it.id +
            '">Remove</button>';
          li.addEventListener('dragstart', (e) => {
            e.dataTransfer.setData('text/plain', it.id);
            li.classList.add('dragging');
          });
          li.addEventListener('dragend', () => li.classList.remove('dragging'));
          li.addEventListener('dragover', (e) => e.preventDefault());
          li.addEventListener('drop', (e) => {
            e.preventDefault();
            const fromId = e.dataTransfer.getData('text/plain');
            const toId = it.id;
            if (!fromId || fromId === toId) return;
            const fromIx = items.findIndex((x) => x.id === fromId);
            const toIx = items.findIndex((x) => x.id === toId);
            if (fromIx < 0 || toIx < 0) return;
            const [moved] = items.splice(fromIx, 1);
            items.splice(toIx, 0, moved);
            renderList();
          });
          mergeList.appendChild(li);
        });
        mergeList.querySelectorAll('.merge-remove').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            items = items.filter((x) => x.id !== id);
            if (!items.length) {
              mergePanel.style.display = 'none';
              banner.style.display = 'none';
            } else renderList();
          });
        });
      }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      mergeBtn.addEventListener('click', async () => {
        if (items.length < 2) {
          alert('Add at least two PDF files to merge.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Merging… This may take a moment for large files.';
        results.innerHTML = '';
        try {
          const mergedPdf = await PDFDocument.create();
          for (const it of items) {
            const src = await PDFDocument.load(it.buffer);
            const copiedPages = await mergedPdf.copyPages(src, src.getPageIndices());
            copiedPages.forEach((p) => mergedPdf.addPage(p));
          }
          const bytes = await mergedPdf.save();
          const blob = new Blob([bytes], { type: 'application/pdf' });
          const url = URL.createObjectURL(blob);
          resultsHeader.style.display = 'block';
          const row = document.createElement('div');
          row.className = 'file-item';
          row.innerHTML =
            '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info">' +
            '<div class="file-name">merged.pdf</div>' +
            '<div class="file-status done">Ready — ' +
            (bytes.byteLength / 1024).toFixed(1) +
            ' KB</div></div>' +
            '<div class="file-actions-col"><a class="btn" href="' +
            url +
            '" download="merged.pdf">Download</a></div></div>';
          results.appendChild(row);
          actions.style.display = 'flex';
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ Merged PDF ready';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } catch (err) {
          banner.className = 'banner banner-info';
          bannerText.textContent = 'Error: ' + (err.message || 'Merge failed');
          alert('Merge failed: ' + (err.message || err));
        }
      });

      document.getElementById('clearAll').addEventListener('click', () => {
        items = [];
        mergeList.innerHTML = '';
        mergePanel.style.display = 'none';
        results.innerHTML = '';
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });
    });
  </script>

