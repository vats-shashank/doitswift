      flex: 1;
      font-size: 14px;
      font-weight: 600;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .merge-pages {
      font-size: 13px;
      color: var(--text-muted);
    }
    .results-header {
      font-weight: 700;
      margin: 20px 0 10px;
    }
    .file-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 10px;
    }
    .file-item-main {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .file-thumb {
      font-size: 28px;
    }
    .file-name {
      font-weight: 600;
    }
    .file-status.done {
      font-size: 13px;
      color: var(--text-muted);
    }
    .actions {
      display: flex;
      gap: 12px;
      margin-top: 16px;
    }
    .section-title {
      text-align: center;
      margin-bottom: 24px;
    }

    .merge-edu {
      padding: 40px 0 16px;
    }
    .merge-edu-inner {
      max-width: 760px;
    }
    .merge-edu-block {
      margin-bottom: 2.5rem;
    }
    .merge-edu-block:last-child {
      margin-bottom: 0;
    }
    .merge-edu h2 {
      font-size: clamp(1.35rem, 2.5vw, 1.55rem);
      line-height: 1.3;
      margin: 0 0 1rem;
      color: var(--text);
    }
    .merge-edu p {
      font-size: 16px;
      line-height: 1.75;
      color: var(--text);
      margin: 0 0 1rem;
    }
    .merge-edu a {
      color: var(--blue);
      font-weight: 600;
