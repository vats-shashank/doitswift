---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const pageDescription =
  'Merge JPG, PNG, WebP, HEIC, GIF, and BMP into one PDF in your browser — drag to reorder pages, choose A4, Letter, or Legal. Built with pdf-lib and local HEIC decode (heic2any). No upload, unlimited, default download images-combined.pdf.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'DoItSwift Image to PDF',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web browser',
      browserRequirements: 'Requires JavaScript, pdf-lib, Canvas API, and heic2any for HEIC (loaded from CDN)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description:
        'Combine raster images into a single PDF using pdf-lib in the browser. Reorder thumbnails with drag and drop, select page size A4 Letter or Legal, per-page orientation from image dimensions. HEIC converts to JPEG locally; WebP GIF BMP rasterize to JPEG for embedding. No server upload.',
      featureList: [
        'Combine JPG, PNG, WebP, HEIC/HEIF, GIF, and BMP in one merged PDF',
        'Drag-and-drop thumbnail list to set page order before export',
        'Page size: A4, US Letter, or US Legal; each page orientation follows image width vs height',
        'Images scale to fit the page while preserving aspect ratio',
        'HEIC decoded to JPEG in-browser with heic2any before embedding',
        'PNG embedded directly; transparency composited on white; WebP/GIF/BMP converted via canvas to JPEG',
        'Animated GIFs: first frame only',
        'Output download filename images-combined.pdf by default',
        '100% client-side processing — image bytes are not uploaded to DoItSwift',
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is Image to PDF free and unlimited?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Build as many PDFs as you need locally with no signup, watermarks, or usage quotas.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are my images uploaded to DoItSwift servers?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. pdf-lib and image decoding run in your browser tab only; files never leave your device.',
          },
        },
        {
          '@type': 'Question',
          name: 'How does PNG transparency work in the PDF?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'PNG files embed in the PDF with transparency flattened onto a white background because PDF pages are opaque rectangles.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I mix JPG, PNG, WebP, and HEIC in one PDF?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Add any supported types in one batch, reorder thumbnails, then create a single combined PDF.',
          },
        },
        {
          '@type': 'Question',
          name: 'How are HEIC or HEIF photos from an iPhone handled?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'HEIC is converted to JPEG in your browser using heic2any, then embedded — same privacy model as other HEIC tools, with no server upload.',
          },
        },
        {
          '@type': 'Question',
          name: 'How is WebP handled?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'WebP is decoded to pixels and saved as a JPEG representation inside the PDF for compatibility.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can portrait and landscape pages appear in the same PDF?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Each page orientation follows that image\'s dimensions — wider images use a landscape page, taller images use portrait, within your chosen paper size.',
          },
        },
        {
          '@type': 'Question',
          name: 'Which page sizes can I choose?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Select A4, US Letter, or US Legal before building the PDF. Images scale to fit within the page while keeping aspect ratio.',
          },
        },
        {
          '@type': 'Question',
          name: 'What about GIF, BMP, or animated GIFs?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'GIF and BMP are rasterized to JPEG for embedding. Animated GIFs use the first frame only.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is there a monthly limit or account required?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No accounts, no quotas, and no premium tier.',
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'PDF Tools',
          item: new URL('/pdf/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Image to PDF',
          item: canonical,
        },
      ],
    },
  ],
};
---

<MainLayout
  title="Image to PDF — Merge JPG, PNG, WebP, HEIC, Reorder Pages, A4/Letter | DoItSwift"
  description={pageDescription}
  keywords="image to pdf, jpg to pdf, png to pdf, multiple images to one pdf, photo to pdf, heic to pdf, webp to pdf, combine images pdf, reorder pages pdf, a4 letter pdf, browser image to pdf, private image to pdf, pdf-lib, merge photos pdf free"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/heic2any@0.0.4/dist/heic2any.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js" is:inline></script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>Image to PDF</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Image to PDF Converter</h1>
      <p class="subtitle">
        Combine JPG, PNG, WebP, HEIC, GIF, or BMP into one PDF with pdf-lib — drag thumbnails to reorder, pick A4, Letter,
        or Legal, per-page portrait or landscape. Download as <code class="hero-code">images-combined.pdf</code>. Local only;
        no upload.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited images</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">🖼️</div>
        <div class="dropzone-text">Drop images here or click to browse</div>
        <div class="dropzone-sub">JPG, PNG, WebP, HEIC, GIF, BMP — batch supported</div>
        <input
          type="file"
          id="fileInput"
          multiple
          accept=".jpg,.jpeg,.png,.webp,.heic,.heif,.gif,.bmp,image/jpeg,image/png,image/webp,image/heic,image/heif,image/gif,image/bmp"
        />
      </div>

      <div class="tool-options" id="toolOptions" style="display:none">
        <label class="opt-label" for="pageSize">Page size</label>
        <select id="pageSize" class="opt-select">
          <option value="a4" selected>A4</option>
          <option value="letter">Letter</option>
          <option value="legal">Legal</option>
        </select>
        <p class="opt-hint">Orientation is chosen per image (portrait vs landscape) based on width and height.</p>
      </div>

      <div id="thumbPanel" class="thumb-panel" style="display:none">
        <p class="thumb-title">Order (drag to reorder)</p>
        <ul id="thumbList" class="thumb-list"></ul>
        <button type="button" class="btn btn-lg" id="buildBtn">Create PDF</button>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">Result:</div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <article class="i2pdf-edu" aria-label="Guide: combining images into a PDF">
    <div class="container i2pdf-edu-inner">
      <section class="i2pdf-edu-block">
        <h2 id="when-image-to-pdf">When to combine images into a PDF</h2>
        <p>
          Sharing many separate photos by email is noisy; one PDF keeps the sequence and opens on any device. Freelancers
          merge receipts; teachers bundle worksheet scans. The important part is <strong>order</strong>: our thumbnail list
          is drag-sortable so page 1 in the PDF is exactly the order you set before clicking <strong>Create PDF</strong>.
        </p>
        <p>
          Default download is <code>images-combined.pdf</code>. You can rename the file after saving. For the reverse
          workflow — extracting pages as images — use{' '}
          <a href="/pdf/pdf-to-jpg/">PDF to JPG</a>.
        </p>
      </section>

      <section class="i2pdf-edu-block">
        <h2 id="formats-handling">How each image format is handled</h2>
        <div class="i2pdf-table-wrap">
          <table class="i2pdf-compare-table">
            <caption class="sr-only">Image formats and how Image to PDF processes them</caption>
            <thead>
              <tr>
                <th scope="col">Format</th>
                <th scope="col">In the PDF</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>JPG / JPEG</td>
                <td>Embedded directly as JPEG</td>
              </tr>
              <tr>
                <td>PNG</td>
                <td>Embedded as PNG; transparency flattened on white</td>
              </tr>
              <tr>
                <td>HEIC / HEIF</td>
                <td>Converted to JPEG in-browser (heic2any), then embedded</td>
              </tr>
              <tr>
                <td>WebP, GIF, BMP</td>
                <td>Decoded to pixels, written as JPEG inside the PDF; animated GIF uses first frame only</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          Wide panoramas <strong>scale to fit</strong> the selected paper size (A4, Letter, or Legal) while keeping aspect
          ratio — the page orientation (portrait vs landscape) follows whether each image is wider or taller than tall.
        </p>
      </section>

      <section class="i2pdf-edu-block">
        <h2 id="privacy-offline">Privacy and offline use</h2>
        <p>
          Processing uses <strong>pdf-lib</strong> and your browser’s canvas — nothing is sent to DoItSwift. After the page
          loads, you can disconnect from the internet and still build PDFs from local images. For more on keeping PDF work
          private, read{' '}
          <a href="/blog/how-to-compress-pdf/">how to compress a PDF</a> (browser-based tools vs upload sites).
        </p>
      </section>
    </div>
  </article>

  <section class="i2pdf-related" aria-label="Related PDF and image tools">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="i2pdf-related-grid">
        <li><a href="/pdf/pdf-to-jpg/">PDF to JPG</a></li>
        <li><a href="/pdf/jpg-to-pdf/">JPG to PDF</a></li>
        <li><a href="/pdf/compress-pdf/">Compress PDF</a></li>
        <li><a href="/pdf/merge-pdf/">Merge PDF</a></li>
        <li><a href="/pdf/split-pdf/">Split PDF</a></li>
        <li><a href="/image/heic-to-jpg/">HEIC to JPG</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="i2pdf-related-grid i2pdf-related-guides">
        <li><a href="/blog/how-to-merge-pdf/">How to merge PDFs</a></li>
        <li><a href="/blog/how-to-compress-pdf/">How to compress a PDF</a></li>
        <li><a href="/blog/how-to-convert-pdf-to-jpg/">How to convert PDF to JPG</a></li>
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Is Image to PDF free and unlimited?</h4>
          <p>Yes. Build as many PDFs as you need locally with no signup, watermarks, or usage quotas.</p>
        </div>
        <div class="faq-item">
          <h4>Are my images uploaded to DoItSwift servers?</h4>
          <p>No. pdf-lib and image decoding run in your browser tab only; files never leave your device.</p>
        </div>
        <div class="faq-item">
          <h4>How does PNG transparency work in the PDF?</h4>
          <p>
            PNG files embed in the PDF with transparency flattened onto a white background because PDF pages are opaque
            rectangles.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I mix JPG, PNG, WebP, and HEIC in one PDF?</h4>
          <p>Yes. Add any supported types in one batch, reorder thumbnails, then create a single combined PDF.</p>
        </div>
        <div class="faq-item">
          <h4>How are HEIC or HEIF photos from an iPhone handled?</h4>
          <p>
            HEIC is converted to JPEG in your browser using heic2any, then embedded — same privacy as our{' '}
            <a href="/image/heic-to-jpg/">HEIC to JPG</a> tool, with no server upload.
          </p>
        </div>
        <div class="faq-item">
          <h4>How is WebP handled?</h4>
          <p>WebP is decoded to pixels and saved as a JPEG representation inside the PDF for compatibility.</p>
        </div>
        <div class="faq-item">
          <h4>Can portrait and landscape pages appear in the same PDF?</h4>
          <p>
            Yes. Each page orientation follows that image&apos;s dimensions — wider images use a landscape page, taller
            images use portrait, within your chosen paper size.
          </p>
        </div>
        <div class="faq-item">
          <h4>Which page sizes can I choose?</h4>
          <p>
            Select A4, US Letter, or US Legal before building the PDF. Images scale to fit within the page while keeping
            aspect ratio.
          </p>
        </div>
        <div class="faq-item">
          <h4>What about GIF, BMP, or animated GIFs?</h4>
          <p>GIF and BMP are rasterized to JPEG for embedding. Animated GIFs use the first frame only.</p>
        </div>
        <div class="faq-item">
          <h4>Is there a monthly limit or account required?</h4>
          <p>No accounts, no quotas, and no premium tier.</p>
        </div>
      </div>
      <p class="faq-filename-note">
        <strong>Download name:</strong> the default file is <code>images-combined.pdf</code> — rename after saving if you
        need a different name.
      </p>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const PDFLibGlobal = typeof PDFLib !== 'undefined' ? PDFLib : window.PDFLib;
      if (!PDFLibGlobal) return;
      const { PDFDocument } = PDFLibGlobal;

      const SIZES = {
        a4: { w: 595.28, h: 841.89 },
        letter: { w: 612, h: 792 },
        legal: { w: 612, h: 1008 },
      };

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const thumbPanel = document.getElementById('thumbPanel');
      const thumbList = document.getElementById('thumbList');
      const buildBtn = document.getElementById('buildBtn');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const toolOptions = document.getElementById('toolOptions');
      const pageSizeEl = document.getElementById('pageSize');

      let items = [];
      function uid() {
        return 'x' + Math.random().toString(36).slice(2, 9);
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        void addFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        void addFiles(fs);
      });

      async function bitmapToJpegBytes(file) {
        const bmp = await createImageBitmap(file);
        const canvas = document.createElement('canvas');
        canvas.width = bmp.width;
        canvas.height = bmp.height;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#fff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(bmp, 0, 0);
        const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', 0.92));
        return new Uint8Array(await blob.arrayBuffer());
      }

      async function fileToEmbeddedBytes(file) {
        const type = file.type || '';
        const name = file.name.toLowerCase();
        if (name.endsWith('.heic') || name.endsWith('.heif') || type.includes('heic') || type.includes('heif')) {
          if (typeof heic2any === 'undefined') throw new Error('HEIC library not loaded — refresh the page.');
          const outBlob = await heic2any({ blob: file, toType: 'image/jpeg', quality: 0.92 });
          const finalBlob = Array.isArray(outBlob) ? outBlob[0] : outBlob;
          const bytes = new Uint8Array(await finalBlob.arrayBuffer());
          return { kind: 'jpg', bytes: bytes, previewBlob: finalBlob };
        }
        if (type.includes('jpeg') || /\.jpe?g$/i.test(name)) {
          return { kind: 'jpg', bytes: new Uint8Array(await file.arrayBuffer()) };
        }
        if (type.includes('png') || name.endsWith('.png')) {
          return { kind: 'png', bytes: new Uint8Array(await file.arrayBuffer()) };
        }
        if (type.includes('webp') || name.endsWith('.webp')) {
          const bytes = await bitmapToJpegBytes(file);
          return { kind: 'jpg', bytes: bytes };
        }
        if (type.includes('gif') || name.endsWith('.gif') || type.includes('bmp') || name.endsWith('.bmp')) {
          const bytes = await bitmapToJpegBytes(file);
          return { kind: 'jpg', bytes: bytes };
        }
        throw new Error('Unsupported image type');
      }

      async function addFiles(files) {
        const ok = files.filter((f) => {
          const n = f.name.toLowerCase();
          return f.type.startsWith('image/') || /\.(jpe?g|png|webp|heic|heif|gif|bmp)$/i.test(n);
        });
        if (!ok.length) {
          alert('Please add supported images: JPG, PNG, WebP, HEIC, GIF, or BMP.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Loading images…';
        for (const file of ok) {
          try {
            const emb = await fileToEmbeddedBytes(file);
            let previewUrl;
            if (emb.previewBlob) {
              previewUrl = URL.createObjectURL(emb.previewBlob);
              delete emb.previewBlob;
            } else {
              previewUrl = URL.createObjectURL(file);
            }
            items.push({ id: uid(), file, name: file.name, emb, preview: previewUrl });
          } catch (err) {
            alert(file.name + ': ' + (err.message || err));
          }
        }
        toolOptions.style.display = 'block';
        thumbPanel.style.display = 'block';
        banner.className = 'banner banner-success';
        bannerText.textContent = '✓ ' + items.length + ' image(s) — reorder if needed, then Create PDF';
        renderThumbs();
      }

      function renderThumbs() {
        thumbList.innerHTML = '';
        items.forEach((it, index) => {
          const li = document.createElement('li');
          li.className = 'thumb-row';
          li.draggable = true;
          li.dataset.id = it.id;
          li.innerHTML =
            '<span class="thumb-grip">⋮⋮</span><img class="thumb-img" src="' +
            it.preview +
            '" alt=""/><span class="thumb-name">' +
            escapeHtml(it.name) +
            '</span><button type="button" class="btn-text thumb-remove" data-id="' +
            it.id +
            '">Remove</button>';
          li.addEventListener('dragstart', (e) => {
            e.dataTransfer.setData('text/plain', it.id);
            li.classList.add('dragging');
          });
          li.addEventListener('dragend', () => li.classList.remove('dragging'));
          li.addEventListener('dragover', (e) => e.preventDefault());
          li.addEventListener('drop', (e) => {
            e.preventDefault();
            const fromId = e.dataTransfer.getData('text/plain');
            const toId = it.id;
            if (!fromId || fromId === toId) return;
            const fromIx = items.findIndex((x) => x.id === fromId);
            const toIx = items.findIndex((x) => x.id === toId);
            if (fromIx < 0 || toIx < 0) return;
            const [mv] = items.splice(fromIx, 1);
            items.splice(toIx, 0, mv);
            renderThumbs();
          });
          thumbList.appendChild(li);
        });
        thumbList.querySelectorAll('.thumb-remove').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const rem = items.find((x) => x.id === id);
            if (rem && rem.preview) URL.revokeObjectURL(rem.preview);
            items = items.filter((x) => x.id !== id);
            if (!items.length) {
              thumbPanel.style.display = 'none';
              toolOptions.style.display = 'none';
              banner.style.display = 'none';
            } else renderThumbs();
          });
        });
      }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      buildBtn.addEventListener('click', async () => {
        if (!items.length) return;
        const sizeKey = pageSizeEl.value;
        const base = SIZES[sizeKey] || SIZES.a4;
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Building PDF…';
        results.innerHTML = '';
        try {
          const pdfDoc = await PDFDocument.create();
          for (const it of items) {
            let img;
            if (it.emb.kind === 'jpg') img = await pdfDoc.embedJpg(it.emb.bytes);
            else img = await pdfDoc.embedPng(it.emb.bytes);
            const w = img.width;
            const h = img.height;
            const landscape = w > h;
            let pageW = base.w;
            let pageH = base.h;
            if (landscape) {
              pageW = base.h;
              pageH = base.w;
            }
            const page = pdfDoc.addPage([pageW, pageH]);
            const scale = Math.min(pageW / w, pageH / h);
            const dw = w * scale;
            const dh = h * scale;
            page.drawImage(img, {
              x: (pageW - dw) / 2,
              y: (pageH - dh) / 2,
              width: dw,
              height: dh,
            });
          }
          const bytes = await pdfDoc.save();
          const blob = new Blob([bytes], { type: 'application/pdf' });
          const url = URL.createObjectURL(blob);
          resultsHeader.style.display = 'block';
          const row = document.createElement('div');
          row.className = 'file-item';
          row.innerHTML =
            '<div class="file-item-main"><div class="file-thumb">📑</div><div class="file-info">' +
            '<div class="file-name">images-combined.pdf</div>' +
            '<div class="file-status done">' +
            (bytes.byteLength / 1024).toFixed(1) +
            ' KB</div></div>' +
            '<div class="file-actions-col"><a class="btn" href="' +
            url +
            '" download="images-combined.pdf">Download</a></div></div>';
          results.appendChild(row);
          actions.style.display = 'flex';
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ PDF ready';
        } catch (err) {
          alert('Failed: ' + (err.message || err));
          bannerText.textContent = 'Error: ' + (err.message || 'failed');
        }
      });

      document.getElementById('clearAll').addEventListener('click', () => {
        items.forEach((it) => {
          if (it.preview) URL.revokeObjectURL(it.preview);
        });
        items = [];
        thumbList.innerHTML = '';
        thumbPanel.style.display = 'none';
        toolOptions.style.display = 'none';
        results.innerHTML = '';
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });
    });
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
