---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const pageDescription =
  'Split a PDF in your browser: extract every page as its own file, or export one PDF for a page range. PDF.js thumbnails, pdf-lib splitting, optional ZIP. Private — no upload. 50 MB warning on very large files.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'DoItSwift Split PDF',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web browser',
      browserRequirements: 'Requires JavaScript, pdf-lib, PDF.js for previews, and JSZip for batch ZIP (loaded from CDN)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description:
        'Split one PDF per session using pdf-lib in the browser. Choose to export each page as a separate PDF or a single PDF for a contiguous page range. Thumbnail previews via PDF.js. Optional ZIP of per-page PDFs. No server upload.',
      featureList: [
        'Single input PDF per session — page-focused splitting with clear numbering',
        'Mode: every page as its own PDF, or one PDF for a start–end page range (inclusive)',
        'Thumbnail strip previews up to 48 pages; all pages remain exportable when the document is longer',
        'Page numbers are 1-based in the UI and range fields',
        'Output names: Filename-page-N.pdf per page, or Filename-pages-X-Y.pdf for range; ZIP named Filename-split-pages.zip for per-page export',
        'Optional confirmation when the source PDF exceeds about 50 MB',
        'Client-side processing with pdf-lib — PDF bytes are not uploaded to DoItSwift',
        'Password-protected PDFs may fail unless unlocked first',
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is Split PDF free and unlimited?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Split as many documents as you need with no signup, watermarks, or usage quotas. Each run uses one source PDF at a time.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are my PDFs uploaded to DoItSwift servers?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. PDF.js renders thumbnails and pdf-lib performs the split in your browser tab only.',
          },
        },
        {
          '@type': 'Question',
          name: 'Why can I only load one PDF at a time?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Splitting is page-focused; multiple sources would confuse numbering. Combine files first with Merge PDF if you need one document to split.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are page numbers 1-based?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes — the first page is 1, matching the labels on thumbnails and the range inputs.',
          },
        },
        {
          '@type': 'Question',
          name: 'What is the difference between each page and range mode?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Each page mode creates one PDF per page and can download all as a ZIP. Range mode creates a single PDF containing only pages from the start through end numbers you enter, inclusive.',
          },
        },
        {
          '@type': 'Question',
          name: 'Do password-protected or encrypted PDFs work?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'They may fail to load. Unlock with the correct password using DoItSwift Unlock PDF, then split the unlocked file.',
          },
        },
        {
          '@type': 'Question',
          name: 'What about very large PDFs?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The tool warns above about 50 MB. Huge files may take time or stress memory — close other tabs and wait for processing to finish.',
          },
        },
        {
          '@type': 'Question',
          name: 'Why do I only see 48 thumbnails?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Previews show the first 48 pages for performance. All pages can still be split or included in range export when the PDF has more than 48 pages.',
          },
        },
        {
          '@type': 'Question',
          name: 'What are the output filenames?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Per-page exports use the original name stem plus -page- and the page number. Range export uses the stem plus -pages- and the start and end numbers. Per-page mode can also download a ZIP named with the stem plus -split-pages.zip.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is there a monthly limit or account required?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No accounts, no quotas, and no premium tier.',
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'PDF Tools',
          item: new URL('/pdf/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Split PDF',
          item: canonical,
        },
      ],
    },
  ],
};
---

<MainLayout
  title="Split PDF — Extract Pages or Range, Thumbnails, ZIP | DoItSwift"
  description={pageDescription}
  keywords="split pdf, extract pdf pages, pdf page range, separate pdf pages, split pdf online free, browser split pdf, pdf.js split, extract pdf zip, one pdf per page, private split pdf, no upload split pdf"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js" is:inline></script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>Split PDF</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Split PDF</h1>
      <p class="subtitle">
        Split one PDF with pdf-lib — <strong>every page as its own file</strong> (ZIP optional) or <strong>one export for a
        page range</strong>. PDF.js thumbnails (first 48 shown; all pages export). Local only; no upload.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">✂️</div>
        <div class="dropzone-text">Drop one PDF here or click to browse</div>
        <div class="dropzone-sub">Single PDF only — page previews appear after load</div>
        <input type="file" id="fileInput" accept=".pdf,application/pdf" />
      </div>

      <div id="splitControls" class="split-controls" style="display:none">
        <fieldset class="mode-fieldset">
          <legend>Mode</legend>
          <label><input type="radio" name="splitMode" value="each" checked /> Extract every page as a separate PDF</label>
          <label><input type="radio" name="splitMode" value="range" /> Extract a range of pages (one PDF)</label>
        </fieldset>
        <div id="rangeInputs" class="range-inputs" style="display:none">
          <label>Start page <input type="number" id="rangeStart" min="1" value="1" /></label>
          <label>End page <input type="number" id="rangeEnd" min="1" value="1" /></label>
        </div>
        <div id="thumbStrip" class="thumb-strip"></div>
        <button type="button" class="btn btn-lg" id="exportBtn">Export</button>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">Download:</div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadZip" style="display:none">⬇ Download all as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <article class="split-edu" aria-label="Guide: splitting PDF files">
    <div class="container split-edu-inner">
      <section class="split-edu-block">
        <h2 id="split-vs-merge">Split vs merge: when to use each</h2>
        <p>
          <strong>Split</strong> when you need one chapter, a single signed page, or smaller attachments. <strong>Merge</strong>{' '}
          when several files should read as one. Both tools run locally: thumbnails use <strong>PDF.js</strong>; cutting
          pages uses <strong>pdf-lib</strong>, so text stays selectable on born-digital PDFs (scanned pages behave like images
          inside the file).
        </p>
        <p>
          For a full guide, see <a href="/blog/how-to-split-pdf/">how to split a PDF</a> on the DoItSwift blog.
        </p>
      </section>

      <section class="split-edu-block">
        <h2 id="split-modes">Two ways to export</h2>
        <div class="split-table-wrap">
          <table class="split-compare-table">
            <caption class="sr-only">Split PDF export modes</caption>
            <thead>
              <tr>
                <th scope="col">Mode</th>
                <th scope="col">You get</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Every page as its own PDF</td>
                <td>One file per page; download individually or as a ZIP archive</td>
              </tr>
              <tr>
                <td>Range of pages</td>
                <td>One PDF containing pages from start through end (inclusive)</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          Need the opposite later? Use <a href="/pdf/merge-pdf/">Merge PDF</a> to recombine. To shrink files, use{' '}
          <a href="/pdf/compress-pdf/">Compress PDF</a>.
        </p>
      </section>

      <section class="split-edu-block">
        <h2 id="filenames">Output filenames</h2>
        <p>
          Per-page files look like <code>MyDoc-page-1.pdf</code>. A range export looks like{' '}
          <code>MyDoc-pages-3-10.pdf</code>. In per-page mode, <strong>Download all as ZIP</strong> uses{' '}
          <code>MyDoc-split-pages.zip</code> (based on your file name stem).
        </p>
      </section>
    </div>
  </article>

  <section class="split-related" aria-label="Related PDF tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="split-related-grid">
        <li><a href="/pdf/merge-pdf/">Merge PDF</a></li>
        <li><a href="/pdf/compress-pdf/">Compress PDF</a></li>
        <li><a href="/pdf/unlock-pdf/">Unlock PDF</a></li>
        <li><a href="/pdf/pdf-to-jpg/">PDF to JPG</a></li>
        <li><a href="/pdf/image-to-pdf/">Image to PDF</a></li>
        <li><a href="/pdf/jpg-to-pdf/">JPG to PDF</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="split-related-grid split-related-guides">
        <li><a href="/blog/how-to-split-pdf/">How to split a PDF</a></li>
        <li><a href="/blog/how-to-merge-pdf/">How to merge PDFs</a></li>
        <li><a href="/blog/how-to-compress-pdf/">How to compress a PDF</a></li>
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Is Split PDF free and unlimited?</h4>
          <p>Yes. Split as many documents as you need with no signup, watermarks, or usage quotas. Each run uses one source PDF.</p>
        </div>
        <div class="faq-item">
          <h4>Are my PDFs uploaded to DoItSwift servers?</h4>
          <p>No. PDF.js renders thumbnails and pdf-lib performs the split in your browser tab only.</p>
        </div>
        <div class="faq-item">
          <h4>Why can I only load one PDF at a time?</h4>
          <p>
            Splitting is page-focused; multiple sources would confuse numbering. Combine files first with{' '}
            <a href="/pdf/merge-pdf/">Merge PDF</a> if you need one document to split.
          </p>
        </div>
        <div class="faq-item">
          <h4>Are page numbers 1-based?</h4>
          <p>Yes — the first page is 1, matching the labels on thumbnails and the range inputs.</p>
        </div>
        <div class="faq-item">
          <h4>What is the difference between each page and range mode?</h4>
          <p>
            Each page mode creates one PDF per page and can download all as a ZIP. Range mode creates a single PDF containing
            only pages from the start through end numbers you enter, inclusive.
          </p>
        </div>
        <div class="faq-item">
          <h4>Do password-protected or encrypted PDFs work?</h4>
          <p>
            They may fail to load. Unlock with the correct password using <a href="/pdf/unlock-pdf/">Unlock PDF</a>, then split
            the unlocked file.
          </p>
        </div>
        <div class="faq-item">
          <h4>What about very large PDFs?</h4>
          <p>
            The tool warns above about 50 MB. Huge files may take time or stress memory — close other tabs and wait for
            processing to finish.
          </p>
        </div>
        <div class="faq-item">
          <h4>Why do I only see 48 thumbnails?</h4>
          <p>Previews show the first 48 pages for performance. All pages can still be split or included in range export.</p>
        </div>
        <div class="faq-item">
          <h4>What are the output filenames?</h4>
          <p>
            Per-page exports use the original name stem plus <code>-page-</code> and the page number. Range export uses the
            stem plus <code>-pages-</code> and start–end. Per-page mode can also download a ZIP named with the stem plus{' '}
            <code>-split-pages.zip</code>.
          </p>
        </div>
        <div class="faq-item">
          <h4>Is there a monthly limit or account required?</h4>
          <p>No accounts, no quotas, and no premium tier.</p>
        </div>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    import * as pdfjsLib from 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs';
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';
    window.__pdfjsSplit = pdfjsLib;
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const PDFLibGlobal = typeof PDFLib !== 'undefined' ? PDFLib : window.PDFLib;
      if (!PDFLibGlobal) {
        console.error('pdf-lib missing');
        return;
      }
      const { PDFDocument } = PDFLibGlobal;

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const splitControls = document.getElementById('splitControls');
      const thumbStrip = document.getElementById('thumbStrip');
      const exportBtn = document.getElementById('exportBtn');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const rangeInputs = document.getElementById('rangeInputs');
      const downloadZip = document.getElementById('downloadZip');
      const rangeStart = document.getElementById('rangeStart');
      const rangeEnd = document.getElementById('rangeEnd');

      let pdfBuffer = null;
      let pdfName = 'document';
      let numPages = 0;
      let outputBlobs = [];

      document.querySelectorAll('input[name="splitMode"]').forEach((r) => {
        r.addEventListener('change', () => {
          rangeInputs.style.display = r.value === 'range' ? 'flex' : 'none';
          downloadZip.style.display = r.value === 'each' ? 'inline-flex' : 'none';
        });
      });

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        const f = e.dataTransfer.files[0];
        if (f) void loadPdf(f);
      });
      fileInput.addEventListener('change', (e) => {
        const f = e.target.files[0];
        e.target.value = '';
        if (f) void loadPdf(f);
      });

      async function waitPdfJs() {
        for (let i = 0; i < 60; i++) {
          if (window.__pdfjsSplit) return window.__pdfjsSplit;
          await new Promise((r) => setTimeout(r, 50));
        }
        alert('PDF engine still loading. Wait and retry, or refresh.');
        return null;
      }

      async function loadPdf(file) {
        const pj = await waitPdfJs();
        if (!pj) return;
        if (file.size > 50 * 1024 * 1024) {
          if (!confirm('This PDF is over 50MB. Processing may take a while or fail on low memory. Continue?')) return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Loading PDF… This may take a moment for large files.';
        pdfBuffer = await file.arrayBuffer();
        pdfName = file.name.replace(/\.pdf$/i, '') || 'document';
        const pdf = await pj.getDocument({ data: pdfBuffer.slice(0) }).promise;
        numPages = pdf.numPages;
        rangeStart.min = 1;
        rangeEnd.min = 1;
        rangeStart.max = numPages;
        rangeEnd.max = numPages;
        rangeStart.value = 1;
        rangeEnd.value = numPages;
        thumbStrip.innerHTML = '';
        const maxThumb = Math.min(numPages, 48);
        for (let i = 1; i <= maxThumb; i++) {
          const page = await pdf.getPage(i);
          const vp = page.getViewport({ scale: 0.2 });
          const canvas = document.createElement('canvas');
          canvas.width = vp.width;
          canvas.height = vp.height;
          await page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise;
          const wrap = document.createElement('div');
          wrap.className = 'thumb-cell';
          wrap.innerHTML = '<span class="thumb-label">' + i + '</span>';
          wrap.appendChild(canvas);
          thumbStrip.appendChild(wrap);
        }
        if (numPages > 48) {
          const note = document.createElement('p');
          note.className = 'thumb-note';
          note.textContent = 'Showing first 48 thumbnail previews. All ' + numPages + ' pages can still be exported.';
          thumbStrip.appendChild(note);
        }
        splitControls.style.display = 'block';
        banner.className = 'banner banner-success';
        bannerText.textContent = '✓ ' + numPages + ' page(s) loaded — choose mode and export';
      }

      exportBtn.addEventListener('click', async () => {
        if (!pdfBuffer) return;
        const mode = document.querySelector('input[name="splitMode"]:checked').value;
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Splitting…';
        results.innerHTML = '';
        outputBlobs = [];
        try {
          const srcDoc = await PDFDocument.load(pdfBuffer, { ignoreEncryption: true });
          if (mode === 'each') {
            for (let i = 0; i < numPages; i++) {
              const out = await PDFDocument.create();
              const [copied] = await out.copyPages(srcDoc, [i]);
              out.addPage(copied);
              const bytes = await out.save();
              const name = pdfName + '-page-' + (i + 1) + '.pdf';
              outputBlobs.push({ name, blob: new Blob([bytes], { type: 'application/pdf' }) });
            }
          } else {
            const start = Math.max(1, parseInt(rangeStart.value, 10) || 1);
            const end = Math.min(numPages, parseInt(rangeEnd.value, 10) || numPages);
            if (start > end) {
              alert('Start page must be ≤ end page.');
              return;
            }
            const indices = [];
            for (let p = start - 1; p <= end - 1; p++) indices.push(p);
            const out = await PDFDocument.create();
            const copied = await out.copyPages(srcDoc, indices);
            copied.forEach((pg) => out.addPage(pg));
            const bytes = await out.save();
            outputBlobs.push({
              name: pdfName + '-pages-' + start + '-' + end + '.pdf',
              blob: new Blob([bytes], { type: 'application/pdf' }),
            });
          }
          resultsHeader.style.display = 'block';
          outputBlobs.forEach((o) => {
            const url = URL.createObjectURL(o.blob);
            const row = document.createElement('div');
            row.className = 'file-item';
            row.innerHTML =
              '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info"><div class="file-name">' +
              escapeHtml(o.name) +
              '</div></div><div class="file-actions-col"><a class="btn" href="' +
              url +
              '" download="' +
              escapeHtml(o.name) +
              '">Download</a></div></div>';
            results.appendChild(row);
          });
          actions.style.display = 'flex';
          downloadZip.style.display = mode === 'each' ? 'inline-flex' : 'none';
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ Ready';
        } catch (err) {
          alert('Split failed: ' + (err.message || err));
          bannerText.textContent = 'Error';
        }
      });

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      downloadZip.addEventListener('click', async () => {
        if (typeof JSZip === 'undefined' || !outputBlobs.length) return;
        const zip = new JSZip();
        outputBlobs.forEach((o) => zip.file(o.name, o.blob));
        const blob = await zip.generateAsync({ type: 'blob' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = pdfName + '-split-pages.zip';
        a.click();
      });

      document.getElementById('clearAll').addEventListener('click', () => {
        pdfBuffer = null;
        numPages = 0;
        thumbStrip.innerHTML = '';
        splitControls.style.display = 'none';
        results.innerHTML = '';
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
        outputBlobs = [];
      });
    });
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 820px;
    }
    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }
    .hero {
      padding: 40px 0 20px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 680px;
      margin: 0 auto 28px;
    }
    .subtitle strong {
      color: var(--text);
      font-weight: 700;
    }
    .converter-section {
      padding: 30px 0;
    }
    .converter-section .container {
      max-width: 820px;
    }
    .banner {
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      font-weight: 600;
      text-align: center;
    }
    .banner-info {
      background: #dbeafe;
      color: #1e40af;
    }
    .banner-success {
      background: #d1fae5;
      color: #065f46;
    }
    [data-theme='dark'] .banner-info {
      background: rgba(30, 64, 175, 0.2);
      color: #93c5fd;
    }
    [data-theme='dark'] .banner-success {
      background: rgba(6, 95, 70, 0.2);
      color: #6ee7b7;
    }
    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 70px 20px;
      text-align: center;
      cursor: pointer;
      box-shadow: var(--shadow);
    }
    .dropzone:hover,
    .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    .dropzone-icon {
      font-size: 56px;
      margin-bottom: 14px;
    }
    .dropzone-text {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .dropzone-sub {
      font-size: 14px;
      color: var(--text-muted);
    }
    #fileInput {
      display: none;
    }
    .split-controls {
      margin-top: 16px;
    }
    .mode-fieldset {
      border: 1px solid var(--border);
