---
import MainLayout from '../../layouts/MainLayout.astro';

const tools = [
  { href: '/pdf/pdf-to-jpg/', icon: '🖼️', title: 'PDF to JPG', desc: 'Export every page as a JPEG image' },
  { href: '/pdf/image-to-pdf/', icon: '📑', title: 'Image to PDF', desc: 'Combine JPG, PNG, WebP, HEIC & more' },
  { href: '/pdf/jpg-to-pdf/', icon: '📷', title: 'JPG to PDF', desc: 'Turn JPEG photos into a PDF' },
  { href: '/pdf/merge-pdf/', icon: '➕', title: 'Merge PDFs', desc: 'Join multiple PDFs in order' },
  { href: '/pdf/split-pdf/', icon: '✂️', title: 'Split PDF', desc: 'Extract pages or ranges' },
  { href: '/pdf/compress-pdf/', icon: '🗜️', title: 'Compress PDF', desc: 'Shrink file size in your browser' },
  { href: '/pdf/unlock-pdf/', icon: '🔓', title: 'Unlock PDF', desc: 'Remove password with the correct key' },
];

const pageDescription =
  'Free browser-based PDF tools: merge, split, compress, PDF to JPG, image to PDF, JPG to PDF, unlock with password. pdf-lib and PDF.js — all run locally. No upload, no signup, batch and ZIP where supported.';

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Free Online PDF Tools',
  description: pageDescription,
  url: new URL(Astro.url.pathname, Astro.site).href,
  isPartOf: {
    '@type': 'WebSite',
    name: 'DoItSwift',
    url: new URL('/', Astro.site).href,
  },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: tools.length,
    itemListElement: tools.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: t.title,
      url: new URL(t.href, Astro.site).href,
      description: t.desc,
    })),
  },
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is there a file size limit for DoItSwift PDF tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'There is no fixed cap from DoItSwift — limits come from your device RAM and browser. PDFs above about 50 MB may take a noticeable time; very large files can fail on low-memory mobile browsers.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are my PDFs uploaded to DoItSwift?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'No. Tools load libraries from CDNs, but your document bytes stay in the browser unless you download a result. You can verify by going offline after the page loads.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I process multiple PDFs in one session?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes — merge, compress, PDF to JPG, unlock, and related flows support batches where the tool allows. Split focuses on one document at a time for clear page numbering. Image to PDF and JPG to PDF accept many images with reordering before export.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will PDF compression always make files smaller?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Usually, but not always. Light modes mostly re-save and strip metadata. Heavier modes may rasterize pages, trading smaller size against sharp text — pick the level that fits your document.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do DoItSwift PDF tools add watermarks?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Output is whatever the conversion produces — no DoItSwift branding on your files.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which browsers work best for PDF tools?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Latest Chrome, Edge, Firefox, or Safari on desktop. Mobile Safari and Chrome work for moderate file sizes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are these PDF tools free? Is there a monthly limit?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes, they are free to use with no signup. There are no monthly quotas, accounts, or premium tiers.',
      },
    },
    {
      '@type': 'Question',
      name: 'What if my PDF is password-protected?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Use Unlock PDF with the correct password first, then merge, split, compress, or convert as needed. DoItSwift does not crack forgotten passwords.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I export PDF pages as images?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes — use the PDF to JPG tool to export pages as JPEG images in your browser.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I create a PDF from photos or scans?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes. Image to PDF accepts many image formats with reorder; JPG to PDF is optimized for JPEG photo workflows.',
      },
    },
  ],
};

// Head JSON-LD only (slot="head"). FAQ answers match visible FAQ on this page.
const pdfHubBreadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://doitswift.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'PDF Tools',
      item: 'https://doitswift.com/pdf/',
    },
  ],
};

const pdfHubItemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Free Online PDF Tools',
  description:
    'Browser-based PDF utilities — merge, split, compress, convert, unlock. All processing happens locally with PDF-lib and PDF.js; files never leave your device.',
  numberOfItems: 7,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      url: 'https://doitswift.com/pdf/pdf-to-jpg/',
      name: 'PDF to JPG Converter',
    },
    {
      '@type': 'ListItem',
      position: 2,
      url: 'https://doitswift.com/pdf/image-to-pdf/',
      name: 'Image to PDF Converter',
    },
    {
      '@type': 'ListItem',
      position: 3,
      url: 'https://doitswift.com/pdf/jpg-to-pdf/',
      name: 'JPG to PDF Converter',
    },
    {
      '@type': 'ListItem',
      position: 4,
      url: 'https://doitswift.com/pdf/merge-pdf/',
      name: 'Merge PDFs',
    },
    {
      '@type': 'ListItem',
      position: 5,
      url: 'https://doitswift.com/pdf/split-pdf/',
      name: 'Split PDF',
    },
    {
      '@type': 'ListItem',
      position: 6,
      url: 'https://doitswift.com/pdf/compress-pdf/',
      name: 'Compress PDF',
    },
    {
      '@type': 'ListItem',
      position: 7,
      url: 'https://doitswift.com/pdf/unlock-pdf/',
      name: 'Unlock PDF',
    },
  ],
};

const pdfHubFaqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is there a file size limit?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'We do not impose a fixed cap — limits come from your device RAM and browser. PDFs above ~50MB may take a noticeable time to process; very large files can fail on low-memory mobile browsers.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are my PDFs uploaded to DoItSwift?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'No. Tools load PDF-lib and related code from CDNs, but your document bytes stay in the browser unless you choose to download the result. You can verify by going offline after the page loads.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I process multiple PDFs in one session?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Yes — merge, compress, and PDF-to-JPG support batches. Split focuses on one document at a time for clarity. JPG-to-PDF accepts many images at once with reordering before export.',
      },
    },
    {
      '@type': 'Question',
      name: 'Will compression always make files smaller?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Usually, but not always. “Light” modes mostly re-save and strip metadata. Heavier modes may rasterize pages, which trades smaller size against sharp text — pick the level that fits your document type.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do these tools add watermarks?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. Output is whatever the conversion produces — no DoItSwift branding on your files.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which browsers work best?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Latest Chrome, Edge, Firefox, or Safari on desktop. Mobile Safari and Chrome work for moderate file sizes.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are these PDF tools free? Is there a monthly limit?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — free to use with no signup. There are no monthly quotas, accounts, or premium tiers.',
      },
    },
    {
      '@type': 'Question',
      name: 'What if my PDF is password-protected?',
      acceptedAnswer: {
        '@type': 'Answer',
        text:
          'Use Unlock PDF with the correct password first, then merge, split, compress, or convert. DoItSwift does not recover forgotten passwords.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I export PDF pages as images?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — PDF to JPG exports pages as JPEG files in your browser.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I create a PDF from photos or scans?',
      acceptedAnswer: {
