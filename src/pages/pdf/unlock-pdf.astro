      margin-bottom: 20px;
    }

    .unlock-edu {
      padding: 40px 0 16px;
    }
    .unlock-edu-inner {
      max-width: 760px;
    }
    .unlock-edu-block {
      margin-bottom: 2.5rem;
    }
    .unlock-edu-block:last-child {
      margin-bottom: 0;
    }
    .unlock-edu h2 {
      font-size: clamp(1.35rem, 2.5vw, 1.55rem);
      line-height: 1.3;
      margin: 0 0 1rem;
      color: var(--text);
    }
    .unlock-edu p {
      font-size: 16px;
      line-height: 1.75;
      color: var(--text);
      margin: 0 0 1rem;
    }
    .unlock-edu a {
      color: var(--blue);
