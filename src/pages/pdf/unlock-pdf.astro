      font-weight: 700;
    }
    .hero-code {
      font-family: ui-monospace, 'Cascadia Code', 'Courier New', monospace;
      font-size: 0.88em;
      padding: 0.12em 0.35em;
      background: var(--gray-100);
      border-radius: 4px;
      color: var(--text);
    }
    [data-theme='dark'] .hero-code {
      background: rgba(255, 255, 255, 0.1);
    }
