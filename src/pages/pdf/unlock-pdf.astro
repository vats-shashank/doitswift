---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const pageDescription =
  'Remove PDF open-password protection when you know the password — pdf-lib in your browser, batch supported, output stem-unlocked.pdf. Does not crack encryption. Private: files never upload. Legal use only.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'DoItSwift Unlock PDF',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web browser',
      browserRequirements: 'Requires JavaScript and pdf-lib (loaded from CDN)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description:
        'Unlock password-protected PDFs locally with pdf-lib by entering the correct open password. Loads each file without a password first; if encryption requires it, applies the password you supply. Copies all pages into a new unencrypted PDF for download. Same password is used across a batch. Does not crack, guess, or bypass encryption.',
      featureList: [
        'Requires the correct password for encrypted PDFs — no password cracking or bypass',
        'Batch multiple PDFs; one password field applies to files that need decryption',
        'Unencrypted PDFs load without a password and copy through to an unlocked-style export',
        'Rebuilds each document by copying pages into a new PDF and saving without encryption',
        'Download names use the original filename stem plus -unlocked.pdf',
        'Shows per-file success or errors (wrong password, needs password, parse errors)',
        '100% client-side processing — PDF bytes are not uploaded to DoItSwift',
        'Intended only for PDFs you own or are authorized to modify',
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Can this unlock PDFs without a password?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. You must enter the correct password for encrypted files. This tool does not crack, guess, or bypass PDF encryption.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are my PDFs uploaded to DoItSwift servers?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. pdf-lib runs entirely in your browser; your PDF bytes never leave your device.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is Unlock PDF free and unlimited?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Process as many files as your device can handle with no signup, watermarks, or usage quotas.',
          },
        },
        {
          '@type': 'Question',
          name: 'Why did unlock fail?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Common causes are an incorrect password, a corrupted PDF, or a format pdf-lib cannot parse. Check caps lock and try again. Unencrypted PDFs should process without a password.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I batch-unlock many PDFs?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Add multiple files. If they share the same password, enter it once; each encrypted file uses that password. Files that are not encrypted load without a password.',
          },
        },
        {
          '@type': 'Question',
          name: 'What happens if a PDF is not password-protected?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The tool loads it without a password and copies pages into a new PDF named with -unlocked.pdf like other outputs.',
          },
        },
        {
          '@type': 'Question',
          name: 'What is the output filename?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Each download uses the original name stem plus -unlocked.pdf.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does this remove editing or printing restrictions?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Re-saving to a new PDF typically produces a file you can open without the open password. Complex rights management may not be fully preserved — verify the output for your workflow.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is there a monthly limit or account required?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No accounts, no quotas, and no premium tier.',
          },
        },
        {
          '@type': 'Question',
          name: 'When is it legal to unlock a PDF?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Only when you own the document or have permission to remove protection — for example your own password, or a password your employer gave you for files you may modify. Do not use on documents you are not authorized to change.',
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'PDF Tools',
          item: new URL('/pdf/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'Unlock PDF',
          item: canonical,
        },
      ],
    },
  ],
};
---

<MainLayout
  title="Unlock PDF — Remove Password (Correct Key Required), Browser & Private | DoItSwift"
  description={pageDescription}
  keywords="unlock pdf, remove pdf password, pdf decrypt with password, unprotect pdf browser, batch unlock pdf, pdf-lib unlock, private pdf unlock, no upload pdf password, cannot crack pdf, legal unlock pdf"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js" is:inline></script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>Unlock PDF</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>Unlock PDF</h1>
      <p class="subtitle">
        Enter the <strong>correct open password</strong> — pdf-lib rebuilds each file locally as <code class="hero-code">stem-unlocked.pdf</code>.
        No cracking, no upload. Batch supported with one shared password for locked files.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Requires correct password</span>
        <span><span class="check">✓</span> No upload</span>
        <span><span class="check">✓</span> Batch files</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div class="legal-disclaimer" role="note">
        <strong>⚠️ Legal use only.</strong> You must own these PDFs or have permission to unlock them. This tool only works when you enter the
        <strong>correct password</strong> — it does <strong>not</strong> crack, guess, or bypass encryption. Use only on documents you are
        allowed to modify.
      </div>

      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">🔓</div>
        <div class="dropzone-text">Drop password-protected PDFs here or click to browse</div>
        <div class="dropzone-sub">Add one or more PDFs — enter the password, then unlock</div>
        <input type="file" id="fileInput" multiple accept=".pdf,application/pdf" />
      </div>

      <div id="unlockPanel" class="unlock-panel" style="display:none">
        <label class="pwd-label" for="pdfPassword">PDF password</label>
        <p class="pwd-hint">If your files share the same password, enter it once. If a file is not encrypted, it will unlock automatically.</p>
        <div class="pwd-row">
          <input type="password" id="pdfPassword" class="pwd-input" autocomplete="off" placeholder="Enter password" />
          <button type="button" class="btn btn-lg" id="unlockBtn">Unlock</button>
        </div>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">Unlocked files:</div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <article class="unlock-edu" aria-label="Guide: unlocking PDFs with a password">
    <div class="container unlock-edu-inner">
      <section class="unlock-edu-block">
        <h2 id="why-passwords">Why PDFs are password-protected</h2>
        <p>
          Organizations add passwords to limit casual access to contracts, payslips, or medical PDFs. Apps can set an{' '}
          <strong>open password</strong> (required to view) or permissions that restrict printing and editing. Legitimate reasons
          to remove protection include: you set the password and want a plain copy for archival; your employer gave you a
          known password and you need a workflow without prompts; or you are consolidating files you already have rights to
          modify.
        </p>
      </section>

      <section class="unlock-edu-block">
        <h2 id="how-tool-works">How this tool unlocks (no cracking)</h2>
        <p>
          <strong>pdf-lib</strong> tries to load each PDF without a password first. If the file is encrypted, you must supply
          the correct password — the same field is used for every file in your batch that needs it. The tool copies all pages
          into a <strong>new document</strong> and saves it <strong>without encryption</strong>, named{' '}
          <code>yourfile-unlocked.pdf</code>.
        </p>
        <p>
          If you <strong>forgot the password entirely</strong>, this page cannot help — we do not provide cracking. Request an
          unprotected copy from the sender or recreate from source files (Word, InDesign, scans). For privacy context on
          browser PDF tools, see <a href="/blog/how-to-compress-pdf/">how to compress a PDF</a> (local vs upload sites).
        </p>
      </section>

      <section class="unlock-edu-block">
        <h2 id="next-steps">After unlocking: merge, split, or compress</h2>
        <p>
          Once open, you can <a href="/pdf/merge-pdf/">merge PDFs</a>, <a href="/pdf/split-pdf/">split pages</a>, or{' '}
          <a href="/pdf/compress-pdf/">compress</a> — all with the same local-processing model on DoItSwift.
        </p>
      </section>
    </div>
  </article>

  <section class="unlock-related" aria-label="Related PDF tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="unlock-related-grid">
        <li><a href="/pdf/merge-pdf/">Merge PDF</a></li>
        <li><a href="/pdf/split-pdf/">Split PDF</a></li>
        <li><a href="/pdf/compress-pdf/">Compress PDF</a></li>
        <li><a href="/pdf/pdf-to-jpg/">PDF to JPG</a></li>
        <li><a href="/pdf/image-to-pdf/">Image to PDF</a></li>
        <li><a href="/pdf/jpg-to-pdf/">JPG to PDF</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="unlock-related-grid unlock-related-guides">
        <li><a href="/blog/how-to-compress-pdf/">How to compress a PDF</a></li>
        <li><a href="/blog/how-to-merge-pdf/">How to merge PDFs</a></li>
        <li><a href="/blog/how-to-split-pdf/">How to split a PDF</a></li>
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Can this unlock PDFs without a password?</h4>
          <p>
            <strong>No.</strong> You must enter the correct password for encrypted files. This tool does not crack or bypass PDF
            encryption. If you forgot the password entirely, recreate the file or ask the sender for an unprotected copy.
          </p>
        </div>
        <div class="faq-item">
          <h4>Are my PDFs uploaded to DoItSwift servers?</h4>
          <p>No. pdf-lib runs entirely in your browser; your PDF bytes never leave your device.</p>
        </div>
        <div class="faq-item">
          <h4>Is Unlock PDF free and unlimited?</h4>
          <p>Yes. Process as many files as your device can handle with no signup, watermarks, or usage quotas.</p>
        </div>
        <div class="faq-item">
          <h4>Why did unlock fail?</h4>
          <p>
            Usually an incorrect password, a corrupted PDF, or a format pdf-lib cannot parse. Double-check caps lock. Unencrypted
            PDFs should load without a password.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I batch-unlock many PDFs?</h4>
          <p>
            Yes. Add multiple files. If they share the same password, enter it once; each encrypted file uses that password.
          </p>
        </div>
        <div class="faq-item">
          <h4>What happens if a PDF is not password-protected?</h4>
          <p>
            The tool loads it without a password and copies pages into a new file named with <code>-unlocked.pdf</code>, same as
            other outputs.
          </p>
        </div>
        <div class="faq-item">
          <h4>What is the output filename?</h4>
          <p>Each download uses the original filename stem plus <code>-unlocked.pdf</code>.</p>
        </div>
        <div class="faq-item">
          <h4>Does this remove editing or printing restrictions?</h4>
          <p>
            Re-saving to a new PDF typically produces a file you can open without the open password. Complex rights management
            may not be fully preserved — verify the output for your workflow.
          </p>
        </div>
        <div class="faq-item">
          <h4>When is it legal to unlock a PDF?</h4>
          <p>
            Only when you own the document or have permission to remove protection — for example your own password, or a
            password your employer gave you for files you may modify. Do not use on documents you are not authorized to
            change.
          </p>
        </div>
        <div class="faq-item">
          <h4>Is there a monthly limit or account required?</h4>
          <p>No accounts, no quotas, and no premium tier.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const PDFLibGlobal = typeof PDFLib !== 'undefined' ? PDFLib : window.PDFLib;
      if (!PDFLibGlobal) return;
      const { PDFDocument } = PDFLibGlobal;

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const unlockPanel = document.getElementById('unlockPanel');
      const unlockBtn = document.getElementById('unlockBtn');
      const pdfPassword = document.getElementById('pdfPassword');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');

      let queue = [];

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        void addFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        void addFiles(fs);
      });

      async function addFiles(files) {
        const pdfs = files.filter((f) => f.type === 'application/pdf' || /\.pdf$/i.test(f.name));
        if (!pdfs.length) {
          alert('Please add PDF files only.');
          return;
        }
        queue = [];
        for (const file of pdfs) {
          const buffer = await file.arrayBuffer();
          queue.push({ name: file.name, buffer });
        }
        unlockPanel.style.display = 'block';
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '✓ ' + queue.length + ' file(s) added — enter password if required, then Unlock';
        pdfPassword.value = '';
        results.innerHTML = '';
        resultsHeader.style.display = 'none';
        actions.style.display = 'none';
      }

      unlockBtn.addEventListener('click', async () => {
        if (!queue.length) return;
        const pwd = pdfPassword.value;
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Unlocking…';
        results.innerHTML = '';
        resultsHeader.style.display = 'block';

        let anyOk = false;
        for (const item of queue) {
          const row = document.createElement('div');
          row.className = 'file-item';
          try {
            let src;
            try {
              src = await PDFDocument.load(item.buffer);
            } catch (e1) {
              if (!pwd) {
                row.innerHTML =
                  '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info"><div class="file-name">' +
                  escapeHtml(item.name) +
                  '</div><div class="file-status error">This PDF requires a password — enter it above and try again.</div></div></div>';
                results.appendChild(row);
                continue;
              }
              try {
                src = await PDFDocument.load(item.buffer, { password: pwd });
              } catch (e2) {
                row.innerHTML =
                  '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info"><div class="file-name">' +
                  escapeHtml(item.name) +
                  '</div><div class="file-status error">Incorrect password — please try again.</div></div></div>';
                results.appendChild(row);
                continue;
              }
            }
            const out = await PDFDocument.create();
            const copied = await out.copyPages(src, src.getPageIndices());
            copied.forEach((p) => out.addPage(p));
            const bytes = await out.save();
            const base = item.name.replace(/\.pdf$/i, '') || 'document';
            const outName = base + '-unlocked.pdf';
            const blob = new Blob([bytes], { type: 'application/pdf' });
            const url = URL.createObjectURL(blob);
            anyOk = true;
            row.innerHTML =
              '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info"><div class="file-name">' +
              escapeHtml(outName) +
              '</div><div class="file-status done">Ready</div></div><div class="file-actions-col"><a class="btn" href="' +
              url +
              '" download="' +
              escapeHtml(outName) +
              '">Download</a></div></div>';
            results.appendChild(row);
          } catch (err) {
            row.innerHTML =
              '<div class="file-item-main"><div class="file-thumb">📄</div><div class="file-info"><div class="file-name">' +
              escapeHtml(item.name) +
              '</div><div class="file-status error">' +
              escapeHtml(err.message || 'Could not process this PDF') +
              '</div></div></div>';
            results.appendChild(row);
          }
        }

        actions.style.display = 'flex';
        if (anyOk) {
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ Done — download unlocked PDFs below';
        } else {
          banner.className = 'banner banner-info';
          bannerText.textContent = 'No successful unlocks — check password or file integrity.';
        }
      });

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        queue = [];
        unlockPanel.style.display = 'none';
        results.innerHTML = '';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
        actions.style.display = 'none';
        pdfPassword.value = '';
      });
    });
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 820px;
    }
    .breadcrumb a {
      color: var(--blue);
