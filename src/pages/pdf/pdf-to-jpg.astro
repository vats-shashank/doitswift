---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'DoItSwift PDF to JPG',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web browser',
      browserRequirements: 'Requires JavaScript, HTML5 Canvas, and PDF.js (loaded from CDN)',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description:
        'Export PDF pages as JPEG images in the browser using PDF.js. Each page renders to a canvas at 2x scale, then encodes to JPG with selectable quality. Supports batch PDFs and ZIP download. No server upload.',
      featureList: [
        'Render PDFs locally with PDF.js — files are not uploaded to DoItSwift',
        'One JPEG per page; filenames use the PDF name stem plus -page-N.jpg',
        'Page rasterization at 2x viewport scale for sharper images',
        'JPEG quality presets: Maximum, Balanced (~85%), and Small file (~70%)',
        'Process multiple PDFs in one session; pages export in document order',
        'Per-page download links plus Download All as ZIP',
        'Optional confirmation when a single PDF exceeds 50 MB',
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is PDF to JPG free and unlimited?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Export as many pages as your device can handle with no signup, watermarks, or usage quotas.',
          },
        },
        {
          '@type': 'Question',
          name: 'Are PDFs uploaded to DoItSwift servers?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No. PDF.js and the canvas run entirely in your browser. Your PDF bytes stay on your device.',
          },
        },
        {
          '@type': 'Question',
          name: 'What resolution or sharpness do the JPG images have?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Each page is rendered to a canvas at 2x the PDF page viewport scale for sharper output. JPEG compression is controlled by the quality preset you choose (Maximum, Balanced, or Small file).',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I convert multiple PDFs at once?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes. Drop or select several PDFs; the tool processes each file in order and exports every page. You can download JPGs individually or all at once as a ZIP archive.',
          },
        },
        {
          '@type': 'Question',
          name: 'How are output JPG files named?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Files use the original PDF filename stem plus -page- and the page number, for example report-page-1.jpg. Multiple PDFs keep separate stems so batches stay organized.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I get PNG instead of JPG?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'This tool outputs JPEG for smaller files. If you need lossless PNG, export JPG here and convert with an image tool, or use a workflow that rasterizes to PNG elsewhere.',
          },
        },
        {
          '@type': 'Question',
          name: 'Do password-protected PDFs work?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Encrypted PDFs must be unlocked before conversion. Use DoItSwift Unlock PDF with the correct password, then convert the unlocked file to JPG.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does PDF to JPG work on mobile?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Yes for moderate file sizes. Very large PDFs or hundreds of pages may exhaust memory on phones or older tablets.',
          },
        },
        {
          '@type': 'Question',
          name: 'What about very large PDFs?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'The tool asks for confirmation when a single PDF is over 50 MB. Huge documents or many pages use significant CPU and RAM; keep the tab active until export finishes.',
          },
        },
        {
          '@type': 'Question',
          name: 'Is there a monthly limit or account required?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'No accounts, no quotas, and no premium tier.',
          },
        },
      ],
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'PDF Tools',
          item: new URL('/pdf/', Astro.site).href,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: 'PDF to JPG',
          item: canonical,
        },
      ],
    },
  ],
};
---

<MainLayout
  title="PDF to JPG Converter — Batch Pages, ZIP, Private Browser Export | DoItSwift"
  description="Convert PDF pages to JPG in your browser with PDF.js: 2x sharpness, Maximum/Balanced/Small JPEG quality, batch PDFs, per-page or ZIP download. No upload, no signup. For slides, scans, and sharing where JPEG works best."
  keywords="pdf to jpg, pdf to jpeg, convert pdf to jpg online, pdf pages to images, extract pdf pages as jpg, batch pdf to jpg, pdf to jpg free private, browser pdf to jpg, pdf.js jpg export, zip pdf pages jpg, no upload pdf converter"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js" is:inline></script>

  <script type="module" is:inline>
    import * as pdfjsLib from 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs';
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';
    window.__pdfjsJpg = pdfjsLib;
  </script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>PDF to JPG</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>PDF to JPG</h1>
      <p class="subtitle">
        Export every page as a JPEG using PDF.js in your tab — 2× rendering, three quality presets, batch PDFs, individual
        downloads or one ZIP. Nothing uploads to our servers.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited pages</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">🖼️</div>
        <div class="dropzone-text">Drop PDF files here or click to browse</div>
        <div class="dropzone-sub">One or many PDFs — one JPG per page</div>
        <input type="file" id="fileInput" multiple accept=".pdf,application/pdf" />
      </div>

      <p class="converter-hint">
        <span id="hintMain">Exporting at maximum JPEG quality</span>
        ·
        <button type="button" class="hint-toggle" id="toggleAdvanced" aria-expanded="false" aria-controls="advancedPanel">
          Change settings
        </button>
      </p>
      <div id="advancedPanel" class="advanced-panel" hidden>
        <p class="advanced-title">JPEG quality</p>
        <div class="preset-buttons" role="radiogroup" aria-label="JPEG quality preset">
          <button type="button" class="preset-btn is-selected" data-q="100" role="radio" aria-checked="true">Maximum</button>
          <button type="button" class="preset-btn" data-q="85" role="radio" aria-checked="false">Balanced</button>
          <button type="button" class="preset-btn" data-q="70" role="radio" aria-checked="false">Small file</button>
        </div>
        <p class="preset-desc" id="presetDesc">Best fidelity — larger JPEG files.</p>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Exported images (<span id="fileCount">0</span>):
      </div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <!-- ShareButtons: optional placement before FAQ -->

  <article class="pdf-edu" aria-label="Guide: PDF to JPG conversion">
    <div class="container pdf-edu-inner">
      <section class="pdf-edu-block">
        <h2 id="why-pdf-to-jpg">Why export PDF pages as JPG?</h2>
        <p>
          PDF is ideal for fixed-layout documents, but social apps, CMS galleries, and some email clients prefer raster
          images. Turning slides, flyers, or scanned pages into JPEGs lets you use Instagram carousels, WordPress media
          libraries, or PowerPoint without asking recipients to install a PDF reader. Each page becomes a standalone file named
          <code>YourFile-page-1.jpg</code>, <code>YourFile-page-2.jpg</code>, and so on — easy to sort and rename in bulk.
        </p>
        <p>
          For a longer walkthrough — use cases, quality trade-offs, and privacy — see{' '}
          <a href="/blog/how-to-convert-pdf-to-jpg/">how to convert PDF to JPG</a> on the DoItSwift blog.
        </p>
      </section>

      <section class="pdf-edu-block">
        <h2 id="how-it-works">How this converter works (browser-only)</h2>
        <p>
          The page loads <strong>PDF.js</strong> to parse each PDF in memory, draws every page to an HTML <strong>canvas</strong> at
          <strong>2×</strong> the page viewport scale for sharper pixels, then saves a <strong>JPEG</strong> blob with your chosen
          quality preset. Your file bytes are not sent to DoItSwift — processing stays in your tab, which matters for contracts,
          medical forms, and financial statements.
        </p>
        <ol class="pdf-steps">
          <li><strong>Add PDFs.</strong> Drop one or many files (each page becomes one JPG).</li>
          <li><strong>Optional:</strong> Open <strong>Change settings</strong> for Balanced or Small file JPEG quality.</li>
          <li><strong>Download</strong> per page or use <strong>Download All as ZIP</strong> for the full set.</li>
        </ol>
      </section>

      <section class="pdf-edu-block">
        <h2 id="pdf-vs-jpg-use-cases">PDF vs JPG: when to export</h2>
        <div class="pdf-table-wrap">
          <table class="pdf-compare-table">
            <caption class="sr-only">When to keep PDF versus export pages as JPG</caption>
            <thead>
              <tr>
                <th scope="col">Need</th>
                <th scope="col">Best choice</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Print-ready multi-page document, text selection, forms</td>
                <td>Keep PDF</td>
              </tr>
              <tr>
                <td>Social post, thumbnail strip, or CMS that wants images</td>
                <td>Export JPG per page</td>
              </tr>
              <tr>
                <td>Smallest lossless archive of graphics</td>
                <td>PNG or original PDF — JPG is lossy</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          Need a smaller PDF instead of images? Try{' '}
          <a href="/pdf/compress-pdf/">Compress PDF</a> before sharing. To combine scans as one document, use{' '}
          <a href="/pdf/image-to-pdf/">Image to PDF</a>.
        </p>
      </section>

      <section class="pdf-edu-block">
        <h2 id="large-pdfs">Large PDFs and performance</h2>
        <p>
          Multi-hundred-page PDFs or files over about <strong>50 MB</strong> can stress CPU and RAM. The tool warns before
          processing a very large single file; keep the browser tab active until export completes. Splitting a huge file
          first with <a href="/pdf/split-pdf/">Split PDF</a> can make exports more reliable on low-memory devices.
        </p>
      </section>
    </div>
  </article>

  <section class="pdf-related" aria-label="Related PDF tools and guides">
    <div class="container">
      <h2 class="section-title">Related tools</h2>
      <ul class="pdf-related-grid">
        <li><a href="/pdf/compress-pdf/">Compress PDF</a></li>
        <li><a href="/pdf/image-to-pdf/">Image to PDF</a></li>
        <li><a href="/pdf/jpg-to-pdf/">JPG to PDF</a></li>
        <li><a href="/pdf/split-pdf/">Split PDF</a></li>
        <li><a href="/pdf/unlock-pdf/">Unlock PDF</a></li>
        <li><a href="/pdf/merge-pdf/">Merge PDF</a></li>
      </ul>
      <h2 class="section-title section-title-sub">Related guides</h2>
      <ul class="pdf-related-grid pdf-related-guides">
        <li><a href="/blog/how-to-convert-pdf-to-jpg/">How to convert PDF to JPG</a></li>
        <li><a href="/blog/how-to-compress-pdf/">How to compress a PDF</a></li>
        <li><a href="/blog/how-to-split-pdf/">How to split a PDF</a></li>
      </ul>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Is PDF to JPG free and unlimited?</h4>
          <p>Yes. Export as many pages as your device can handle with no signup, watermarks, or usage quotas.</p>
        </div>
        <div class="faq-item">
          <h4>Are PDFs uploaded to DoItSwift servers?</h4>
          <p>No. PDF.js and the canvas run entirely in your browser. Your PDF bytes stay on your device.</p>
        </div>
        <div class="faq-item">
          <h4>What resolution or sharpness do the JPG images have?</h4>
          <p>
            Each page is rendered to a canvas at 2× the PDF page viewport scale for sharper output. JPEG compression is
            controlled by the quality preset you choose (Maximum, Balanced, or Small file).
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I convert multiple PDFs at once?</h4>
          <p>
            Yes. Drop or select several PDFs; the tool processes each file in order and exports every page. You can download
            JPGs individually or all at once as a ZIP archive.
          </p>
        </div>
        <div class="faq-item">
          <h4>How are output JPG files named?</h4>
          <p>
            Files use the original PDF filename stem plus <code>-page-</code> and the page number, for example
            <code>report-page-1.jpg</code>. Multiple PDFs keep separate stems so batches stay organized.
          </p>
        </div>
        <div class="faq-item">
          <h4>Can I get PNG instead of JPG?</h4>
          <p>
            This tool outputs JPEG for smaller files. If you need lossless PNG, export JPG here and convert with an image
            tool, or use a workflow that rasterizes to PNG elsewhere.
          </p>
        </div>
        <div class="faq-item">
          <h4>Do password-protected PDFs work?</h4>
          <p>
            Encrypted PDFs must be unlocked before conversion. Use{' '}
            <a href="/pdf/unlock-pdf/">Unlock PDF</a> with the correct password, then convert the unlocked file to JPG.
          </p>
        </div>
        <div class="faq-item">
          <h4>Does PDF to JPG work on mobile?</h4>
          <p>Yes for moderate file sizes. Very large PDFs or hundreds of pages may exhaust memory on phones or older tablets.</p>
        </div>
        <div class="faq-item">
          <h4>What about very large PDFs?</h4>
          <p>
            The tool asks for confirmation when a single PDF is over 50 MB. Huge documents or many pages use significant CPU
            and RAM; keep the tab active until export finishes.
          </p>
        </div>
        <div class="faq-item">
          <h4>Is there a monthly limit or account required?</h4>
          <p>No accounts, no quotas, and no premium tier.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const Q_MAP = { 100: 0.95, 85: 0.85, 70: 0.72 };
      const HINT = {
        100: 'Exporting at maximum JPEG quality',
        85: 'Exporting at balanced quality (85%)',
        70: 'Exporting for smaller JPEG files (~70% quality)',
      };
      const DESC = {
        100: 'Best fidelity — larger JPEG files.',
        85: 'Good balance of size and detail.',
        70: 'Smallest files — more compression visible on close inspection.',
      };

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      const toggleAdvanced = document.getElementById('toggleAdvanced');
      const advancedPanel = document.getElementById('advancedPanel');
      const presetDesc = document.getElementById('presetDesc');
      const hintMain = document.getElementById('hintMain');

      let exported = [];

      async function ensurePdfJs() {
        for (let i = 0; i < 60; i++) {
          if (window.__pdfjsJpg) return window.__pdfjsJpg;
          await new Promise((r) => setTimeout(r, 50));
        }
        alert('PDF engine still loading. Wait a moment and try again, or refresh.');
        return null;
      }

      document.querySelectorAll('.preset-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.preset-btn').forEach((b) => {
            b.classList.remove('is-selected');
            b.setAttribute('aria-checked', 'false');
          });
          btn.classList.add('is-selected');
          btn.setAttribute('aria-checked', 'true');
          const q = btn.dataset.q;
          if (presetDesc) presetDesc.textContent = DESC[q] || DESC['100'];
          if (hintMain) hintMain.textContent = HINT[q] || HINT['100'];
        });
      });

      toggleAdvanced?.addEventListener('click', () => {
        const open = advancedPanel.hidden;
        advancedPanel.hidden = !open;
        toggleAdvanced.setAttribute('aria-expanded', open ? 'true' : 'false');
      });

      function getJpegQuality() {
        const sel = document.querySelector('.preset-btn.is-selected');
        const q = sel ? sel.dataset.q : '100';
        return Q_MAP[q] || 0.95;
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        void handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        void handleFiles(fs);
      });

      async function handleFiles(files) {
        const pdfjsLib = await ensurePdfJs();
        if (!pdfjsLib) return;
        const pdfs = files.filter((f) => f.type === 'application/pdf' || /\.pdf$/i.test(f.name));
        if (!pdfs.length) {
          alert('Please add PDF files.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Rendering pages… This may take a moment for large PDFs.';
        results.innerHTML = '';
        exported = [];
        const jpegQ = getJpegQuality();
        let total = 0;

        for (const file of pdfs) {
          if (file.size > 50 * 1024 * 1024) {
            if (!confirm(file.name + ' is over 50MB. Continue?')) continue;
          }
          const buf = await file.arrayBuffer();
          const pdf = await pdfjsLib.getDocument({ data: buf.slice(0) }).promise;
          const n = pdf.numPages;
          const base = file.name.replace(/\.pdf$/i, '') || 'document';
          for (let i = 1; i <= n; i++) {
            bannerText.textContent = '⏳ ' + file.name + ' — page ' + i + ' / ' + n;
            const page = await pdf.getPage(i);
            const vp = page.getViewport({ scale: 2 });
            const canvas = document.createElement('canvas');
            canvas.width = vp.width;
            canvas.height = vp.height;
            await page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise;
            const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', jpegQ));
            const fname = base + '-page-' + i + '.jpg';
            exported.push({ name: fname, blob });
            total++;
            const url = URL.createObjectURL(blob);
            const row = document.createElement('div');
            row.className = 'file-item';
            row.innerHTML =
              '<div class="file-item-main">' +
              '<div class="file-thumb file-thumb--gallery"><img src="' +
              url +
              '" alt="Page ' +
              i +
              '"/></div>' +
              '<div class="file-info">' +
              '<div class="file-name">' +
              escapeHtml(fname) +
              '</div>' +
              '<div class="file-status done">' +
              formatBytes(blob.size) +
              '</div></div>' +
              '<div class="file-actions-col"><a class="btn" href="' +
              url +
              '" download="' +
              escapeHtml(fname) +
              '">Download</a></div></div>';
            results.appendChild(row);
          }
        }

        if (exported.length) {
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(total);
          actions.style.display = 'flex';
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + total + ' image(s) ready';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      function formatBytes(n) {
        if (n >= 1048576) return (n / 1048576).toFixed(2) + ' MB';
        return (n / 1024).toFixed(1) + ' KB';
      }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        results.innerHTML = '';
        exported = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined' || !exported.length) return alert('ZIP library not loaded.');
        const zip = new JSZip();
        exported.forEach((f) => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(content);
        a.download = 'pdf-pages-jpg.zip';
        a.click();
      });
    });
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 820px;
    }
    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }
    .hero {
      padding: 40px 0 20px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 auto 28px;
    }
    .converter-section {
      padding: 30px 0;
    }
    .converter-section .container {
      max-width: 820px;
    }
    .banner {
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      font-weight: 600;
      text-align: center;
    }
    .banner-info {
      background: #dbeafe;
      color: #1e40af;
    }
    .banner-success {
      background: #d1fae5;
      color: #065f46;
    }
    [data-theme='dark'] .banner-info {
      background: rgba(30, 64, 175, 0.2);
      color: #93c5fd;
    }
    [data-theme='dark'] .banner-success {
      background: rgba(6, 95, 70, 0.2);
      color: #6ee7b7;
    }
    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 70px 20px;
      text-align: center;
      cursor: pointer;
      box-shadow: var(--shadow);
    }
    .dropzone:hover,
    .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    .dropzone-icon {
      font-size: 56px;
      margin-bottom: 14px;
    }
    .dropzone-text {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .dropzone-sub {
      font-size: 14px;
      color: var(--text-muted);
    }
    #fileInput {
