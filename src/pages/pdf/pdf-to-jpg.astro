---
import MainLayout from '../../layouts/MainLayout.astro';

const canonical = 'https://doitswift.com/pdf/pdf-to-jpg/';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'PDF to JPG — DoItSwift',
      url: canonical,
      applicationCategory: 'UtilitiesApplication',
      operatingSystem: 'Web',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      description: 'Export PDF pages as JPG images in your browser. Batch PDFs, quality presets, ZIP download.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'How do I convert a PDF to JPG without uploading?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Use DoItSwift PDF to JPG. PDF.js renders each page to a canvas in your browser; images are saved as JPEG files.',
          },
        },
      ],
    },
  ],
};
---

<MainLayout
  title="PDF to JPG — Free, Private & Unlimited | DoItSwift"
  description="Convert PDF pages to JPG images in your browser. Batch PDFs, adjustable JPEG quality, ZIP download. No upload, no signup."
  keywords="pdf to jpg, pdf to jpeg, extract images from pdf, convert pdf pages to jpg, pdf to jpg free online"
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js" is:inline></script>

  <script type="module" is:inline>
    import * as pdfjsLib from 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs';
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';
    window.__pdfjsJpg = pdfjsLib;
  </script>

  <nav class="breadcrumb container" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/pdf/">PDF Tools</a> › <span>PDF to JPG</span>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="badge">🔒 100% Private — Files Never Leave Your Device</div>
      <h1>PDF to JPG</h1>
      <p class="subtitle">
        Turn every page of your PDFs into high-quality JPEG images. Process multiple PDFs at once — download individually
        or as one ZIP archive.
      </p>
      <div class="trust">
        <span><span class="check">✓</span> Unlimited pages</span>
        <span><span class="check">✓</span> No size limit</span>
        <span><span class="check">✓</span> Works offline</span>
        <span><span class="check">✓</span> No watermarks</span>
      </div>
    </div>
  </section>

  <section class="converter-section">
    <div class="container">
      <div id="successBanner" class="banner" style="display:none">
        <span id="bannerText">Ready</span>
      </div>

      <div class="dropzone" id="dropzone">
        <div class="dropzone-icon">🖼️</div>
        <div class="dropzone-text">Drop PDF files here or click to browse</div>
        <div class="dropzone-sub">One or many PDFs — one JPG per page</div>
        <input type="file" id="fileInput" multiple accept=".pdf,application/pdf" />
      </div>

      <p class="converter-hint">
        <span id="hintMain">Exporting at maximum JPEG quality</span>
        ·
        <button type="button" class="hint-toggle" id="toggleAdvanced" aria-expanded="false" aria-controls="advancedPanel">
          Change settings
        </button>
      </p>
      <div id="advancedPanel" class="advanced-panel" hidden>
        <p class="advanced-title">JPEG quality</p>
        <div class="preset-buttons" role="radiogroup" aria-label="JPEG quality preset">
          <button type="button" class="preset-btn is-selected" data-q="100" role="radio" aria-checked="true">Maximum</button>
          <button type="button" class="preset-btn" data-q="85" role="radio" aria-checked="false">Balanced</button>
          <button type="button" class="preset-btn" data-q="70" role="radio" aria-checked="false">Small file</button>
        </div>
        <p class="preset-desc" id="presetDesc">Best fidelity — larger JPEG files.</p>
      </div>

      <div id="resultsHeader" class="results-header" style="display:none">
        Exported images (<span id="fileCount">0</span>):
      </div>
      <div class="results" id="results"></div>

      <div class="actions" id="actions" style="display:none">
        <button class="btn btn-lg" id="downloadAll">⬇ Download All as ZIP</button>
        <button class="btn btn-secondary btn-lg" id="clearAll">Clear All</button>
      </div>
    </div>
  </section>

  <section class="affiliate">
    <div class="container">
      <div class="affiliate-inner">
        <div class="affiliate-icon">📄</div>
        <div class="affiliate-content">
          <h3>Need professional PDF editing?</h3>
          <p>Adobe Acrobat is the industry standard for editing, signing, and managing PDFs on Mac, Windows, and mobile.</p>
        </div>
        <a href="https://www.adobe.com/acrobat.html?ref=YOUR_AFFILIATE_ID" class="btn btn-orange" target="_blank" rel="sponsored noopener">Try Adobe Acrobat →</a>
      </div>
    </div>
  </section>

  <!-- ShareButtons: optional placement before FAQ -->

  <section class="long-form">
    <div class="container">
      <h2 class="section-title">Why export PDF pages as JPG?</h2>
      <p>
        PDF is perfect for fixed-layout documents, but social platforms, CMS galleries, and some email clients prefer
        raster images. Converting slides or flyers to JPGs lets you drop them into Instagram carousels, WordPress media
        libraries, or PowerPoint decks without recipients needing a PDF reader. Each page becomes a standalone image named
        with the original file stem plus <code>-page-N</code> so you can sort and batch-rename predictably.
      </p>
      <p>
        DoItSwift renders pages with PDF.js at two times scale for sharper output, then encodes JPEGs at the quality you
        pick (Maximum, Balanced, or Small file). Vector diagrams stay crisp at high quality; photo-heavy PDFs benefit from
        Balanced or Small when you need to shrink attachments. Because rendering happens locally, confidential reports never
        pass through a third-party converter — a requirement for many small businesses and freelancers handling client
        contracts or financial PDFs.
      </p>
      <p>
        For multi-PDF workflows (annual reports split by chapter), drop every file at once: the tool walks each document in
        order and numbers pages per file. Very large PDFs (&gt;50MB or hundreds of pages) can take noticeable CPU time; let
        the tab finish and avoid putting the device to sleep mid-export.
      </p>
    </div>
  </section>

  <section class="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h4>Is PDF to JPG free?</h4>
          <p>Yes — export as many pages as your device can handle, no account.</p>
        </div>
        <div class="faq-item">
          <h4>Are PDFs uploaded to your servers?</h4>
          <p>No. PDF.js and the canvas run in your browser only.</p>
        </div>
        <div class="faq-item">
          <h4>What resolution are the JPGs?</h4>
          <p>Pages render at 2× scale for reasonable sharpness; quality presets control JPEG compression.</p>
        </div>
        <div class="faq-item">
          <h4>Can I get PNG instead?</h4>
          <p>This tool outputs JPG for smaller files; use an image converter if you need lossless PNG.</p>
        </div>
        <div class="faq-item">
          <h4>Password-protected PDFs?</h4>
          <p>Encrypted files must be unlocked before conversion.</p>
        </div>
        <div class="faq-item">
          <h4>Does it work on mobile?</h4>
          <p>Yes for moderate files; very large PDFs may fail on limited RAM.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const Q_MAP = { 100: 0.95, 85: 0.85, 70: 0.72 };
      const HINT = {
        100: 'Exporting at maximum JPEG quality',
        85: 'Exporting at balanced quality (85%)',
        70: 'Exporting for smaller JPEG files (~70% quality)',
      };
      const DESC = {
        100: 'Best fidelity — larger JPEG files.',
        85: 'Good balance of size and detail.',
        70: 'Smallest files — more compression visible on close inspection.',
      };

      const dropzone = document.getElementById('dropzone');
      const fileInput = document.getElementById('fileInput');
      const results = document.getElementById('results');
      const actions = document.getElementById('actions');
      const banner = document.getElementById('successBanner');
      const bannerText = document.getElementById('bannerText');
      const resultsHeader = document.getElementById('resultsHeader');
      const fileCount = document.getElementById('fileCount');
      const toggleAdvanced = document.getElementById('toggleAdvanced');
      const advancedPanel = document.getElementById('advancedPanel');
      const presetDesc = document.getElementById('presetDesc');
      const hintMain = document.getElementById('hintMain');

      let exported = [];

      async function ensurePdfJs() {
        for (let i = 0; i < 60; i++) {
          if (window.__pdfjsJpg) return window.__pdfjsJpg;
          await new Promise((r) => setTimeout(r, 50));
        }
        alert('PDF engine still loading. Wait a moment and try again, or refresh.');
        return null;
      }

      document.querySelectorAll('.preset-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.preset-btn').forEach((b) => {
            b.classList.remove('is-selected');
            b.setAttribute('aria-checked', 'false');
          });
          btn.classList.add('is-selected');
          btn.setAttribute('aria-checked', 'true');
          const q = btn.dataset.q;
          if (presetDesc) presetDesc.textContent = DESC[q] || DESC['100'];
          if (hintMain) hintMain.textContent = HINT[q] || HINT['100'];
        });
      });

      toggleAdvanced?.addEventListener('click', () => {
        const open = advancedPanel.hidden;
        advancedPanel.hidden = !open;
        toggleAdvanced.setAttribute('aria-expanded', open ? 'true' : 'false');
      });

      function getJpegQuality() {
        const sel = document.querySelector('.preset-btn.is-selected');
        const q = sel ? sel.dataset.q : '100';
        return Q_MAP[q] || 0.95;
      }

      dropzone.addEventListener('click', () => fileInput.click());
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('drag');
      });
      dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag'));
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('drag');
        void handleFiles(Array.from(e.dataTransfer.files));
      });
      fileInput.addEventListener('change', (e) => {
        const fs = Array.from(e.target.files || []);
        e.target.value = '';
        void handleFiles(fs);
      });

      async function handleFiles(files) {
        const pdfjsLib = await ensurePdfJs();
        if (!pdfjsLib) return;
        const pdfs = files.filter((f) => f.type === 'application/pdf' || /\.pdf$/i.test(f.name));
        if (!pdfs.length) {
          alert('Please add PDF files.');
          return;
        }
        banner.style.display = 'block';
        banner.className = 'banner banner-info';
        bannerText.textContent = '⏳ Rendering pages… This may take a moment for large PDFs.';
        results.innerHTML = '';
        exported = [];
        const jpegQ = getJpegQuality();
        let total = 0;

        for (const file of pdfs) {
          if (file.size > 50 * 1024 * 1024) {
            if (!confirm(file.name + ' is over 50MB. Continue?')) continue;
          }
          const buf = await file.arrayBuffer();
          const pdf = await pdfjsLib.getDocument({ data: buf.slice(0) }).promise;
          const n = pdf.numPages;
          const base = file.name.replace(/\.pdf$/i, '') || 'document';
          for (let i = 1; i <= n; i++) {
            bannerText.textContent = '⏳ ' + file.name + ' — page ' + i + ' / ' + n;
            const page = await pdf.getPage(i);
            const vp = page.getViewport({ scale: 2 });
            const canvas = document.createElement('canvas');
            canvas.width = vp.width;
            canvas.height = vp.height;
            await page.render({ canvasContext: canvas.getContext('2d'), viewport: vp }).promise;
            const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', jpegQ));
            const fname = base + '-page-' + i + '.jpg';
            exported.push({ name: fname, blob });
            total++;
            const url = URL.createObjectURL(blob);
            const row = document.createElement('div');
            row.className = 'file-item';
            row.innerHTML =
              '<div class="file-item-main">' +
              '<div class="file-thumb file-thumb--gallery"><img src="' +
              url +
              '" alt="Page ' +
              i +
              '"/></div>' +
              '<div class="file-info">' +
              '<div class="file-name">' +
              escapeHtml(fname) +
              '</div>' +
              '<div class="file-status done">' +
              formatBytes(blob.size) +
              '</div></div>' +
              '<div class="file-actions-col"><a class="btn" href="' +
              url +
              '" download="' +
              escapeHtml(fname) +
              '">Download</a></div></div>';
            results.appendChild(row);
          }
        }

        if (exported.length) {
          resultsHeader.style.display = 'block';
          fileCount.textContent = String(total);
          actions.style.display = 'flex';
          banner.className = 'banner banner-success';
          bannerText.textContent = '✓ ' + total + ' image(s) ready';
          banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }

      function formatBytes(n) {
        if (n >= 1048576) return (n / 1048576).toFixed(2) + ' MB';
        return (n / 1024).toFixed(1) + ' KB';
      }

      function escapeHtml(s) {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      document.getElementById('clearAll').addEventListener('click', () => {
        results.innerHTML = '';
        exported = [];
        actions.style.display = 'none';
        banner.style.display = 'none';
        resultsHeader.style.display = 'none';
      });

      document.getElementById('downloadAll').addEventListener('click', async () => {
        if (typeof JSZip === 'undefined' || !exported.length) return alert('ZIP library not loaded.');
        const zip = new JSZip();
        exported.forEach((f) => zip.file(f.name, f.blob));
        const content = await zip.generateAsync({ type: 'blob' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(content);
        a.download = 'pdf-pages-jpg.zip';
        a.click();
      });
    });
  </script>

  <style>
    .breadcrumb {
      font-size: 13px;
      color: var(--text-muted);
      padding: 16px 0 0;
      max-width: 820px;
    }
    .breadcrumb a {
      color: var(--blue);
      text-decoration: none;
    }
    .hero {
      padding: 40px 0 20px;
      text-align: center;
    }
    .subtitle {
      font-size: 19px;
      color: var(--text-muted);
      max-width: 640px;
      margin: 0 auto 28px;
    }
    .converter-section {
      padding: 30px 0;
    }
    .converter-section .container {
      max-width: 820px;
    }
    .banner {
      padding: 14px 20px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
      font-weight: 600;
      text-align: center;
    }
    .banner-info {
      background: #dbeafe;
      color: #1e40af;
    }
    .banner-success {
      background: #d1fae5;
      color: #065f46;
    }
    [data-theme='dark'] .banner-info {
      background: rgba(30, 64, 175, 0.2);
      color: #93c5fd;
    }
    [data-theme='dark'] .banner-success {
      background: rgba(6, 95, 70, 0.2);
      color: #6ee7b7;
    }
    .dropzone {
      background: var(--card);
      border: 2px dashed var(--gray-300);
      border-radius: var(--radius-lg);
      padding: 70px 20px;
      text-align: center;
      cursor: pointer;
      box-shadow: var(--shadow);
    }
    .dropzone:hover,
    .dropzone.drag {
      border-color: var(--blue);
      background: var(--blue-light);
    }
    .dropzone-icon {
      font-size: 56px;
      margin-bottom: 14px;
    }
    .dropzone-text {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .dropzone-sub {
      font-size: 14px;
      color: var(--text-muted);
    }
    #fileInput {
      display: none;
    }
    .converter-hint {
      text-align: center;
      font-size: 14px;
      color: var(--text-muted);
      margin-top: 14px;
    }
    .hint-toggle {
      background: none;
      border: none;
      padding: 0;
      font: inherit;
      color: var(--blue);
      font-weight: 600;
      cursor: pointer;
      text-decoration: underline;
    }
    .advanced-panel {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 18px;
      margin-top: 12px;
    }
    .advanced-title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-muted);
      margin-bottom: 12px;
    }
    .preset-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .preset-btn {
      flex: 1;
      min-width: 100px;
      padding: 10px 14px;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      background: var(--bg);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
    }
    .preset-btn.is-selected {
      border-color: var(--blue);
      background: var(--blue-light);
      color: var(--blue);
    }
    .preset-desc {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 12px;
      margin-bottom: 0;
    }
    .results-header {
      font-weight: 700;
      margin: 20px 0 10px;
    }
    .file-item {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 12px;
      margin-bottom: 10px;
      background: var(--card);
    }
    .file-item-main {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .file-thumb--gallery img {
      width: 72px;
      height: 96px;
      object-fit: cover;
      border-radius: 4px;
      border: 1px solid var(--border);
    }
    .file-name {
      font-weight: 600;
      font-size: 14px;
    }
    .file-status.done {
      font-size: 13px;
      color: var(--text-muted);
    }
    .actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 16px;
    }
    .affiliate {
      padding: 40px 0;
    }
    .affiliate .container {
      max-width: 820px;
    }
    .affiliate-inner {
      background: linear-gradient(135deg, #fff7ed, #ffedd5);
      border: 1px solid #fed7aa;
      border-radius: var(--radius-lg);
      padding: 28px;
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    [data-theme='dark'] .affiliate-inner {
      background: linear-gradient(135deg, rgba(249, 115, 22, 0.1), rgba(245, 158, 11, 0.1));
      border-color: rgba(249, 115, 22, 0.3);
    }
    .affiliate-icon {
      font-size: 42px;
    }
    .affiliate-content {
      flex: 1;
      min-width: 200px;
    }
    .affiliate-content h3 {
      font-size: 18px;
      margin-bottom: 4px;
    }
    .affiliate-content p {
      font-size: 14px;
      color: var(--text-muted);
    }
    .long-form {
      padding: 40px 0;
    }
    .long-form .container {
      max-width: 760px;
    }
    .long-form p {
      font-size: 15px;
      line-height: 1.75;
      color: var(--text-muted);
      margin-bottom: 14px;
    }
    .long-form code {
      font-size: 0.9em;
      padding: 2px 6px;
      background: var(--gray-100);
      border-radius: 4px;
    }
    [data-theme='dark'] .long-form code {
      background: var(--gray-200);
    }
    .section-title {
      text-align: center;
      margin-bottom: 20px;
    }
    .faq {
      padding: 40px 0 60px;
    }
    .faq .container {
      max-width: 820px;
    }
    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin-bottom: 12px;
    }
    .faq-item h4 {
      font-size: 16px;
      margin-bottom: 6px;
    }
    .faq-item p {
      font-size: 14px;
      color: var(--text-muted);
    }
  </style>
</MainLayout>
