---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const twitterHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}&via=doitswift`;
const linkedInHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
const whatsAppHref = `https://api.whatsapp.com/send?text=${encodeURIComponent(`${title} ${url}`)}`;
const telegramHref = `https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const redditHref = `https://www.reddit.com/submit?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`;
---

<div class="share-buttons">
  <p class="share-buttons-heading">Share this article:</p>
  <div class="share-buttons-row">
    <a
      href={twitterHref}
      class="share-btn share-btn--x"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on X"
    >
      <svg class="share-btn-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        />
      </svg>
      <span>X</span>
    </a>
    <a
      href={linkedInHref}
      class="share-btn share-btn--linkedin"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on LinkedIn"
    >
      <svg class="share-btn-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        />
      </svg>
      <span>LinkedIn</span>
    </a>
    <a
      href={whatsAppHref}
      class="share-btn share-btn--whatsapp"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on WhatsApp"
    >
      <svg class="share-btn-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        />
      </svg>
      <span>WhatsApp</span>
    </a>
    <a
      href={telegramHref}
      class="share-btn share-btn--telegram"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Telegram"
    >
      <svg class="share-btn-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"
        />
      </svg>
      <span>Telegram</span>
    </a>
    <a
      href={redditHref}
      class="share-btn share-btn--reddit"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Reddit"
    >
      <svg class="share-btn-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-2.597-2.597 2.597a1.25 1.25 0 0 1-1.768-1.768l2.597-2.597-2.597-2.597a1.25 1.25 0 0 1 1.768-1.768l2.597 2.597 2.597-2.597a1.25 1.25 0 0 1 1.768 0l2.597 2.597 2.597-2.597a1.25 1.25 0 0 1 1.768 0 1.25 1.25 0 0 1 0 1.768l-2.597 2.597 2.597 2.597a1.25 1.25 0 0 1-1.25 2.498zm-5.01 3.256c-2.761 0-5.026 2.266-5.026 5.027 0 2.761 2.265 5.027 5.026 5.027 2.762 0 5.027-2.266 5.027-5.027 0-2.761-2.265-5.027-5.027-5.027zm0 1.5c1.947 0 3.527 1.58 3.527 3.527s-1.58 3.527-3.527 3.527-3.527-1.58-3.527-3.527 1.58-3.527 3.527-3.527z"
        />
      </svg>
      <span>Reddit</span>
    </a>
    <button type="button" class="share-btn share-btn--copy share-btn-copy" data-url={url} aria-label="Copy link to article">
      <svg class="share-btn-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"
        />
      </svg>
      <span class="share-btn-copy-label" aria-live="polite">Copy link</span>
    </button>
  </div>
</div>

<script>
  function initShareCopy() {
    document.querySelectorAll('.share-buttons .share-btn-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-url');
        const label = btn.querySelector('.share-btn-copy-label');
        if (!url || !label) return;
        try {
          await navigator.clipboard.writeText(url);
          label.textContent = 'Copied!';
          btn.classList.add('is-copied');
          window.setTimeout(() => {
            label.textContent = 'Copy link';
            btn.classList.remove('is-copied');
          }, 2000);
        } catch {
          label.textContent = 'Copy failed';
          window.setTimeout(() => {
            label.textContent = 'Copy link';
          }, 2000);
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShareCopy);
  } else {
    initShareCopy();
  }
</script>

<style>
  .share-buttons {
    margin: 48px 0;
  }
  .share-buttons-heading {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    margin: 0 0 12px;
  }
  .share-buttons-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }
  .share-buttons .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    cursor: pointer;
    font-family: inherit;
    line-height: 1.2;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .share-buttons a.share-btn {
    text-decoration: none;
    color: var(--text);
  }
  .share-btn-icon {
    flex-shrink: 0;
    display: block;
  }

  .share-btn--x:hover {
    background: #000000;
    border-color: #000000;
    color: #ffffff;
  }
  .share-btn--linkedin:hover {
    background: #0a66c2;
    border-color: #0a66c2;
    color: #ffffff;
  }
  .share-btn--whatsapp:hover {
    background: #25d366;
    border-color: #25d366;
    color: #ffffff;
  }
  .share-btn--telegram:hover {
    background: #26a5e4;
    border-color: #26a5e4;
    color: #ffffff;
  }
  .share-btn--reddit:hover {
    background: #ff4500;
    border-color: #ff4500;
    color: #ffffff;
  }
  .share-btn--copy:hover:not(.is-copied) {
    background: var(--gray-100);
    border-color: var(--border);
    color: var(--text);
  }

  .share-btn-copy.is-copied {
    background: var(--green);
    border-color: var(--green);
    color: #fff;
  }
  .share-btn-copy.is-copied:hover {
    background: var(--green);
    border-color: var(--green);
    color: #fff;
  }

  [data-theme='dark'] .share-btn--copy:hover:not(.is-copied) {
    background: var(--gray-200);
  }
  [data-theme='dark'] .share-btn-copy.is-copied {
    background: var(--green);
    border-color: var(--green);
    color: #fff;
  }
</style>
