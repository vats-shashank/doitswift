---
import BrandLogo from '../components/BrandLogo.astro';
// src/layouts/MainLayout.astro
// Shared layout used by every page on the site.
// Pass title, description, optional keywords. Canonical defaults to site + current path (see astro.config `site`).
export interface Props {
  title: string;
  description: string;
  keywords?: string;
  /** Override computed canonical URL (rare). */
  canonical?: string;
  /** Absolute URL, or site-root path (e.g. `/og-default.svg`) for Open Graph / Twitter image. */
  ogImage?: string;
  /** Set on error pages so they are not indexed. */
  noindex?: boolean;
}

const {
  title,
  description,
  keywords = "doitswift, free online tools, browser utilities, privacy tools, file converter",
  canonical: canonicalOverride,
  ogImage: ogImageProp,
  noindex = false,
} = Astro.props;

const site = Astro.site;
const pathname = Astro.url.pathname;
/** Smart upload handoff: home stores; image tools + compress PDF consume. */
const needsPendingTransfer =
  pathname === '/' ||
  (pathname.startsWith('/image/') && pathname !== '/image/') ||
  pathname.startsWith('/pdf/compress-pdf');
/** Batch file UI helpers — only image converter/resizer tool pages. */
const needsFileResultsUI = pathname.startsWith('/image/') && pathname !== '/image/';
/** Match `trailingSlash: 'always'` so canonical/og:url never omit the final slash. */
function canonicalPath(pathname) {
  if (!pathname || pathname === '/') return '/';
  return pathname.endsWith('/') ? pathname : `${pathname}/`;
}
const canonical =
  canonicalOverride ??
  (site ? new URL(canonicalPath(Astro.url.pathname), site).href : undefined);

const ogImageUrl =
  site &&
  (ogImageProp
    ? ogImageProp.startsWith('http')
      ? ogImageProp
      : new URL(ogImageProp.startsWith('/') ? ogImageProp : `/${ogImageProp}`, site).href
    : new URL('/og-default.svg', site).href);

const siteRootUrl = site ? new URL('/', site).href : null;
const organizationWebSchema = site
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Organization',
          '@id': `${siteRootUrl}#organization`,
          name: 'DoItSwift',
          url: siteRootUrl,
          description: 'Free online calculators and browser-based tools for finance, health, images, and PDFs.',
          logo: {
            '@type': 'ImageObject',
            url: new URL('/favicon.svg', site).href,
          },
        },
        {
          '@type': 'WebSite',
          '@id': `${siteRootUrl}#website`,
          name: 'DoItSwift',
          url: siteRootUrl,
          inLanguage: 'en',
          publisher: { '@id': `${siteRootUrl}#organization` },
        },
      ],
    }
  : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="google-site-verification" content="DDpsnvcRpXDogWCo46v_orLn42QJ_2Xlw3_mopO1LmA" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonical && <link rel="canonical" href={canonical} />}
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DoItSwift" />
    <meta name="twitter:card" content="summary_large_image" />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:image" content={ogImageUrl} />
      </>
    )}
    {organizationWebSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(organizationWebSchema)} />
    )}
    <slot name="head" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles/global.css" />
    {needsPendingTransfer && <script src="/pending-transfer.js" defer />}
    {needsFileResultsUI && <script src="/js/file-results-ui.js" defer />}
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HFRCW0V7Y1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HFRCW0V7Y1', {
        anonymize_ip: true,
        cookie_flags: 'SameSite=None;Secure'
      });
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <!-- NAV -->
    <nav class="nav">
      <div class="nav-inner container">
        <a href="/" class="logo">
          <BrandLogo id="nav" variant="nav" />
        </a>
        <button
          type="button"
          class="nav-burger"
          id="navBurger"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="navMenu"
        >
          <svg class="nav-burger-icon" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M4 6h16v2H4V6zm0 5h16v2H4v-2zm0 5h16v2H4v-2z"
            />
          </svg>
        </button>
        <div class="nav-links" id="navMenu" role="navigation" aria-label="Main">
          <a href="/image/">Image</a>
          <a href="/pdf/">PDF</a>
          <a href="/calculator/">Calculators</a>
          <a href="/#categories">Categories</a>
          <a href="/#tools">All Tools</a>
          <a href="/blog/">Blog</a>
          <a href="/#faq">FAQ</a>
          <button type="button" id="themeToggle" class="theme-toggle" aria-label="Switch to dark mode">🌙</button>
          <a href="/pro/">Roadmap</a>
        </div>
      </div>
    </nav>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer>
      <div class="footer-inner container">
        <div class="footer-col">
          <a href="/" class="logo footer-logo">
            <BrandLogo id="foot" variant="footer" />
          </a>
          <p class="footer-tag">
            Fast, privacy-first utilities. Everything runs in your browser when possible — your files stay on your device.
          </p>
        </div>
        <div class="footer-col">
          <h5>Image tools</h5>
          <a href="/image/">All image tools</a>
          <a href="/image/heic-to-jpg/">HEIC to JPG</a>
          <a href="/image/webp-to-jpg/">WEBP to JPG</a>
          <a href="/image/image-compressor/">Image Compressor</a>
          <a href="/image/image-resizer/">Image Resizer</a>
          <a href="/image/svg-to-png/">SVG to PNG</a>
          <a href="/image/favicon-generator/">Favicon Generator</a>
          <a href="/image/avif-to-jpg/">AVIF to JPG</a>
          <a href="/image/image-to-base64/">Image to Base64</a>
        </div>
        <div class="footer-col">
          <h5>PDF tools</h5>
          <a href="/pdf/">All PDF tools</a>
          <a href="/pdf/merge-pdf/">Merge PDFs</a>
          <a href="/pdf/split-pdf/">Split PDF</a>
          <a href="/pdf/pdf-to-jpg/">PDF to JPG</a>
          <a href="/pdf/image-to-pdf/">Image to PDF</a>
          <a href="/pdf/compress-pdf/">Compress PDF</a>
          <a href="/pdf/unlock-pdf/">Unlock PDF</a>
        </div>
        <div class="footer-col">
          <h5>Calculators</h5>
          <a href="/calculator/">All calculators</a>
          <a href="/calculator/mortgage/">Mortgage Calculator <span class="footer-new">NEW</span></a>
          <a href="/calculator/period-ovulation/">Period Calculator <span class="footer-new">NEW</span></a>
          <a href="/calculator/fraction/">Fraction Calculator <span class="footer-new">NEW</span></a>
          <a href="/calculator/statistics/">Statistics Calculator <span class="footer-new">NEW</span></a>
          <a href="/calculator/personal-loan/">Personal Loan EMI <span class="footer-new">NEW</span></a>
        </div>
        <div class="footer-col">
          <h5>Company</h5>
          <a href="/about/">About</a>
          <a href="/blog/">Blog</a>
          <a href="/pro/">Roadmap</a>
          <a href="/contact/">Contact</a>
        </div>
        <div class="footer-col">
          <h5>Legal</h5>
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
          <a href="/cookies/">Cookies</a>
        </div>
      </div>
      <div class="footer-bottom container">
        © {new Date().getFullYear()} DoItSwift. Built with care for privacy.
      </div>
    </footer>

    <script is:inline>
      (function () {
        function updateThemeButton() {
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          const btn = document.getElementById('themeToggle');
          if (!btn) return;
          btn.textContent = isDark ? '☀️' : '🌙';
          btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        }
        const saved = localStorage.getItem('theme');
        if (saved === 'dark' || (!saved && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
        updateThemeButton();
        document.getElementById('themeToggle')?.addEventListener('click', () => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          if (next === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
          else document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', next);
          updateThemeButton();
        });

        const burger = document.getElementById('navBurger');
        const menu = document.getElementById('navMenu');
        function closeMenu() {
          if (!menu || !burger) return;
          menu.classList.remove('is-open');
          burger.setAttribute('aria-expanded', 'false');
          burger.setAttribute('aria-label', 'Open menu');
        }
        function openMenu() {
          if (!menu || !burger) return;
          menu.classList.add('is-open');
          burger.setAttribute('aria-expanded', 'true');
          burger.setAttribute('aria-label', 'Close menu');
        }
        burger?.addEventListener('click', function (e) {
          e.stopPropagation();
          if (menu?.classList.contains('is-open')) closeMenu();
          else openMenu();
        });
        menu?.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', closeMenu);
        });
        document.addEventListener('click', function (e) {
          if (!menu?.classList.contains('is-open')) return;
          if (menu.contains(e.target) || burger?.contains(e.target)) return;
          closeMenu();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeMenu();
        });
      })();
    </script>

    <style>
      .nav {
        background: rgba(255, 255, 255, .9);
        border-bottom: 1px solid var(--border);
        padding: 14px 0;
        padding-top: max(14px, env(safe-area-inset-top));
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(10px);
      }
      :global([data-theme="dark"]) .nav { background: rgba(10, 10, 10, .9); }
      .nav-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
      }
      .nav-burger {
        display: none;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: var(--radius-sm, 8px);
        background: transparent;
        line-height: 1;
        color: var(--text);
      }
      .nav-burger-icon {
        display: block;
      }
      .nav-burger:hover {
        background: var(--gray-100);
      }
      :global([data-theme='dark']) .nav-burger:hover {
        background: var(--gray-200);
      }
      .logo {
        display: inline-flex;
        align-items: center;
        line-height: 1;
        flex: 0 0 auto;
        min-width: 0;
        max-width: min(100%, 280px);
        text-decoration: none;
      }
      /* Override `.footer-col a { display: block }` so the wordmark is not full-column width. */
      .footer-logo {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        max-width: 100%;
        margin-bottom: 14px;
      }
      .nav-links {
        display: flex;
        gap: 24px;
        align-items: center;
        font-size: 14px;
      }
      .nav-links a { color: var(--text); font-weight: 500; }
      .nav-links a:hover { color: var(--blue); }
      .theme-toggle {
        background: transparent;
        font-size: 18px;
        padding: 4px 8px;
        border-radius: 6px;
      }
      .theme-toggle:hover { background: var(--gray-100); }
      :global([data-theme='dark']) .theme-toggle:hover {
        background: var(--gray-200);
      }

      footer {
        background: var(--gray-900);
        color: #94a3b8;
        padding: 50px 0 30px;
        margin-top: 80px;
      }
      .footer-inner {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
        gap: 32px;
      }
      .footer-col h5 {
        color: #fff;
        font-size: 13px;
        margin-bottom: 14px;
        text-transform: uppercase;
        letter-spacing: .5px;
      }
      .footer-col a {
        display: block;
        color: #94a3b8;
        font-size: 14px;
        margin-bottom: 8px;
      }
      .footer-col a:hover { color: #fff; }
      .footer-new {
        font-size: 10px;
        font-weight: 700;
        color: #fbbf24;
        margin-left: 4px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .footer-tag { font-size: 13px; max-width: 280px; }
      .footer-bottom {
        margin-top: 30px;
        padding-top: 24px;
        border-top: 1px solid #1f2937;
        text-align: center;
        font-size: 13px;
      }

      @media (max-width: 768px) {
        .nav-burger {
          display: inline-flex;
        }
        .nav-links {
          display: none;
          width: 100%;
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          padding: 8px 0 4px;
          margin-top: 4px;
          border-top: 1px solid var(--border);
        }
        .nav-links.is-open {
          display: flex;
        }
        .nav-links > a {
          padding: 12px 8px;
          border-radius: var(--radius-sm, 8px);
        }
        .nav-links > .theme-toggle {
          align-self: flex-start;
          padding: 12px 8px;
        }
        .footer-inner { grid-template-columns: 1fr 1fr; gap: 30px; }
      }
    </style>
  </body>
</html>
