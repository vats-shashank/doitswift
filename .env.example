# Copy to .env locally, or set in Cloudflare Pages → Settings → Environment variables (Production + Preview).
# Canonical URLs, sitemap, and Astro.site use `site` in astro.config.mjs (https://doitswift.com).

# Shown on /contact (mailto link).
PUBLIC_CONTACT_EMAIL=hello@doitswift.com

# Cloudflare Pages: build command `npm run build`, output directory `dist`, Node.js 22.x.
# Add custom domain doitswift.com in Pages; SSL Full (strict); redirect www ↔ apex in Rules as you prefer.
