{
  "name": "doitswift",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "npm run verify:sitemap",
    "preview": "astro preview",
    "astro": "astro",
    "test:calculators": "node scripts/test-calculators.mjs",
    "verify:sitemap": "node scripts/verify-sitemap.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "audit:seo": "node scripts/seo-audit.mjs",
    "test:indexing": "npm run build && npm run check:links && node scripts/seo-audit.mjs",
    "normalize:hrefs": "node scripts/normalize-href-trailing-slash.mjs",
    "smoke:preview": "node scripts/smoke-preview.mjs",
    "check:prod-sitemap": "node scripts/check-prod-sitemap.mjs",
    "verify:deploy": "npm run test:indexing && npm run smoke:preview && npm run check:prod-sitemap",
    "regression": "npm run build && npm run check:links && node scripts/seo-audit.mjs && node scripts/test-calculators.mjs && node scripts/regression-preview.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.5",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2"
  }
}
